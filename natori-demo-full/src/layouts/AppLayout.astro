---
import '../styles/global.css';

interface Props {
  title: string;
  activePage: string;
}

const { title, activePage } = Astro.props;

const sections = [
  {
    label: 'Operação',
    items: [
      { href: '/dashboard', label: 'Dashboard', id: 'dashboard', icon: 'grid' },
      { href: '/buybox', label: 'Buy Box Monitor', id: 'buybox', icon: 'monitor' },
      { href: '/historico', label: 'Histórico', id: 'historico', icon: 'chart' },
      { href: '/estoque', label: 'Estoque', id: 'estoque', icon: 'box' },
    ]
  },
  {
    label: 'Inteligência',
    items: [
      { href: '/diagnostico', label: 'Diagnóstico IA', id: 'diagnostico', icon: 'brain' },
      { href: '/simulador', label: 'Simulador de Preço', id: 'simulador', icon: 'sliders' },
      { href: '/reviews', label: 'Análise de Reviews', id: 'reviews', icon: 'star' },
    ]
  },
  {
    label: 'Automação',
    items: [
      { href: '/regras', label: 'Regras Automáticas', id: 'regras', icon: 'zap' },
      { href: '/whatsapp', label: 'Alertas WhatsApp', id: 'whatsapp', icon: 'message' },
    ]
  },
  {
    label: 'Configuração',
    items: [
      { href: '/catalogo', label: 'Catálogo', id: 'catalogo', icon: 'list' },
      { href: '/equipe', label: 'Equipe', id: 'equipe', icon: 'users' },
      { href: '/relatorios', label: 'Relatórios', id: 'relatorios', icon: 'file' },
    ]
  },
];
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Natori Foods Intelligence</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body style="background: var(--bg-primary);">

<div style="display:flex; min-height:100vh;">

  <!-- Sidebar -->
  <aside id="sidebar" style="
    width: var(--sidebar-width);
    min-height: 100vh;
    background: var(--bg-secondary);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    position: fixed;
    top: 0; left: 0; bottom: 0;
    z-index: 100;
    overflow-y: auto;
  ">
    <!-- Logo -->
    <div style="padding: 24px 20px 20px; border-bottom: 1px solid var(--border);">
      <div style="display:flex; align-items:center; gap:10px;">
        <div style="
          width: 32px; height: 32px; border-radius: 8px;
          background: var(--red);
          display: flex; align-items: center; justify-content: center;
        ">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 2h10l-1.5 4H4.5L3 2z" fill="white" opacity="0.9"/>
            <path d="M4 8h8l1.5 4H2.5L4 8z" fill="white"/>
            <line x1="8" y1="6" x2="8" y2="8" stroke="white" stroke-width="1.5"/>
          </svg>
        </div>
        <div>
          <div style="font-size:13px; font-weight:600; color:var(--text-primary); letter-spacing:-0.02em;">Natori Foods</div>
          <div style="font-size:10px; color:var(--text-muted); font-weight:400;">Intelligence Platform</div>
        </div>
      </div>
    </div>

    <!-- Nav sections -->
    <nav style="padding: 12px 12px 16px; flex:1;">
      {sections.map(section => (
        <div style="margin-bottom: 4px;">
          <div style="font-size:9px; font-weight:600; color:var(--gold); letter-spacing:0.12em; text-transform:uppercase; padding: 10px 8px 5px; opacity:0.7;">{section.label}</div>
          {section.items.map(item => (
            <a
              href={item.href}
              style={`
                display: flex; align-items: center; gap: 10px;
                padding: 8px 10px; border-radius: 8px; margin-bottom: 1px;
                font-size: 13px; font-weight: 500;
                text-decoration: none;
                transition: all 0.15s;
                ${activePage === item.id
                  ? 'background: var(--red-dim); color: var(--red); border: 1px solid rgba(200,16,46,0.15);'
                  : 'color: var(--text-secondary); border: 1px solid transparent;'}
              `}
              onmouseover={activePage !== item.id ? "this.style.background='var(--bg-card)'; this.style.color='var(--text-primary)';" : ''}
              onmouseout={activePage !== item.id ? "this.style.background='transparent'; this.style.color='var(--text-secondary)';" : ''}
            >
              {item.icon === 'grid' && (
                <svg width="14" height="14" viewBox="0 0 15 15" fill="none">
                  <rect x="1" y="1" width="5.5" height="5.5" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
                  <rect x="8.5" y="1" width="5.5" height="5.5" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
                  <rect x="1" y="8.5" width="5.5" height="5.5" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
                  <rect x="8.5" y="8.5" width="5.5" height="5.5" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
                </svg>
              )}
              {item.icon === 'monitor' && (
                <svg width="14" height="14" viewBox="0 0 15 15" fill="none">
                  <rect x="1" y="2" width="13" height="9" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
                  <path d="M5 13h5M7.5 11v2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                  <circle cx="7.5" cy="6.5" r="1.5" stroke="currentColor" stroke-width="1.3"/>
                </svg>
              )}
              {item.icon === 'chart' && (
                <svg width="14" height="14" viewBox="0 0 15 15" fill="none">
                  <polyline points="1.5,11.5 5,6.5 8,8.5 13.5,3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M1 13.5h13" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                </svg>
              )}
              {item.icon === 'box' && (
                <svg width="14" height="14" viewBox="0 0 15 15" fill="none">
                  <path d="M7.5 1.5l6 3v6l-6 3-6-3v-6l6-3z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
                  <path d="M7.5 1.5v13M1.5 4.5l6 3 6-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                </svg>
              )}
              {item.icon === 'brain' && (
                <svg width="14" height="14" viewBox="0 0 15 15" fill="none">
                  <path d="M7.5 2C5.5 2 4 3.5 4 5.5c0 .8.3 1.6.8 2.2L4 13h7l-.8-5.3c.5-.6.8-1.4.8-2.2C11 3.5 9.5 2 7.5 2z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
                  <path d="M5.5 5.5h4M6 7.5h3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                </svg>
              )}
              {item.icon === 'sliders' && (
                <svg width="14" height="14" viewBox="0 0 15 15" fill="none">
                  <line x1="1" y1="4" x2="14" y2="4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                  <line x1="1" y1="11" x2="14" y2="11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                  <circle cx="5" cy="4" r="2" fill="var(--bg-secondary)" stroke="currentColor" stroke-width="1.3"/>
                  <circle cx="10" cy="11" r="2" fill="var(--bg-secondary)" stroke="currentColor" stroke-width="1.3"/>
                </svg>
              )}
              {item.icon === 'star' && (
                <svg width="14" height="14" viewBox="0 0 15 15" fill="none">
                  <path d="M7.5 1.5l1.6 4.8H14l-3.9 2.9 1.5 4.8-4.1-3-4.1 3 1.5-4.8L1 6.3h4.9z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
                </svg>
              )}
              {item.icon === 'zap' && (
                <svg width="14" height="14" viewBox="0 0 15 15" fill="none">
                  <path d="M9 1.5L3 8.5h4.5L6 13.5l7-8h-4.5L9 1.5z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
                </svg>
              )}
              {item.icon === 'message' && (
                <svg width="14" height="14" viewBox="0 0 15 15" fill="none">
                  <path d="M2 2.5A1.5 1.5 0 013.5 1h8A1.5 1.5 0 0113 2.5v7A1.5 1.5 0 0111.5 11H9l-2 2.5L5 11H3.5A1.5 1.5 0 012 9.5v-7z" stroke="currentColor" stroke-width="1.3"/>
                  <path d="M5 5h5M5 7.5h3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                </svg>
              )}
              {item.icon === 'list' && (
                <svg width="14" height="14" viewBox="0 0 15 15" fill="none">
                  <path d="M2 4h11M2 7.5h11M2 11h11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                </svg>
              )}
              {item.icon === 'users' && (
                <svg width="14" height="14" viewBox="0 0 15 15" fill="none">
                  <circle cx="5.5" cy="4.5" r="2.5" stroke="currentColor" stroke-width="1.3"/>
                  <path d="M1 13c0-2.5 2-4 4.5-4s4.5 1.5 4.5 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                  <circle cx="11" cy="4" r="2" stroke="currentColor" stroke-width="1.3"/>
                  <path d="M13 12.5c0-1.5-1-2.5-2-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                </svg>
              )}
              {item.icon === 'file' && (
                <svg width="14" height="14" viewBox="0 0 15 15" fill="none">
                  <path d="M3 1.5A1.5 1.5 0 014.5 0H9l3 3v10.5A1.5 1.5 0 0110.5 15h-6A1.5 1.5 0 013 13.5v-12z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
                  <path d="M9 0v3h3" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
                  <path d="M5.5 7h4M5.5 9.5h4M5.5 12h2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                </svg>
              )}
              {item.label}
            </a>
          ))}
        </div>
      ))}
    </nav>

    <!-- Footer brand -->
    <div style="padding: 16px 20px; border-top: 1px solid var(--border);">
      <div style="font-size:10px; color:var(--text-muted);">Powered by</div>
      <div style="font-size:12px; font-weight:600; color:var(--text-secondary); letter-spacing:-0.01em;">u4digital</div>
    </div>
  </aside>

  <!-- Main content -->
  <div style="margin-left: var(--sidebar-width); flex:1; display:flex; flex-direction:column; min-height:100vh;">

    <!-- Top bar -->
    <header style="
      position: sticky; top: 0; z-index: 50;
      background: rgba(8,8,8,0.85);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      padding: 0 28px;
      height: 56px;
      display: flex; align-items: center; justify-content: space-between;
    ">
      <div style="font-size:13px; font-weight:500; color:var(--text-secondary);">
        Natori Foods — <span style="color:var(--text-primary);">{title}</span>
      </div>

      <div style="display:flex; align-items:center; gap:16px;">
        <!-- Bell -->
        <button style="position:relative; background:none; border:none; cursor:pointer; padding:6px; border-radius:8px;" onclick="window.location.href='/buybox'">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="color:var(--text-secondary);">
            <path d="M9 1a5 5 0 015 5v3l1.5 2.5H2.5L4 9V6a5 5 0 015-5z" stroke="currentColor" stroke-width="1.4"/>
            <path d="M7 15.5a2 2 0 004 0" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
          <span style="
            position:absolute; top:2px; right:2px;
            background:var(--red); color:white;
            font-size:9px; font-weight:700;
            width:15px; height:15px; border-radius:50%;
            display:flex; align-items:center; justify-content:center;
            border:1.5px solid var(--bg-primary);
          ">12</span>
        </button>

        <!-- Avatar -->
        <div style="
          width:32px; height:32px; border-radius:50%;
          background: linear-gradient(135deg, var(--red), #8B0015);
          display:flex; align-items:center; justify-content:center;
          font-size:11px; font-weight:700; color:white; letter-spacing:0.02em;
          cursor:pointer;
        ">KH</div>
      </div>
    </header>

    <!-- Page content -->
    <main style="flex:1; padding:32px 28px;">
      <slot />
    </main>
  </div>
</div>

<!-- Mobile responsive -->
<style>
  @media (max-width: 768px) {
    #sidebar { display: none; }
    div[style*="margin-left: var(--sidebar-width)"] { margin-left: 0 !important; }
  }
</style>

</body>
</html>
