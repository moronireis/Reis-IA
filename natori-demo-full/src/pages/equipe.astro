---
import AppLayout from '../layouts/AppLayout.astro';
import equipeData from '../data/equipe.json';
---

<AppLayout title="Performance da Equipe" activePage="equipe">

  <!-- Header -->
  <div style="margin-bottom:28px;">
    <h1 style="font-size:22px; font-weight:700; color:var(--text-primary); letter-spacing:-0.03em; margin-bottom:4px;">Performance da Equipe</h1>
    <div style="font-size:13px; color:var(--text-muted);">Esta semana · SLA de Buy Box crítico em tempo real</div>
  </div>

  <!-- Leaderboard highlight -->
  <div style="
    background:linear-gradient(135deg, rgba(34,197,94,0.08) 0%, rgba(212,175,55,0.04) 100%);
    border:1px solid rgba(34,197,94,0.2); border-radius:14px;
    padding:20px 24px; margin-bottom:24px;
    display:flex; align-items:center; gap:16px;
  ">
    <div style="
      width:44px; height:44px; border-radius:50%;
      background:linear-gradient(135deg, var(--green), #16a34a);
      display:flex; align-items:center; justify-content:center;
      font-size:14px; font-weight:700; color:white; flex-shrink:0;
    ">JM</div>
    <div>
      <div style="font-size:14px; font-weight:600; color:var(--text-primary);">Juliana Mori respondeu 12 alertas em menos de 5 minutos essa semana</div>
      <div style="font-size:12px; color:var(--green); margin-top:2px;">Melhor SLA do time · Ops & Marketplace</div>
    </div>
    <div style="margin-left:auto; flex-shrink:0;">
      <span class="badge badge-green">Destaque da semana</span>
    </div>
  </div>

  <!-- Member cards -->
  <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:24px;">
    {equipeData.members.map(member => (
      <div class="card" style="padding:24px;">
        <!-- Avatar + name -->
        <div style="display:flex; align-items:center; gap:14px; margin-bottom:20px; padding-bottom:16px; border-bottom:1px solid var(--border);">
          <div style={`
            width:44px; height:44px; border-radius:50%; flex-shrink:0;
            background:linear-gradient(135deg, ${member.color}, ${member.color}88);
            display:flex; align-items:center; justify-content:center;
            font-size:14px; font-weight:700; color:white;
          `}>{member.initials}</div>
          <div>
            <div style="font-size:14px; font-weight:600; color:var(--text-primary);">{member.name}</div>
            <div style="font-size:11px; color:var(--text-muted);">{member.role}</div>
          </div>
        </div>

        <!-- Stats grid -->
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
          <div>
            <div style="font-size:11px; color:var(--text-muted); margin-bottom:4px;">Alertas atendidos</div>
            <div style={`font-size:22px; font-weight:700; color:${member.color};`}>{member.alerts_this_week}</div>
          </div>
          <div>
            <div style="font-size:11px; color:var(--text-muted); margin-bottom:4px;">Tempo médio</div>
            <div style="font-size:22px; font-weight:700; color:var(--text-primary);">{member.avg_response_min.toFixed(1)}<span style="font-size:13px; color:var(--text-muted); font-weight:400;">min</span></div>
          </div>
          <div>
            <div style="font-size:11px; color:var(--text-muted); margin-bottom:4px;">Buy Box recuperados</div>
            <div style="font-size:22px; font-weight:700; color:var(--green);">{member.buybox_recovered}</div>
          </div>
          <div>
            <div style="font-size:11px; color:var(--text-muted); margin-bottom:4px;">Ajustes aplicados</div>
            <div style="font-size:22px; font-weight:700; color:var(--text-primary);">{member.adjustments_applied}</div>
          </div>
        </div>

        <!-- Response time bar -->
        <div style="margin-top:16px;">
          <div style="display:flex; justify-content:space-between; font-size:11px; color:var(--text-muted); margin-bottom:5px;">
            <span>Tempo de resposta</span>
            <span style={`color:${member.avg_response_min <= equipeData.sla_target_min ? 'var(--green)' : 'var(--yellow)'};`}>
              {member.avg_response_min <= equipeData.sla_target_min ? 'Dentro do SLA' : 'Acima do SLA'}
            </span>
          </div>
          <div style="height:5px; background:var(--bg-secondary); border-radius:3px; overflow:hidden;">
            <div style={`
              height:100%; border-radius:3px;
              width:${Math.min(100, (member.avg_response_min / 15) * 100)}%;
              background:${member.avg_response_min <= equipeData.sla_target_min ? 'var(--green)' : 'var(--yellow)'};
              transition:width 0.3s;
            `}></div>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Bottom row: chart + SLA -->
  <div style="display:grid; grid-template-columns:1fr 320px; gap:20px;">

    <!-- Alerts by day chart -->
    <div class="card" style="padding:24px;">
      <div style="font-size:14px; font-weight:600; color:var(--text-primary); margin-bottom:4px;">Alertas resolvidos por dia</div>
      <div style="font-size:12px; color:var(--text-muted); margin-bottom:20px;">Toda a equipe · semana atual</div>
      <div id="alerts-chart" style="width:100%; height:140px;"></div>
    </div>

    <!-- SLA card -->
    <div class="card" style="padding:24px; display:flex; flex-direction:column; justify-content:center;">
      <div style="font-size:14px; font-weight:600; color:var(--text-primary); margin-bottom:20px;">SLA de Buy Box Crítico</div>

      <div style="margin-bottom:16px;">
        <div style="display:flex; justify-content:space-between; font-size:12px; color:var(--text-muted); margin-bottom:8px;">
          <span>Meta: responder em &lt;{equipeData.sla_target_min} minutos</span>
          <span style="color:var(--green);">{equipeData.sla_achieved_pct}%</span>
        </div>
        <div style="height:8px; background:var(--bg-secondary); border-radius:4px; overflow:hidden;">
          <div style={`height:100%; border-radius:4px; width:${equipeData.sla_achieved_pct}%; background:var(--green); transition:width 0.5s;`}></div>
        </div>
      </div>

      <div style="display:flex; flex-direction:column; gap:10px;">
        <div style="display:flex; justify-content:space-between; align-items:center; padding:10px 14px; background:var(--bg-secondary); border:1px solid var(--border); border-radius:8px;">
          <span style="font-size:12px; color:var(--text-muted);">Meta SLA</span>
          <span style="font-size:13px; font-weight:600; color:var(--text-primary);">{equipeData.sla_target_min} minutos</span>
        </div>
        <div style="display:flex; justify-content:space-between; align-items:center; padding:10px 14px; background:var(--bg-secondary); border:1px solid var(--border); border-radius:8px;">
          <span style="font-size:12px; color:var(--text-muted);">Realizado</span>
          <span style="font-size:13px; font-weight:600; color:var(--green);">{equipeData.sla_achieved_pct}%</span>
        </div>
        <div style="display:flex; justify-content:space-between; align-items:center; padding:10px 14px; background:var(--bg-secondary); border:1px solid var(--border); border-radius:8px;">
          <span style="font-size:12px; color:var(--text-muted);">Fora do SLA</span>
          <span style="font-size:13px; font-weight:600; color:var(--yellow);">{100 - equipeData.sla_achieved_pct}%</span>
        </div>
      </div>
    </div>
  </div>

</AppLayout>

<script define:vars={{ alertsByDay: equipeData.alerts_by_day }}>

function drawAlertsChart() {
  const container = document.getElementById('alerts-chart');
  if (!container) return;

  const W = container.clientWidth || 500;
  const H = 140;
  const padL = 8, padR = 8, padT = 10, padB = 28;
  const cW = W - padL - padR;
  const cH = H - padT - padB;

  const data = alertsByDay;
  const maxVal = Math.max(...data.map(d => d.resolved));
  const barW = cW / data.length * 0.6;
  const gap = cW / data.length;

  const bars = data.map((d, i) => {
    const h = (d.resolved / maxVal) * cH;
    const x = padL + i * gap + gap * 0.2;
    const y = padT + cH - h;
    const isTop = d.resolved === maxVal;
    const color = isTop ? 'var(--gold)' : 'var(--red)';
    return `
      <rect x="${x}" y="${y}" width="${barW}" height="${h}" rx="4" fill="${color}" opacity="${isTop ? '0.9' : '0.5'}"/>
      <text x="${x + barW/2}" y="${y - 5}" text-anchor="middle" font-size="10" fill="${isTop ? 'var(--gold)' : 'var(--text-muted)'}" font-family="Inter" font-weight="${isTop ? '600' : '400'}">${d.resolved}</text>
      <text x="${x + barW/2}" y="${H - 8}" text-anchor="middle" font-size="10" fill="var(--text-muted)" font-family="Inter">${d.day}</text>`;
  }).join('');

  container.innerHTML = `<svg width="${W}" height="${H}" viewBox="0 0 ${W} ${H}" fill="none">${bars}</svg>`;
}

drawAlertsChart();
window.addEventListener('resize', drawAlertsChart);
</script>
