---
import AppLayout from '../layouts/AppLayout.astro';
import reviewData from '../data/reviews.json';
---

<AppLayout title="Análise de Reviews" activePage="reviews">

  <!-- Header -->
  <div style="margin-bottom:28px;">
    <h1 style="font-size:22px; font-weight:700; color:var(--text-primary); letter-spacing:-0.03em; margin-bottom:4px;">Análise Inteligente de Reviews</h1>
    <div style="font-size:13px; color:var(--text-muted);">Padrões detectados por IA em todos os marketplaces · última análise há 2h</div>
  </div>

  <!-- 4 KPIs -->
  <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:24px;">
    <div class="card" style="padding:20px;">
      <div style="font-size:11px; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:8px;">Reviews analisados</div>
      <div style="font-size:28px; font-weight:700; color:var(--text-primary);">{reviewData.kpis.total.toLocaleString('pt-BR')}</div>
    </div>
    <div class="card" style="padding:20px;">
      <div style="font-size:11px; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:8px;">Média de estrelas</div>
      <div style="display:flex; align-items:baseline; gap:6px;">
        <div style="font-size:28px; font-weight:700; color:var(--gold);">{reviewData.kpis.avg_stars}</div>
        <div style="font-size:13px; color:var(--text-muted);">/ 5</div>
      </div>
    </div>
    <div class="card" style="padding:20px;">
      <div style="font-size:11px; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:8px;">Reviews positivos</div>
      <div style="font-size:28px; font-weight:700; color:var(--green);">{reviewData.kpis.pct_positive}%</div>
    </div>
    <div class="card" style="padding:20px;">
      <div style="font-size:11px; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:8px;">Com menção a problema</div>
      <div style="font-size:28px; font-weight:700; color:var(--red);">{reviewData.kpis.pct_problem}%</div>
    </div>
  </div>

  <!-- AI patterns -->
  <div style="margin-bottom:24px;">
    <div style="font-size:14px; font-weight:600; color:var(--text-primary); margin-bottom:14px;">Padrões detectados pela IA</div>
    <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:14px;">
      {reviewData.patterns.map(pat => (
        <div class="card" style={`padding:20px; ${pat.trend_type === 'up_bad' ? 'border-color:rgba(200,16,46,0.15);' : pat.trend_type === 'up_good' ? 'border-color:rgba(34,197,94,0.15);' : ''}`}>
          <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:12px; margin-bottom:10px;">
            <div style="font-size:14px; font-weight:600; color:var(--text-primary); line-height:1.4;">{pat.title}</div>
            <span class={`badge ${pat.trend_type === 'up_bad' ? 'badge-red' : pat.trend_type === 'up_good' ? 'badge-green' : 'badge-yellow'}`} style="font-size:10px; white-space:nowrap; flex-shrink:0;">
              {pat.trend}
            </span>
          </div>
          <div style="display:flex; align-items:center; gap:6px; margin-bottom:8px;">
            <span style={`font-size:24px; font-weight:700; ${pat.trend_type === 'up_bad' ? 'color:var(--red)' : pat.trend_type === 'up_good' ? 'color:var(--green)' : 'color:var(--text-primary)'}`}>{pat.mentions}</span>
            <span style="font-size:12px; color:var(--text-muted);">menções nos {pat.period}</span>
          </div>
          <div style="font-size:12px; color:var(--text-secondary); line-height:1.5;">{pat.detail}</div>
          <div style="margin-top:10px; font-size:11px; color:var(--text-muted);">Fonte: {pat.source}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Recent reviews -->
  <div class="card" style="overflow:hidden;">
    <div style="padding:20px 24px 14px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between;">
      <div style="font-size:14px; font-weight:600; color:var(--text-primary);">Reviews Recentes</div>
      <span style="font-size:12px; color:var(--text-muted);">Ordenados por relevância</span>
    </div>
    <div>
      {reviewData.recent_reviews.map((r, i) => (
        <div style={`padding:18px 24px; border-bottom:${i < reviewData.recent_reviews.length - 1 ? '1px solid var(--border)' : 'none'};`}>
          <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:16px; flex-wrap:wrap;">
            <div style="flex:1; min-width:0;">
              <div style="display:flex; align-items:center; gap:10px; margin-bottom:6px; flex-wrap:wrap;">
                <!-- Stars -->
                <div style="display:flex; gap:2px;">
                  {[1,2,3,4,5].map(s => (
                    <svg width="11" height="11" viewBox="0 0 15 15" fill="none">
                      <path d="M7.5 1.5l1.6 4.8H14l-3.9 2.9 1.5 4.8-4.1-3-4.1 3 1.5-4.8L1 6.3h4.9z"
                        fill={s <= r.stars ? 'var(--gold)' : 'none'}
                        stroke={s <= r.stars ? 'var(--gold)' : 'var(--text-muted)'}
                        stroke-width="1.2"/>
                    </svg>
                  ))}
                </div>
                <span class={`badge ${r.sentiment === 'positive' ? 'badge-green' : r.sentiment === 'negative' ? 'badge-red' : 'badge-yellow'}`} style="font-size:10px;">
                  {r.sentiment === 'positive' ? 'Positivo' : r.sentiment === 'negative' ? 'Negativo' : 'Neutro'}
                </span>
                <span class="badge badge-gold" style="font-size:10px;">{r.marketplace}</span>
                <span style="font-size:11px; color:var(--text-muted);">{r.date}</span>
              </div>
              <div style="font-size:12px; color:var(--text-muted); margin-bottom:4px;">{r.product}</div>
              <div style="font-size:13px; color:var(--text-secondary); line-height:1.6;">{r.text}</div>
              <div style="font-size:11px; color:var(--text-muted); margin-top:4px;">{r.author}</div>
            </div>
            {r.sentiment === 'negative' && (
              <button class="btn btn-ghost" style="padding:7px 14px; font-size:11px; flex-shrink:0; white-space:nowrap;" onclick={`openReplyModal(\`${r.text.replace(/`/g, "'")}\`)`}>
                Responder com IA
              </button>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Reply modal -->
  <div id="reply-modal" class="modal-overlay" style="display:none;">
    <div class="modal-box" style="max-width:520px;">
      <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
        <h2 style="font-size:16px; font-weight:600; color:var(--text-primary);">Resposta gerada pela IA</h2>
        <button onclick="closeReplyModal()" style="background:none; border:none; cursor:pointer; color:var(--text-muted);">
          <svg width="16" height="16" viewBox="0 0 15 15" fill="none"><path d="M2 2l11 11M13 2L2 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
      </div>
      <div style="background:var(--bg-secondary); border:1px solid var(--border); border-radius:8px; padding:16px; margin-bottom:16px;">
        <div style="font-size:11px; color:var(--text-muted); margin-bottom:8px; text-transform:uppercase; letter-spacing:0.08em;">Review original</div>
        <div id="original-review" style="font-size:13px; color:var(--text-secondary); line-height:1.6; font-style:italic;"></div>
      </div>
      <textarea id="ai-reply" class="input-field" style="min-height:120px; resize:vertical; line-height:1.6;" readonly></textarea>
      <div style="display:flex; gap:10px; margin-top:16px;">
        <button class="btn btn-ghost" style="flex:1;" onclick="closeReplyModal()">Cancelar</button>
        <button class="btn btn-red" style="flex:1;" onclick="publishReply()">Publicar resposta</button>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div id="toast" class="toast" style="display:none;"></div>

</AppLayout>

<script>
const aiReplies: Record<string, string> = {
  negative_delivery: 'Olá! Lamentamos muito pela demora na entrega. Estamos trabalhando para melhorar nossos prazos em parceria com as transportadoras. Caso precise de qualquer suporte, entre em contato conosco diretamente — garantimos que você ficará satisfeito.',
  negative_packaging: 'Pedimos desculpas pela embalagem danificada. Sabemos o quanto isso é frustrante. Já estamos reforçando nosso processo de embalagem para produtos em vidro. Ficaremos felizes em reenviar o produto — entre em contato com nosso suporte.',
  negative_confusion: 'Obrigado pela observação! Você tem razão — vamos melhorar nossas fotos e títulos para deixar as diferenças entre os produtos mais claras. Se quiser trocar pelo produto correto, é só nos chamar.',
  default: 'Obrigado pelo seu feedback! Levamos todos os comentários a sério e estamos sempre buscando melhorar. Entre em contato com nosso suporte e garantimos que você ficará satisfeito com nossa solução.',
};

function openReplyModal(reviewText: string) {
  const modal = document.getElementById('reply-modal');
  const originalEl = document.getElementById('original-review');
  const replyEl = document.getElementById('ai-reply') as HTMLTextAreaElement;
  if (!modal || !originalEl || !replyEl) return;

  originalEl.textContent = reviewText;

  let reply = aiReplies.default;
  if (reviewText.toLowerCase().includes('demorou') || reviewText.toLowerCase().includes('entrega')) {
    reply = aiReplies.negative_delivery;
  } else if (reviewText.toLowerCase().includes('embalagem') || reviewText.toLowerCase().includes('amassada')) {
    reply = aiReplies.negative_packaging;
  } else if (reviewText.toLowerCase().includes('confundi') || reviewText.toLowerCase().includes('pedi')) {
    reply = aiReplies.negative_confusion;
  }

  replyEl.value = reply;
  modal.style.display = 'flex';
}

function closeReplyModal() {
  const modal = document.getElementById('reply-modal');
  if (modal) modal.style.display = 'none';
}

function publishReply() {
  closeReplyModal();
  showToast('Resposta publicada com sucesso');
}

function showToast(msg: string) {
  const t = document.getElementById('toast');
  if (!t) return;
  t.textContent = msg;
  t.style.display = 'block';
  setTimeout(() => { t.style.display = 'none'; }, 3000);
}

(window as any).openReplyModal = openReplyModal;
(window as any).closeReplyModal = closeReplyModal;
(window as any).publishReply = publishReply;
</script>
