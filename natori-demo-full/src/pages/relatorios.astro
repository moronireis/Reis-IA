---
import AppLayout from '../layouts/AppLayout.astro';
import report from '../data/report.json';
---

<AppLayout title="Relatórios" activePage="relatorios">

  <!-- Header -->
  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:28px; flex-wrap:wrap; gap:12px;">
    <div>
      <h1 style="font-size:20px; font-weight:700; color:var(--text-primary); letter-spacing:-0.03em; margin-bottom:4px;">
        Relatório Executivo Semanal
      </h1>
      <p style="font-size:13px; color:var(--text-muted);">
        Semana de {report.period} · Natori Foods
      </p>
    </div>
    <button class="btn btn-red" onclick="downloadReport()">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M7 1v8M4 6l3 3 3-3" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M2 11h10" stroke="white" stroke-width="1.6" stroke-linecap="round"/>
      </svg>
      Baixar PDF
    </button>
  </div>

  <!-- Report preview card -->
  <div class="card" style="padding:0; overflow:hidden; margin-bottom:20px;">

    <!-- Report header bar -->
    <div style="
      background:linear-gradient(135deg, rgba(200,16,46,0.12) 0%, rgba(212,175,55,0.06) 100%);
      border-bottom:1px solid var(--border);
      padding:24px 28px;
      display:flex; align-items:center; justify-content:space-between;
    ">
      <div style="display:flex; align-items:center; gap:14px;">
        <div style="
          width:44px; height:44px; border-radius:10px;
          background:var(--red); display:flex; align-items:center; justify-content:center;
          box-shadow:0 4px 16px rgba(200,16,46,0.3);
        ">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
            <path d="M4 3h10l4 4v12a1 1 0 01-1 1H4a1 1 0 01-1-1V4a1 1 0 011-1z" stroke="white" stroke-width="1.5"/>
            <path d="M14 3v4h4" stroke="white" stroke-width="1.5" stroke-linejoin="round"/>
            <path d="M7 10h8M7 13h8M7 16h5" stroke="white" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
        </div>
        <div>
          <div style="font-size:15px; font-weight:700; color:var(--text-primary); letter-spacing:-0.02em;">
            Relatório Executivo Natori Foods
          </div>
          <div style="font-size:12px; color:var(--text-muted);">
            Semana {report.period} · gerado automaticamente
          </div>
        </div>
      </div>
      <span class="badge badge-gold">PDF Disponível</span>
    </div>

    <!-- KPI row -->
    <div style="display:grid; grid-template-columns:repeat(4,1fr); border-bottom:1px solid var(--border);">
      {[
        { label: 'Receita Curva A', value: `R$ ${report.revenue.toLocaleString('pt-BR')}`, change: `+${report.revenue_change}%`, up: true },
        { label: 'vs semana anterior', value: `R$ ${report.revenue_prev.toLocaleString('pt-BR')}`, change: 'referência', up: null },
        { label: 'Buy Box win rate', value: `${report.buybox_winrate}%`, change: '+2pp', up: true },
        { label: 'Alertas processados', value: `${report.alerts_total}`, change: `${report.competitors_tracked} concorrentes`, up: null },
      ].map((kpi, i) => (
        <div style={`
          padding:20px 24px;
          border-right:${i < 3 ? '1px solid var(--border)' : 'none'};
        `}>
          <div style="font-size:11px; color:var(--text-muted); margin-bottom:6px; text-transform:uppercase; letter-spacing:0.06em;">{kpi.label}</div>
          <div style="font-size:22px; font-weight:700; color:var(--text-primary); letter-spacing:-0.03em; margin-bottom:4px;">{kpi.value}</div>
          <div style={`font-size:12px; font-weight:500; color:${kpi.up === true ? 'var(--green)' : kpi.up === false ? 'var(--red)' : 'var(--text-muted)'};`}>
            {kpi.change}
          </div>
        </div>
      ))}
    </div>

    <!-- Top movers + Recommendations -->
    <div style="display:grid; grid-template-columns:1fr 1fr; border-bottom:1px solid var(--border);">

      <!-- Top movers -->
      <div style="padding:22px 24px; border-right:1px solid var(--border);">
        <div style="font-size:13px; font-weight:600; color:var(--text-primary); margin-bottom:14px;">Top Movers</div>
        <div style="display:flex; flex-direction:column; gap:10px;">
          {report.top_movers.map(m => (
            <div style="display:flex; align-items:center; justify-content:space-between;">
              <div style="font-size:13px; color:var(--text-secondary); flex:1; min-width:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                {m.name}
              </div>
              <span class={`badge ${m.direction === 'up' ? 'badge-green' : 'badge-red'}`} style="margin-left:10px; flex-shrink:0;">
                {m.direction === 'up' ? '+' : ''}{m.change}%
              </span>
            </div>
          ))}
        </div>
      </div>

      <!-- Recommendations -->
      <div style="padding:22px 24px;">
        <div style="font-size:13px; font-weight:600; color:var(--text-primary); margin-bottom:14px;">
          5 Ações Recomendadas
        </div>
        <ol style="list-style:none; display:flex; flex-direction:column; gap:10px;">
          {report.recommendations.map((r, i) => (
            <li style="display:flex; align-items:flex-start; gap:10px;">
              <span style="
                width:18px; height:18px; border-radius:50%; background:var(--red-dim);
                border:1px solid rgba(200,16,46,0.2); color:var(--red);
                font-size:10px; font-weight:700; display:flex; align-items:center;
                justify-content:center; flex-shrink:0; margin-top:1px;
              ">{i+1}</span>
              <span style="font-size:12px; color:var(--text-secondary); line-height:1.5;">{r}</span>
            </li>
          ))}
        </ol>
      </div>
    </div>

    <!-- Footer schedule -->
    <div style="padding:16px 24px; display:flex; align-items:center; justify-content:space-between;">
      <div style="display:flex; align-items:center; gap:8px;">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <circle cx="7" cy="7" r="5.5" stroke="var(--text-muted)" stroke-width="1.3"/>
          <path d="M7 4v3l2 2" stroke="var(--text-muted)" stroke-width="1.3" stroke-linecap="round"/>
        </svg>
        <span style="font-size:12px; color:var(--text-muted);">
          Próximo envio: <strong style="color:var(--text-secondary);">segunda-feira 08:00</strong> via email + WhatsApp
        </span>
      </div>
      <div style="font-size:11px; color:var(--text-muted);">Frequência: semanal</div>
    </div>
  </div>

  <!-- Historical reports -->
  <div>
    <div style="font-size:13px; font-weight:600; color:var(--text-primary); margin-bottom:14px;">Relatórios anteriores</div>
    <div style="display:flex; flex-direction:column; gap:8px;">
      {[
        { period: '30/mar–05/abr', revenue: 167339, winrate: 92, status: 'Disponível' },
        { period: '23–29/mar', revenue: 154210, winrate: 89, status: 'Disponível' },
        { period: '16–22/mar', revenue: 148900, winrate: 91, status: 'Disponível' },
      ].map(r => (
        <div class="card" style="padding:14px 20px; display:flex; align-items:center; justify-content:space-between; cursor:pointer;" onmouseover="this.style.borderColor='var(--border-accent)'" onmouseout="this.style.borderColor=''">
          <div style="display:flex; align-items:center; gap:16px;">
            <div>
              <div style="font-size:13px; font-weight:500; color:var(--text-primary);">Semana {r.period}</div>
              <div style="font-size:12px; color:var(--text-muted); margin-top:2px;">
                R$ {r.revenue.toLocaleString('pt-BR')} · Buy Box {r.winrate}%
              </div>
            </div>
          </div>
          <div style="display:flex; align-items:center; gap:12px;">
            <span class="badge badge-gold">{r.status}</span>
            <button class="btn btn-ghost" style="padding:5px 12px; font-size:12px;" onclick="downloadReport()">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path d="M6 1v7M3 5l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M1 10h10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              </svg>
              PDF
            </button>
          </div>
        </div>
      ))}
    </div>
  </div>

</AppLayout>

<!-- Toast -->
<div id="pdf-toast" class="toast" style="display:none; border-color:rgba(212,175,55,0.3);">
  <div style="display:flex; align-items:center; gap:8px;">
    <div style="width:8px;height:8px;border-radius:50%;background:var(--gold);"></div>
    <span style="color:var(--text-primary);">Relatório PDF preparado — download iniciando</span>
  </div>
</div>

<script>
  function downloadReport() {
    const t = document.getElementById('pdf-toast')!;
    t.style.display = 'block';
    setTimeout(() => { t.style.display = 'none'; }, 3000);
  }
  (window as any).downloadReport = downloadReport;
</script>
