---
import AppLayout from '../layouts/AppLayout.astro';
import products from '../data/products.json';
import competitors from '../data/competitors.json';

const extraSkus = [
  { id: 8, name: 'Vinagre de Arroz Mizkan 500ml', sku: 'NAT-0112', marketplaces: ['ML', 'Shopee'], competitors_tracked: 4, check_freq: '30min', status: 'active' },
  { id: 9, name: 'Missô Shiro Branco 500g', sku: 'NAT-0215', marketplaces: ['ML'], competitors_tracked: 3, check_freq: '1h', status: 'active' },
  { id: 10, name: 'Gergelim Torrado 100g', sku: 'NAT-0318', marketplaces: ['Shopee', 'Amazon'], competitors_tracked: 5, check_freq: '30min', status: 'active' },
  { id: 11, name: 'Wasabi em Pó 30g', sku: 'NAT-0421', marketplaces: ['ML', 'Amazon'], competitors_tracked: 2, check_freq: '2h', status: 'paused' },
  { id: 12, name: 'Macarrão Soba 300g', sku: 'NAT-0524', marketplaces: ['ML', 'Shopee'], competitors_tracked: 6, check_freq: '30min', status: 'active' },
];
---

<AppLayout title="Catálogo Monitorado" activePage="catalogo">

  <!-- Header -->
  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:28px; flex-wrap:wrap; gap:12px;">
    <div>
      <h1 style="font-size:22px; font-weight:700; color:var(--text-primary); letter-spacing:-0.03em; margin-bottom:4px;">Catálogo Monitorado</h1>
      <div style="font-size:13px; color:var(--text-muted);">55 produtos ativos · 12 concorrentes rastreados</div>
    </div>
    <div style="display:flex; gap:10px;">
      <button class="btn btn-ghost" id="btn-importar" onclick="showToast('Planilha importada: 12 SKUs adicionados')">
        <svg width="14" height="14" viewBox="0 0 15 15" fill="none"><path d="M7.5 1v9M4 7l3.5 3.5L11 7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/><path d="M2 11v2.5h11V11" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Importar via planilha
      </button>
      <button class="btn btn-red" id="btn-add" onclick="openModal()">
        <svg width="14" height="14" viewBox="0 0 15 15" fill="none"><path d="M7.5 1v13M1 7.5h13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        Adicionar produto
      </button>
    </div>
  </div>

  <!-- Tabs -->
  <div style="display:flex; gap:4px; margin-bottom:20px; background:var(--bg-card); border:1px solid var(--border); border-radius:10px; padding:4px; width:fit-content;">
    <button id="tab-produtos" class="tab-btn tab-active" onclick="switchTab('produtos')">Produtos</button>
    <button id="tab-concorrentes" class="tab-btn" onclick="switchTab('concorrentes')">Concorrentes</button>
  </div>

  <!-- Produtos tab -->
  <div id="panel-produtos">
    <div class="card" style="overflow:hidden;">
      <table class="data-table">
        <thead>
          <tr>
            <th>Produto</th>
            <th>SKU Interno</th>
            <th>Marketplaces</th>
            <th>Concorrentes</th>
            <th>Frequência</th>
            <th>Status</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          {products.map((p, i) => (
            <tr>
              <td>
                <div style="font-weight:500; color:var(--text-primary);">{p.name}</div>
                <div style="font-size:11px; color:var(--text-muted);">{p.category}</div>
              </td>
              <td><span style="font-size:12px; font-family:monospace; color:var(--text-secondary);">NAT-{String(p.id).padStart(4,'0')}{i}</span></td>
              <td>
                <div style="display:flex; gap:4px; flex-wrap:wrap;">
                  {p.marketplace === 'Mercado Livre' || i % 3 === 0 ? <span class="badge badge-gold" style="font-size:10px;">ML</span> : null}
                  {p.marketplace === 'Shopee' || i % 3 === 1 ? <span class="badge badge-red" style="font-size:10px; background:rgba(255,94,61,0.12); color:#ff5e3d; border-color:rgba(255,94,61,0.2);">Shopee</span> : null}
                  {p.marketplace === 'Amazon' || i % 3 === 2 ? <span class="badge badge-green" style="font-size:10px;">Amazon</span> : null}
                </div>
              </td>
              <td><span style="font-weight:600; color:var(--text-primary);">{3 + (i % 4)}</span> <span style="color:var(--text-muted); font-size:12px;">rastreados</span></td>
              <td><span style="font-size:12px; color:var(--text-secondary);">30min</span></td>
              <td>
                <span class={`badge ${p.buybox === 'ACTIVE' ? 'badge-green' : p.buybox === 'LOST' ? 'badge-red' : 'badge-yellow'}`} style="font-size:10px;">
                  {p.buybox === 'ACTIVE' ? 'Ativo' : p.buybox === 'LOST' ? 'Alerta' : 'Risco'}
                </span>
              </td>
              <td>
                <div style="display:flex; gap:6px;">
                  <button class="btn btn-ghost" style="padding:5px 10px; font-size:11px;">Editar</button>
                  <button class="btn btn-ghost" style="padding:5px 10px; font-size:11px; color:var(--text-muted);">Pausar</button>
                </div>
              </td>
            </tr>
          ))}
          {extraSkus.map(p => (
            <tr>
              <td>
                <div style="font-weight:500; color:var(--text-primary);">{p.name}</div>
              </td>
              <td><span style="font-size:12px; font-family:monospace; color:var(--text-secondary);">{p.sku}</span></td>
              <td>
                <div style="display:flex; gap:4px; flex-wrap:wrap;">
                  {p.marketplaces.includes('ML') && <span class="badge badge-gold" style="font-size:10px;">ML</span>}
                  {p.marketplaces.includes('Shopee') && <span class="badge badge-red" style="font-size:10px; background:rgba(255,94,61,0.12); color:#ff5e3d; border-color:rgba(255,94,61,0.2);">Shopee</span>}
                  {p.marketplaces.includes('Amazon') && <span class="badge badge-green" style="font-size:10px;">Amazon</span>}
                </div>
              </td>
              <td><span style="font-weight:600; color:var(--text-primary);">{p.competitors_tracked}</span> <span style="color:var(--text-muted); font-size:12px;">rastreados</span></td>
              <td><span style="font-size:12px; color:var(--text-secondary);">{p.check_freq}</span></td>
              <td>
                <span class={`badge ${p.status === 'active' ? 'badge-green' : 'badge-yellow'}`} style="font-size:10px;">
                  {p.status === 'active' ? 'Ativo' : 'Pausado'}
                </span>
              </td>
              <td>
                <div style="display:flex; gap:6px;">
                  <button class="btn btn-ghost" style="padding:5px 10px; font-size:11px;">Editar</button>
                  <button class="btn btn-ghost" style="padding:5px 10px; font-size:11px; color:var(--text-muted);">Pausar</button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Concorrentes tab -->
  <div id="panel-concorrentes" style="display:none;">
    <div class="card" style="overflow:hidden;">
      <table class="data-table">
        <thead>
          <tr>
            <th>Concorrente</th>
            <th>Marketplaces</th>
            <th>SKUs em conflito</th>
            <th>Agressividade</th>
            <th>Última mudança de preço</th>
            <th>Ação</th>
          </tr>
        </thead>
        <tbody>
          {competitors.map(c => (
            <tr>
              <td>
                <div style="font-weight:500; color:var(--text-primary);">{c.name}</div>
                <div style="font-size:11px; color:var(--text-muted);">Rastreado desde {c.tracked_since}</div>
              </td>
              <td>
                <div style="display:flex; gap:4px; flex-wrap:wrap;">
                  {c.marketplaces.includes('ML') && <span class="badge badge-gold" style="font-size:10px;">ML</span>}
                  {c.marketplaces.includes('Shopee') && <span class="badge badge-red" style="font-size:10px; background:rgba(255,94,61,0.12); color:#ff5e3d; border-color:rgba(255,94,61,0.2);">Shopee</span>}
                  {c.marketplaces.includes('Amazon') && <span class="badge badge-green" style="font-size:10px;">Amazon</span>}
                </div>
              </td>
              <td><span style="font-weight:600; color:var(--text-primary);">{c.skus_in_conflict}</span></td>
              <td>
                <span class={`badge ${c.aggressiveness === 'Alta' ? 'badge-red' : c.aggressiveness === 'Média' ? 'badge-yellow' : 'badge-green'}`} style="font-size:10px;">{c.aggressiveness}</span>
              </td>
              <td><span style="font-size:12px; color:var(--text-secondary);">{c.last_price_change}</span></td>
              <td>
                {c.slug === 'importadora-asia-sp'
                  ? <a href="/concorrentes/importadora-asia-sp" class="btn btn-ghost" style="padding:5px 10px; font-size:11px; text-decoration:none;">Ver ficha</a>
                  : <button class="btn btn-ghost" style="padding:5px 10px; font-size:11px;">Ver ficha</button>
                }
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Add product modal -->
  <div id="add-modal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
      <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:24px;">
        <h2 style="font-size:16px; font-weight:600; color:var(--text-primary);">Adicionar produto</h2>
        <button onclick="closeModal()" style="background:none; border:none; cursor:pointer; color:var(--text-muted);">
          <svg width="16" height="16" viewBox="0 0 15 15" fill="none"><path d="M2 2l11 11M13 2L2 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
      </div>
      <div style="display:flex; flex-direction:column; gap:14px;">
        <div>
          <label style="font-size:12px; color:var(--text-muted); margin-bottom:6px; display:block;">Nome do produto</label>
          <input class="input-field" placeholder="Ex: Shoyu Premium 500ml" type="text" />
        </div>
        <div>
          <label style="font-size:12px; color:var(--text-muted); margin-bottom:6px; display:block;">SKU interno</label>
          <input class="input-field" placeholder="Ex: NAT-0625" type="text" />
        </div>
        <div>
          <label style="font-size:12px; color:var(--text-muted); margin-bottom:6px; display:block;">Marketplaces</label>
          <div style="display:flex; gap:10px;">
            <label style="display:flex; align-items:center; gap:6px; font-size:13px; color:var(--text-secondary); cursor:pointer;">
              <input type="checkbox" checked /> ML
            </label>
            <label style="display:flex; align-items:center; gap:6px; font-size:13px; color:var(--text-secondary); cursor:pointer;">
              <input type="checkbox" /> Shopee
            </label>
            <label style="display:flex; align-items:center; gap:6px; font-size:13px; color:var(--text-secondary); cursor:pointer;">
              <input type="checkbox" /> Amazon
            </label>
          </div>
        </div>
        <div>
          <label style="font-size:12px; color:var(--text-muted); margin-bottom:6px; display:block;">Frequência de monitoramento</label>
          <select class="input-field" style="cursor:pointer;">
            <option>30 minutos</option>
            <option>1 hora</option>
            <option>2 horas</option>
          </select>
        </div>
        <div style="display:flex; gap:10px; margin-top:8px;">
          <button class="btn btn-ghost" style="flex:1;" onclick="closeModal()">Cancelar</button>
          <button class="btn btn-red" style="flex:1;" onclick="addProduct()">Adicionar</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div id="toast" class="toast" style="display:none;"></div>

</AppLayout>

<style>
.tab-btn {
  padding: 7px 16px;
  border-radius: 7px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  background: transparent;
  border: none;
  color: var(--text-secondary);
  transition: all 0.15s;
}
.tab-active {
  background: var(--bg-secondary);
  color: var(--text-primary);
  border: 1px solid var(--border) !important;
}
</style>

<script>
function switchTab(tab: string) {
  const products = document.getElementById('panel-produtos');
  const comps = document.getElementById('panel-concorrentes');
  const btnP = document.getElementById('tab-produtos');
  const btnC = document.getElementById('tab-concorrentes');
  if (!products || !comps || !btnP || !btnC) return;
  if (tab === 'produtos') {
    products.style.display = 'block';
    comps.style.display = 'none';
    btnP.classList.add('tab-active');
    btnC.classList.remove('tab-active');
  } else {
    products.style.display = 'none';
    comps.style.display = 'block';
    btnC.classList.add('tab-active');
    btnP.classList.remove('tab-active');
  }
}

function openModal() {
  const m = document.getElementById('add-modal');
  if (m) m.style.display = 'flex';
}

function closeModal() {
  const m = document.getElementById('add-modal');
  if (m) m.style.display = 'none';
}

function addProduct() {
  closeModal();
  showToast('Produto adicionado ao monitoramento');
}

function showToast(msg: string) {
  const t = document.getElementById('toast');
  if (!t) return;
  t.textContent = msg;
  t.style.display = 'block';
  setTimeout(() => { t.style.display = 'none'; }, 3000);
}

(window as any).switchTab = switchTab;
(window as any).openModal = openModal;
(window as any).closeModal = closeModal;
(window as any).addProduct = addProduct;
(window as any).showToast = showToast;
</script>
