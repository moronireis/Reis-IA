---
import AppLayout from '../../layouts/AppLayout.astro';
import competitors from '../../data/competitors.json';

const competitor = competitors.find(c => c.slug === 'importadora-asia-sp')!;
---

<AppLayout title="Ficha do Concorrente" activePage="catalogo">

  <!-- Back link -->
  <div style="margin-bottom:20px;">
    <a href="/catalogo" style="display:inline-flex; align-items:center; gap:6px; font-size:13px; color:var(--text-muted); text-decoration:none; transition:color 0.15s;"
       onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-muted)'">
      <svg width="14" height="14" viewBox="0 0 15 15" fill="none"><path d="M9 2L4 7.5 9 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Voltar ao Catálogo
    </a>
  </div>

  <!-- Header card -->
  <div class="card" style="padding:28px; margin-bottom:20px; background: linear-gradient(135deg, rgba(200,16,46,0.05) 0%, transparent 60%);">
    <div style="display:flex; align-items:flex-start; justify-content:space-between; flex-wrap:wrap; gap:16px;">
      <div style="display:flex; align-items:center; gap:20px;">
        <!-- Logo placeholder -->
        <div style="
          width:56px; height:56px; border-radius:12px;
          background:var(--bg-secondary); border:1px solid var(--border);
          display:flex; align-items:center; justify-content:center;
          font-size:18px; font-weight:700; color:var(--text-muted); letter-spacing:-0.02em;
        ">IA</div>
        <div>
          <h1 style="font-size:20px; font-weight:700; color:var(--text-primary); letter-spacing:-0.02em; margin-bottom:4px;">{competitor.name}</h1>
          <div style="font-size:12px; color:var(--text-muted); margin-bottom:8px;">Rastreado desde {competitor.tracked_since}</div>
          <!-- Stars -->
          <div style="display:flex; align-items:center; gap:6px;">
            <div style="display:flex; gap:2px;">
              {[1,2,3,4,5].map(s => (
                <svg width="12" height="12" viewBox="0 0 15 15" fill="none">
                  <path d="M7.5 1.5l1.6 4.8H14l-3.9 2.9 1.5 4.8-4.1-3-4.1 3 1.5-4.8L1 6.3h4.9z"
                    fill={s <= Math.floor(competitor.reputation) ? 'var(--gold)' : 'none'}
                    stroke="var(--gold)" stroke-width="1.2"/>
                </svg>
              ))}
            </div>
            <span style="font-size:12px; color:var(--text-secondary);">{competitor.reputation} · Mercado Livre</span>
          </div>
        </div>
      </div>
      <div style="display:flex; gap:8px; flex-wrap:wrap;">
        {competitor.marketplaces.map(m => (
          <span class={`badge ${m === 'ML' ? 'badge-gold' : m === 'Shopee' ? 'badge-red' : 'badge-green'}`}>{m}</span>
        ))}
        <span class="badge badge-red">{competitor.skus_in_conflict} SKUs em conflito</span>
      </div>
    </div>
  </div>

  <!-- Stats row -->
  <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:20px;">
    <div class="card" style="padding:20px;">
      <div style="font-size:11px; color:var(--text-muted); margin-bottom:6px; text-transform:uppercase; letter-spacing:0.08em;">Diferença média de preço</div>
      <div style="font-size:24px; font-weight:700; color:var(--red);">R${Math.abs(competitor.avg_price_diff).toFixed(2)}</div>
      <div style="font-size:11px; color:var(--text-muted); margin-top:2px;">abaixo do seu preço médio</div>
    </div>
    <div class="card" style="padding:20px;">
      <div style="font-size:11px; color:var(--text-muted); margin-bottom:6px; text-transform:uppercase; letter-spacing:0.08em;">Agressividade</div>
      <div style="font-size:24px; font-weight:700; color:var(--red);">{competitor.aggressiveness}</div>
      <div style="font-size:11px; color:var(--text-muted); margin-top:2px;">grau de competição</div>
    </div>
    <div class="card" style="padding:20px;">
      <div style="font-size:11px; color:var(--text-muted); margin-bottom:6px; text-transform:uppercase; letter-spacing:0.08em;">Mudanças/semana</div>
      <div style="font-size:24px; font-weight:700; color:var(--yellow);">{competitor.price_changes_per_week}</div>
      <div style="font-size:11px; color:var(--text-muted); margin-top:2px;">alterações de preço</div>
    </div>
    <div class="card" style="padding:20px;">
      <div style="font-size:11px; color:var(--text-muted); margin-bottom:6px; text-transform:uppercase; letter-spacing:0.08em;">Horários frequentes</div>
      <div style="font-size:15px; font-weight:700; color:var(--text-primary); margin-top:4px;">{competitor.common_change_hours}</div>
      <div style="font-size:11px; color:var(--text-muted); margin-top:2px;">picos de atividade</div>
    </div>
  </div>

  <!-- SKU conflict table -->
  <div class="card" style="overflow:hidden; margin-bottom:20px;">
    <div style="padding:20px 24px 14px; border-bottom:1px solid var(--border);">
      <div style="font-size:14px; font-weight:600; color:var(--text-primary);">SKUs em conflito com Natori</div>
    </div>
    <table class="data-table">
      <thead>
        <tr>
          <th>Produto</th>
          <th>Seu preço</th>
          <th>Preço deles</th>
          <th>Diferença</th>
          <th>Última ação</th>
        </tr>
      </thead>
      <tbody>
        {competitor.sku_conflicts?.map(s => (
          <tr>
            <td style="font-weight:500;">{s.sku}</td>
            <td>R${s.our_price.toFixed(2)}</td>
            <td style={`font-weight:600; color:${s.diff < 0 ? 'var(--red)' : 'var(--green)'};`}>R${s.their_price.toFixed(2)}</td>
            <td>
              <span class={`badge ${s.diff < -0.5 ? 'badge-red' : s.diff < 0 ? 'badge-yellow' : 'badge-green'}`}>
                {s.diff > 0 ? '+' : ''}{s.diff.toFixed(2)}
              </span>
            </td>
            <td style="font-size:12px; color:var(--text-muted);">{s.last_action}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Timeline + CTA -->
  <div style="display:grid; grid-template-columns:1fr 320px; gap:20px;">

    <!-- Timeline -->
    <div class="card" style="padding:24px;">
      <div style="font-size:14px; font-weight:600; color:var(--text-primary); margin-bottom:20px;">Linha do Tempo de Ações Recentes</div>
      {competitor.recent_actions?.map((a, i) => (
        <div style={`display:flex; gap:14px; padding:12px 0; border-bottom:${i < (competitor.recent_actions?.length ?? 0)-1 ? '1px solid var(--border)' : 'none'};`}>
          <div style="flex-shrink:0; font-size:11px; font-weight:600; color:var(--text-muted); width:80px; padding-top:2px;">{a.date}</div>
          <div style="display:flex; align-items:flex-start; gap:10px; flex:1;">
            <div style="width:6px; height:6px; border-radius:50%; background:var(--red); margin-top:5px; flex-shrink:0;"></div>
            <div style="font-size:13px; color:var(--text-primary); line-height:1.5;">{a.action}</div>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA card -->
    <div class="card" style="padding:24px; display:flex; flex-direction:column; justify-content:center; gap:16px; background:linear-gradient(135deg, rgba(200,16,46,0.06) 0%, transparent 80%);">
      <div>
        <div style="font-size:13px; font-weight:600; color:var(--text-primary); margin-bottom:6px;">Automatizar resposta</div>
        <div style="font-size:12px; color:var(--text-muted); line-height:1.6;">Crie uma regra automática especificamente contra este concorrente — ajuste de preço, alerta ou diagnóstico.</div>
      </div>
      <a href="/regras" class="btn btn-red" style="text-decoration:none; text-align:center; justify-content:center;">
        Criar regra automática
      </a>
      <button class="btn btn-ghost" onclick="alert('Concorrente pausado do monitoramento')">Pausar monitoramento</button>
    </div>
  </div>

</AppLayout>
