---
interface Props {
  title: string;
  activePage: 'chat' | 'connection' | 'dashboard' | 'comercial' | 'settings';
}
const { title, activePage } = Astro.props;
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Castelo dos Lagos</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --forest-deep: #1E2E24;
      --forest-mid: #2F4A3A;
      --forest-light: #3D5E4A;
      --gold: #C9A96E;
      --gold-dim: rgba(201,169,110,0.25);
      --cream: #F4EFE6;
      --cream-dim: rgba(244,239,230,0.55);
      --red: #F87171;
    }
    html, body { height: 100%; font-family: 'Inter', sans-serif; background: var(--forest-deep); color: var(--cream); -webkit-font-smoothing: antialiased; }
    .app-shell { display: flex; height: 100vh; overflow: hidden; }
    .sidebar { width: 56px; background: #0E1A13; display: flex; flex-direction: column; align-items: center; padding: 1rem 0; border-right: 1px solid var(--gold-dim); flex-shrink: 0; }
    .sidebar-nav { display: flex; flex-direction: column; gap: 0.5rem; width: 100%; }
    .nav-item { display: flex; align-items: center; justify-content: center; width: 100%; height: 44px; cursor: pointer; border-left: 2px solid transparent; text-decoration: none; color: var(--cream-dim); transition: all 0.2s; }
    .nav-item:hover { color: var(--cream); background: var(--gold-dim); }
    .nav-item.active { color: var(--gold); border-left-color: var(--gold); background: rgba(201,169,110,0.1); }
    .nav-item svg { width: 20px; height: 20px; }
    .sidebar-bottom { margin-top: auto; }
    .logout-btn { display: flex; align-items: center; justify-content: center; width: 56px; height: 44px; cursor: pointer; border-left: 2px solid transparent; color: var(--cream-dim); background: none; border-top: none; border-right: none; border-bottom: none; transition: all 0.2s; }
    .logout-btn:hover { color: var(--red); background: rgba(248,113,113,0.08); }
    .logout-btn svg { width: 20px; height: 20px; }
    .main-content { flex: 1; overflow: hidden; }
  </style>
</head>
<body>
  <div class="app-shell">
    <aside class="sidebar">
      <nav class="sidebar-nav">
        <a href="/chat" class={`nav-item ${activePage === 'chat' ? 'active' : ''}`} title="Conversas">
          <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" />
          </svg>
        </a>
        <a href="/dashboard" class={`nav-item ${activePage === 'dashboard' ? 'active' : ''}`} title="Dashboard">
          <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
          </svg>
        </a>
        <a href="/comercial" class={`nav-item ${activePage === 'comercial' ? 'active' : ''}`} title="Comercial">
          <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 0 0 .75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 0 0-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0 1 12 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 0 1-.673-.38m0 0A2.18 2.18 0 0 1 3 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 0 1 3.413-.387m7.5 0V5.25A2.25 2.25 0 0 0 13.5 3h-3a2.25 2.25 0 0 0-2.25 2.25v.894m7.5 0a48.667 48.667 0 0 0-7.5 0M12 12.75h.008v.008H12v-.008Z" />
          </svg>
        </a>
      </nav>
      <div class="sidebar-bottom">
        <a href="/connection" class={`nav-item ${activePage === 'connection' ? 'active' : ''}`} title="Conexão / Configurações">
          <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
          </svg>
        </a>
        <form method="POST" action="/api/auth/logout">
          <button type="submit" class="logout-btn" title="Sair">
            <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15M12 9l-3 3m0 0 3 3m-3-3h12.75" />
            </svg>
          </button>
        </form>
      </div>
    </aside>
    <main class="main-content">
      <slot />
    </main>
  </div>
</body>
</html>
