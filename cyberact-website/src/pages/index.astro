---
import Layout from '../layouts/Layout.astro';
import TestimonialCarousel from '../components/TestimonialCarousel';
import AnimatedNumbers from '../components/AnimatedNumbers';
import { SuporteMockup } from '../components/MockupDashboard';
import CyberGridHero from '../components/backgrounds/CyberGridHero';
import HeroDashboard from '../components/HeroDashboard';
import StatsStrip from '../components/StatsStrip';
import ComparisonMockup from '../components/ComparisonMockup';
import PhoneMockup from '../components/PhoneMockup';

const partners = [
  { name: 'Kaspersky', file: 'kaspersky.avif' },
  { name: 'Fortinet', file: 'fortinet.avif' },
  { name: 'Sophos', file: 'sophos.avif' },
  { name: 'Cisco', file: 'cisco.avif' },
  { name: 'Azure', file: 'azure.avif' },
  { name: 'CrashPlan', file: 'crashplan.avif' },
  { name: 'Dell', file: 'dell.avif' },
  { name: 'Microsoft Office', file: 'office.avif' },
  { name: 'HP', file: 'hp.avif' },
  { name: 'Windows 11', file: 'windows11.avif' },
  { name: 'AutoCAD', file: 'autoad.avif' },
  { name: 'Intelbras', file: 'intelbras.avif' },
  { name: 'Ubiquiti', file: 'ubiquiti.avif' },
  { name: 'Furukawa', file: 'furukawa.avif' },
  { name: 'Hikvision', file: 'hikvision.avif' },
];
---

<Layout title="CyberAct Tecnologia — TI Descomplicado para Empresas">

  <!-- Hero -->
  <section class="relative min-h-[80vh] md:min-h-[90vh] flex items-center section-padding overflow-hidden">
    <CyberGridHero client:load />

    <div class="container-narrow relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <!-- Left: Text -->
        <div>
          <div class="flex items-center gap-3 mb-8 animate-fade-up">
            <div class="relative flex items-center gap-2">
              <span class="relative flex h-2.5 w-2.5">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyber-red opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-cyber-red"></span>
              </span>
              <div class="h-px w-10 bg-cyber-red"></div>
            </div>
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-cyber-red">Sistema Ativo</span>
          </div>
          <h1 class="text-[1.75rem] sm:text-4xl md:text-5xl lg:text-[3.25rem] font-bold leading-[1.15] mb-6 md:mb-8 animate-fade-up animate-delay-100">
            <span class="text-cyber-white">Um time de TI que</span><br/>
            <span class="text-cyber-white">custa menos do que</span><br/>
            <span class="text-cyber-red">um funcionário.</span>
          </h1>
          <p class="text-base md:text-lg text-cyber-text leading-relaxed max-w-lg mb-5 animate-fade-up animate-delay-200">
            Terceirização de TI com helpdesk, segurança, infraestrutura e monitoramento inteligente.
            <span class="text-cyber-white font-medium"> TI que funciona sempre.</span>
          </p>
          <p class="text-sm text-cyber-text/60 leading-relaxed max-w-md mb-8 md:mb-10 animate-fade-up animate-delay-300">
            Seu técnico pediu demissão e levou o conhecimento? Com a CyberAct, esse problema não existe.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 animate-fade-up animate-delay-400">
            <a href="/contato" class="btn-primary">
              Solicitar consultoria gratuita
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 8h10M9 4l4 4-4 4"/>
              </svg>
            </a>
            <a href="/servicos" class="btn-outline">Conhecer serviços</a>
          </div>
        </div>

        <!-- Right: Dashboard Mockup -->
        <div class="mt-8 lg:mt-0 animate-fade-up animate-delay-300">
          <HeroDashboard client:load />
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Strip -->
  <section class="border-t border-cyber-border">
    <div class="container-narrow">
      <StatsStrip client:load />
    </div>
  </section>

  <!-- Trabalhamos Juntos -->
  <section class="section-padding border-t border-cyber-border">
    <div class="container-narrow">
      <div class="text-center mb-16 reveal">
        <span class="text-xs font-semibold uppercase tracking-[0.2em] text-cyber-red">Trabalhamos juntos</span>
        <h2 class="text-2xl sm:text-3xl md:text-5xl font-light text-cyber-white mt-4 mb-4">
          Simples. Prático. <span class="text-cyber-red">Eficiente.</span>
        </h2>
        <p class="text-cyber-text max-w-2xl mx-auto">
          Cada empresa tem sua engrenagem. Nossa função é fazer a tecnologia rodar sem que você precise pensar nela.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger-children">
        <div class="card group">
          <div class="w-12 h-12 flex items-center justify-center border border-cyber-border group-hover:border-cyber-red transition-colors mb-6">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-cyber-red">
              <path d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="text-lg font-medium text-cyber-white mb-3">Suporte Técnico</h3>
          <p class="text-sm text-cyber-text leading-relaxed">
            Auxílio remoto e presencial com laboratório próprio para computadores e impressoras. Tempo de resposta de 5 minutos. Backup em nuvem incluído no pacote.
          </p>
        </div>

        <div class="card group">
          <div class="w-12 h-12 flex items-center justify-center border border-cyber-border group-hover:border-cyber-red transition-colors mb-6">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-cyber-red">
              <path d="M15 10l-4 4l6 6l4-16l-18 7l4 2l2 6l3-4"/>
            </svg>
          </div>
          <h3 class="text-lg font-medium text-cyber-white mb-3">Câmeras e Alarmes</h3>
          <p class="text-sm text-cyber-text leading-relaxed">
            Instalação, configuração e monitoramento para escritórios, casas, escolas ou indústrias. Acionamos a polícia e enviamos vigilantes ao local automaticamente.
          </p>
        </div>

        <div class="card group">
          <div class="w-12 h-12 flex items-center justify-center border border-cyber-border group-hover:border-cyber-red transition-colors mb-6">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-cyber-red">
              <path d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01M1.394 9.393a12 12 0 0121.212 0M4.636 13.05a8 8 0 0114.728 0"/>
            </svg>
          </div>
          <h3 class="text-lg font-medium text-cyber-white mb-3">Projetos de Infraestrutura</h3>
          <p class="text-sm text-cyber-text leading-relaxed">
            Do mais simples ao mais complexo. Entregamos 100% de cobertura de internet por cabo e WiFi, com mapa de calor, certificação e garantia de 5 anos.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Suporte Avançado -->
  <section class="section-padding border-t border-cyber-border grid-bg" style="background-color: var(--color-cyber-surface-1);">
    <div class="container-narrow">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
        <div class="reveal-left">
          <div class="flex items-center gap-3 mb-6">
            <div class="h-px w-12 bg-cyber-red"></div>
            <span class="text-xs font-medium uppercase tracking-[0.2em] text-cyber-red">Suporte Avançado</span>
          </div>
          <h2 class="text-xl sm:text-3xl md:text-4xl font-bold text-cyber-white mb-6">
            Automatizamos toda<br/>a sua <span class="text-cyber-red">estrutura.</span>
          </h2>
          <p class="text-cyber-text leading-relaxed mb-8">
            Enquanto você foca nos seus objetivos, a gente cuida de cada detalhe da sua operação de TI. Da prevenção de problemas à negociação com fornecedores — tudo resolvido antes de virar dor de cabeça.
          </p>
          <a href="/servicos" class="btn-primary">
            Saiba mais
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 8h10M9 4l4 4-4 4"/>
            </svg>
          </a>
        </div>
        <div class="reveal-right">
          <SuporteMockup client:load />
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-line"></div>

  <!-- Comparativo -->
  <section class="section-padding border-t border-cyber-border relative">
    <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(90deg, transparent 48%, rgba(230,57,70,0.03) 50%, rgba(230,57,70,0.06) 100%);"></div>
    <div class="container-narrow relative z-10">
      <div class="text-center mb-12 reveal">
        <span class="text-xs font-semibold uppercase tracking-[0.2em] text-cyber-red">Comparativo</span>
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-cyber-white mt-4 mb-4">
          Por que a diferença <span class="text-cyber-red">importa.</span>
        </h2>
        <p class="text-cyber-text max-w-2xl mx-auto text-sm">
          Mesmos eventos. Resultados completamente diferentes. A IA da CyberAct elimina 100% dos falsos alarmes.
        </p>
      </div>

      <div class="reveal">
        <ComparisonMockup client:load />
      </div>
    </div>
  </section>

  <!-- Segurança -->
  <section class="section-padding border-t border-cyber-border relative overflow-hidden" style="background-color: var(--color-cyber-surface-1);">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(42,90,143,0.08),transparent_60%)] pointer-events-none"></div>
    <div class="container-narrow relative z-10">
      <div class="text-center mb-12 reveal">
        <div class="flex items-center gap-3 justify-center mb-6">
          <div class="h-px w-12 bg-cyber-red"></div>
          <span class="text-xs font-semibold uppercase tracking-[0.2em] text-cyber-red">Segurança</span>
          <div class="h-px w-12 bg-cyber-red"></div>
        </div>
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-cyber-white mb-4">
          Seu ambiente precisa de<br/><span class="text-cyber-red">proteção real.</span>
        </h2>
        <p class="text-cyber-text max-w-2xl mx-auto">
          Não adianta trancar a porta se a janela está aberta. Segurança digital é sobre fechar cada brecha.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 stagger-children">
        <div class="card group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 flex items-center justify-center border border-cyber-border group-hover:border-cyber-red transition-colors">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-cyber-red">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <h3 class="text-base font-semibold text-cyber-white">Firewall & VPN</h3>
          </div>
          <p class="text-sm text-cyber-text leading-relaxed">Proteção de perímetro e acesso remoto seguro para filiais e colaboradores.</p>
        </div>

        <div class="card group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 flex items-center justify-center border border-cyber-border group-hover:border-cyber-red transition-colors">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-cyber-red">
                <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/>
                <line x1="4" y1="22" x2="4" y2="15"/>
              </svg>
            </div>
            <h3 class="text-base font-semibold text-cyber-white">Testes de Intrusão</h3>
          </div>
          <p class="text-sm text-cyber-text leading-relaxed">Simulação de ataques para descobrir vulnerabilidades antes que alguém mais descubra.</p>
        </div>

        <div class="card group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 flex items-center justify-center border border-cyber-border group-hover:border-cyber-red transition-colors">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-cyber-red">
                <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                <polyline points="17 8 12 3 7 8"/>
                <line x1="12" y1="3" x2="12" y2="15"/>
              </svg>
            </div>
            <h3 class="text-base font-semibold text-cyber-white">Backup Automático</h3>
          </div>
          <p class="text-sm text-cyber-text leading-relaxed">Backup em nuvem com restauração em horas. Se algo acontecer, seus dados estão seguros.</p>
        </div>

        <div class="card group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 flex items-center justify-center border border-cyber-border group-hover:border-cyber-red transition-colors">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-cyber-red">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0110 0v4"/>
              </svg>
            </div>
            <h3 class="text-base font-semibold text-cyber-white">Criptografia & LGPD</h3>
          </div>
          <p class="text-sm text-cyber-text leading-relaxed">Criptografia de dados em trânsito e repouso. Adequação completa à LGPD.</p>
        </div>

        <div class="card group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 flex items-center justify-center border border-cyber-border group-hover:border-cyber-red transition-colors">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-cyber-red">
                <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
              </svg>
            </div>
            <h3 class="text-base font-semibold text-cyber-white">Anti-Ransomware</h3>
          </div>
          <p class="text-sm text-cyber-text leading-relaxed">Proteção ativa contra sequestro de dados. Detecção, bloqueio e restauração rápida.</p>
        </div>

        <div class="card group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 flex items-center justify-center border border-cyber-border group-hover:border-cyber-red transition-colors">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-cyber-red">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
              </svg>
            </div>
            <h3 class="text-base font-semibold text-cyber-white">Auditoria Contínua</h3>
          </div>
          <p class="text-sm text-cyber-text leading-relaxed">Scans periódicos de vulnerabilidade e relatórios de conformidade para gestão.</p>
        </div>
      </div>

      <div class="text-center mt-10 reveal">
        <a href="/servicos" class="btn-outline">Ver todos os serviços</a>
      </div>
    </div>
  </section>

  <!-- Monitoramento -->
  <section class="section-padding border-t border-cyber-border grid-bg" style="background-color: var(--color-cyber-surface-1);">
    <div class="container-narrow">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
        <div class="reveal-left">
          <div class="flex items-center gap-3 mb-6">
            <div class="h-px w-12 bg-cyber-red"></div>
            <span class="text-xs font-medium uppercase tracking-[0.2em] text-cyber-red">Monitoramento</span>
          </div>
          <h2 class="text-xl sm:text-3xl md:text-4xl font-bold text-cyber-white mb-6">
            Seu ambiente protegido<br/><span class="text-cyber-red">24 x 7.</span>
          </h2>
          <p class="text-cyber-text leading-relaxed mb-4">
            Sistemas convencionais dependem de alguém lembrar de armar o alarme. O nosso não. Inteligência artificial monitora seu perímetro 24 horas por dia — sem intervenção humana, sem falha por esquecimento.
          </p>
          <ul class="space-y-2 mb-8">
            <li class="flex items-start gap-3 text-sm text-cyber-text">
              <span class="w-1.5 h-1.5 bg-cyber-red flex-shrink-0 mt-1.5"></span>
              IA diferencia pessoas, veículos e animais — zero alarmes falsos
            </li>
            <li class="flex items-start gap-3 text-sm text-cyber-text">
              <span class="w-1.5 h-1.5 bg-cyber-red flex-shrink-0 mt-1.5"></span>
              Visão noturna colorida em alta definição
            </li>
            <li class="flex items-start gap-3 text-sm text-cyber-text">
              <span class="w-1.5 h-1.5 bg-cyber-red flex-shrink-0 mt-1.5"></span>
              Áudio bidirecional — operador age no momento do evento
            </li>
            <li class="flex items-start gap-3 text-sm text-cyber-text">
              <span class="w-1.5 h-1.5 bg-cyber-red flex-shrink-0 mt-1.5"></span>
              Gestão centralizada em nuvem — múltiplos locais num painel
            </li>
          </ul>
          <a href="/servicos" class="btn-primary">
            Saiba mais
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 8h10M9 4l4 4-4 4"/>
            </svg>
          </a>
        </div>
        <div class="reveal-right">
          <PhoneMockup client:load />
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-line"></div>

  <!-- Depoimentos -->
  <section class="section-padding border-t border-cyber-border">
    <div class="container-narrow reveal-scale">
      <TestimonialCarousel client:load />
    </div>
  </section>

  <!-- Parceiros -->
  <section class="section-padding border-t border-cyber-border" style="background-color: var(--color-cyber-surface-1);">
    <div class="container-narrow">
      <div class="text-center mb-12 reveal">
        <span class="text-xs font-semibold uppercase tracking-[0.2em] text-cyber-red">Tecnologia</span>
        <h2 class="text-xl sm:text-3xl md:text-4xl font-bold text-cyber-white mt-4 mb-4">
          Nossos <span class="text-cyber-red">parceiros</span>
        </h2>
        <p class="text-cyber-text max-w-2xl mx-auto text-sm">
          Buscamos sempre o que há de mais moderno no mercado. Aliamos custo-benefício ao integrar essas tecnologias para que você tenha qualidade e garantia. Já viu uma empresa dar <span class="text-cyber-white font-medium">5 anos de garantia</span> em projetos? Nós damos.
        </p>
      </div>

      <div class="overflow-hidden relative reveal-scale">
        <div class="absolute left-0 top-0 bottom-0 w-24 z-10 pointer-events-none" style="background: linear-gradient(to right, var(--color-cyber-surface-1), transparent);"></div>
        <div class="absolute right-0 top-0 bottom-0 w-24 z-10 pointer-events-none" style="background: linear-gradient(to left, var(--color-cyber-surface-1), transparent);"></div>
        <div class="marquee-track">
          {[...partners, ...partners].map((partner, i) => (
            <div class="flex-shrink-0 px-8 md:px-12 py-6 flex items-center justify-center" key={i}>
              <img
                src={`/partners/${partner.file}`}
                alt={partner.name}
                class="h-8 md:h-10 w-auto object-contain opacity-40 hover:opacity-100 transition-opacity duration-500 grayscale hover:grayscale-0"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CyberAct em Números -->
  <section class="border-t border-cyber-border grid-bg">
    <div class="container-narrow px-6 py-20">
      <div class="text-center mb-16 reveal">
        <span class="text-xs font-semibold uppercase tracking-[0.2em] text-cyber-red">CyberAct em números</span>
      </div>
      <AnimatedNumbers client:load />
    </div>
  </section>

  <div class="gradient-line"></div>

  <!-- CTA Final -->
  <section class="section-padding border-t border-cyber-border bg-cyber-dark/30 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(230,57,70,0.08),transparent_70%)]"></div>
    <div class="container-narrow text-center relative z-10 reveal-scale">
      <h2 class="text-2xl sm:text-3xl md:text-5xl font-bold text-cyber-white mb-6">
        Pronto para uma TI que<br/><span class="text-cyber-red">funciona de verdade?</span>
      </h2>
      <p class="text-cyber-text max-w-lg mx-auto mb-10 leading-relaxed">
        Consultoria e visita de avaliação gratuitas. Sem compromisso, sem contrato com multa. A gente mostra exatamente o que sua infraestrutura precisa.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contato" class="btn-primary">
          Agendar consultoria gratuita
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M3 8h10M9 4l4 4-4 4"/>
          </svg>
        </a>
        <a href="https://wa.me/5511976665786" target="_blank" class="btn-outline">
          Chamar no WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- Scroll reveal script -->
  <script>
    const observerOptions = { threshold: 0.15, rootMargin: '0px 0px -50px 0px' };
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, observerOptions);

    document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale, .stagger-children').forEach(el => {
      observer.observe(el);
    });
  </script>

</Layout>
