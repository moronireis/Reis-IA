---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contato — CyberAct Tecnologia">

  <!-- Header -->
  <section class="section-padding pb-12">
    <div class="container-narrow">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-6 animate-fade-up">
          <div class="h-px w-12 bg-cyber-red"></div>
          <span class="text-xs font-medium uppercase tracking-[0.2em] text-cyber-red">Contato</span>
        </div>
        <h1 class="text-2xl sm:text-4xl md:text-6xl font-light text-cyber-white mb-6 animate-fade-up animate-delay-100">
          Ter o melhor da TI<br/><span class="text-cyber-red">ficou fácil.</span>
        </h1>
        <p class="text-base md:text-lg text-cyber-text leading-relaxed max-w-xl animate-fade-up animate-delay-200">
          Consultoria e visita de avaliação gratuitas. A gente responde rápido — é o que fazemos.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="section-padding pt-0">
    <div class="container-narrow">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16">
        <!-- Form -->
        <div>
          <form class="space-y-6" id="contact-form">
            <div>
              <label class="block text-xs font-medium uppercase tracking-widest text-cyber-text mb-3" for="nome">Nome</label>
              <input
                type="text"
                id="nome"
                name="nome"
                required
                class="w-full bg-cyber-dark border border-cyber-border px-4 py-3.5 text-sm text-cyber-white placeholder-cyber-text/50 focus:border-cyber-red focus:outline-none transition-colors"
                placeholder="Seu nome"
              />
            </div>
            <div>
              <label class="block text-xs font-medium uppercase tracking-widest text-cyber-text mb-3" for="email">E-mail</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full bg-cyber-dark border border-cyber-border px-4 py-3.5 text-sm text-cyber-white placeholder-cyber-text/50 focus:border-cyber-red focus:outline-none transition-colors"
                placeholder="seu@email.com"
              />
            </div>
            <div>
              <label class="block text-xs font-medium uppercase tracking-widest text-cyber-text mb-3" for="telefone">Telefone</label>
              <input
                type="tel"
                id="telefone"
                name="telefone"
                class="w-full bg-cyber-dark border border-cyber-border px-4 py-3.5 text-sm text-cyber-white placeholder-cyber-text/50 focus:border-cyber-red focus:outline-none transition-colors"
                placeholder="(11) 99999-9999"
              />
            </div>
            <div>
              <label class="block text-xs font-medium uppercase tracking-widest text-cyber-text mb-3" for="servico">Serviço</label>
              <select
                id="servico"
                name="servico"
                class="w-full bg-cyber-dark border border-cyber-border px-4 py-3.5 text-sm text-cyber-white focus:border-cyber-red focus:outline-none transition-colors"
              >
                <option value="">Selecione o serviço</option>
                <option value="suporte">Suporte Técnico</option>
                <option value="seguranca">Segurança Eletrônica</option>
                <option value="redes">Projetos de Rede</option>
                <option value="backup">Backup em Nuvem</option>
                <option value="vpn">VPN Corporativa</option>
                <option value="ciberseguranca">Cibersegurança</option>
                <option value="consultoria">Consultoria Gratuita</option>
                <option value="outro">Outro</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-medium uppercase tracking-widest text-cyber-text mb-3" for="mensagem">Mensagem</label>
              <textarea
                id="mensagem"
                name="mensagem"
                rows="5"
                class="w-full bg-cyber-dark border border-cyber-border px-4 py-3.5 text-sm text-cyber-white placeholder-cyber-text/50 focus:border-cyber-red focus:outline-none transition-colors resize-none"
                placeholder="Conte um pouco sobre o que precisa..."
              ></textarea>
            </div>
            <button type="submit" class="btn-primary w-full justify-center">
              Enviar mensagem
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 8h10M9 4l4 4-4 4"/>
              </svg>
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="space-y-6">
          <div class="card">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-10 h-10 flex items-center justify-center border border-cyber-border">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-cyber-red">
                  <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <h3 class="text-sm font-medium text-cyber-white">Endereço</h3>
            </div>
            <p class="text-sm text-cyber-text leading-relaxed pl-14">
              Av. Eng. Luís Carlos Berrini, 1681<br/>
              Conj. 111 e 112 — Cidade Monções<br/>
              São Paulo, SP — 04571-011
            </p>
          </div>

          <div class="card">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-10 h-10 flex items-center justify-center border border-cyber-border">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-cyber-red">
                  <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <h3 class="text-sm font-medium text-cyber-white">Telefone</h3>
            </div>
            <a href="tel:+5511976665786" class="text-sm text-cyber-text hover:text-cyber-white transition-colors pl-14 block">
              (11) 97666-5786
            </a>
          </div>

          <div class="card">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-10 h-10 flex items-center justify-center border border-cyber-border">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-cyber-red">
                  <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <h3 class="text-sm font-medium text-cyber-white">E-mail</h3>
            </div>
            <a href="mailto:contato@cyberact.com.br" class="text-sm text-cyber-text hover:text-cyber-white transition-colors pl-14 block">
              contato@cyberact.com.br
            </a>
          </div>

          <a href="https://wa.me/5511976665786" target="_blank" class="card block bg-cyber-red/5 border-cyber-red/20 hover:bg-cyber-red/10">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 flex items-center justify-center border border-cyber-red/30">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-cyber-red">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-medium text-cyber-white">Chama no Zap</h3>
                <p class="text-xs text-cyber-text mt-1">Resposta rápida pelo WhatsApp</p>
              </div>
            </div>
          </a>

          <div class="card bg-cyber-red/5 border-cyber-red/20">
            <h3 class="text-sm font-medium text-cyber-white mb-3">Consultoria gratuita</h3>
            <p class="text-sm text-cyber-text leading-relaxed">
              Não sabe exatamente o que precisa? A gente vai até você, analisa sua infraestrutura e entrega um relatório completo. Sem custo, sem compromisso.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="section-padding border-t border-cyber-border bg-cyber-dark/30">
    <div class="container-narrow text-center">
      <h2 class="text-2xl font-light text-cyber-white mb-4">Receba novidades e atualizações</h2>
      <p class="text-sm text-cyber-text mb-8">Fique por dentro das novidades da CyberAct.</p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input
          type="email"
          placeholder="Seu e-mail"
          class="flex-1 bg-cyber-dark border border-cyber-border px-4 py-3 text-sm text-cyber-white placeholder-cyber-text/50 focus:border-cyber-red focus:outline-none transition-colors"
        />
        <button type="submit" class="btn-primary py-3">Assinar</button>
      </form>
    </div>
  </section>

</Layout>
