---
import '../styles/global.css'

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'CyberAct Tecnologia — Terceirização de TI, Segurança e Infraestrutura para empresas que não podem parar.' } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="noise-overlay">
    <nav class="fixed top-0 left-0 right-0 z-50 bg-cyber-black/90 backdrop-blur-md border-b border-cyber-border">
      <div class="container-narrow flex items-center justify-between h-16 px-6">
        <a href="/" class="flex items-center gap-0 text-xl tracking-tight">
          <span class="font-light text-cyber-white">CYBER</span><span class="font-light text-cyber-red">ACT</span>
        </a>
        <div class="hidden lg:flex items-center gap-8">
          <a href="/" class="text-sm text-cyber-text hover:text-cyber-white transition-colors">Home</a>
          <a href="/servicos" class="text-sm text-cyber-text hover:text-cyber-white transition-colors">Serviços</a>
          <a href="/sobre" class="text-sm text-cyber-text hover:text-cyber-white transition-colors">Sobre</a>
          <a href="/contato" class="text-sm text-cyber-text hover:text-cyber-white transition-colors">Contato</a>
          <a href="/ticket" class="text-sm text-cyber-text hover:text-cyber-white transition-colors">Abrir Ticket</a>
        </div>
        <div class="hidden lg:flex items-center gap-3">
          <a href="https://wa.me/5511976665786" target="_blank" class="btn-outline text-xs py-2 px-4">WhatsApp</a>
          <a href="/contato" class="btn-primary text-xs py-2 px-4">Fale Conosco</a>
        </div>
        <button id="mobile-toggle" class="lg:hidden text-cyber-white" aria-label="Menu">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M3 12h18M3 6h18M3 18h18" />
          </svg>
        </button>
      </div>
      <div id="mobile-menu" class="hidden lg:hidden border-t border-cyber-border bg-cyber-black">
        <div class="flex flex-col p-6 gap-4">
          <a href="/" class="text-sm text-cyber-text hover:text-cyber-white transition-colors">Home</a>
          <a href="/servicos" class="text-sm text-cyber-text hover:text-cyber-white transition-colors">Serviços</a>
          <a href="/sobre" class="text-sm text-cyber-text hover:text-cyber-white transition-colors">Sobre</a>
          <a href="/contato" class="text-sm text-cyber-text hover:text-cyber-white transition-colors">Contato</a>
          <a href="/ticket" class="text-sm text-cyber-text hover:text-cyber-white transition-colors">Abrir Ticket</a>
          <div class="pt-4 border-t border-cyber-border flex flex-col gap-3">
            <a href="https://wa.me/5511976665786" target="_blank" class="btn-outline text-xs py-2.5 px-4 text-center">WhatsApp</a>
            <a href="/contato" class="btn-primary text-xs py-2.5 px-4 text-center">Fale Conosco</a>
          </div>
        </div>
      </div>
    </nav>

    <main class="pt-16">
      <slot />
    </main>

    <footer class="border-t border-cyber-border bg-cyber-black">
      <div class="container-narrow px-4 md:px-6 py-10 md:py-16">
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
          <div class="md:col-span-1">
            <a href="/" class="flex items-center gap-0 text-2xl tracking-tight mb-4">
              <span class="font-light text-cyber-white">CYBER</span><span class="font-light text-cyber-red">ACT</span>
            </a>
            <p class="text-xs text-cyber-text leading-relaxed">Tecnologia</p>
          </div>
          <div>
            <h4 class="text-xs font-semibold uppercase tracking-widest text-cyber-white mb-4">Navegação</h4>
            <div class="flex flex-col gap-3">
              <a href="/" class="text-sm text-cyber-text hover:text-cyber-white transition-colors">Home</a>
              <a href="/servicos" class="text-sm text-cyber-text hover:text-cyber-white transition-colors">Serviços</a>
              <a href="/sobre" class="text-sm text-cyber-text hover:text-cyber-white transition-colors">Sobre</a>
              <a href="/contato" class="text-sm text-cyber-text hover:text-cyber-white transition-colors">Contato</a>
              <a href="/ticket" class="text-sm text-cyber-text hover:text-cyber-white transition-colors">Abrir Ticket</a>
            </div>
          </div>
          <div>
            <h4 class="text-xs font-semibold uppercase tracking-widest text-cyber-white mb-4">Contato</h4>
            <div class="flex flex-col gap-3 text-sm text-cyber-text">
              <a href="tel:+5511976665786" class="hover:text-cyber-white transition-colors">(11) 97666-5786</a>
              <a href="mailto:contato@cyberact.com.br" class="hover:text-cyber-white transition-colors">contato@cyberact.com.br</a>
              <a href="https://wa.me/5511976665786" target="_blank" class="hover:text-cyber-red transition-colors">WhatsApp</a>
            </div>
          </div>
          <div>
            <h4 class="text-xs font-semibold uppercase tracking-widest text-cyber-white mb-4">Endereço</h4>
            <div class="flex flex-col gap-3 text-sm text-cyber-text">
              <span>Av. Eng. Luís Carlos Berrini, 1681</span>
              <span>Cidade Monções — São Paulo, SP</span>
              <span>04571-011</span>
            </div>
            <div class="flex items-center gap-4 mt-6">
              <a href="https://instagram.com/cyberacttecnologia" target="_blank" class="text-cyber-text hover:text-cyber-red transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </a>
              {/* YouTube — link pending */}
              <span class="text-cyber-text opacity-40 cursor-default" title="YouTube — em breve">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              </span>
              {/* Facebook — link pending */}
              <span class="text-cyber-text opacity-40 cursor-default" title="Facebook — em breve">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </span>
            </div>
          </div>
        </div>
        <div class="gradient-line mt-12 mb-8"></div>
        <div class="flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="text-xs text-cyber-text">&copy; {new Date().getFullYear()} CyberAct Tecnologia. Todos os direitos reservados.</p>
          <p class="text-xs text-cyber-text">CNPJ: 48.228.858/0001-34</p>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('mobile-toggle');
      const menu = document.getElementById('mobile-menu');
      toggle?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
