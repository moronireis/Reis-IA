---
import '../styles/global.css';
---
<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Natori Foods — Intelligence Platform</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body style="background:var(--bg-primary); min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center;">

  <!-- Subtle grid background -->
  <div style="
    position:fixed; inset:0; pointer-events:none;
    background-image: linear-gradient(rgba(200,16,46,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(200,16,46,0.03) 1px, transparent 1px);
    background-size: 48px 48px;
  "></div>

  <!-- Glow -->
  <div style="position:fixed; top:30%; left:50%; transform:translate(-50%,-50%); width:600px; height:400px; background:radial-gradient(ellipse, rgba(200,16,46,0.06) 0%, transparent 70%); pointer-events:none;"></div>

  <!-- Login card -->
  <div style="
    position:relative; z-index:1;
    width:100%; max-width:400px; padding:0 24px;
    animation: fade-in 0.5s ease;
  ">

    <!-- Logo mark -->
    <div style="text-align:center; margin-bottom:36px;">
      <div style="
        width:56px; height:56px; border-radius:14px;
        background:var(--red);
        display:inline-flex; align-items:center; justify-content:center;
        margin-bottom:18px;
        box-shadow: 0 8px 32px rgba(200,16,46,0.3);
      ">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
          <path d="M5 4h18l-2.5 7H7.5L5 4z" fill="white" opacity="0.9"/>
          <path d="M7 13h14l2.5 8H4.5L7 13z" fill="white"/>
          <line x1="14" y1="11" x2="14" y2="13" stroke="white" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </div>
      <div style="font-size:22px; font-weight:700; color:var(--text-primary); letter-spacing:-0.03em; margin-bottom:4px;">
        Natori Foods
      </div>
      <div style="font-size:13px; color:var(--text-muted); font-weight:400;">
        Competitive Intelligence Platform
      </div>
    </div>

    <!-- Card -->
    <div style="
      background:var(--bg-card);
      border:1px solid var(--border);
      border-radius:16px;
      padding:32px;
    ">
      <div style="font-size:15px; font-weight:600; color:var(--text-primary); margin-bottom:6px;">Entrar na conta</div>
      <div style="font-size:13px; color:var(--text-muted); margin-bottom:24px;">Acesso exclusivo Natori Foods</div>

      <form id="login-form">
        <div style="margin-bottom:16px;">
          <label style="display:block; font-size:12px; font-weight:500; color:var(--text-secondary); margin-bottom:6px; letter-spacing:0.02em;">EMAIL</label>
          <input
            type="email"
            class="input-field"
            value="kaio@natorifoods.com.br"
            readonly
            style="background:rgba(255,255,255,0.03); cursor:default;"
          />
        </div>

        <div style="margin-bottom:24px;">
          <label style="display:block; font-size:12px; font-weight:500; color:var(--text-secondary); margin-bottom:6px; letter-spacing:0.02em;">SENHA</label>
          <input
            type="password"
            class="input-field"
            value="natori2026"
            readonly
            style="background:rgba(255,255,255,0.03); cursor:default;"
          />
        </div>

        <button type="submit" id="login-btn" class="btn btn-red" style="width:100%; justify-content:center; padding:12px; font-size:14px;">
          Entrar na plataforma
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M3 7h8M8 4l3 3-3 3" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </form>
    </div>

    <!-- Status indicator -->
    <div style="display:flex; align-items:center; justify-content:center; gap:8px; margin-top:20px;">
      <div class="dot-green"></div>
      <span style="font-size:12px; color:var(--text-muted);">Todos os sistemas operacionais — atualizado há 12s</span>
    </div>
  </div>

  <!-- Footer -->
  <div style="position:fixed; bottom:24px; font-size:11px; color:var(--text-muted);">
    Powered by <span style="color:var(--text-secondary); font-weight:500;">u4digital</span>
  </div>

  <script>
    document.getElementById('login-form')!.addEventListener('submit', (e) => {
      e.preventDefault();
      const btn = document.getElementById('login-btn') as HTMLButtonElement;
      btn.innerHTML = 'Autenticando...';
      btn.style.opacity = '0.7';
      setTimeout(() => { window.location.href = '/dashboard'; }, 900);
    });
  </script>

</body>
</html>
