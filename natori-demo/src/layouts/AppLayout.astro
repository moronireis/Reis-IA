---
import '../styles/global.css';

interface Props {
  title: string;
  activePage: string;
}

const { title, activePage } = Astro.props;

const navItems = [
  { href: '/dashboard', label: 'Dashboard', id: 'dashboard', icon: 'grid' },
  { href: '/buybox', label: 'Buy Box Monitor', id: 'buybox', icon: 'monitor' },
  { href: '/diagnostico', label: 'Diagnóstico IA', id: 'diagnostico', icon: 'brain' },
  { href: '/whatsapp', label: 'Alertas WhatsApp', id: 'whatsapp', icon: 'message' },
  { href: '/relatorios', label: 'Relatórios', id: 'relatorios', icon: 'file' },
];
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Natori Foods Intelligence</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body style="background: var(--bg-primary);">

<div style="display:flex; min-height:100vh;">

  <!-- Sidebar -->
  <aside id="sidebar" style="
    width: var(--sidebar-width);
    min-height: 100vh;
    background: var(--bg-secondary);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    position: fixed;
    top: 0; left: 0; bottom: 0;
    z-index: 100;
  ">
    <!-- Logo -->
    <div style="padding: 24px 20px 20px; border-bottom: 1px solid var(--border);">
      <div style="display:flex; align-items:center; gap:10px;">
        <div style="
          width: 32px; height: 32px; border-radius: 8px;
          background: var(--red);
          display: flex; align-items: center; justify-content: center;
        ">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 2h10l-1.5 4H4.5L3 2z" fill="white" opacity="0.9"/>
            <path d="M4 8h8l1.5 4H2.5L4 8z" fill="white"/>
            <line x1="8" y1="6" x2="8" y2="8" stroke="white" stroke-width="1.5"/>
          </svg>
        </div>
        <div>
          <div style="font-size:13px; font-weight:600; color:var(--text-primary); letter-spacing:-0.02em;">Natori Foods</div>
          <div style="font-size:10px; color:var(--text-muted); font-weight:400;">Intelligence Platform</div>
        </div>
      </div>
    </div>

    <!-- Nav -->
    <nav style="padding: 16px 12px; flex:1;">
      <div style="font-size:10px; font-weight:500; color:var(--text-muted); letter-spacing:0.1em; text-transform:uppercase; padding: 0 8px; margin-bottom:8px;">Plataforma</div>
      {navItems.map(item => (
        <a
          href={item.href}
          style={`
            display: flex; align-items: center; gap: 10px;
            padding: 9px 10px; border-radius: 8px; margin-bottom: 2px;
            font-size: 13px; font-weight: 500;
            text-decoration: none;
            transition: all 0.15s;
            ${activePage === item.id
              ? 'background: var(--red-dim); color: var(--red); border: 1px solid rgba(200,16,46,0.15);'
              : 'color: var(--text-secondary); border: 1px solid transparent;'}
          `}
          onmouseover={activePage !== item.id ? "this.style.background='var(--bg-card)'; this.style.color='var(--text-primary)';" : ''}
          onmouseout={activePage !== item.id ? "this.style.background='transparent'; this.style.color='var(--text-secondary)';" : ''}
        >
          <!-- Icon -->
          {item.icon === 'grid' && (
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
              <rect x="1" y="1" width="5.5" height="5.5" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
              <rect x="8.5" y="1" width="5.5" height="5.5" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
              <rect x="1" y="8.5" width="5.5" height="5.5" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
              <rect x="8.5" y="8.5" width="5.5" height="5.5" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
            </svg>
          )}
          {item.icon === 'monitor' && (
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
              <rect x="1" y="2" width="13" height="9" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
              <path d="M5 13h5M7.5 11v2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              <circle cx="7.5" cy="6.5" r="1.5" stroke="currentColor" stroke-width="1.3"/>
            </svg>
          )}
          {item.icon === 'brain' && (
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
              <path d="M7.5 2C5.5 2 4 3.5 4 5.5c0 .8.3 1.6.8 2.2L4 13h7l-.8-5.3c.5-.6.8-1.4.8-2.2C11 3.5 9.5 2 7.5 2z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
              <path d="M5.5 5.5h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              <path d="M6 7.5h3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
          )}
          {item.icon === 'message' && (
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
              <path d="M2 2.5A1.5 1.5 0 013.5 1h8A1.5 1.5 0 0113 2.5v7A1.5 1.5 0 0111.5 11H9l-2 2.5L5 11H3.5A1.5 1.5 0 012 9.5v-7z" stroke="currentColor" stroke-width="1.3"/>
              <path d="M5 5h5M5 7.5h3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
          )}
          {item.icon === 'file' && (
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
              <path d="M3 1.5A1.5 1.5 0 014.5 0H9l3 3v10.5A1.5 1.5 0 0110.5 15h-6A1.5 1.5 0 013 13.5v-12z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
              <path d="M9 0v3h3" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
              <path d="M5.5 7h4M5.5 9.5h4M5.5 12h2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
          )}
          {item.label}
        </a>
      ))}

      <div style="font-size:10px; font-weight:500; color:var(--text-muted); letter-spacing:0.1em; text-transform:uppercase; padding: 0 8px; margin: 16px 0 8px;">Sistema</div>
      <a
        href="#"
        style="display:flex; align-items:center; gap:10px; padding:9px 10px; border-radius:8px; font-size:13px; font-weight:500; color:var(--text-secondary); text-decoration:none; border:1px solid transparent;"
        onmouseover="this.style.background='var(--bg-card)'; this.style.color='var(--text-primary)';"
        onmouseout="this.style.background='transparent'; this.style.color='var(--text-secondary)';"
      >
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
          <circle cx="7.5" cy="7.5" r="6.5" stroke="currentColor" stroke-width="1.3"/>
          <path d="M5.5 6a2 2 0 114 0c0 1.5-2 2-2 3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
          <circle cx="7.5" cy="11.5" r="0.6" fill="currentColor"/>
        </svg>
        Configurações
      </a>
    </nav>

    <!-- Footer brand -->
    <div style="padding: 16px 20px; border-top: 1px solid var(--border);">
      <div style="font-size:10px; color:var(--text-muted);">Powered by</div>
      <div style="font-size:12px; font-weight:600; color:var(--text-secondary); letter-spacing:-0.01em;">u4digital</div>
    </div>
  </aside>

  <!-- Main content -->
  <div style="margin-left: var(--sidebar-width); flex:1; display:flex; flex-direction:column; min-height:100vh;">

    <!-- Top bar -->
    <header style="
      position: sticky; top: 0; z-index: 50;
      background: rgba(8,8,8,0.85);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      padding: 0 28px;
      height: 56px;
      display: flex; align-items: center; justify-content: space-between;
    ">
      <div style="font-size:13px; font-weight:500; color:var(--text-secondary);">
        Natori Foods — <span style="color:var(--text-primary);">{title}</span>
      </div>

      <div style="display:flex; align-items:center; gap:16px;">
        <!-- Bell -->
        <button style="position:relative; background:none; border:none; cursor:pointer; padding:6px; border-radius:8px;" onclick="window.location.href='/buybox'">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="color:var(--text-secondary);">
            <path d="M9 1a5 5 0 015 5v3l1.5 2.5H2.5L4 9V6a5 5 0 015-5z" stroke="currentColor" stroke-width="1.4"/>
            <path d="M7 15.5a2 2 0 004 0" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
          <span style="
            position:absolute; top:2px; right:2px;
            background:var(--red); color:white;
            font-size:9px; font-weight:700;
            width:15px; height:15px; border-radius:50%;
            display:flex; align-items:center; justify-content:center;
            border:1.5px solid var(--bg-primary);
          ">12</span>
        </button>

        <!-- Avatar -->
        <div style="
          width:32px; height:32px; border-radius:50%;
          background: linear-gradient(135deg, var(--red), #8B0015);
          display:flex; align-items:center; justify-content:center;
          font-size:11px; font-weight:700; color:white; letter-spacing:0.02em;
          cursor:pointer;
        ">KH</div>
      </div>
    </header>

    <!-- Page content -->
    <main style="flex:1; padding:32px 28px;">
      <slot />
    </main>
  </div>
</div>

<!-- Mobile responsive -->
<style>
  @media (max-width: 768px) {
    #sidebar { display: none; }
    div[style*="margin-left: var(--sidebar-width)"] { margin-left: 0 !important; }
  }
</style>

</body>
</html>
