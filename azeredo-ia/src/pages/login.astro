---
import '../styles/global.css';
export const prerender = false;
---
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Entrar | Azeredo IA</title>
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 viewBox=%270 0 64 64%27%3E%3Cdefs%3E%3ClinearGradient id=%27g%27 x1=%270%27 y1=%270%27 x2=%270%27 y2=%271%27%3E%3Cstop offset=%270%27 stop-color=%27%23F2984F%27/%3E%3Cstop offset=%271%27 stop-color=%27%23D96E1F%27/%3E%3C/linearGradient%3E%3C/defs%3E%3Crect width=%2764%27 height=%2764%27 rx=%2714%27 fill=%27url(%23g)%27/%3E%3Ctext x=%2732%27 y=%2743%27 font-family=%27Arial, sans-serif%27 font-size=%2727%27 font-weight=%27800%27 fill=%27white%27 text-anchor=%27middle%27%3EAZ%3C/text%3E%3C/svg%3E" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="login-body">
  <div class="login-wrapper">

    <!-- LEFT PANEL — vitrine (vidro sobre o fundo ambiente) -->
    <div class="left-panel glass-panel">
      <div class="left-content">
        <div class="left-logo anim" style="--i: 0">
          <div class="logo-icon">AZ<span class="logo-year">1989</span></div>
          <div>
            <div class="logo-text">AZEREDO <span>IA</span></div>
            <div class="logo-sub">Representações Comerciais · desde 1989</div>
          </div>
        </div>

        <!-- WhatsApp message bubbles (decorative) -->
        <div class="bubbles">
          <div class="bubble bubble-out anim" style="--i: 2">
            <span>Olá! Temos novidades esta semana</span>
            <div class="bubble-meta">09:41 ✓✓</div>
          </div>
          <div class="bubble bubble-in anim" style="--i: 3">
            <span>Que ótimo! Pode me enviar o catálogo?</span>
            <div class="bubble-meta">09:42</div>
          </div>
          <div class="bubble bubble-out anim" style="--i: 4">
            <span>Claro! Segue a tabela atualizada da Tilibra</span>
            <div class="bubble-meta">09:43 ✓✓</div>
          </div>
          <div class="bubble bubble-in anim" style="--i: 5">
            <span>Perfeito, obrigado! Vou analisar</span>
            <div class="bubble-meta">09:44</div>
          </div>
        </div>

        <!-- Stats -->
        <div class="left-stats">
          <div class="stat-card card-surface anim" style="--i: 6">
            <div class="stat-number">25</div>
            <div class="stat-desc">Marcas representadas</div>
          </div>
          <div class="stat-card card-surface anim" style="--i: 7">
            <div class="stat-number">2.370</div>
            <div class="stat-desc">Clientes no banco</div>
          </div>
          <div class="stat-card card-surface anim" style="--i: 8">
            <div class="stat-number">RS</div>
            <div class="stat-desc">Rio Grande do Sul</div>
          </div>
        </div>
      </div>

      <div class="left-footer">u4digital · Tecnologia para representantes comerciais</div>
    </div>

    <!-- RIGHT PANEL — formulário em vidro -->
    <div class="right-panel">
      <div class="form-card glass-modal anim-scale">
        <div class="form-header">
          <h1>Bem-vindo</h1>
          <p>Entre com sua conta para acessar a plataforma</p>
        </div>

        <form id="loginForm" autocomplete="on">
          <div class="field">
            <label for="email">E-mail</label>
            <div class="input-group">
              <svg class="field-icon" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <input class="input" type="email" id="email" name="email" required placeholder="seu@email.com" autocomplete="email" />
            </div>
          </div>

          <div class="field">
            <label for="password">Senha</label>
            <div class="input-group">
              <svg class="field-icon" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <input class="input" type="password" id="password" name="password" required placeholder="Sua senha" autocomplete="current-password" />
              <button type="button" id="togglePw" class="pw-toggle" aria-label="Mostrar senha">
                <svg id="eyeOpen" viewBox="0 0 24 24" style="display:block"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                <svg id="eyeClosed" viewBox="0 0 24 24" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
              </button>
            </div>
          </div>

          <label class="remember">
            <input type="checkbox" id="rememberMe" name="remember" />
            <span>Lembrar por 90 dias</span>
          </label>

          <button type="submit" class="btn-primary submit-btn" id="submitBtn">
            <span id="btnText">Entrar</span>
            <svg id="btnSpinner" class="spin hidden" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" fill="none" stroke-dasharray="31.4" stroke-dashoffset="10"><animateTransform attributeName="transform" type="rotate" dur="0.8s" from="0 12 12" to="360 12 12" repeatCount="indefinite"/></circle></svg>
          </button>

          <p id="errorMsg" class="error-msg"></p>
        </form>
      </div>
    </div>

  </div>
</body>

<script>
  // Toggle password visibility
  const pwInput = document.getElementById('password') as HTMLInputElement;
  const eyeOpen = document.getElementById('eyeOpen') as HTMLElement;
  const eyeClosed = document.getElementById('eyeClosed') as HTMLElement;
  document.getElementById('togglePw')?.addEventListener('click', () => {
    if (!pwInput) return;
    const showing = pwInput.type === 'text';
    pwInput.type = showing ? 'password' : 'text';
    eyeOpen.style.display = showing ? 'block' : 'none';
    eyeClosed.style.display = showing ? 'none' : 'block';
  });

  // Form submit
  const form = document.getElementById('loginForm') as HTMLFormElement;
  const errorMsg = document.getElementById('errorMsg') as HTMLElement;
  const btnText = document.getElementById('btnText') as HTMLElement;
  const btnSpinner = document.getElementById('btnSpinner') as HTMLElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg.textContent = '';
    btnText.textContent = 'Entrando...';
    btnSpinner.classList.remove('hidden');
    submitBtn.disabled = true;

    const fd = new FormData(form);
    const rememberEl = document.getElementById('rememberMe') as HTMLInputElement;
    try {
      const res = await fetch('/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: fd.get('email'),
          password: fd.get('password'),
          remember: rememberEl?.checked ?? false,
        }),
      });
      const data = await res.json();
      if (res.ok) {
        window.location.href = '/disparos';
      } else {
        errorMsg.textContent = data.error || 'E-mail ou senha incorretos.';
      }
    } catch {
      errorMsg.textContent = 'Erro de conexão. Tente novamente.';
    }
    btnText.textContent = 'Entrar';
    btnSpinner.classList.add('hidden');
    submitBtn.disabled = false;
  });
</script>

<style>
  .login-body { margin: 0; min-height: 100vh; background: var(--bg-primary); }
  .login-wrapper { display: flex; min-height: 100vh; padding: 20px; gap: 20px; }

  /* Left — painel de vidro flutuante */
  .left-panel {
    width: 48%;
    display: flex; flex-direction: column;
    padding: 48px;
    overflow: hidden;
  }
  .left-content { flex: 1; display: flex; flex-direction: column; justify-content: center; max-width: 380px; margin: 0 auto; }

  .left-logo { display: flex; align-items: center; gap: 14px; margin-bottom: 48px; }
  .logo-icon {
    width: 46px; height: 46px; border-radius: 13px;
    background: linear-gradient(180deg, #F2984F, #D96E1F);
    display: flex; align-items: center; justify-content: center;
    color: #fff; flex-shrink: 0;
    font-size: 17px; font-weight: 800; letter-spacing: -0.02em;
    position: relative;
    box-shadow: 0 6px 24px color-mix(in srgb, var(--accent) 35%, transparent), inset 0 1px 0 rgba(255,255,255,0.28);
  }
  .logo-year {
    position: absolute; bottom: -6px; right: -8px;
    font-size: 7px; font-weight: 800; letter-spacing: 0.04em;
    background: var(--navy); color: #fff;
    padding: 2px 5px; border-radius: 5px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.35);
  }
  .logo-text { font-size: 20px; font-weight: 700; color: var(--text-primary); letter-spacing: -0.02em; }
  .logo-text span { color: var(--accent); }
  .logo-sub { font-size: 11px; color: var(--text-muted); margin-top: 2px; }

  /* Bubbles — superfícies de conteúdo, sem blur */
  .bubbles { display: flex; flex-direction: column; gap: 10px; margin-bottom: 40px; }
  .bubble {
    max-width: 80%; padding: 10px 14px;
    font-size: 13px; line-height: 1.5; color: var(--text-primary);
    box-shadow: inset 0 1px 0 var(--highlight);
  }
  .bubble-out {
    align-self: flex-end;
    background: linear-gradient(180deg, color-mix(in srgb, var(--accent) 18%, transparent), color-mix(in srgb, var(--accent) 9%, transparent));
    border: 1px solid color-mix(in srgb, var(--accent) 22%, transparent);
    border-radius: 14px 14px 4px 14px;
  }
  .bubble-in {
    align-self: flex-start;
    background: linear-gradient(180deg, var(--card-grad-top), var(--card-grad-bot));
    border: 1px solid var(--hairline);
    border-radius: 14px 14px 14px 4px;
  }
  .bubble-meta { font-size: 10px; color: var(--text-muted); margin-top: 4px; text-align: right; }

  /* Stats */
  .left-stats { display: flex; gap: 14px; }
  .stat-card { flex: 1; padding: 14px 16px; }
  .stat-number { font-size: 20px; font-weight: 700; color: var(--accent-light); letter-spacing: -0.02em; }
  .stat-desc { font-size: 10px; color: var(--text-muted); margin-top: 3px; }

  .left-footer { font-size: 11px; color: var(--text-muted); opacity: 0.6; text-align: center; }

  /* Right — card de vidro central */
  .right-panel {
    flex: 1; display: flex; align-items: center; justify-content: center;
    padding: 20px 28px;
  }
  .form-card {
    width: 100%; max-width: 400px;
    padding: 38px 36px 30px;
  }

  .form-header { margin-bottom: 30px; }
  .form-header h1 { font-size: 26px; font-weight: 700; color: var(--text-primary); letter-spacing: -0.03em; }
  .form-header p { font-size: 13px; color: var(--text-muted); margin-top: 6px; }

  .field { margin-bottom: 18px; }
  .field label { display: block; font-size: 12px; font-weight: 600; color: var(--text-secondary); margin-bottom: 7px; letter-spacing: 0.01em; }
  .input-group { position: relative; display: flex; align-items: center; }
  .field-icon {
    position: absolute; left: 13px; width: 15px; height: 15px; z-index: 1;
    stroke: var(--text-muted); fill: none; stroke-width: 1.5;
    stroke-linecap: round; stroke-linejoin: round; pointer-events: none;
  }
  .input-group .input { padding-left: 38px; }

  .pw-toggle {
    position: absolute; right: 11px; background: none; border: none;
    cursor: pointer; padding: 4px; display: flex; align-items: center;
    color: var(--text-muted);
    transition: color var(--dur-fast) var(--ease-glass);
  }
  .pw-toggle svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
  .pw-toggle:hover { color: var(--text-secondary); }

  .remember {
    display: flex; align-items: center; gap: 9px; margin-bottom: 20px;
    cursor: pointer; font-size: 13px; color: var(--text-muted);
    user-select: none;
  }
  .remember input[type="checkbox"] { width: 15px; height: 15px; accent-color: var(--accent); cursor: pointer; flex-shrink: 0; }

  .submit-btn { width: 100%; padding: 13px; font-size: 14px; }

  .spin { width: 18px; height: 18px; }
  .hidden { display: none; }
  .error-msg { font-size: 13px; color: var(--red); text-align: center; margin-top: 14px; min-height: 20px; }

  @media (max-width: 860px) {
    .left-panel { display: none; }
    .login-wrapper { justify-content: center; padding: 14px; }
    .right-panel { padding: 10px; }
    .form-card { padding: 30px 24px 24px; }
  }
</style>
</html>
