---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
export const prerender = false;

interface Props {
  title: string;
  activeSection?: 'metricas' | 'disparos' | 'conversas' | 'contatos' | 'leads' | 'processos' | 'templates' | 'ferramentas' | 'config';
}

const { title, activeSection = 'disparos' } = Astro.props;
const profile = (Astro.locals as any).profile;
const role: string = profile?.role || 'vendedor';

function getInitials(name: string | undefined): string {
  if (!name) return 'U';
  const parts = name.trim().split(' ');
  if (parts.length === 1) return parts[0].charAt(0).toUpperCase();
  return (parts[0].charAt(0) + parts[parts.length - 1].charAt(0)).toUpperCase();
}
const initials = getInitials(profile?.full_name);
const firstName = profile?.full_name?.split(' ')[0] || 'Usuário';
const roleLabel = ({ admin: 'Admin', operacional: 'Operacional', vendedor: 'Vendedor', gerencia: 'Gerência' } as Record<string, string>)[role] || role;

// #16: Métricas → Dashboard, Leads → Funil; Processos e Padrões saiu do menu.
// #18: menu por papel — admin vê tudo; operacional ganha Ferramentas/Config;
// gerência ganha Dashboard; vendedor fica com o núcleo.
const allNav = [
  { id: 'disparos',    label: 'Disparos',    href: '/disparos',    icon: 'send',      roles: ['admin', 'operacional', 'vendedor', 'gerencia'] },
  { id: 'metricas',    label: 'Dashboard',   href: '/metricas',    icon: 'bar-chart', roles: ['admin', 'gerencia'] },
  { id: 'conversas',   label: 'Conversas',   href: '/conversas',   icon: 'message',   roles: ['admin', 'operacional', 'vendedor', 'gerencia'] },
  { id: 'contatos',    label: 'Contatos',    href: '/contatos',    icon: 'users',     roles: ['admin', 'operacional', 'vendedor', 'gerencia'] },
  { id: 'leads',       label: 'Funil',       href: '/leads',       icon: 'funnel',    roles: ['admin', 'operacional', 'vendedor', 'gerencia'] },
  { id: 'templates',   label: 'Templates',   href: '/templates',   icon: 'file-text', roles: ['admin', 'operacional', 'vendedor', 'gerencia'] },
  { id: 'ferramentas', label: 'Ferramentas', href: '/ferramentas', icon: 'tool',      roles: ['admin', 'operacional'] },
];
const navItems = allNav.filter(item => item.roles.includes(role));
const showConfig = role === 'admin' || role === 'operacional';
---
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Azeredo IA</title>
  <link rel="icon" type="image/png" href="/brand/favicon-az.png" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <ClientRouter />
  <!-- #16: tema claro/escuro — aplica antes do primeiro paint (sem flash).
       is:inline + re-aplicação em astro:after-swap porque o ClientRouter troca o <html>. -->
  <script is:inline>
    (function () {
      var apply = function () {
        var t = 'dark';
        try { t = localStorage.getItem('az-theme') || 'dark'; } catch (e) {}
        document.documentElement.setAttribute('data-theme', t);
      };
      apply();
      document.addEventListener('astro:after-swap', apply);
    })();
  </script>
</head>
<body>
  <!-- Mobile header -->
  <header class="mobile-header">
    <button id="sidebar-toggle" class="hamburger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
    <div class="mobile-logo">
      <img class="brand-mark brand-mark--sm" src="/brand/monograma-az.png" alt="AZ" />
      AZEREDO IA
    </div>
    <div style="width:38px"></div>
  </header>

  <!-- Overlay -->
  <div id="sidebar-overlay" class="overlay"></div>

  <!-- Sidebar -->
  <nav id="sidebar" class="sidebar">
    <!-- Logo — monograma AZ oficial (#21: ID Visual em anexo) -->
    <a href="/disparos" class="sidebar-brand">
      <img class="brand-mark" src="/brand/monograma-az.png" alt="AZ" />
      <div>
        <div class="brand-name">AZEREDO <span>IA</span></div>
        <div class="brand-tagline">Representações Comerciais</div>
      </div>
    </a>

    <div class="sidebar-divider"></div>

    <!-- Nav -->
    <div class="sidebar-nav">
      {navItems.map(item => (
        <a href={item.href} class:list={['nav-item', { active: activeSection === item.id }]}>
          <svg class="nav-icon" viewBox="0 0 24 24">
            {item.icon === 'send'      && <><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></>}
            {item.icon === 'bar-chart' && <><line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/></>}
            {item.icon === 'message'   && <><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></>}
            {item.icon === 'users'     && <><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></>}
            {item.icon === 'funnel'    && <><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></>}
            {item.icon === 'book'      && <><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></>}
            {item.icon === 'file-text' && <><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></>}
            {item.icon === 'tool'      && <><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></>}
          </svg>
          <span class="nav-label">{item.label}</span>
        </a>
      ))}
    </div>

    <!-- Bottom -->
    <div class="sidebar-footer">
      <!-- #16: alternar tema claro/escuro — pílula estilo Marpe -->
      <button id="theme-toggle" class="theme-row" type="button" aria-label="Alternar entre tema escuro e claro">
        <svg class="nav-icon" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
        </svg>
        <span class="nav-label">Tema</span>
        <span class="theme-pill">
          <span class="theme-pill-thumb">
            <svg class="theme-ic theme-ic--moon" width="9" height="9" viewBox="0 0 24 24" fill="currentColor"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            <svg class="theme-ic theme-ic--sun" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          </span>
        </span>
      </button>

      {showConfig && (
        <a href="/config" class:list={['nav-item', { active: activeSection === 'config' }]}>
          <svg class="nav-icon" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="3"/>
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
          </svg>
          <span class="nav-label">Configurações</span>
        </a>
      )}

      <div class="sidebar-divider"></div>

      <!-- User -->
      <div class="user-row">
        <div class="user-avatar">{initials}</div>
        <div class="user-info">
          <div class="user-name">{firstName}</div>
          <div class="user-role">{roleLabel}</div>
        </div>
        <form action="/api/auth/logout" method="post">
          <button type="submit" class="logout-btn" title="Sair">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          </button>
        </form>
      </div>
    </div>
  </nav>

  <!-- Main -->
  <main class="main-content">
    <slot />
  </main>
</body>
</html>

<style>
/* Layout */
body { display: flex; height: 100vh; overflow: hidden; }
.main-content { flex: 1; overflow: hidden; display: flex; flex-direction: column; min-width: 0; }

/* Sidebar — frosted glass rail */
.sidebar {
  width: var(--sidebar-width);
  background: var(--glass-bg-strong);
  -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(1.6);
  backdrop-filter: blur(var(--glass-blur)) saturate(1.6);
  border-right: 1px solid var(--glass-border);
  box-shadow: inset -1px 0 0 rgba(255,255,255,0.03);
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  overflow: hidden;
}
@supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
  .sidebar { background: #070b13; }
}

/* Brand */
.sidebar-brand {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 20px 16px 16px;
  text-decoration: none;
  color: var(--text-primary);
}
.brand-mark {
  height: 26px; width: auto; flex-shrink: 0; display: block;
  filter: drop-shadow(0 3px 10px var(--accent-glow));
}
.brand-mark--sm { height: 18px; }
.brand-name {
  font-size: 14px; font-weight: 700;
  letter-spacing: -0.01em; color: var(--text-primary);
}
.brand-name span { color: var(--accent); }
.brand-tagline { font-size: 10px; color: var(--text-muted); margin-top: 1px; }

/* Divider */
.sidebar-divider { height: 1px; background: var(--border); margin: 8px 16px; }

/* Nav */
.sidebar-nav { flex: 1; padding: 4px 10px; display: flex; flex-direction: column; gap: 2px; }

.nav-item {
  display: flex; align-items: center; gap: 10px;
  padding: 9px 12px; border-radius: 10px;
  color: var(--text-muted); text-decoration: none;
  font-size: 13px; font-weight: 500;
  transition: all var(--dur-fast, 0.18s) var(--ease-glass, ease-out);
  cursor: pointer; background: none; border: none; font-family: inherit;
  width: 100%;
}
.nav-item:hover { background: rgba(255,255,255,0.05); color: var(--text-secondary); }
.nav-item.active {
  background: linear-gradient(180deg, var(--accent-dim), var(--accent-dim));
  color: var(--accent-light);
  border: 1px solid var(--accent-glow);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.10), 0 4px 14px var(--accent-dim);
}
.nav-icon {
  width: 17px; height: 17px; stroke: currentColor; fill: none;
  stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0;
}
.nav-label { flex: 1; }

/* Footer */
.sidebar-footer { padding: 8px 10px 16px; display: flex; flex-direction: column; gap: 2px; }

.user-row {
  display: flex; align-items: center; gap: 9px;
  padding: 10px 12px; border-radius: 8px;
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  margin-top: 4px;
}
.user-avatar {
  width: 30px; height: 30px; border-radius: 50%;
  background: var(--accent-dim); border: 1px solid var(--accent-dim);
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 700; color: var(--accent-light);
  flex-shrink: 0;
}
.user-info { flex: 1; min-width: 0; }
.user-name { font-size: 12px; font-weight: 600; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.user-role { font-size: 10px; color: var(--text-muted); text-transform: capitalize; }
.logout-btn {
  background: none; border: none; cursor: pointer; padding: 4px;
  color: var(--text-muted); display: flex; align-items: center; flex-shrink: 0;
  border-radius: 4px; transition: all 0.15s;
}
.logout-btn:hover { color: var(--red); background: var(--red-dim); }

/* #16: toggle de tema — pílula estilo Marpe */
.theme-row {
  display: flex; align-items: center; gap: 10px;
  padding: 9px 12px; border-radius: 10px;
  color: var(--text-muted); background: none; border: none;
  font-size: 13px; font-weight: 500; font-family: inherit;
  cursor: pointer; width: 100%; text-align: left;
  transition: all var(--dur-fast, 0.18s) var(--ease-glass, ease-out);
}
.theme-row:hover { background: rgba(255,255,255,0.05); color: var(--text-secondary); }
.theme-row .nav-label { flex: 1; }
.theme-pill {
  width: 38px; height: 22px; border-radius: 11px;
  background: var(--field-bg);
  border: 1px solid var(--hairline-hi);
  display: flex; align-items: center; padding: 2px;
  transition: background 0.25s var(--ease-glass);
  flex-shrink: 0;
}
.theme-pill-thumb {
  width: 16px; height: 16px; border-radius: 50%;
  background: var(--text-muted); color: var(--bg-primary);
  display: flex; align-items: center; justify-content: center;
  transform: translateX(0);
  transition: transform 0.25s var(--ease-spring, ease), background 0.25s var(--ease-glass);
}
.theme-ic--sun { display: none; }
:global([data-theme="light"]) .theme-pill { background: var(--accent-dim); border-color: color-mix(in srgb, var(--accent) 35%, transparent); }
:global([data-theme="light"]) .theme-pill-thumb { transform: translateX(16px); background: var(--accent); color: #fff; }
:global([data-theme="light"]) .theme-ic--sun { display: block; }
:global([data-theme="light"]) .theme-ic--moon { display: none; }

/* Mobile header */
.mobile-header {
  display: none; position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  height: 52px;
  background: var(--glass-bg-strong);
  -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(1.6);
  backdrop-filter: blur(var(--glass-blur)) saturate(1.6);
  border-bottom: 1px solid var(--glass-border);
  padding: 0 12px; align-items: center; justify-content: space-between;
}
.mobile-logo {
  display: flex; align-items: center; gap: 8px;
  font-size: 13px; font-weight: 700; color: var(--text-primary);
}
.hamburger {
  width: 36px; height: 36px; background: var(--bg-card); border: 1px solid var(--border);
  border-radius: 8px; cursor: pointer; display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 4px; padding: 0;
}
.hamburger span { width: 16px; height: 1.5px; background: var(--text-secondary); border-radius: 1px; display: block; }

/* Overlay */
.overlay { display: none; position: fixed; inset: 0; z-index: 99; background: rgba(0,0,0,0.7); }
.overlay.active { display: block; }

/* Mobile responsive */
@media (max-width: 768px) {
  .mobile-header { display: flex; }
  body { display: block; }
  .sidebar {
    position: fixed; top: 0; left: 0; height: 100%; z-index: 100;
    transform: translateX(-100%); transition: transform 0.25s cubic-bezier(0.23,1,0.32,1);
    padding-top: 52px;
  }
  .sidebar.open { transform: translateX(0); }
  .main-content { padding-top: 52px; height: calc(100vh - 52px); }
}
</style>

<script>
  // ClientRouter troca o DOM a cada navegação — re-liga os listeners em cada
  // astro:page-load (dispara também no primeiro load). Idempotente por design:
  // os elementos antigos morrem com o DOM antigo.
  function bindSidebar() {
    const toggle = document.getElementById('sidebar-toggle');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');
    const open = () => { sidebar?.classList.add('open'); overlay?.classList.add('active'); };
    const close = () => { sidebar?.classList.remove('open'); overlay?.classList.remove('active'); };
    toggle?.addEventListener('click', () => sidebar?.classList.contains('open') ? close() : open());
    overlay?.addEventListener('click', close);
    sidebar?.querySelectorAll('a[href]').forEach(l => l.addEventListener('click', () => { if (window.innerWidth <= 768) close(); }));

    // #16: tema claro/escuro persistido por dispositivo
    document.getElementById('theme-toggle')?.addEventListener('click', () => {
      const next = document.documentElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', next);
      try { localStorage.setItem('az-theme', next); } catch {}
    });
  }
  document.addEventListener('astro:page-load', bindSidebar);
</script>
