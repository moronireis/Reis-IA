---
---

<section id="hero" class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Background effects -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(42,111,242,0.1),transparent_50%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,rgba(42,111,242,0.06),transparent_50%)]"></div>
  <div class="absolute inset-0 grid-bg"></div>
  <div class="absolute inset-0 noise-overlay"></div>

  <!-- Animated orbs -->
  <div class="absolute top-1/4 right-1/4 w-[400px] h-[400px] bg-fort-blue/5 rounded-full blur-[100px] animate-pulse-slow"></div>
  <div class="absolute bottom-1/4 left-1/6 w-[300px] h-[300px] bg-fort-blue/3 rounded-full blur-[80px] animate-float"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 pt-24 sm:pt-28 pb-12 sm:pb-16 w-full">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">
      <!-- Left: Text content -->
      <div>
        <!-- Badge -->
        <div class="text-blur-in inline-flex items-center gap-2 bg-fort-blue/10 border border-fort-blue/20 rounded-full px-3 sm:px-4 py-1.5 mb-6 sm:mb-8">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping-slow absolute inline-flex h-full w-full rounded-full bg-fort-blue opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-fort-blue"></span>
          </span>
          <span class="text-xs sm:text-sm text-fort-blue font-medium">Monitoramento com Inteligência Artificial</span>
        </div>

        <!-- Headline — word-by-word reveal -->
        <h1 class="text-3xl sm:text-5xl lg:text-[3.5rem] font-extrabold text-fort-white leading-[1.1] mb-5 sm:mb-6 tracking-tight">
          <span class="text-slide-up block overflow-hidden">
            <span class="inner">Segurança que</span>
          </span>
          <span class="text-slide-up block overflow-hidden" style="transition-delay: 150ms">
            <span class="inner text-gradient-animated">identifica ameaças</span>
          </span>
          <span class="text-slide-up block overflow-hidden" style="transition-delay: 300ms">
            <span class="inner">antes que aconteçam</span>
          </span>
        </h1>

        <!-- Subheadline — blur in -->
        <p class="text-blur-in text-base sm:text-lg text-fort-text leading-relaxed mb-8 sm:mb-10 max-w-xl" style="transition-delay: 500ms">
          CFTV, alarme e portaria remota com detecção inteligente de pessoas e ações suspeitas. Machine learning que reduz falsos alarmes em até <span class="text-fort-white font-semibold">100x</span>.
        </p>

        <!-- CTAs -->
        <div class="text-blur-in flex flex-col sm:flex-row gap-4" style="transition-delay: 700ms">
          <a
            href="https://wa.me/5511999999999?text=Ol%C3%A1%2C%20gostaria%20de%20um%20or%C3%A7amento%20BATALION%20Defense%20AI"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center justify-center gap-3 bg-fort-blue hover:bg-fort-blue-dark text-white font-semibold px-8 py-4 rounded-xl transition-all duration-300 hover:shadow-[0_0_40px_rgba(42,111,242,0.4)] active:scale-[0.98]"
          >
            <svg class="w-5 h-5 transition-transform group-hover:scale-110" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Falar com Especialista
          </a>
          <a
            href="#contato"
            class="group inline-flex items-center justify-center gap-2 border border-fort-border hover:border-fort-blue/50 text-fort-white font-medium px-8 py-4 rounded-xl transition-all duration-300 hover:bg-fort-blue/5"
          >
            Solicitar Orçamento
            <svg class="w-4 h-4 transition-transform group-hover:translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: Dashboard Mockup -->
      <div class="reveal-right">
        <div class="relative lg:animate-float">
          <!-- Main dashboard window -->
          <div class="mockup-window shadow-2xl shadow-black/40">
            <div class="mockup-toolbar">
              <div class="mockup-dot bg-fort-red/80"></div>
              <div class="mockup-dot bg-fort-amber/80"></div>
              <div class="mockup-dot bg-fort-green/80"></div>
              <span class="text-[9px] sm:text-[11px] text-fort-text/60 ml-3 font-mono">BATALION — Central de Monitoramento IA</span>
            </div>

            <!-- Dashboard content -->
            <div class="flex">
              <!-- Sidebar -->
              <div class="mockup-sidebar">
                <div class="mockup-sidebar-icon active">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                </div>
                <div class="mockup-sidebar-icon">
                  <svg class="w-4 h-4 text-fort-text/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                </div>
                <div class="mockup-sidebar-icon">
                  <svg class="w-4 h-4 text-fort-text/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                </div>
                <div class="mockup-sidebar-icon">
                  <svg class="w-4 h-4 text-fort-text/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
              </div>

              <!-- Main content area -->
              <div class="flex-1 p-3">
                <!-- Camera grid -->
                <div class="grid grid-cols-2 gap-2 mb-3">
                  <!-- Camera 1 - Main with detection -->
                  <div class="mockup-camera-feed rounded-lg aspect-video relative">
                    <!-- Simulated camera view with gradient -->
                    <div class="absolute inset-0 bg-gradient-to-br from-fort-dark via-fort-gray/30 to-fort-dark"></div>
                    <!-- Scan line -->
                    <div class="absolute left-0 right-0 h-[1px] bg-fort-blue/30 animate-scan"></div>
                    <!-- Building silhouette -->
                    <div class="absolute bottom-0 left-0 right-0 h-[60%] bg-gradient-to-t from-fort-black/60 to-transparent"></div>
                    <!-- Detection box - person -->
                    <div class="mockup-detection-box mockup-detection-box-alert w-[28%] h-[55%] top-[20%] left-[55%]" data-label="PESSOA 97%">
                      <div class="absolute bottom-1 right-1 w-1.5 h-1.5 rounded-full bg-fort-red animate-blink"></div>
                    </div>
                    <!-- Camera label -->
                    <div class="absolute top-2 left-2 flex items-center gap-1.5">
                      <span class="w-1.5 h-1.5 rounded-full bg-fort-red animate-pulse-slow"></span>
                      <span class="text-[9px] text-fort-white/70 font-mono">CAM 01 — ENTRADA</span>
                    </div>
                    <!-- Timestamp -->
                    <div class="absolute bottom-2 right-2 text-[9px] text-fort-white/40 font-mono">01/04/2026 15:42:18</div>
                  </div>

                  <!-- Camera 2 -->
                  <div class="mockup-camera-feed rounded-lg aspect-video relative">
                    <div class="absolute inset-0 bg-gradient-to-bl from-fort-dark via-fort-gray/20 to-fort-dark"></div>
                    <div class="absolute bottom-0 left-0 right-0 h-[40%] bg-gradient-to-t from-fort-black/40 to-transparent"></div>
                    <!-- Vehicle detection -->
                    <div class="mockup-detection-box w-[35%] h-[40%] bottom-[15%] left-[30%]" data-label="VEÍCULO">
                    </div>
                    <div class="absolute top-2 left-2 flex items-center gap-1.5">
                      <span class="w-1.5 h-1.5 rounded-full bg-fort-green"></span>
                      <span class="text-[9px] text-fort-white/70 font-mono">CAM 02 — GARAGEM</span>
                    </div>
                    <div class="absolute bottom-2 right-2 text-[9px] text-fort-white/40 font-mono">01/04/2026 15:42:18</div>
                  </div>

                  <!-- Camera 3 -->
                  <div class="mockup-camera-feed rounded-lg aspect-video relative">
                    <div class="absolute inset-0 bg-gradient-to-tr from-fort-dark via-fort-gray/20 to-fort-dark"></div>
                    <div class="absolute bottom-0 left-0 right-0 h-[50%] bg-gradient-to-t from-fort-black/50 to-transparent"></div>
                    <div class="absolute top-2 left-2 flex items-center gap-1.5">
                      <span class="w-1.5 h-1.5 rounded-full bg-fort-green"></span>
                      <span class="text-[9px] text-fort-white/70 font-mono">CAM 03 — PERÍMETRO</span>
                    </div>
                    <div class="absolute bottom-2 right-2 text-[9px] text-fort-white/40 font-mono">01/04/2026 15:42:18</div>
                  </div>

                  <!-- Camera 4 -->
                  <div class="mockup-camera-feed rounded-lg aspect-video relative">
                    <div class="absolute inset-0 bg-gradient-to-tl from-fort-dark via-fort-gray/20 to-fort-dark"></div>
                    <div class="absolute bottom-0 left-0 right-0 h-[45%] bg-gradient-to-t from-fort-black/40 to-transparent"></div>
                    <div class="absolute top-2 left-2 flex items-center gap-1.5">
                      <span class="w-1.5 h-1.5 rounded-full bg-fort-green"></span>
                      <span class="text-[9px] text-fort-white/70 font-mono">CAM 04 — HALL</span>
                    </div>
                    <div class="absolute bottom-2 right-2 text-[9px] text-fort-white/40 font-mono">01/04/2026 15:42:18</div>
                  </div>
                </div>

                <!-- Status bar -->
                <div class="flex items-center justify-between bg-fort-dark/80 rounded-lg px-2 sm:px-3 py-1.5 sm:py-2">
                  <div class="flex items-center gap-2 sm:gap-4">
                    <div class="flex items-center gap-1 sm:gap-1.5">
                      <span class="w-1.5 h-1.5 rounded-full bg-fort-green"></span>
                      <span class="text-[8px] sm:text-[10px] text-fort-text font-mono">12 câmeras online</span>
                    </div>
                    <div class="flex items-center gap-1 sm:gap-1.5">
                      <span class="w-1.5 h-1.5 rounded-full bg-fort-red animate-blink"></span>
                      <span class="text-[8px] sm:text-[10px] text-fort-red font-mono">1 alerta ativo</span>
                    </div>
                  </div>
                  <div class="flex items-center gap-1 sm:gap-1.5">
                    <svg class="w-3 h-3 text-fort-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3"/></svg>
                    <span class="text-[8px] sm:text-[10px] text-fort-blue font-mono">IA ativa</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Floating alert notification -->
          <div class="absolute -bottom-4 left-0 lg:-left-6 animate-float-delayed z-20">
            <div class="glass rounded-xl px-4 py-3 flex items-center gap-3 glow-blue-card">
              <div class="w-9 h-9 rounded-lg bg-fort-red/20 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-fort-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/>
                </svg>
              </div>
              <div>
                <p class="text-[11px] text-fort-white font-semibold">Alerta: Pessoa detectada</p>
                <p class="text-[10px] text-fort-text">CAM 01 — Entrada principal &middot; agora</p>
              </div>
            </div>
          </div>

          <!-- Floating accuracy badge -->
          <div class="absolute -top-3 right-0 lg:-right-3 z-20 animate-float">
            <div class="glass rounded-xl px-4 py-3 text-center glow-blue-card">
              <p class="text-2xl font-bold text-fort-blue">98.7%</p>
              <p class="text-[10px] text-fort-text">Precisão IA</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats strip with animated counters -->
    <div class="mt-10 sm:mt-16 pt-8 sm:pt-10 border-t border-fort-border/50 grid grid-cols-2 md:grid-cols-4 gap-6 sm:gap-8">
      <div class="counter-animate group" style="transition-delay: 0ms">
        <div class="text-2xl sm:text-3xl font-extrabold text-fort-white group-hover:text-gradient-blue transition-all duration-300">
          <span data-count-to="98" data-count-suffix="%+">0</span>
        </div>
        <div class="text-sm text-fort-text mt-1">Precisão na detecção por IA</div>
      </div>
      <div class="counter-animate group" style="transition-delay: 150ms">
        <div class="text-2xl sm:text-3xl font-extrabold text-fort-white group-hover:text-gradient-blue transition-all duration-300">24/7</div>
        <div class="text-sm text-fort-text mt-1">Monitoramento ininterrupto</div>
      </div>
      <div class="counter-animate group" style="transition-delay: 300ms">
        <div class="text-2xl sm:text-3xl font-extrabold text-fort-white group-hover:text-gradient-blue transition-all duration-300">
          <span data-count-to="100" data-count-suffix="x">0</span>
        </div>
        <div class="text-sm text-fort-text mt-1">Menos falsos alarmes</div>
      </div>
      <div class="counter-animate group" style="transition-delay: 450ms">
        <div class="text-2xl sm:text-3xl font-extrabold text-fort-white group-hover:text-gradient-blue transition-all duration-300">&lt;<span data-count-to="60" data-count-suffix="s">0</span></div>
        <div class="text-sm text-fort-text mt-1">Tempo de resposta</div>
      </div>
    </div>
  </div>
</section>
