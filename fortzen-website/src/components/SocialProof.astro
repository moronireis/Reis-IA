---
const testimonials = [
  {
    quote: "Depois que instalamos o sistema da BATALION, os falsos alarmes praticamente zeraram. A equipe de segurança agora confia nos alertas e responde mais rápido.",
    name: "Roberto M.",
    role: "Síndico — Condomínio Residencial",
    rating: 5,
  },
  {
    quote: "A portaria remota reduziu nossos custos em mais de 50% e o controle de acesso ficou muito mais eficiente. Os moradores adoraram o app.",
    name: "Patrícia S.",
    role: "Administradora de Condomínios",
    rating: 5,
  },
  {
    quote: "O monitoramento com IA detectou uma tentativa de invasão às 3h da manhã. A resposta foi em menos de 40 segundos. Impressionante.",
    name: "Carlos A.",
    role: "Proprietário — Galpão Industrial",
    rating: 5,
  },
];

const partners = ["Hikvision", "Intelbras", "Dahua", "Axis", "Bosch"];
---

<section class="py-24 relative">
  <div class="section-divider absolute top-0 left-0 right-0"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-10 sm:mb-16">
      <p class="text-blur-in text-fort-blue text-sm font-semibold tracking-wider uppercase mb-3">Depoimentos</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-fort-white mb-4">
        <span class="text-slide-up block overflow-hidden"><span class="inner">Quem confia na BATALION</span></span>
      </h2>
      <p class="text-blur-in text-fort-text max-w-2xl mx-auto" style="transition-delay: 200ms">
        Empresas e condomínios que escolheram proteção inteligente.
      </p>
    </div>

    <!-- Testimonials -->
    <div class="grid md:grid-cols-3 gap-6 mb-20 stagger-children">
      {testimonials.map((t) => (
        <div class="group relative bg-fort-gray/20 border border-fort-border/40 rounded-2xl p-7 hover:border-fort-blue/20 transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_8px_40px_rgba(42,111,242,0.08)]">
          <!-- Quote icon -->
          <svg class="w-8 h-8 text-fort-blue/20 mb-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>

          <!-- Stars -->
          <div class="flex gap-0.5 mb-4">
            {Array.from({length: t.rating}).map(() => (
              <svg class="w-4 h-4 text-fort-amber" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <p class="text-fort-light text-sm leading-relaxed mb-6">{t.quote}</p>

          <div class="flex items-center gap-3 pt-4 border-t border-fort-border/30">
            <div class="w-10 h-10 rounded-full bg-fort-blue/10 border border-fort-blue/20 flex items-center justify-center">
              <span class="text-sm font-bold text-fort-blue">{t.name.charAt(0)}</span>
            </div>
            <div>
              <p class="text-fort-white font-medium text-sm">{t.name}</p>
              <p class="text-fort-text text-xs">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Partners -->
    <div class="reveal">
      <div class="gradient-line mb-10"></div>
      <p class="text-center text-sm text-fort-text mb-8">Compatível com os principais fabricantes</p>
      <div class="flex flex-wrap justify-center items-center gap-10 md:gap-16">
        {partners.map((p) => (
          <span class="text-fort-text/30 font-bold text-xl tracking-wider hover:text-fort-text/60 transition-colors duration-300 cursor-default">{p}</span>
        ))}
      </div>
    </div>
  </div>
</section>
