---
const features = [
  {
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/></svg>`,
    title: "Alertas em Tempo Real",
    desc: "Receba notificações de eventos e monitore o status do seu sistema",
  },
  {
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>`,
    title: "Status das Câmeras",
    desc: "Visualize quantas câmeras estão online, offline ou com erro",
  },
  {
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"/></svg>`,
    title: "Suporte 24/7",
    desc: "Fale direto com um especialista pelo painel a qualquer momento",
  },
  {
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3"/></svg>`,
    title: "Apps Nativos",
    desc: "Disponível para iOS, Android e Apple Watch",
  },
];
---

<section id="painel" class="py-24 relative overflow-hidden">
  <div class="section-divider absolute top-0 left-0 right-0"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-fort-darker via-fort-dark/40 to-fort-darker"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Header -->
    <div class="text-center mb-14">
      <p class="text-blur-in text-fort-blue text-sm font-semibold tracking-wider uppercase mb-3">Plataforma</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-fort-white mb-4">
        <span class="text-slide-up block overflow-hidden">
          <span class="inner">Painel de Controle do Cliente</span>
        </span>
      </h2>
      <p class="text-blur-in text-fort-text max-w-xl mx-auto" style="transition-delay: 200ms">
        Acesse seus alertas, câmeras e relatórios em uma interface intuitiva. Disponível na web e nos apps iOS e Android.
      </p>
    </div>

    <!-- Dashboard image in browser mockup -->
    <div class="reveal max-w-4xl mx-auto mb-12">
      <div class="mockup-window shadow-2xl shadow-black/50 glow-blue-strong">
        <div class="mockup-toolbar">
          <div class="mockup-dot bg-fort-red/80"></div>
          <div class="mockup-dot bg-fort-amber/80"></div>
          <div class="mockup-dot bg-fort-green/80"></div>
          <div class="flex-1 mx-4">
            <div class="bg-fort-dark/80 border border-fort-border/50 rounded-md px-3 py-1 flex items-center gap-2 max-w-xs mx-auto">
              <svg class="w-3 h-3 text-fort-green shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
              </svg>
              <span class="text-[10px] text-fort-text/60 font-mono truncate">painel.bataliondefense.com.br/dashboard</span>
            </div>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <img
            src="/images/area-cliente.jpeg"
            alt="Painel de controle do cliente com alertas, status das câmeras e opção de download do app"
            loading="lazy"
            class="w-full h-auto object-contain"
          />
          <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-fort-black/30 pointer-events-none"></div>
        </div>
      </div>
    </div>

    <!-- Feature cards -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 stagger-children">
      {features.map((feat) => (
        <div class="group bg-fort-gray/20 border border-fort-border/40 rounded-2xl p-5 hover:border-fort-blue/25 transition-all duration-500 hover:-translate-y-0.5 hover:shadow-[0_8px_32px_rgba(51,136,255,0.08)]">
          <div class="w-10 h-10 rounded-xl bg-fort-blue/10 border border-fort-blue/20 flex items-center justify-center text-fort-blue mb-4 group-hover:bg-fort-blue/20 group-hover:scale-105 transition-all duration-300" set:html={feat.icon} />
          <h3 class="text-fort-white font-semibold text-sm mb-2">{feat.title}</h3>
          <p class="text-fort-text text-xs leading-relaxed">{feat.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
