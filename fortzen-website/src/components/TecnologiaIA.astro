---
---

<section id="tecnologia" class="py-24 relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(42,111,242,0.06),transparent_70%)]"></div>
  <div class="section-divider absolute top-0 left-0 right-0"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-blur-in text-fort-blue text-sm font-semibold tracking-wider uppercase mb-3">Tecnologia</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-fort-white mb-4">
        <span class="text-slide-up block overflow-hidden"><span class="inner">Detecção inteligente.</span></span>
        <span class="text-slide-up block overflow-hidden" style="transition-delay: 150ms"><span class="inner text-gradient-animated">Não é só movimento. É compreensão.</span></span>
      </h2>
      <p class="text-blur-in text-fort-text max-w-2xl mx-auto" style="transition-delay: 300ms">
        Machine learning treinado com milhões de horas de vídeo. Identifica pessoas, reconhece veículos, detecta permanência e ações suspeitas.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-start">
      <!-- Left: Visual comparison mockup -->
      <div class="reveal-left">
        <!-- Traditional system -->
        <div class="mb-6">
          <div class="flex items-center gap-2 mb-3">
            <div class="w-2.5 h-2.5 rounded-full bg-fort-red/80"></div>
            <span class="text-sm font-semibold text-fort-text">Sistema Tradicional</span>
          </div>
          <div class="mockup-window">
            <div class="mockup-toolbar">
              <div class="mockup-dot bg-fort-red/60"></div>
              <div class="mockup-dot bg-fort-amber/60"></div>
              <div class="mockup-dot bg-fort-green/60"></div>
              <span class="text-[10px] text-fort-text/40 ml-2 font-mono">Sensor de Movimento v2.1</span>
            </div>
            <div class="p-4 space-y-2">
              {[
                { event: "Gato no jardim", time: "03:12", result: "ALARME" },
                { event: "Folha caindo", time: "03:28", result: "ALARME" },
                { event: "Sombra de árvore", time: "03:45", result: "ALARME" },
                { event: "Chuva forte", time: "04:02", result: "ALARME" },
                { event: "Pessoa suspeita", time: "04:18", result: "ALARME" },
              ].map((item) => (
                <div class="flex items-center justify-between bg-fort-dark/60 rounded-lg px-4 py-2.5 border border-fort-border/30">
                  <div class="flex items-center gap-3">
                    <span class="text-[10px] text-fort-text/50 font-mono w-10">{item.time}</span>
                    <span class="text-sm text-fort-text">{item.event}</span>
                  </div>
                  <span class="text-[10px] font-bold bg-fort-red/20 text-fort-red px-2.5 py-0.5 rounded-full tracking-wide">{item.result}</span>
                </div>
              ))}
              <div class="flex items-center justify-between pt-2 px-2">
                <span class="text-[11px] text-fort-red/60">5 alarmes disparados</span>
                <span class="text-[11px] text-fort-red/60">4 falsos (80%)</span>
              </div>
            </div>
          </div>
        </div>

        <!-- BATALION system -->
        <div>
          <div class="flex items-center gap-2 mb-3">
            <div class="w-2.5 h-2.5 rounded-full bg-fort-blue"></div>
            <span class="text-sm font-semibold text-fort-blue">BATALION com IA</span>
          </div>
          <div class="mockup-window border-fort-blue/20 animate-glow-pulse">
            <div class="mockup-toolbar">
              <div class="mockup-dot bg-fort-red/60"></div>
              <div class="mockup-dot bg-fort-amber/60"></div>
              <div class="mockup-dot bg-fort-green/60"></div>
              <span class="text-[10px] text-fort-blue/60 ml-2 font-mono">BATALION AI Engine v5.0</span>
              <div class="ml-auto flex items-center gap-1.5">
                <span class="w-1.5 h-1.5 rounded-full bg-fort-green animate-pulse-slow"></span>
                <span class="text-[10px] text-fort-green font-mono">ML ativo</span>
              </div>
            </div>
            <div class="p-4 space-y-2">
              {[
                { event: "Gato no jardim", time: "03:12", result: "IGNORADO", type: "ignored", conf: "Animal 94%" },
                { event: "Folha caindo", time: "03:28", result: "IGNORADO", type: "ignored", conf: "Objeto 99%" },
                { event: "Sombra de árvore", time: "03:45", result: "IGNORADO", type: "ignored", conf: "Ambiente 97%" },
                { event: "Chuva forte", time: "04:02", result: "IGNORADO", type: "ignored", conf: "Clima 99%" },
                { event: "Pessoa suspeita", time: "04:18", result: "ALERTA", type: "alert", conf: "Pessoa 98%" },
              ].map((item) => (
                <div class={`flex items-center justify-between rounded-lg px-4 py-2.5 border transition-all duration-300 ${item.type === 'alert' ? 'bg-fort-blue/10 border-fort-blue/30' : 'bg-fort-dark/60 border-fort-border/30'}`}>
                  <div class="flex items-center gap-3">
                    <span class="text-[10px] text-fort-text/50 font-mono w-10">{item.time}</span>
                    <span class={`text-sm ${item.type === 'alert' ? 'text-fort-white font-medium' : 'text-fort-text/60 line-through decoration-fort-border/50'}`}>{item.event}</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <span class="text-[9px] text-fort-text/40 font-mono">{item.conf}</span>
                    <span class={`text-[10px] font-bold px-2.5 py-0.5 rounded-full tracking-wide ${item.type === 'alert' ? 'bg-fort-blue/20 text-fort-blue' : 'bg-fort-gray text-fort-text/50'}`}>{item.result}</span>
                  </div>
                </div>
              ))}
              <div class="flex items-center justify-between pt-2 px-2">
                <span class="text-[11px] text-fort-blue/60">1 alerta real disparado</span>
                <span class="text-[11px] text-fort-green/60">0 falsos (0%)</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Features + Phone mockup -->
      <div class="reveal-right hidden lg:block">
        <div class="space-y-8 mb-12">
          {[
            {
              icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
              title: "Processamento em nuvem",
              desc: "Sem hardware especial. A inteligência está no software, não na câmera. Funciona com qualquer modelo de câmera IP.",
            },
            {
              icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
              title: "LGPD compliant",
              desc: "100% em conformidade com a Lei Geral de Proteção de Dados. Sem reconhecimento facial em áreas públicas.",
            },
            {
              icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>`,
              title: "Aprendizado contínuo",
              desc: "O sistema melhora a cada análise. Quanto mais opera, mais preciso fica.",
            },
          ].map((item) => (
            <div class="flex items-start gap-4 group/feature">
              <div class="w-10 h-10 rounded-xl bg-fort-blue/10 border border-fort-blue/20 flex items-center justify-center shrink-0 text-fort-blue group-hover/feature:bg-fort-blue/20 group-hover/feature:scale-105 transition-all duration-300" set:html={item.icon} />
              <div>
                <h4 class="text-fort-white font-semibold mb-1">{item.title}</h4>
                <p class="text-fort-text text-sm leading-relaxed">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Phone mockup -->
        <div class="flex justify-center">
          <div class="relative">
            <div class="mockup-phone animate-float">
              <div class="mockup-phone-notch"></div>
              <div class="mockup-phone-screen">
                <!-- App header -->
                <div class="pt-8 px-4 pb-3 border-b border-fort-border/30">
                  <div class="flex items-center justify-between">
                    <div>
                      <p class="text-[9px] text-fort-text/50 font-mono">BATALION</p>
                      <p class="text-[13px] text-fort-white font-bold">Meu Sistema</p>
                    </div>
                    <div class="flex items-center gap-1">
                      <span class="w-1.5 h-1.5 rounded-full bg-fort-green"></span>
                      <span class="text-[9px] text-fort-green font-mono">Armado</span>
                    </div>
                  </div>
                </div>
                <!-- Camera preview -->
                <div class="px-3 pt-3">
                  <div class="mockup-camera-feed rounded-lg aspect-video relative mb-3">
                    <div class="absolute inset-0 bg-gradient-to-br from-fort-dark via-fort-gray/30 to-fort-dark rounded-lg"></div>
                    <div class="absolute top-1.5 left-2 flex items-center gap-1">
                      <span class="w-1 h-1 rounded-full bg-fort-red animate-blink"></span>
                      <span class="text-[7px] text-fort-white/60 font-mono">AO VIVO</span>
                    </div>
                    <div class="absolute bottom-1.5 left-2 text-[7px] text-fort-white/40 font-mono">CAM 01</div>
                  </div>
                  <!-- Quick actions -->
                  <div class="grid grid-cols-3 gap-2 mb-3">
                    {[
                      { label: "Desarmar", icon: "unlock" },
                      { label: "Câmeras", icon: "camera" },
                      { label: "Portão", icon: "gate" },
                    ].map((action) => (
                      <div class="bg-fort-gray/50 rounded-lg p-2 text-center border border-fort-border/30">
                        <div class="w-6 h-6 mx-auto mb-1 rounded-lg bg-fort-blue/20 flex items-center justify-center">
                          <div class="w-3 h-3 rounded-sm bg-fort-blue/60"></div>
                        </div>
                        <p class="text-[8px] text-fort-text">{action.label}</p>
                      </div>
                    ))}
                  </div>
                  <!-- Recent events -->
                  <div>
                    <p class="text-[9px] text-fort-text/50 font-semibold uppercase tracking-wider mb-2">Eventos recentes</p>
                    {[
                      { text: "Pessoa detectada — Entrada", time: "15:42", type: "alert" },
                      { text: "Veículo identificado — Garagem", time: "15:38", type: "info" },
                      { text: "Sistema armado", time: "15:30", type: "ok" },
                    ].map((event) => (
                      <div class="flex items-center justify-between py-1.5 border-b border-fort-border/20 last:border-0">
                        <div class="flex items-center gap-2">
                          <div class={`w-1.5 h-1.5 rounded-full ${event.type === 'alert' ? 'bg-fort-red' : event.type === 'info' ? 'bg-fort-blue' : 'bg-fort-green'}`}></div>
                          <span class="text-[8px] text-fort-light">{event.text}</span>
                        </div>
                        <span class="text-[7px] text-fort-text/40 font-mono">{event.time}</span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>

            <!-- Floating notification near phone -->
            <div class="absolute -right-4 top-1/3 animate-float-delayed z-20">
              <div class="glass rounded-lg px-3 py-2 glow-blue-card">
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 rounded-md bg-fort-green/20 flex items-center justify-center">
                    <svg class="w-3.5 h-3.5 text-fort-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                  </div>
                  <div>
                    <p class="text-[10px] text-fort-white font-medium">Portão aberto</p>
                    <p class="text-[8px] text-fort-text">Via app</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
