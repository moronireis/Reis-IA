---
const steps = [
  {
    num: "01",
    title: "Consultoria",
    desc: "Analisamos seu imóvel, mapeamos vulnerabilidades e projetamos a solução ideal. Cada ponto cego recebe atenção — sem pacote genérico.",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>`,
  },
  {
    num: "02",
    title: "Instalação",
    desc: "Equipe técnica especializada realiza a instalação completa. Câmeras, sensores, alarmes e portaria configurados e testados no local.",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75a4.5 4.5 0 01-4.884 4.484c-1.076-.091-2.264.071-2.95.904l-7.152 8.684a2.548 2.548 0 11-3.586-3.586l8.684-7.152c.833-.686.995-1.874.904-2.95a4.5 4.5 0 016.336-4.486l-3.276 3.276a3.004 3.004 0 002.25 2.25l3.276-3.276c.256.565.398 1.192.398 1.852zM4.867 19.125h.008v.008h-.008v-.008z"/></svg>`,
  },
  {
    num: "03",
    title: "Monitoramento Ativo",
    desc: "Sistema operante 24/7. IA analisando cada frame, central monitorando eventos reais, e você com controle total pelo aplicativo.",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
  },
];
---

<section id="como-funciona" class="py-24 relative">
  <div class="absolute inset-0 bg-gradient-to-b from-fort-darker via-fort-dark/50 to-fort-darker"></div>
  <div class="section-divider absolute top-0 left-0 right-0"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-10 sm:mb-16">
      <p class="text-blur-in text-fort-blue text-sm font-semibold tracking-wider uppercase mb-3">Processo</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-fort-white mb-4">
        <span class="text-slide-up block overflow-hidden"><span class="inner">Como funciona</span></span>
      </h2>
      <p class="text-blur-in text-fort-text max-w-2xl mx-auto" style="transition-delay: 200ms">
        Da análise inicial à operação. <span class="text-fort-white font-medium">Três etapas</span> para proteger o que importa.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 stagger-children">
      {steps.map((step, i) => (
        <div class="group relative">
          {/* Connecting line between cards */}
          {i < steps.length - 1 && (
            <div class="hidden md:block absolute top-1/2 -right-3 w-6 z-20">
              <svg class="w-6 h-6 text-fort-blue/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          )}

          <div class="relative bg-fort-gray/20 border border-fort-border/40 rounded-2xl p-8 h-full hover:border-fort-blue/20 transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_8px_40px_rgba(42,111,242,0.08)] overflow-hidden">
            <!-- Background number -->
            <span class="absolute -top-4 -right-2 text-[100px] font-extrabold text-fort-border/10 leading-none select-none">{step.num}</span>

            <div class="relative z-10">
              <div class="w-14 h-14 rounded-2xl bg-fort-blue/10 border border-fort-blue/20 flex items-center justify-center text-fort-blue mb-6 group-hover:bg-fort-blue group-hover:text-white transition-all duration-500" set:html={step.icon} />
              <div class="flex items-center gap-2 mb-3">
                <span class="text-xs font-bold text-fort-blue font-mono">{step.num}</span>
                <div class="h-px flex-1 bg-fort-border/30"></div>
              </div>
              <h3 class="text-xl font-bold text-fort-white mb-3">{step.title}</h3>
              <p class="text-fort-text text-sm leading-relaxed">{step.desc}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA after steps -->
    <div class="text-center mt-14 reveal">
      <a
        href="#contato"
        class="group inline-flex items-center gap-3 bg-fort-blue/10 hover:bg-fort-blue/20 border border-fort-blue/30 text-fort-blue font-semibold px-8 py-4 rounded-xl transition-all duration-300"
      >
        Agendar Consultoria Gratuita
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>
