---
import BatalionLogo from "./BatalionLogo.astro";
const currentYear = new Date().getFullYear();
---

<footer class="relative pt-16 pb-8">
  <div class="section-divider absolute top-0 left-0 right-0"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      <!-- Brand -->
      <div class="md:col-span-2 lg:col-span-1">
        <div class="flex flex-col items-start mb-4">
          <BatalionLogo size="md" />
        </div>
        <p class="text-sm text-fort-text leading-relaxed max-w-xs mb-5">
          Inteligência que protege. Resposta que age. Monitoramento com IA, CFTV, alarme e portaria remota para empresas e condomínios.
        </p>
        <div class="flex items-center gap-1.5 mb-5">
          <span class="w-2 h-2 rounded-full bg-fort-green"></span>
          <span class="text-xs text-fort-green font-mono">Sistema operacional 24/7</span>
        </div>
        <!-- Social icons -->
        <div class="flex items-center gap-3">
          <a
            href="#"
            aria-label="Instagram"
            class="w-8 h-8 rounded-lg border border-fort-border/50 flex items-center justify-center text-fort-text hover:text-fort-white hover:border-fort-blue/40 transition-all duration-300"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
            </svg>
          </a>
          <a
            href="#"
            aria-label="LinkedIn"
            class="w-8 h-8 rounded-lg border border-fort-border/50 flex items-center justify-center text-fort-text hover:text-fort-white hover:border-fort-blue/40 transition-all duration-300"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-sm font-bold text-fort-white mb-5 tracking-wider uppercase">Serviços</h4>
        <ul class="space-y-3">
          <li><a href="#servicos" class="text-sm text-fort-text hover:text-fort-white transition-colors duration-300">Monitoramento e CFTV</a></li>
          <li><a href="#servicos" class="text-sm text-fort-text hover:text-fort-white transition-colors duration-300">Sistema de Alarme</a></li>
          <li><a href="#servicos" class="text-sm text-fort-text hover:text-fort-white transition-colors duration-300">Portaria Remota</a></li>
          <li><a href="#tecnologia" class="text-sm text-fort-text hover:text-fort-white transition-colors duration-300">Tecnologia IA</a></li>
        </ul>
      </div>

      <!-- Empresa + Áreas -->
      <div>
        <h4 class="text-sm font-bold text-fort-white mb-5 tracking-wider uppercase">Empresa</h4>
        <ul class="space-y-3 mb-8">
          <li><a href="#sobre" class="text-sm text-fort-text hover:text-fort-white transition-colors duration-300">Sobre</a></li>
          <li><a href="#faq" class="text-sm text-fort-text hover:text-fort-white transition-colors duration-300">FAQ</a></li>
          <li><a href="#contato" class="text-sm text-fort-text hover:text-fort-white transition-colors duration-300">Contato</a></li>
        </ul>

        <h4 class="text-sm font-bold text-fort-white mb-4 tracking-wider uppercase">Áreas de Atendimento</h4>
        <ul class="space-y-2">
          <li class="text-xs text-fort-text">São Paulo (Capital e Grande SP)</li>
          <li class="text-xs text-fort-text">Guarulhos</li>
          <li class="text-xs text-fort-text">Osasco</li>
          <li class="text-xs text-fort-text">ABC Paulista</li>
          <li class="text-xs text-fort-text">Campinas e Região</li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-sm font-bold text-fort-white mb-5 tracking-wider uppercase">Contato</h4>
        <ul class="space-y-3">
          <li class="text-sm text-fort-text">(11) 9 9888-0000</li>
          <li class="text-sm text-fort-text">contato@bataliondefense.com.br</li>
          <li>
            <a
              href="https://wa.me/5511999999999"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-fort-blue hover:text-fort-blue-glow transition-colors duration-300"
            >
              WhatsApp
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="gradient-line"></div>
    <div class="pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <div class="flex flex-col sm:flex-row items-center gap-4">
        <p class="text-xs text-fort-text/50">
          &copy; {currentYear} BATALION Defense AI. Todos os direitos reservados.
        </p>
        <span class="hidden sm:block text-fort-text/20">·</span>
        <p class="text-xs text-fort-text/30">CNPJ: XX.XXX.XXX/0001-XX</p>
      </div>
      <p class="text-xs text-fort-text/30 italic">
        Inteligência que protege. Resposta que age.
      </p>
    </div>
  </div>
</footer>
