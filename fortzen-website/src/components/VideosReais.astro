---
const videos = [
  {
    src: "/videos/deteccao-01.mp4",
    label: "Detecção de invasão — Monitoramento noturno",
    span: "md:col-span-2",
  },
  {
    src: "/videos/deteccao-02.mp4",
    label: "IA identificando movimentação suspeita",
    span: "",
  },
  {
    src: "/videos/deteccao-03.mp4",
    label: "Sistema de alerta em tempo real",
    span: "",
  },
  {
    src: "/videos/deteccao-04.mp4",
    label: "Câmera com detecção inteligente em operação",
    span: "md:col-span-2",
  },
];
---

<section id="videos" class="py-24 relative overflow-hidden">
  <div class="section-divider absolute top-0 left-0 right-0"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,rgba(51,136,255,0.05),transparent_60%)]"></div>
  <div class="absolute inset-0 carbon-texture opacity-30"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Header -->
    <div class="text-center mb-14">
      <p class="text-blur-in text-fort-blue text-sm font-semibold tracking-wider uppercase mb-3">Em Campo</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-fort-white mb-4">
        <span class="text-slide-up block overflow-hidden">
          <span class="inner">Veja o sistema funcionando</span>
        </span>
      </h2>
      <p class="text-blur-in text-fort-text max-w-xl mx-auto" style="transition-delay: 200ms">
        Registros reais do funcionamento das câmeras com IA em operação.
      </p>
    </div>

    <!-- Video grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-5 stagger-children">
      {videos.map((video) => (
        <div class={`group relative rounded-2xl overflow-hidden border border-fort-border/40 hover:border-fort-blue/30 transition-all duration-500 ${video.span}`}>
          <!-- Video player -->
          <div class="aspect-video bg-fort-black relative">
            <video
              src={video.src}
              autoplay
              muted
              loop
              playsinline
              class="w-full h-full object-contain"
            />
          </div>

          <!-- Bottom overlay with label -->
          <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-fort-black/90 via-fort-black/40 to-transparent p-4 pointer-events-none">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-fort-red animate-blink shrink-0"></span>
              <p class="text-fort-light text-sm font-medium">{video.label}</p>
            </div>
          </div>

          <!-- Corner badge -->
          <div class="absolute top-3 left-3">
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-[10px] font-semibold bg-fort-black/70 border border-fort-border/50 text-fort-light backdrop-blur-sm">
              <svg class="w-2.5 h-2.5 text-fort-red" fill="currentColor" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="5"/>
              </svg>
              AO VIVO
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
