---
interface Props {
  size?: "sm" | "md" | "lg";
}

const { size = "md" } = Astro.props;

const config = {
  sm: "h-10 max-w-[180px]",
  md: "h-14 max-w-[240px]",
  lg: "h-20 max-w-[340px]",
};
---

<div class={`flex items-center ${size === "sm" ? "" : ""}`}>
  <img
    src="/images/batalion-logo.png"
    alt="BATALION Defense AI"
    class={`${config[size]} w-auto object-contain rounded-sm`}
    loading="eager"
  />
</div>
