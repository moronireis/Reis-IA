---
const cards = [
  {
    image: "/images/deteccao/invasao-noturna.jpeg",
    alt: "Câmera infravermelha em modo noturno com detecção de pessoa destacada em vermelho",
    badge: "Visão Noturna",
    badgeColor: "bg-fort-red/90 text-white",
    title: "Detecção de Invasão — Modo Noturno",
    desc: "IA identifica presença humana em câmeras infravermelhas P&B com 98%+ de precisão, mesmo em escuridão total.",
  },
  {
    image: "/images/deteccao/area-interesse.jpeg",
    alt: "Câmera diurna com zona azul delimitada de área de interesse para prevenção de falsos alertas",
    badge: "Zona Inteligente",
    badgeColor: "bg-fort-blue/90 text-white",
    title: "Área de Interesse Configurável",
    desc: "Delimite zonas específicas para monitoramento. A IA ignora movimento fora da área, eliminando falsos alertas.",
  },
  {
    image: "/images/deteccao/deteccao-diurna.jpeg",
    alt: "Câmera diurna com identificação de pessoa e log de eventos lateral",
    badge: "Detecção Diurna",
    badgeColor: "bg-fort-green/90 text-white",
    title: "Detecção de Pessoas em Tempo Real",
    desc: "Identificação automática de pessoas com log de eventos, horário e status. Cada alerta é verificado e registrado.",
  },
  {
    image: "/images/deteccao/mudanca-cena.jpeg",
    alt: "IA detectando caminhões e mudança de cena no ambiente monitorado",
    badge: "Mudança de Cena",
    badgeColor: "bg-fort-amber/90 text-fort-black",
    title: "IA Analisa Mudanças no Ambiente",
    desc: "O sistema detecta alterações no cenário como veículos estacionados, objetos movidos ou obstruções. Alerta automático para a central.",
  },
  {
    image: "/images/deteccao/problema-camera.jpeg",
    alt: "Câmera com obstrução detectada automaticamente pelo sistema de IA",
    badge: "Saúde da Câmera",
    badgeColor: "bg-fort-amber/90 text-fort-black",
    title: "Diagnóstico Automático de Câmeras",
    desc: "A IA monitora a própria câmera: identifica obstrução, perda de foco, deslocamento ou falta de imagem em tempo real.",
  },
  {
    image: "/images/deteccao/invasao-fullcolor.jpeg",
    alt: "Câmera full color com pessoa detectada e silhueta destacada em vermelho",
    badge: "Full Color",
    badgeColor: "bg-fort-red/90 text-white",
    title: "Detecção de Invasão — Câmera Colorida",
    desc: "Identificação precisa de pessoas em câmeras full color com silhueta destacada. Resposta da central em menos de 60 segundos.",
  },
];
---

<section id="galeria" class="py-24 relative overflow-hidden">
  <div class="section-divider absolute top-0 left-0 right-0"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-fort-darker via-fort-black/60 to-fort-darker"></div>
  <div class="absolute inset-0 carbon-texture opacity-40"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Header -->
    <div class="text-center mb-10 sm:mb-16">
      <p class="text-blur-in text-fort-blue text-sm font-semibold tracking-wider uppercase mb-3">IA em Ação</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-fort-white mb-4">
        <span class="text-slide-up block overflow-hidden">
          <span class="inner">Detecção inteligente em tempo real</span>
        </span>
      </h2>
      <p class="text-blur-in text-fort-text max-w-2xl mx-auto" style="transition-delay: 200ms">
        Imagens reais do sistema BATALION em operação. Cada câmera é monitorada com inteligência artificial 24 horas por dia.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-5 stagger-children">
      {cards.map((card) => (
        <div class="group relative rounded-2xl overflow-hidden border border-fort-border/40 hover:border-fort-blue/30 transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_8px_40px_rgba(51,136,255,0.12)]">
          <!-- Image -->
          <div class="aspect-video overflow-hidden bg-fort-black">
            <img
              src={card.image}
              alt={card.alt}
              loading="lazy"
              class="w-full h-full object-contain transition-transform duration-700 group-hover:scale-105"
            />
          </div>

          <!-- Overlay gradient -->
          <div class="absolute inset-0 bg-gradient-to-t from-fort-black/90 via-fort-black/20 to-transparent pointer-events-none"></div>

          <!-- Badge -->
          <div class="absolute top-3 left-3">
            <span class={`inline-flex items-center px-2.5 py-1 rounded-md text-[11px] font-bold tracking-wider uppercase ${card.badgeColor} backdrop-blur-sm`}>
              {card.badge}
            </span>
          </div>

          <!-- Text content over overlay -->
          <div class="absolute bottom-0 left-0 right-0 p-3 sm:p-5">
            <h3 class="text-fort-white font-bold text-sm sm:text-base mb-1 sm:mb-1.5 leading-snug">{card.title}</h3>
            <p class="text-fort-text text-xs sm:text-sm leading-relaxed line-clamp-2">{card.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom note -->
    <div class="mt-8 sm:mt-10 flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-3 reveal">
      <div class="flex items-center gap-1.5">
        <span class="w-2 h-2 rounded-full bg-fort-green animate-pulse-slow"></span>
        <span class="text-xs text-fort-green font-mono">Sistema operacional 24/7</span>
      </div>
      <span class="text-fort-border">·</span>
      <span class="text-xs text-fort-text/60 font-mono">Imagens capturadas em campo por câmeras reais</span>
    </div>
  </div>
</section>
