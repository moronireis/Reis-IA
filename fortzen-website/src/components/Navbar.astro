---
import BatalionLogo from "./BatalionLogo.astro";

const links = [
  { href: "#servicos", label: "Serviços" },
  { href: "#tecnologia", label: "Tecnologia" },
  { href: "#como-funciona", label: "Como Funciona" },
  { href: "#sobre", label: "Sobre" },
  { href: "#contato", label: "Contato" },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-3 sm:py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="#" class="flex items-center group relative" aria-label="BATALION Defense AI">
      <BatalionLogo size="sm" />
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          class="text-sm text-fort-text hover:text-fort-white transition-colors duration-300 relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[1px] after:bg-fort-blue after:transition-all after:duration-300 hover:after:w-full"
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://wa.me/5511999999999?text=Ol%C3%A1%2C%20gostaria%20de%20um%20or%C3%A7amento%20BATALION"
        target="_blank"
        rel="noopener noreferrer"
        class="relative bg-fort-blue hover:bg-fort-blue-dark text-white text-sm font-semibold px-6 py-2.5 rounded-lg transition-all duration-300 hover:shadow-[0_0_20px_rgba(42,111,242,0.4)] active:scale-95"
      >
        Solicitar Orçamento
      </a>
    </div>

    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="md:hidden text-fort-white p-2 relative" aria-label="Menu">
      <div id="hamburger" class="w-6 h-5 flex flex-col justify-between transition-all duration-300">
        <span class="w-full h-[2px] bg-current transition-all duration-300 origin-center" id="bar1"></span>
        <span class="w-full h-[2px] bg-current transition-all duration-300" id="bar2"></span>
        <span class="w-2/3 h-[2px] bg-current transition-all duration-300 origin-center ml-auto" id="bar3"></span>
      </div>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden overflow-hidden transition-all duration-500">
    <div class="glass mx-4 mb-4 rounded-xl">
      <div class="px-6 py-5 flex flex-col gap-4">
        {links.map((link) => (
          <a href={link.href} class="text-fort-text hover:text-fort-white transition-colors py-2 border-b border-fort-border/30 last:border-0">
            {link.label}
          </a>
        ))}
        <a
          href="https://wa.me/5511999999999?text=Ol%C3%A1%2C%20gostaria%20de%20um%20or%C3%A7amento%20BATALION"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-fort-blue text-white text-center font-semibold px-5 py-3 rounded-lg mt-2"
        >
          Solicitar Orçamento
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById("navbar");
  let lastScroll = 0;

  window.addEventListener("scroll", () => {
    const current = window.scrollY;
    if (current > 50) {
      navbar?.classList.add("bg-fort-darker/90", "backdrop-blur-xl", "shadow-lg", "shadow-black/10");
      navbar?.classList.remove("py-1");
    } else {
      navbar?.classList.remove("bg-fort-darker/90", "backdrop-blur-xl", "shadow-lg", "shadow-black/10");
    }
    lastScroll = current;
  });

  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const bar1 = document.getElementById("bar1");
  const bar2 = document.getElementById("bar2");
  const bar3 = document.getElementById("bar3");
  let menuOpen = false;

  btn?.addEventListener("click", () => {
    menuOpen = !menuOpen;
    menu?.classList.toggle("hidden");
    if (menuOpen) {
      bar1?.style.setProperty("transform", "rotate(45deg) translateY(7.5px)");
      bar2?.style.setProperty("opacity", "0");
      bar3?.style.setProperty("transform", "rotate(-45deg) translateY(-7.5px)");
      bar3?.style.setProperty("width", "100%");
      bar3?.style.setProperty("margin-left", "0");
    } else {
      bar1?.style.setProperty("transform", "none");
      bar2?.style.setProperty("opacity", "1");
      bar3?.style.setProperty("transform", "none");
      bar3?.style.setProperty("width", "66%");
      bar3?.style.setProperty("margin-left", "auto");
    }
  });

  menu?.querySelectorAll("a").forEach((a) => {
    a.addEventListener("click", () => {
      menu?.classList.add("hidden");
      menuOpen = false;
      bar1?.style.setProperty("transform", "none");
      bar2?.style.setProperty("opacity", "1");
      bar3?.style.setProperty("transform", "none");
      bar3?.style.setProperty("width", "66%");
      bar3?.style.setProperty("margin-left", "auto");
    });
  });
</script>
