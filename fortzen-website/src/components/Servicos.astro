---
const services = [
  {
    id: "monitoramento",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 10.5l4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25h-9A2.25 2.25 0 002.25 7.5v9a2.25 2.25 0 002.25 2.25z"/></svg>`,
    title: "Monitoramento e CFTV",
    subtitle: "Câmeras com inteligência artificial",
    desc: "Sistema de videomonitoramento com análise por IA. Detecção de pessoas, veículos, leitura de placas e identificação de comportamento suspeito — tudo em nuvem, acessível de qualquer lugar.",
    features: [
      "Detecção de pessoas com 98%+ de precisão",
      "Leitura automática de placas (LPR)",
      "Detecção de permanência e vadiagem",
      "Compatível com 50+ fabricantes de câmeras",
      "Armazenamento em nuvem com acesso remoto",
      "Redução de até 100x em falsos alarmes",
    ],
    platform: null,
    color: "fort-blue",
  },
  {
    id: "alarme",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/></svg>`,
    title: "Sistemas de Alarme",
    subtitle: "Proteção perimetral inteligente",
    desc: "Alarmes monitorados 24 horas com sensores de abertura, impacto, vibração e movimento. Integrado à central com resposta imediata e verificação por câmera.",
    features: [
      "Sensores wireless anti-sabotagem",
      "Verificação de alarme por câmera",
      "Resposta em menos de 60 segundos",
      "Controle via aplicativo (armar/desarmar)",
      "Sirene de alta potência com backup",
      "Monitoramento 24/7 com pronta-resposta",
    ],
    platform: null,
    color: "fort-blue",
  },
  {
    id: "portaria",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205l3 1m1.5.5l-1.5-.5M6.75 7.364V3h-3v18m3-13.636l10.5-3.819"/></svg>`,
    title: "Portaria Remota",
    subtitle: "Controle de acesso digital completo",
    desc: "Portaria virtual com operação remota 24h, app para moradores, reconhecimento facial e controle total de acessos. Redução de até 60% nos custos comparado à portaria presencial.",
    features: [
      "Atendimento remoto 24 horas por operadores",
      "App do morador (iOS, Android, Apple Watch)",
      "Reconhecimento facial para liberação",
      "Três modos: remota, autônoma e presencial",
      "Telefonia em nuvem integrada (VoIP)",
      "Painel de gestão para síndicos",
    ],
    platform: null,
    color: "fort-blue",
  },
];
---

<section id="servicos" class="py-24 relative">
  <div class="section-divider absolute top-0 left-0 right-0"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-10 sm:mb-16">
      <p class="text-blur-in text-fort-blue text-sm font-semibold tracking-wider uppercase mb-3">Soluções</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-fort-white mb-4">
        <span class="text-slide-up block overflow-hidden"><span class="inner">Soluções em segurança</span></span>
      </h2>
      <p class="text-blur-in text-fort-text max-w-2xl mx-auto" style="transition-delay: 200ms">
        Três pilares de proteção que funcionam integrados. Cada solução reforça as demais.
      </p>
    </div>

    <div class="space-y-6">
      {services.map((service, i) => (
        <div class="reveal group">
          <div class="relative bg-fort-gray/20 border border-fort-border/40 rounded-2xl overflow-hidden hover:border-fort-blue/20 transition-all duration-500 hover:shadow-[0_4px_40px_rgba(42,111,242,0.08)]">
            <!-- Top accent line -->
            <div class="absolute top-0 left-0 right-0 h-[1px] bg-gradient-to-r from-transparent via-fort-blue/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

            <div class="p-8 lg:p-10">
              <div class="grid lg:grid-cols-2 gap-8 lg:gap-12">
                <div>
                  <div class="flex items-start gap-4 mb-6">
                    <div class="w-14 h-14 rounded-2xl bg-fort-blue/10 border border-fort-blue/20 flex items-center justify-center text-fort-blue shrink-0 group-hover:bg-fort-blue/20 group-hover:scale-105 transition-all duration-300" set:html={service.icon} />
                    <div>
                      <h3 class="text-2xl font-bold text-fort-white">{service.title}</h3>
                      <p class="text-fort-blue text-sm font-medium">{service.subtitle}</p>
                    </div>
                  </div>
                  <p class="text-fort-text leading-relaxed mb-6">{service.desc}</p>
                  {service.platform && (
                    <span class="inline-flex items-center gap-2 text-xs text-fort-text bg-fort-dark border border-fort-border/50 rounded-full px-4 py-1.5">
                      <span class="w-1.5 h-1.5 rounded-full bg-fort-blue animate-pulse-slow"></span>
                      {service.platform}
                    </span>
                  )}
                </div>
                <div>
                  <ul class="space-y-3">
                    {service.features.map((feature) => (
                      <li class="flex items-start gap-3 group/item">
                        <div class="w-5 h-5 rounded-md bg-fort-blue/10 flex items-center justify-center shrink-0 mt-0.5 group-hover/item:bg-fort-blue/20 transition-colors">
                          <svg class="w-3 h-3 text-fort-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                          </svg>
                        </div>
                        <span class="text-fort-light text-sm">{feature}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
