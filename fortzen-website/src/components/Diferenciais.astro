---
const items = [
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"/></svg>`,
    title: "IA com Machine Learning",
    desc: "Detecção inteligente que diferencia pessoas de animais, veículos e objetos. Sem alarmes desnecessários.",
    stat: "98%+",
    statLabel: "precisão",
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    title: "Monitoramento 24/7",
    desc: "Central de operações ativa o tempo todo. Câmeras, alarmes e portaria integrados em uma plataforma.",
    stat: "24h",
    statLabel: "por dia",
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
    title: "Proteção Ativa",
    desc: "A câmera não só grava. Ela detecta, alerta e aciona resposta em tempo real antes da ocorrência.",
    stat: "<60s",
    statLabel: "resposta",
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3"/></svg>`,
    title: "Controle Total no App",
    desc: "Liberação de acesso, câmeras ao vivo, histórico de eventos e controle do alarme pelo celular.",
    stat: "100%",
    statLabel: "remoto",
  },
];
---

<section id="diferenciais" class="py-24 relative">
  <div class="absolute inset-0 bg-gradient-to-b from-fort-darker via-fort-dark/50 to-fort-darker"></div>
  <div class="section-divider absolute top-0 left-0 right-0"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-10 sm:mb-16">
      <p class="text-blur-in text-fort-blue text-sm font-semibold tracking-wider uppercase mb-3">Diferenciais</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-fort-white mb-4">
        <span class="text-slide-up block overflow-hidden"><span class="inner">Por que a BATALION é diferente</span></span>
      </h2>
      <p class="text-blur-in text-fort-text max-w-2xl mx-auto" style="transition-delay: 200ms">
        Enquanto a concorrência depende de sensores de movimento que disparam com qualquer sombra, nós usamos inteligência artificial que <span class="text-fort-white font-medium">entende o que está acontecendo</span>.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5 stagger-children">
      {items.map((item) => (
        <div class="group relative bg-fort-gray/30 border border-fort-border/50 rounded-2xl p-6 hover:border-fort-blue/30 transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_8px_40px_rgba(42,111,242,0.1)]">
          <!-- Hover glow -->
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-b from-fort-blue/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

          <div class="relative z-10">
            <div class="w-12 h-12 rounded-xl bg-fort-blue/10 border border-fort-blue/20 flex items-center justify-center text-fort-blue mb-4 group-hover:bg-fort-blue/20 group-hover:scale-110 transition-all duration-300" set:html={item.icon} />
            <h3 class="text-lg font-bold text-fort-white mb-2">{item.title}</h3>
            <p class="text-sm text-fort-text leading-relaxed mb-4">{item.desc}</p>
            <div class="flex items-baseline gap-1.5 pt-3 border-t border-fort-border/30">
              <span class="text-xl font-extrabold text-fort-blue">{item.stat}</span>
              <span class="text-xs text-fort-text">{item.statLabel}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
