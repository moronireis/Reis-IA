---
---

<section id="contato" class="py-24 relative">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom,rgba(42,111,242,0.08),transparent_60%)]"></div>
  <div class="section-divider absolute top-0 left-0 right-0"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-16">
      <p class="text-blur-in text-fort-blue text-sm font-semibold tracking-wider uppercase mb-3">Contato</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-fort-white mb-4">
        <span class="text-slide-up block overflow-hidden"><span class="inner">Solicite seu orçamento</span></span>
      </h2>
      <p class="text-blur-in text-fort-text max-w-2xl mx-auto" style="transition-delay: 200ms">
        Preencha o formulário ou fale direto com nossa equipe. Respondemos em até <span class="text-fort-white font-semibold">2 horas</span>.
      </p>
    </div>

    <div class="grid lg:grid-cols-5 gap-10 lg:gap-12">
      <!-- Left: Contact info -->
      <div class="lg:col-span-2 reveal-left">
        <div class="space-y-5 mb-10">
          <!-- WhatsApp -->
          <a
            href="https://wa.me/5511999999999?text=Ol%C3%A1%2C%20gostaria%20de%20um%20or%C3%A7amento%20BATALION"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 group p-4 rounded-xl border border-fort-border/30 hover:border-fort-green/30 hover:bg-fort-green/5 transition-all duration-300"
          >
            <div class="w-12 h-12 rounded-xl bg-fort-green/10 border border-fort-green/20 flex items-center justify-center group-hover:bg-fort-green/20 group-hover:scale-105 transition-all duration-300">
              <svg class="w-6 h-6 text-fort-green" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div>
              <p class="text-fort-white font-semibold group-hover:text-fort-green transition-colors">WhatsApp</p>
              <p class="text-fort-text text-sm">Resposta imediata</p>
            </div>
            <svg class="w-4 h-4 text-fort-text/30 ml-auto group-hover:text-fort-green group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>

          <!-- Phone -->
          <div class="flex items-center gap-4 p-4 rounded-xl border border-fort-border/30">
            <div class="w-12 h-12 rounded-xl bg-fort-blue/10 border border-fort-blue/20 flex items-center justify-center">
              <svg class="w-6 h-6 text-fort-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
              </svg>
            </div>
            <div>
              <p class="text-fort-white font-semibold">Telefone</p>
              <p class="text-fort-text text-sm">(11) 9 9888-0000</p>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-center gap-4 p-4 rounded-xl border border-fort-border/30">
            <div class="w-12 h-12 rounded-xl bg-fort-blue/10 border border-fort-blue/20 flex items-center justify-center">
              <svg class="w-6 h-6 text-fort-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
              </svg>
            </div>
            <div>
              <p class="text-fort-white font-semibold">E-mail</p>
              <p class="text-fort-text text-sm">contato@bataliondefense.com.br</p>
            </div>
          </div>
        </div>

        <!-- Trust badges -->
        <div class="grid grid-cols-2 gap-3">
          {[
            { num: "98%+", label: "Precisão IA" },
            { num: "24/7", label: "Monitoramento" },
            { num: "100x", label: "Menos falsos" },
            { num: "2h", label: "Tempo resposta" },
          ].map((badge) => (
            <div class="bg-fort-gray/20 border border-fort-border/30 rounded-xl p-3 text-center">
              <p class="text-lg font-extrabold text-fort-blue">{badge.num}</p>
              <p class="text-[10px] text-fort-text">{badge.label}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Form -->
      <div class="lg:col-span-3 reveal-right">
        <form class="bg-fort-gray/20 border border-fort-border/40 rounded-2xl p-5 sm:p-8 space-y-5 hover:border-fort-blue/10 transition-colors duration-500">
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block text-sm text-fort-light font-medium mb-2">Nome</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full bg-fort-dark/80 border border-fort-border/50 rounded-xl px-4 py-3.5 text-fort-white text-sm placeholder:text-fort-text/40 focus:outline-none focus:border-fort-blue focus:ring-1 focus:ring-fort-blue/20 transition-all duration-300"
                placeholder="Seu nome"
              />
            </div>
            <div>
              <label for="phone" class="block text-sm text-fort-light font-medium mb-2">Telefone</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                class="w-full bg-fort-dark/80 border border-fort-border/50 rounded-xl px-4 py-3.5 text-fort-white text-sm placeholder:text-fort-text/40 focus:outline-none focus:border-fort-blue focus:ring-1 focus:ring-fort-blue/20 transition-all duration-300"
                placeholder="(11) 9 0000-0000"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block text-sm text-fort-light font-medium mb-2">E-mail</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full bg-fort-dark/80 border border-fort-border/50 rounded-xl px-4 py-3.5 text-fort-white text-sm placeholder:text-fort-text/40 focus:outline-none focus:border-fort-blue focus:ring-1 focus:ring-fort-blue/20 transition-all duration-300"
              placeholder="seu@email.com"
            />
          </div>

          <div>
            <label for="service" class="block text-sm text-fort-light font-medium mb-2">Serviço de interesse</label>
            <select
              id="service"
              name="service"
              required
              class="w-full bg-fort-dark/80 border border-fort-border/50 rounded-xl px-4 py-3.5 text-fort-white text-sm focus:outline-none focus:border-fort-blue focus:ring-1 focus:ring-fort-blue/20 transition-all duration-300"
            >
              <option value="" disabled selected>Selecione uma opção</option>
              <option value="monitoramento">Monitoramento e CFTV</option>
              <option value="alarme">Sistema de Alarme</option>
              <option value="portaria">Portaria Remota</option>
              <option value="completo">Solução Completa</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm text-fort-light font-medium mb-2">Mensagem <span class="text-fort-text/40 font-normal">(opcional)</span></label>
            <textarea
              id="message"
              name="message"
              rows="4"
              class="w-full bg-fort-dark/80 border border-fort-border/50 rounded-xl px-4 py-3.5 text-fort-white text-sm placeholder:text-fort-text/40 focus:outline-none focus:border-fort-blue focus:ring-1 focus:ring-fort-blue/20 transition-all duration-300 resize-none"
              placeholder="Descreva seu imóvel, quantidade de câmeras desejada, etc."
            ></textarea>
          </div>

          <button
            id="form-submit-btn"
            type="submit"
            class="group w-full bg-fort-blue hover:bg-fort-blue-dark text-white font-bold py-4 rounded-xl transition-all duration-300 hover:shadow-[0_0_40px_rgba(42,111,242,0.3)] active:scale-[0.99] flex items-center justify-center gap-2"
          >
            <span id="btn-label">Solicitar Orçamento Gratuito</span>
            <svg id="btn-arrow" class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
            <svg id="btn-spinner" class="w-4 h-4 hidden animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 12a8 8 0 018-8v4l3-3-3-3v4a8 8 0 100 16 8 8 0 01-8-8z"/>
            </svg>
          </button>

          <p class="text-xs text-fort-text/50 text-center">
            Sem compromisso. Respondemos em até 2 horas em horário comercial.
          </p>
        </form>

        <!-- Success state (hidden initially) -->
        <div id="form-success" class="hidden bg-fort-gray/20 border border-fort-green/30 rounded-2xl p-12 text-center">
          <div class="w-16 h-16 rounded-full bg-fort-green/10 border border-fort-green/30 flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-fort-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-fort-white mb-3">Mensagem enviada!</h3>
          <p class="text-fort-text text-sm leading-relaxed max-w-sm mx-auto">
            Entraremos em contato em até <span class="text-fort-white font-semibold">2 horas</span>. Verifique também seu WhatsApp.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>("#contato form");
  const successEl = document.getElementById("form-success");
  const btn = document.getElementById("form-submit-btn") as HTMLButtonElement | null;
  const btnLabel = document.getElementById("btn-label");
  const btnArrow = document.getElementById("btn-arrow");
  const btnSpinner = document.getElementById("btn-spinner");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    // Loading state
    if (btn) btn.disabled = true;
    if (btnLabel) btnLabel.textContent = "Enviando...";
    if (btnArrow) btnArrow.classList.add("hidden");
    if (btnSpinner) btnSpinner.classList.remove("hidden");

    // Gather form data
    const name = (form.querySelector<HTMLInputElement>("#name"))?.value || "";
    const phone = (form.querySelector<HTMLInputElement>("#phone"))?.value || "";
    const email = (form.querySelector<HTMLInputElement>("#email"))?.value || "";
    const service = (form.querySelector<HTMLSelectElement>("#service"))?.value || "";
    const message = (form.querySelector<HTMLTextAreaElement>("#message"))?.value || "";

    // Send email via API
    try {
      await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name, phone, email, service, message }),
      });
    } catch {
      // Email send failed silently — WhatsApp still works as fallback
    }

    // WhatsApp redirect
    const waText = encodeURIComponent(
      `Olá, gostaria de um orçamento BATALION.\nNome: ${name}\nTelefone: ${phone}\nServiço: ${service}${message ? `\nMensagem: ${message}` : ""}`
    );
    const waLink = `https://wa.me/5511999999999?text=${waText}`;

    // Show success + open WhatsApp
    if (form) form.classList.add("hidden");
    if (successEl) successEl.classList.remove("hidden");
    window.open(waLink, "_blank", "noopener,noreferrer");
  });
</script>
