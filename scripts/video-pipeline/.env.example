# Copy this file to .env and fill in your API keys.
# Never commit the .env file — it's gitignored.

# Pexels API — https://www.pexels.com/api/ (free tier: 200 req/hour)
PEXELS_API_KEY=

# Pixabay API — https://pixabay.com/api/docs/ (free tier: ~5000 req/hour)
PIXABAY_API_KEY=

# Optional: whisper model size (tiny, base, small, medium, large-v3)
WHISPER_MODEL=medium

# Optional: device for faster-whisper (cpu, cuda, auto)
WHISPER_DEVICE=auto
