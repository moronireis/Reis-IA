---
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pesquisa — Próximos Passos com IA | Reis IA</title>
  <meta name="description" content="Responda em 3 minutos e descubra seu próximo passo para lucrar com IA." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #000;
      --surface-1: #0A0A0A;
      --surface-2: #111;
      --surface-3: #1A1A1A;
      --border: rgba(255,255,255,0.08);
      --border-focus: #4A90FF;
      --text-primary: #fff;
      --text-secondary: rgba(255,255,255,0.6);
      --text-muted: rgba(255,255,255,0.35);
      --blue: #4A90FF;
      --blue-soft: rgba(74,144,255,0.1);
      --blue-hover: rgba(74,144,255,0.15);
      --green: #22C55E;
      --green-soft: rgba(34,197,94,0.1);
      --red: #EF4444;
      --radius: 12px;
      --radius-sm: 8px;
    }

    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text-primary);
      line-height: 1.6;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }

    .container {
      max-width: 640px;
      margin: 0 auto;
      padding: 40px 20px 80px;
    }

    .header {
      text-align: center;
      margin-bottom: 48px;
    }

    .brand {
      font-size: 14px;
      font-weight: 300;
      letter-spacing: 2px;
      color: var(--text-muted);
      margin-bottom: 32px;
    }

    .brand span { color: var(--blue); }

    .header h1 {
      font-size: 28px;
      font-weight: 600;
      line-height: 1.3;
      margin-bottom: 16px;
    }

    .header p {
      color: var(--text-secondary);
      font-size: 15px;
      max-width: 480px;
      margin: 0 auto;
    }

    .time-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: 100px;
      padding: 6px 14px;
      font-size: 13px;
      color: var(--text-secondary);
      margin-top: 20px;
    }

    .time-badge svg {
      width: 14px;
      height: 14px;
      stroke: var(--text-muted);
    }

    .form-section {
      margin-bottom: 40px;
    }

    .section-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--blue);
      margin-bottom: 20px;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--border);
    }

    .field {
      margin-bottom: 24px;
    }

    .field label {
      display: block;
      font-size: 14px;
      font-weight: 500;
      margin-bottom: 8px;
      color: var(--text-primary);
    }

    .field label .required {
      color: var(--blue);
      margin-left: 2px;
    }

    .field .hint {
      font-size: 13px;
      color: var(--text-muted);
      margin-bottom: 8px;
    }

    input[type="text"],
    input[type="email"],
    input[type="tel"],
    textarea,
    select {
      width: 100%;
      padding: 12px 16px;
      background: var(--surface-1);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      color: var(--text-primary);
      font-family: inherit;
      font-size: 15px;
      transition: border-color 0.2s, box-shadow 0.2s;
      outline: none;
    }

    input:focus, textarea:focus, select:focus {
      border-color: var(--border-focus);
      box-shadow: 0 0 0 3px var(--blue-soft);
    }

    input::placeholder, textarea::placeholder {
      color: var(--text-muted);
    }

    textarea { resize: vertical; min-height: 100px; }

    .option-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .option-group.grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }

    .option-item {
      position: relative;
    }

    .option-item input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    .option-item label {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 16px;
      background: var(--surface-1);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      cursor: pointer;
      font-size: 14px;
      font-weight: 400;
      transition: all 0.2s;
    }

    .option-item label:hover {
      background: var(--blue-soft);
      border-color: rgba(74,144,255,0.2);
    }

    .option-item input:checked + label {
      background: var(--blue-soft);
      border-color: var(--blue);
      color: var(--text-primary);
    }

    .radio-mark {
      width: 18px;
      height: 18px;
      border: 1.5px solid var(--border);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: all 0.2s;
    }

    .check-mark {
      width: 18px;
      height: 18px;
      border: 1.5px solid var(--border);
      border-radius: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: all 0.2s;
    }

    .option-item input:checked + label .radio-mark,
    .option-item input:checked + label .check-mark {
      border-color: var(--blue);
      background: var(--blue);
    }

    .option-item input:checked + label .radio-mark::after {
      content: '';
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #fff;
    }

    .option-item input:checked + label .check-mark::after {
      content: '';
      width: 10px;
      height: 6px;
      border-left: 2px solid #fff;
      border-bottom: 2px solid #fff;
      transform: rotate(-45deg) translateY(-1px);
    }

    .submit-btn {
      width: 100%;
      padding: 16px;
      background: var(--blue);
      color: #fff;
      border: none;
      border-radius: var(--radius);
      font-family: inherit;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.1s;
    }

    .submit-btn:hover { opacity: 0.9; }
    .submit-btn:active { transform: scale(0.99); }
    .submit-btn:disabled { opacity: 0.5; cursor: not-allowed; }

    .loading-spinner {
      display: inline-block;
      width: 18px;
      height: 18px;
      border: 2px solid rgba(255,255,255,0.3);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
      vertical-align: middle;
      margin-right: 8px;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    /* Result screens */
    .result-screen {
      display: none;
      text-align: center;
      padding: 60px 20px;
    }

    .result-screen.active { display: block; }

    .result-icon {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 24px;
    }

    .result-icon.green { background: var(--green-soft); }
    .result-icon.blue { background: var(--blue-soft); }

    .result-icon svg {
      width: 32px;
      height: 32px;
    }

    .result-screen h2 {
      font-size: 24px;
      font-weight: 600;
      margin-bottom: 12px;
    }

    .result-screen p {
      color: var(--text-secondary);
      font-size: 15px;
      max-width: 480px;
      margin: 0 auto;
      line-height: 1.7;
    }

    .result-screen p + p {
      margin-top: 16px;
    }

    .result-cta {
      display: inline-block;
      margin-top: 32px;
      padding: 16px 32px;
      border-radius: var(--radius);
      font-family: inherit;
      font-size: 16px;
      font-weight: 600;
      text-decoration: none;
      transition: opacity 0.2s, transform 0.1s;
    }

    .result-cta:hover { opacity: 0.9; }
    .result-cta:active { transform: scale(0.99); }

    .result-cta.green {
      background: var(--green);
      color: #fff;
    }

    .result-cta.blue {
      background: var(--blue);
      color: #fff;
    }

    .result-detail {
      margin-top: 24px;
      padding: 16px 20px;
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      text-align: left;
      max-width: 420px;
      margin-left: auto;
      margin-right: auto;
    }

    .result-detail p {
      font-size: 14px;
      text-align: left;
      margin: 0;
    }

    .error-msg {
      background: rgba(239,68,68,0.1);
      border: 1px solid rgba(239,68,68,0.2);
      color: var(--red);
      padding: 12px 16px;
      border-radius: var(--radius-sm);
      font-size: 14px;
      margin-bottom: 16px;
      display: none;
    }

    .error-msg.active { display: block; }

    .form-container.hidden { display: none; }

    .footer {
      text-align: center;
      padding: 40px 0 20px;
      color: var(--text-muted);
      font-size: 12px;
    }

    @media (max-width: 480px) {
      .container { padding: 24px 16px 60px; }
      .header h1 { font-size: 22px; }
      .option-group.grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div class="brand">REIS <span>[IA]</span></div>
      <h1>Quero te ouvir antes<br/>de dar o próximo passo.</h1>
      <p>Você fez o MDV. Agora estou estruturando algo mais profundo para quem quer realmente implementar IA e gerar resultado. Mas antes de te apresentar, preciso entender onde você está.</p>
      <div class="time-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 6v6l4 2"/>
        </svg>
        3 minutos
      </div>
    </div>

    <div id="error-msg" class="error-msg"></div>

    <form id="survey-form" class="form-container">

      <!-- SECTION 1: DADOS -->
      <div class="form-section">
        <div class="section-label">Seus Dados</div>

        <div class="field">
          <label>Nome completo <span class="required">*</span></label>
          <input type="text" name="nome" required placeholder="Seu nome" />
        </div>

        <div class="field">
          <label>Email <span class="required">*</span></label>
          <input type="email" name="email" required placeholder="seu@email.com" />
        </div>

        <div class="field">
          <label>WhatsApp <span class="required">*</span></label>
          <input type="tel" name="whatsapp" required placeholder="(11) 99999-9999" />
        </div>
      </div>

      <!-- SECTION 2: SEU NEGÓCIO -->
      <div class="form-section">
        <div class="section-label">Seu Negócio</div>

        <div class="field">
          <label>O que você faz hoje? <span class="required">*</span></label>
          <div class="hint">Negócio, cargo, área de atuação</div>
          <input type="text" name="negocio" required placeholder="Ex: Dono de agência, freelancer, consultor, CLT..." />
        </div>

        <div class="field">
          <label>Faturamento mensal do seu negócio <span class="required">*</span></label>
          <div class="option-group">
            <div class="option-item">
              <input type="radio" name="faturamento" id="fat_1" value="Ainda não faturo" data-score="0" required />
              <label for="fat_1"><span class="radio-mark"></span>Ainda não faturo / estou começando</label>
            </div>
            <div class="option-item">
              <input type="radio" name="faturamento" id="fat_2" value="Até R$5.000" data-score="1" />
              <label for="fat_2"><span class="radio-mark"></span>Até R$5.000/mês</label>
            </div>
            <div class="option-item">
              <input type="radio" name="faturamento" id="fat_3" value="R$5.000 a R$15.000" data-score="2" />
              <label for="fat_3"><span class="radio-mark"></span>R$5.000 a R$15.000/mês</label>
            </div>
            <div class="option-item">
              <input type="radio" name="faturamento" id="fat_4" value="R$15.000 a R$50.000" data-score="3" />
              <label for="fat_4"><span class="radio-mark"></span>R$15.000 a R$50.000/mês</label>
            </div>
            <div class="option-item">
              <input type="radio" name="faturamento" id="fat_5" value="Acima de R$50.000" data-score="4" />
              <label for="fat_5"><span class="radio-mark"></span>Acima de R$50.000/mês</label>
            </div>
          </div>
        </div>

        <div class="field">
          <label>Tem equipe no negócio?</label>
          <div class="option-group">
            <div class="option-item">
              <input type="radio" name="equipe" id="eq_1" value="Trabalho sozinho" data-score="0" />
              <label for="eq_1"><span class="radio-mark"></span>Trabalho sozinho</label>
            </div>
            <div class="option-item">
              <input type="radio" name="equipe" id="eq_2" value="1-3 pessoas" data-score="1" />
              <label for="eq_2"><span class="radio-mark"></span>1 a 3 pessoas</label>
            </div>
            <div class="option-item">
              <input type="radio" name="equipe" id="eq_3" value="4+ pessoas" data-score="2" />
              <label for="eq_3"><span class="radio-mark"></span>4 ou mais pessoas</label>
            </div>
          </div>
        </div>
      </div>

      <!-- SECTION 3: SUA RELAÇÃO COM IA -->
      <div class="form-section">
        <div class="section-label">Sua relação com IA</div>

        <div class="field">
          <label>Você já usa IA no seu negócio? <span class="required">*</span></label>
          <div class="option-group">
            <div class="option-item">
              <input type="radio" name="usa_ia" id="ia_1" value="Nunca usei" data-score="0" required />
              <label for="ia_1"><span class="radio-mark"></span>Nunca usei profissionalmente</label>
            </div>
            <div class="option-item">
              <input type="radio" name="usa_ia" id="ia_2" value="Uso ChatGPT no dia a dia" data-score="1" />
              <label for="ia_2"><span class="radio-mark"></span>Uso ChatGPT / Copilot no dia a dia</label>
            </div>
            <div class="option-item">
              <input type="radio" name="usa_ia" id="ia_3" value="Já tentei automações" data-score="2" />
              <label for="ia_3"><span class="radio-mark"></span>Já tentei automações / integrações com IA</label>
            </div>
            <div class="option-item">
              <input type="radio" name="usa_ia" id="ia_4" value="IA gera resultado no negócio" data-score="3" />
              <label for="ia_4"><span class="radio-mark"></span>IA já gera resultado real no meu negócio</label>
            </div>
          </div>
        </div>

        <div class="field">
          <label>O que já tentou fazer com IA? Como foi?</label>
          <div class="hint">Se nunca tentou, escreve "nada ainda". Se tentou, conta o que deu certo e o que não deu.</div>
          <textarea name="experiencia_ia" rows="3" placeholder="Ex: Tentei usar automação no WhatsApp mas não consegui escalar, usei ChatGPT pra gerar conteúdo..."></textarea>
        </div>
      </div>

      <!-- SECTION 4: OBJETIVOS E COMPROMISSO -->
      <div class="form-section">
        <div class="section-label">Seus Objetivos</div>

        <div class="field">
          <label>O que você quer conquistar com IA nos próximos 90 dias? <span class="required">*</span></label>
          <div class="hint">Seja específico. Quanto mais real, melhor consigo te ajudar.</div>
          <textarea name="objetivo_90dias" required rows="3" placeholder="Ex: Montar um serviço de automação com IA e fechar 3 clientes, usar IA pra dobrar minhas vendas..."></textarea>
        </div>

        <div class="field">
          <label>Quanto tempo por semana você consegue dedicar? <span class="required">*</span></label>
          <div class="option-group">
            <div class="option-item">
              <input type="radio" name="tempo_semanal" id="tp_1" value="Menos de 2h" data-score="0" required />
              <label for="tp_1"><span class="radio-mark"></span>Menos de 2 horas/semana</label>
            </div>
            <div class="option-item">
              <input type="radio" name="tempo_semanal" id="tp_2" value="2-5h" data-score="1" />
              <label for="tp_2"><span class="radio-mark"></span>2 a 5 horas/semana</label>
            </div>
            <div class="option-item">
              <input type="radio" name="tempo_semanal" id="tp_3" value="5-10h" data-score="2" />
              <label for="tp_3"><span class="radio-mark"></span>5 a 10 horas/semana</label>
            </div>
            <div class="option-item">
              <input type="radio" name="tempo_semanal" id="tp_4" value="10h+" data-score="3" />
              <label for="tp_4"><span class="radio-mark"></span>Mais de 10 horas/semana</label>
            </div>
          </div>
        </div>

        <div class="field">
          <label>Você investiria em acompanhamento individual pra acelerar seu resultado? <span class="required">*</span></label>
          <div class="hint">Sem compromisso. Só quero entender seu momento.</div>
          <div class="option-group">
            <div class="option-item">
              <input type="radio" name="investimento" id="inv_1" value="Não, só quero conteúdo" data-score="0" required />
              <label for="inv_1"><span class="radio-mark"></span>Agora não, só quero conteúdo gratuito</label>
            </div>
            <div class="option-item">
              <input type="radio" name="investimento" id="inv_2" value="Talvez, depende do valor" data-score="1" />
              <label for="inv_2"><span class="radio-mark"></span>Talvez, depende do formato e valor</label>
            </div>
            <div class="option-item">
              <input type="radio" name="investimento" id="inv_3" value="Sim, se fizer sentido" data-score="2" />
              <label for="inv_3"><span class="radio-mark"></span>Sim, se fizer sentido pro meu momento</label>
            </div>
            <div class="option-item">
              <input type="radio" name="investimento" id="inv_4" value="Sim, quero acelerar" data-score="3" />
              <label for="inv_4"><span class="radio-mark"></span>Com certeza. Quero acelerar e estou pronto pra investir</label>
            </div>
          </div>
        </div>
      </div>

      <!-- SECTION 5: FEEDBACK MDV -->
      <div class="form-section">
        <div class="section-label">Sobre o MDV</div>

        <div class="field">
          <label>O que achou do MDV até agora?</label>
          <div class="hint">O que funcionou, o que faltou, o que mudaria. Isso me ajuda a melhorar tudo.</div>
          <textarea name="feedback_mdv" rows="3" placeholder="Fala sem filtro..."></textarea>
        </div>

        <div class="field">
          <label>Mais alguma coisa que eu precise saber?</label>
          <textarea name="observacoes" rows="2" placeholder="Espaço livre..."></textarea>
        </div>
      </div>

      <button type="submit" class="submit-btn" id="submit-btn">
        Enviar Respostas
      </button>
    </form>

    <!-- RESULT: QUALIFIED (HOT LEAD) -->
    <div id="result-hot" class="result-screen">
      <div class="result-icon green">
        <svg viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 6L9 17l-5-5"/>
        </svg>
      </div>
      <h2>Recebido. E tenho algo pra você.</h2>
      <p>Pelo que você me contou, você está num momento que faz sentido a gente conversar. Estou montando um programa de implementação de IA com acompanhamento individual — o Journey.</p>
      <p>São vagas limitadas e quero entender pessoalmente se faz sentido pro seu caso. Agenda uma conversa comigo.</p>
      <a href="https://cal.com/moronireis/journey" class="result-cta green" target="_blank">Agendar conversa com Moroni</a>
      <div class="result-detail">
        <p style="color: var(--text-muted); font-size: 13px;">Conversa de 20 min, sem compromisso. Se não fizer sentido, eu mesmo vou te falar.</p>
      </div>
    </div>

    <!-- RESULT: NOT YET QUALIFIED (WARM LEAD) -->
    <div id="result-warm" class="result-screen">
      <div class="result-icon blue">
        <svg viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 6L9 17l-5-5"/>
        </svg>
      </div>
      <h2>Recebido. Obrigado pela sinceridade.</h2>
      <p>Vou ler pessoalmente sua resposta. Enquanto isso, preparei uma aula que vai te ajudar a dar o próximo passo com IA no seu negócio — independente do seu momento.</p>
      <p>Assiste e depois me conta o que achou.</p>
      <a href="https://aula.moronireis.com.br" class="result-cta blue" target="_blank">Assistir a aula</a>
      <div class="result-detail">
        <p style="color: var(--text-muted); font-size: 13px;">Aula gratuita sobre como estruturar IA como estratégia de receita — não como ferramenta.</p>
      </div>
    </div>

    <div class="footer">
      REIS <span style="color: var(--blue)">[IA]</span>
    </div>
  </div>

  <script>
    const form = document.getElementById('survey-form');
    const submitBtn = document.getElementById('submit-btn');
    const errorMsg = document.getElementById('error-msg');
    const resultHot = document.getElementById('result-hot');
    const resultWarm = document.getElementById('result-warm');

    function calculateScore() {
      let score = 0;
      const scored = form.querySelectorAll('input[data-score]:checked');
      scored.forEach(input => {
        score += parseInt(input.dataset.score, 10) || 0;
      });
      return score;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorMsg.classList.remove('active');
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span class="loading-spinner"></span>Enviando...';

      const formData = new FormData(form);
      const score = calculateScore();

      // Max possible: faturamento(4) + equipe(2) + usa_ia(3) + tempo(3) + investimento(3) = 15
      // Hot threshold: 8+ points
      const isQualified = score >= 8;

      const data = {
        nome: formData.get('nome'),
        email: formData.get('email'),
        whatsapp: formData.get('whatsapp'),
        negocio: formData.get('negocio'),
        faturamento: formData.get('faturamento'),
        equipe: formData.get('equipe'),
        usa_ia: formData.get('usa_ia'),
        experiencia_ia: formData.get('experiencia_ia'),
        objetivo_90dias: formData.get('objetivo_90dias'),
        tempo_semanal: formData.get('tempo_semanal'),
        investimento: formData.get('investimento'),
        feedback_mdv: formData.get('feedback_mdv'),
        observacoes: formData.get('observacoes'),
        score,
        qualified: isQualified,
      };

      try {
        const res = await fetch('/api/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (!res.ok) {
          const err = await res.json();
          throw new Error(err.error || 'Erro ao enviar');
        }

        form.classList.add('hidden');

        if (isQualified) {
          resultHot.classList.add('active');
        } else {
          resultWarm.classList.add('active');
        }

        window.scrollTo({ top: 0, behavior: 'smooth' });
      } catch (err) {
        errorMsg.textContent = err.message || 'Erro ao enviar. Tente novamente.';
        errorMsg.classList.add('active');
        submitBtn.disabled = false;
        submitBtn.innerHTML = 'Enviar Respostas';
      }
    });
  </script>
</body>
</html>
