---
import BrandbookLayout from '../../layouts/BrandbookLayout.astro';
import SectionLabel from '../../components/SectionLabel.astro';
---

<BrandbookLayout
  title="Moodboard"
  pageName="MOODBOARD"
  description="Visual mood, aesthetic direction, and design references for the Reis IA brand."
>
  <!-- Title Area -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-2xl);">
      <div class="max-w-[900px]">
        <h1
          class="font-bold tracking-tight mb-6"
          style="font-size: var(--text-display); line-height: 1.05; letter-spacing: -0.03em; color: var(--text-primary); text-wrap: balance;"
        >
          Moodboard
        </h1>
        <p
          class="max-w-[680px]"
          style="font-size: var(--text-body-lg); line-height: 1.6; color: var(--text-secondary); text-wrap: pretty;"
        >
          The visual direction for Reis IA — a dark, minimal, premium aesthetic inspired by
          Apple, Porsche, Linear, and Stripe. No HUD elements. No cyberpunk. Pure architectural precision.
        </p>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 01: Aesthetic Pillars -->
  <section style="background: var(--surface-1);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="01" title="Aesthetic Pillars" />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Pillar 1 -->
        <div
          class="p-8 rounded-xl border group transition-all duration-300 hover:border-[var(--border-visible)]"
          style="background: var(--surface-2); border-color: var(--border-default);"
        >
          <div
            class="w-full h-32 rounded-lg mb-6 flex items-center justify-center"
            style="background: var(--surface-0);"
          >
            <!-- Visual: dark space with a single blue line -->
            <div class="w-full h-px" style="background: var(--gradient-blue-sweep);"></div>
          </div>
          <h3 class="text-base font-semibold mb-2" style="color: var(--text-primary);">Dark Canvas Mastery</h3>
          <p class="text-sm" style="color: var(--text-tertiary); line-height: 1.6;">
            Pure black as the foundation. Depth through surface layering, not shadows. The dark canvas creates tension and focus that commands attention.
          </p>
        </div>

        <!-- Pillar 2 -->
        <div
          class="p-8 rounded-xl border group transition-all duration-300 hover:border-[var(--border-visible)]"
          style="background: var(--surface-2); border-color: var(--border-default);"
        >
          <div
            class="w-full h-32 rounded-lg mb-6 flex items-center justify-center overflow-hidden"
            style="background: var(--surface-0);"
          >
            <!-- Visual: typography specimen -->
            <span
              class="text-4xl font-bold tracking-tight"
              style="color: var(--text-primary); letter-spacing: -0.03em;"
            >
              Aa
            </span>
          </div>
          <h3 class="text-base font-semibold mb-2" style="color: var(--text-primary);">Typographic Authority</h3>
          <p class="text-sm" style="color: var(--text-tertiary); line-height: 1.6;">
            Inter Variable at large sizes with tight tracking. The type system does the hierarchy work — confident headlines against generous body text.
          </p>
        </div>

        <!-- Pillar 3 -->
        <div
          class="p-8 rounded-xl border group transition-all duration-300 hover:border-[var(--border-visible)]"
          style="background: var(--surface-2); border-color: var(--border-default);"
        >
          <div
            class="w-full h-32 rounded-lg mb-6 flex items-center justify-center relative overflow-hidden"
            style="background: var(--surface-0);"
          >
            <!-- Visual: blue accent dot -->
            <div
              class="w-3 h-3 rounded-full"
              style="background: var(--accent-blue); box-shadow: 0 0 30px var(--blue-30);"
            ></div>
          </div>
          <h3 class="text-base font-semibold mb-2" style="color: var(--text-primary);">Singular Accent</h3>
          <p class="text-sm" style="color: var(--text-tertiary); line-height: 1.6;">
            One accent color — #4A90FF blue. It is reserved for conversion moments and emphasis. If it is blue, it should be actionable.
          </p>
        </div>

        <!-- Pillar 4 -->
        <div
          class="p-8 rounded-xl border group transition-all duration-300 hover:border-[var(--border-visible)]"
          style="background: var(--surface-2); border-color: var(--border-default);"
        >
          <div
            class="w-full h-32 rounded-lg mb-6 flex items-center justify-center"
            style="background: var(--surface-0);"
          >
            <!-- Visual: geometric lines -->
            <svg viewBox="0 0 200 100" class="w-full h-full p-6" style="color: var(--border-visible);" aria-hidden="true">
              <line x1="0" y1="50" x2="200" y2="50" stroke="currentColor" stroke-width="0.5" />
              <line x1="100" y1="0" x2="100" y2="100" stroke="currentColor" stroke-width="0.5" />
              <line x1="50" y1="0" x2="50" y2="100" stroke="currentColor" stroke-width="0.5" opacity="0.5" />
              <line x1="150" y1="0" x2="150" y2="100" stroke="currentColor" stroke-width="0.5" opacity="0.5" />
            </svg>
          </div>
          <h3 class="text-base font-semibold mb-2" style="color: var(--text-primary);">Geometric Precision</h3>
          <p class="text-sm" style="color: var(--text-tertiary); line-height: 1.6;">
            Grid-based layout. Mathematical spacing. Every value is intentional — engineered like the AI systems we build.
          </p>
        </div>

        <!-- Pillar 5 -->
        <div
          class="p-8 rounded-xl border group transition-all duration-300 hover:border-[var(--border-visible)]"
          style="background: var(--surface-2); border-color: var(--border-default);"
        >
          <div
            class="w-full h-32 rounded-lg mb-6 relative overflow-hidden"
            style="background: var(--surface-0);"
          >
            <!-- Visual: surface layers -->
            <div class="absolute bottom-0 left-0 right-0 h-1/3" style="background: var(--surface-1);"></div>
            <div class="absolute bottom-0 left-4 right-4 h-1/4 rounded-t-lg" style="background: var(--surface-2);"></div>
            <div class="absolute bottom-0 left-8 right-8 h-1/5 rounded-t-lg" style="background: var(--surface-3);"></div>
          </div>
          <h3 class="text-base font-semibold mb-2" style="color: var(--text-primary);">Layered Depth</h3>
          <p class="text-sm" style="color: var(--text-tertiary); line-height: 1.6;">
            Five surface tiers create physical depth perception without shadows. Elevation comes from background lightness, not shadow darkness.
          </p>
        </div>

        <!-- Pillar 6 -->
        <div
          class="p-8 rounded-xl border group transition-all duration-300 hover:border-[var(--border-visible)]"
          style="background: var(--surface-2); border-color: var(--border-default);"
        >
          <div
            class="w-full h-32 rounded-lg mb-6 flex items-center justify-center"
            style="background: var(--surface-0);"
          >
            <!-- Visual: generous whitespace -->
            <div class="w-12 h-1 rounded-full" style="background: var(--text-quaternary);"></div>
          </div>
          <h3 class="text-base font-semibold mb-2" style="color: var(--text-primary);">Premium Breathing Room</h3>
          <p class="text-sm" style="color: var(--text-tertiary); line-height: 1.6;">
            Apple-level section padding (64-160px). Generous spacing signals premium positioning. Every element earns its space.
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 02: Design References -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="02" title="Design References" />

      <p class="text-sm mb-8 max-w-[680px]" style="color: var(--text-tertiary); text-wrap: pretty;">
        The Reis IA design system is a unique synthesis of techniques from 8 premium brands. Each reference contributes specific patterns — none are copied wholesale.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { name: 'Apple', contribution: 'Generous section padding (100-200px), 60%+ viewport breathing room, display headline sizes.' },
          { name: 'Porsche', contribution: 'Fluid clamp() typography, custom easing curves, 3-weight/1-shadow discipline.' },
          { name: 'Linear', contribution: 'Opacity-based text hierarchy, text-wrap: balance/pretty, 800ms entrance animations.' },
          { name: 'Stripe', contribution: 'Optical vertical padding on buttons, card-specific easing, letter-spacing-tightens-as-size-increases.' },
          { name: 'Vercel', contribution: 'Pure black canvas, 3-tier elevation model, ease-out (0.16, 1, 0.3, 1) for reveals.' },
          { name: 'AIOX', contribution: 'Hairline grid technique, section numbered labels, page header bar pattern, mega-menu navigation.' },
          { name: 'Morningside AI', contribution: 'Blue glow shadow (0 0 50px), background-clip gradient border technique.' },
          { name: 'Agencia Lendaria', contribution: 'Ambient light pools at section corners, alternating corner positions for depth.' },
        ].map(ref => (
          <div
            class="p-5 rounded-xl border transition-colors duration-200 hover:border-[var(--border-visible)]"
            style="background: var(--surface-2); border-color: var(--border-default);"
          >
            <h4 class="text-sm font-semibold mb-2" style="color: var(--text-primary);">{ref.name}</h4>
            <p class="text-xs" style="color: var(--text-tertiary); line-height: 1.6;">{ref.contribution}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 03: What We Are Not -->
  <section style="background: var(--surface-1);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="03" title="What We Are Not" />

      <div class="max-w-[680px] space-y-6">
        <p style="font-size: var(--text-body-lg); color: var(--text-secondary); line-height: 1.6; text-wrap: pretty;">
          Knowing what Reis IA is <em>not</em> is as important as knowing what it is. The brand avoids these common traps in the AI/tech space:
        </p>

        <div class="space-y-3">
          {[
            'HUD/cyberpunk/cockpit visual language',
            'Neon green, lime, or bright accent colors',
            'Gradient text effects or rainbow accents',
            'SaaS pricing tables, tier comparison cards',
            'Bouncy, elastic, or spring animations',
            'Decorative illustrations or cartoon mascots',
            'Busy dashboards as hero visuals',
            'Multiple accent colors competing for attention',
            'Light mode or theme toggles',
            'Gold, amber, or warm accent tones',
          ].map(item => (
            <div class="flex items-center gap-3 py-2">
              <svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-error);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="18" y1="6" x2="6" y2="18" />
                <line x1="6" y1="6" x2="18" y2="18" />
              </svg>
              <span class="text-sm" style="color: var(--text-secondary);">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 04: Live Mood Demo -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="04" title="Mood in Practice" />

      <p class="text-sm mb-8 max-w-[680px]" style="color: var(--text-tertiary); text-wrap: pretty;">
        This page itself demonstrates the Reis IA mood: dark canvas, singular blue accent, generous spacing, Inter typography at multiple weights, and surface layering for depth. The design system documents itself.
      </p>

      <!-- Ambient mood demo -->
      <div
        class="relative rounded-2xl border overflow-hidden min-h-[400px] flex items-center justify-center"
        style="background: var(--surface-0); border-color: var(--border-default);"
      >
        <!-- Ambient blue glow -->
        <div
          class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] pointer-events-none"
          style="background: var(--gradient-blue-ambient); opacity: 0.8;"
          aria-hidden="true"
        ></div>

        <!-- Grain overlay -->
        <div class="grain absolute inset-0 pointer-events-none" aria-hidden="true"></div>

        <!-- Hourglass watermark -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 64 64"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="absolute w-48 h-48 opacity-[0.03]"
          style="color: var(--text-primary); top: 20%; right: 10%;"
          aria-hidden="true"
        >
          <line x1="16" y1="8" x2="48" y2="8"/><line x1="16" y1="8" x2="32" y2="32"/><line x1="48" y1="8" x2="32" y2="32"/><line x1="32" y1="32" x2="16" y2="56"/><line x1="32" y1="32" x2="48" y2="56"/><line x1="16" y1="56" x2="48" y2="56"/>
        </svg>

        <!-- Content -->
        <div class="relative text-center px-8 max-w-[600px]">
          <div class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] mb-4" style="color: var(--accent-blue);">
            The Reis IA Aesthetic
          </div>
          <h2
            class="font-bold tracking-tight mb-4"
            style="font-size: var(--text-h2); line-height: 1.1; letter-spacing: -0.02em; color: var(--text-primary); text-wrap: balance;"
          >
            Precision. Depth. Restraint.
          </h2>
          <p class="text-sm" style="color: var(--text-tertiary); line-height: 1.65;">
            A premium dark aesthetic where every element earns its space, blue signals action, and the surface system creates tangible depth.
          </p>
        </div>
      </div>
    </div>
  </section>
</BrandbookLayout>
