---
import BrandbookLayout from '../../layouts/BrandbookLayout.astro';
import SectionLabel from '../../components/SectionLabel.astro';

const componentPages = [
  {
    number: '01',
    title: 'Buttons',
    href: '/brandbook/buttons',
    desc: 'Primary, secondary, ghost, hero, and link variants. All states, sizes, and CTA routing rules.',
    count: '5 variants',
  },
  {
    number: '02',
    title: 'Cards',
    href: '/brandbook/cards',
    desc: 'Standard, accented, glass, featured (Sapphire Scanner), KPI, and content cards. Grid layouts.',
    count: '6 variants',
  },
  {
    number: '03',
    title: 'Forms',
    href: '/brandbook/forms',
    desc: 'Text inputs, textareas, selects, labels, validation states, and glass-morphism inputs.',
    count: '6 states',
  },
  {
    number: '04',
    title: 'Sections',
    href: '/brandbook/sections',
    desc: 'Container system, section wrappers, surface alternation, ambient pools, watermarks, hero and CTA patterns.',
    count: '9 patterns',
  },
  {
    number: '05',
    title: 'Advanced',
    href: '/brandbook/advanced',
    desc: 'FAQ accordion, testimonials, stat blocks, badges, tabs, highlight banners, logo marquee, and navigation.',
    count: '8 components',
  },
];
---

<BrandbookLayout
  title="Components"
  pageName="COMPONENTS"
  description="Component catalog index — buttons, cards, forms, section patterns, and advanced UI components."
>
  <!-- Title Area -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-2xl);">
      <div class="max-w-[900px]">
        <h1
          class="font-bold tracking-tight mb-6"
          style="font-size: var(--text-display); line-height: 1.05; letter-spacing: -0.03em; color: var(--text-primary); text-wrap: balance;"
        >
          Components
        </h1>
        <p
          class="max-w-[680px]"
          style="font-size: var(--text-body-lg); line-height: 1.6; color: var(--text-secondary); text-wrap: pretty;"
        >
          Every component in the Reis IA design system, organized by category. Each page includes live interactive demos, complete specifications, code snippets with copy-to-clipboard, and usage rules.
        </p>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Component Index -->
  <section style="background: var(--surface-1);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="00" title="Component Index" />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {componentPages.map(page => (
          <a
            href={page.href}
            class="rounded-xl border p-6 block transition-colors duration-300 no-underline group"
            style="background: var(--surface-2); border-color: var(--border-default); text-decoration: none;"
            onmouseover="this.style.borderColor='var(--border-visible)';this.style.background='var(--surface-3)'"
            onmouseout="this.style.borderColor='var(--border-default)';this.style.background='var(--surface-2)'"
          >
            <div class="flex items-center justify-between mb-4">
              <span class="font-mono text-[11px] font-bold" style="color: var(--accent-blue);">[{page.number}]</span>
              <span class="badge-accent">{page.count}</span>
            </div>
            <h3 class="text-lg font-semibold mb-2" style="color: var(--text-primary);">{page.title}</h3>
            <p class="text-sm mb-4" style="color: var(--text-secondary); line-height: 1.6;">{page.desc}</p>
            <span class="text-sm font-medium inline-flex items-center gap-1" style="color: var(--text-secondary);">
              View docs <span class="inline-block transition-transform duration-200" style="group-hover: translateX(4px);">&rarr;</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Summary -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="01" title="Component Summary" />

      <div class="rounded-xl border overflow-hidden" style="border-color: var(--border-default);">
        <table style="width: 100%; border-collapse: collapse;">
          <thead>
            <tr style="background: var(--surface-2);">
              <th style="padding: 12px 16px; text-align: left; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-tertiary); border-bottom: 1px solid var(--border-default);">Category</th>
              <th style="padding: 12px 16px; text-align: left; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-tertiary); border-bottom: 1px solid var(--border-default);">Components</th>
              <th style="padding: 12px 16px; text-align: right; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-tertiary); border-bottom: 1px solid var(--border-default);">Count</th>
            </tr>
          </thead>
          <tbody>
            {[
              ['Buttons', 'Primary, Hero, Secondary, Ghost, Link', '5'],
              ['Cards', 'Standard, Accented, Glass, Featured, KPI, Content', '6'],
              ['Forms', 'Text Input, Textarea, Select, Labels, Validation', '5'],
              ['Sections', 'Container, Section Wrapper, Hero, CTA, Transitions', '9'],
              ['Advanced', 'Accordion, Testimonial, Stats, Badge, Tabs, Marquee, Banner', '8'],
            ].map(([cat, items, count]) => (
              <tr style="border-bottom: 1px solid var(--border-subtle);">
                <td style="padding: 12px 16px; font-size: 14px; font-weight: 500; color: var(--text-primary);">{cat}</td>
                <td style="padding: 12px 16px; font-size: 13px; color: var(--text-tertiary);">{items}</td>
                <td style="padding: 12px 16px; font-size: 14px; font-weight: 600; color: var(--accent-blue); text-align: right; font-variant-numeric: tabular-nums;">{count}</td>
              </tr>
            ))}
            <tr style="background: var(--surface-2);">
              <td style="padding: 12px 16px; font-size: 14px; font-weight: 600; color: var(--text-primary);">Total</td>
              <td style="padding: 12px 16px;"></td>
              <td style="padding: 12px 16px; font-size: 14px; font-weight: 700; color: var(--accent-blue); text-align: right; font-variant-numeric: tabular-nums;">33</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</BrandbookLayout>
