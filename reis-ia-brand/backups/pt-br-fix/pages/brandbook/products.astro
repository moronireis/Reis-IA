---
import BrandbookLayout from '../../layouts/BrandbookLayout.astro';
import RelatedPages from '../../components/RelatedPages.astro';
import { relatedLinksMap } from '../../data/navigation';
import SectionLabel from '../../components/SectionLabel.astro';
---

<BrandbookLayout
  title="Produtos Z7 + Systems"
  pageName="PRODUTOS Z7 + SYSTEMS"
  description="Hierarquia de produtos Z7 (Hours, Days, Months), 7 Stages, e produtos Systems (Protocol, Agent, Engine)."
>
  <!-- Title Area -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-2xl);">
      <div class="max-w-[900px]">
        <!-- Dual badge -->
        <div class="flex flex-wrap gap-2 mb-6">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md" style="background: rgba(45, 122, 255, 0.10); border: 1px solid rgba(45, 122, 255, 0.20);">
            <span class="font-mono text-[11px] font-bold uppercase tracking-wider" style="color: #2D7AFF;">Time Builders</span>
          </div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md" style="background: rgba(255, 255, 255, 0.06); border: 1px solid var(--border-visible);">
            <span class="font-mono text-[11px] font-bold uppercase tracking-wider" style="color: var(--text-secondary);">Systems</span>
          </div>
        </div>

        <h1
          class="font-bold tracking-tight mb-6"
          style="font-size: var(--text-display); line-height: 1.05; letter-spacing: -0.03em; color: var(--text-primary); text-wrap: balance;"
        >
          Produtos
        </h1>
        <p
          class="max-w-[680px]"
          style="font-size: var(--text-body-lg); line-height: 1.6; color: var(--text-secondary); text-wrap: pretty;"
        >
          Duas linhas de produto. Produtos Z7 comprimem tempo de aprendizado. Produtos Systems recuperam tempo operacional. Ambos expressam "O Tempo e Rei."
        </p>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 01: Hierarquia de Produtos -->
  <section style="background: var(--surface-1);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="01" title="Hierarquia de Produtos" />

      <div class="max-w-[900px] space-y-8">
        <!-- Z7 Scale -->
        <div>
          <h3 class="text-lg font-bold mb-4" style="color: #2D7AFF;">Escala Z7 (Time Builders)</h3>
          <div class="flex flex-col sm:flex-row items-center gap-4">
            {[
              { name: 'Z7 Hours', sub: 'Faisca', time: '7h = 7 anos' },
              { name: 'Z7 Days', sub: 'Forjamento', time: '7d = 7 meses' },
              { name: 'Z7 Months', sub: 'Evolucao', time: 'Meses = anos' },
            ].map((p, i) => (
              <>
                <div class="flex-1 p-5 rounded-xl border text-center w-full sm:w-auto" style="background: var(--surface-2); border-color: rgba(45, 122, 255, 0.15);">
                  <div class="font-extrabold text-xl mb-1" style="color: #2D7AFF; letter-spacing: -0.04em;">{p.name}</div>
                  <p class="text-xs font-mono uppercase tracking-wider" style="color: var(--text-quaternary);">{p.sub}</p>
                  <p class="text-xs mt-2" style="color: var(--text-tertiary);">{p.time}</p>
                </div>
                {i < 2 && (
                  <svg class="w-5 h-5 flex-shrink-0 rotate-90 sm:rotate-0" style="color: var(--text-quaternary);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                )}
              </>
            ))}
          </div>
        </div>

        <!-- Systems Scale -->
        <div>
          <h3 class="text-lg font-bold mb-4" style="color: var(--text-secondary);">Escala Systems</h3>
          <div class="flex flex-col sm:flex-row items-center gap-4">
            {[
              { name: 'Protocol', sub: 'Mapear', time: 'Identifica 20-100+ h/mes' },
              { name: 'Agent', sub: 'Recuperar', time: 'Recupera 10-40 h/mes' },
              { name: 'Engine', sub: 'Transformar', time: 'Recupera 40-100+ h/mes' },
            ].map((p, i) => (
              <>
                <div class="flex-1 p-5 rounded-xl border text-center w-full sm:w-auto" style="background: var(--surface-2); border-color: var(--border-default);">
                  <div class="font-semibold text-xl mb-1" style="color: var(--text-primary);">{p.name}</div>
                  <p class="text-xs font-mono uppercase tracking-wider" style="color: var(--text-quaternary);">{p.sub}</p>
                  <p class="text-xs mt-2" style="color: var(--text-tertiary);">{p.time}</p>
                </div>
                {i < 2 && (
                  <svg class="w-5 h-5 flex-shrink-0 rotate-90 sm:rotate-0" style="color: var(--text-quaternary);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                )}
              </>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 02: Z7 Hours -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="02" title="Z7 Hours — A Faisca" />

      <div class="max-w-[680px] space-y-6">
        <div class="p-6 rounded-xl border" style="background: var(--surface-2); border-color: rgba(45, 122, 255, 0.15);">
          <div class="font-extrabold text-3xl mb-2" style="color: #2D7AFF; letter-spacing: -0.04em;">Z7 Hours</div>
          <p class="text-xl font-bold mb-3" style="color: var(--text-primary);">"7 horas que valem 7 anos."</p>
          <p class="text-sm" style="color: var(--text-secondary); line-height: 1.65;">
            Experiencia intensiva de 7 horas focadas. O participante vivencia a compressao Z7 na propria pele. Nao e palestra. E uma experiencia onde a pessoa sente, no corpo e no relogio, que 7 horas com IA valem 7 anos de aprendizado convencional.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div class="p-4 rounded-lg" style="background: var(--surface-2);">
            <p class="text-xs font-mono uppercase tracking-wider mb-1" style="color: var(--text-quaternary);">Energia</p>
            <p class="text-sm" style="color: var(--text-secondary);">Eletrica — intensidade concentrada</p>
          </div>
          <div class="p-4 rounded-lg" style="background: var(--surface-2);">
            <p class="text-xs font-mono uppercase tracking-wider mb-1" style="color: var(--text-quaternary);">Transformacao</p>
            <p class="text-sm" style="color: var(--text-secondary);">Entra cetico, sai sabendo que esta 7 anos atras se nao continuar.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 03: Z7 Days -->
  <section style="background: var(--surface-1);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="03" title="Z7 Days — O Forjamento" />

      <div class="max-w-[900px] space-y-8">
        <div class="max-w-[680px]">
          <div class="font-extrabold text-3xl mb-2" style="color: #2D7AFF; letter-spacing: -0.04em;">Z7 Days</div>
          <p class="text-xl font-bold mb-3" style="color: var(--text-primary);">"7 dias que substituem 7 meses."</p>
          <p style="font-size: var(--text-body-lg); color: var(--text-secondary); line-height: 1.6;">
            Programa principal. Consultoria onde implementamos JUNTO. Assim como o mundo foi criado em 7 dias, o negocio de IA do participante e criado em 7 dias.
          </p>
        </div>

        <!-- 7 Stages -->
        <div>
          <h3 class="text-lg font-bold mb-4" style="color: var(--text-primary);">Os 7 Dias da Criacao Z7</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
            {[
              { day: '1', name: 'Materia-Prima', desc: 'Mapeamento de mercado, oportunidades, autoavaliacao.' },
              { day: '2', name: 'Fundicao', desc: 'Arquitetura de oferta, frameworks de precificacao, posicionamento.' },
              { day: '3', name: 'Forjamento', desc: 'Aquisicao de clientes, sistemas de venda, prospeccao.' },
              { day: '4', name: 'Tempera', desc: 'Framework de implementacao, preparacao para entrega.' },
              { day: '5', name: 'Entrega', desc: 'Primeiro projeto real. Mao na massa junto com Reis IA.' },
              { day: '6', name: 'Calibracao', desc: 'Otimizacao, ajustes, sistematizacao.' },
              { day: '7', name: 'Acabamento', desc: 'Sistematizacao final. A criacao esta completa.' },
            ].map(s => (
              <div class="p-4 rounded-xl border transition-colors duration-300 hover:border-[rgba(45,122,255,0.25)]" style="background: var(--surface-2); border-color: var(--border-default);">
                <div class="flex items-baseline gap-2 mb-2">
                  <span class="font-mono text-lg font-bold" style="color: #2D7AFF;">D{s.day}</span>
                  <span class="text-sm font-semibold" style="color: var(--text-primary);">{s.name}</span>
                </div>
                <p class="text-xs" style="color: var(--text-tertiary); line-height: 1.6;">{s.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Certificacao -->
        <div class="p-6 rounded-xl border" style="background: var(--surface-2); border-color: rgba(45, 122, 255, 0.15);">
          <div class="font-mono text-[11px] font-bold uppercase tracking-wider mb-3" style="color: #2D7AFF;">Certificacao</div>
          <h4 class="text-lg font-bold mb-2" style="color: var(--text-primary);">Titulo: Forjado</h4>
          <p class="text-sm" style="color: var(--text-secondary); line-height: 1.6;">
            "Forjado — Reis IA Builder Z7 Days." Uma vez forjado, sempre forjado. O titulo carrega declaracao de tempo: "Esta pessoa comprimiu 7 meses em 7 dias e saiu com um negocio de IA funcionando."
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 04: 7 Stages -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="04" title="7 Stages da Criacao" />

      <div class="max-w-[900px] space-y-6">
        <p class="max-w-[680px]" style="font-size: var(--text-body-lg); color: var(--text-secondary); line-height: 1.6;">
          Os 7 estagios da criacao — analogia com os 7 dias da criacao biblica. Cada estagio e um dia de transformacao no Z7 Days.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-[1px] rounded-xl border overflow-hidden" style="background: var(--border-default); border-color: var(--border-default);">
          {[
            { num: '1', name: 'Materia-Prima', meaning: 'Voce chega como e. Materia bruta.', color: '#2D7AFF' },
            { num: '2', name: 'Fundicao', meaning: 'A materia bruta e derretida e remodelada.', color: '#2D7AFF' },
            { num: '3', name: 'Forjamento', meaning: 'O metal e martelado sob calor e pressao.', color: '#2D7AFF' },
            { num: '4', name: 'Tempera', meaning: 'A tempera torna o metal resiliente.', color: '#2D7AFF' },
            { num: '5', name: 'Entrega', meaning: 'Mao na massa. Projeto real.', color: '#00B4FF' },
            { num: '6', name: 'Calibracao', meaning: 'Acabamento que transforma trabalho bruto em peca.', color: '#00B4FF' },
            { num: '7', name: 'Acabamento', meaning: 'O 7o dia: a criacao esta completa.', color: '#00B4FF' },
          ].map(s => (
            <div class="p-5" style="background: var(--surface-1);">
              <div class="font-extrabold text-3xl mb-2" style={`color: ${s.color}; opacity: 0.3;`}>{s.num}</div>
              <h4 class="text-sm font-bold mb-1" style="color: var(--text-primary);">{s.name}</h4>
              <p class="text-xs" style="color: var(--text-tertiary); line-height: 1.5;">{s.meaning}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 05: Z7 Months -->
  <section style="background: var(--surface-1);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="05" title="Z7 Months — A Evolucao" />

      <div class="max-w-[680px] space-y-6">
        <div class="p-6 rounded-xl border" style="background: var(--surface-2); border-color: rgba(0, 180, 255, 0.15);">
          <div class="font-extrabold text-3xl mb-2" style="color: #00B4FF; letter-spacing: -0.04em;">Z7 Months</div>
          <p class="text-xl font-bold mb-3" style="color: var(--text-primary);">"Meses de proximidade que valem anos de vantagem."</p>
          <p class="text-sm" style="color: var(--text-secondary); line-height: 1.65;">
            Acompanhamento estrategico de longo prazo. Acesso direto a Moroni Reis. Correcao de rota imediata. A multiplicacao composta do tempo.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {[
            { cycle: 'Ciclo 1', name: 'Aceleracao', desc: 'Primeiros projetos e construcao de pipeline.' },
            { cycle: 'Ciclo 2', name: 'Multiplicacao', desc: 'Escala de operacoes. Sistemas repetíveis.' },
            { cycle: 'Ciclo 3', name: 'Dominio', desc: 'Autonomia completa. Velocidade Z7.' },
            { cycle: 'Ciclo 4+', name: 'Expansao', desc: 'Novos mercados, parcerias, evolucao continua.' },
          ].map(c => (
            <div class="p-4 rounded-lg" style="background: var(--surface-2);">
              <span class="font-mono text-[11px] font-bold" style="color: #00B4FF;">{c.cycle}</span>
              <h4 class="text-sm font-semibold mt-1" style="color: var(--text-primary);">{c.name}</h4>
              <p class="text-xs mt-1" style="color: var(--text-tertiary);">{c.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 06: Products Systems -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="06" title="Produtos Systems" />

      <div class="max-w-[900px] space-y-8">
        <p class="max-w-[680px]" style="font-size: var(--text-body-lg); color: var(--text-secondary); line-height: 1.6;">
          O motor de recuperacao de tempo. Para o empresario e C-Level que quer resultado pratico, nao projeto de tecnologia. Filosofia visual: sofisticacao pela ausencia de cor.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <!-- Protocol -->
          <div class="p-6 rounded-xl border" style="background: var(--surface-2); border-color: var(--border-default);">
            <div class="font-semibold text-xl mb-1" style="color: var(--text-primary);">Protocol</div>
            <p class="text-xs font-mono uppercase tracking-wider mb-3" style="color: var(--text-quaternary);">Diagnostico</p>
            <p class="text-sm mb-4" style="color: var(--text-secondary); line-height: 1.6;">
              Diagnostico estruturado. Mapeia onde o negocio esta perdendo tempo e onde a IA pode recupera-lo com maior retorno.
            </p>
            <div class="space-y-1 text-xs" style="color: var(--text-tertiary);">
              <p>Identifica 20-100+ h/mes de tempo recuperavel</p>
              <p>Entregue em 1-2 semanas</p>
            </div>
          </div>

          <!-- Agent -->
          <div class="p-6 rounded-xl border" style="background: var(--surface-2); border-color: var(--border-default);">
            <div class="font-semibold text-xl mb-1" style="color: var(--text-primary);">Agent</div>
            <p class="text-xs font-mono uppercase tracking-wider mb-3" style="color: var(--text-quaternary);">Implementacao Focada</p>
            <p class="text-sm mb-4" style="color: var(--text-secondary); line-height: 1.6;">
              Agente de IA unico que elimina um dreno de tempo especifico. Um problema, uma solucao, deploy rapido.
            </p>
            <div class="space-y-1 text-xs" style="color: var(--text-tertiary);">
              <p>Recupera 10-40 h/mes</p>
              <p>Entregue em 2-4 semanas</p>
            </div>
          </div>

          <!-- Engine -->
          <div class="p-6 rounded-xl border" style="background: var(--surface-2); border-color: var(--border-default);">
            <div class="font-semibold text-xl mb-1" style="color: var(--text-primary);">Engine</div>
            <p class="text-xs font-mono uppercase tracking-wider mb-3" style="color: var(--text-quaternary);">Sistema Integrado</p>
            <p class="text-sm mb-4" style="color: var(--text-secondary); line-height: 1.6;">
              Sistema de IA integrado. Multiplos agentes trabalhando juntos como infraestrutura unificada de recuperacao de tempo.
            </p>
            <div class="space-y-1 text-xs" style="color: var(--text-tertiary);">
              <p>Recupera 40-100+ h/mes</p>
              <p>Entregue em 4-8 semanas</p>
            </div>
          </div>
        </div>

        <!-- Exemplos de Nomenclatura -->
        <div class="p-5 rounded-xl border" style="background: var(--surface-2); border-color: var(--border-default);">
          <div class="font-mono text-[11px] font-bold uppercase tracking-wider mb-3" style="color: var(--text-tertiary);">Exemplos de Nomenclatura</div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            {[
              { name: 'Revenue Engine', time: '60+ h/mes recuperadas' },
              { name: 'Support Agent', time: '47 h/mes recuperadas' },
              { name: 'Qualification Agent', time: '20 h/mes recuperadas' },
              { name: 'Revenue Protocol', time: 'Mapeia perdas em 2 semanas' },
            ].map(ex => (
              <div class="flex items-center justify-between p-3 rounded-lg" style="background: var(--surface-3);">
                <span class="text-sm font-medium" style="color: var(--text-primary);">Reis IA Systems {ex.name}</span>
                <span class="text-xs font-mono" style="color: var(--text-quaternary);">{ex.time}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 07: Naming + Certificacoes -->
  <section style="background: var(--surface-1);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="07" title="Naming + Certificacoes" />

      <div class="max-w-[680px] space-y-8">
        <!-- Nomes Travados -->
        <div>
          <h3 class="text-lg font-semibold mb-4" style="color: var(--text-secondary);">Nomes Travados</h3>
          <div class="space-y-2">
            {[
              { name: 'Reis IA', rule: 'Nunca abreviada. Nunca "RIA" ou "R.IA."' },
              { name: 'Time Builders', rule: 'Sempre em ingles. Nunca traduzir para "Construtores do Tempo."' },
              { name: 'Systems', rule: 'Sempre "Reis IA" como prefixo em contextos formais.' },
              { name: 'Z7', rule: 'Sempre junto: Z7. Nunca "Z 7" ou "Z-7."' },
              { name: 'Z7 Hours', rule: 'Sempre com H maiusculo.' },
              { name: 'Z7 Days', rule: 'Sempre com D maiusculo.' },
              { name: 'Z7 Months', rule: 'Sempre com M maiusculo.' },
            ].map(n => (
              <div class="flex items-start gap-4 p-3 rounded-lg" style="background: var(--surface-2);">
                <span class="font-mono text-sm font-bold flex-shrink-0 w-28" style="color: var(--text-primary);">{n.name}</span>
                <span class="text-sm" style="color: var(--text-tertiary);">{n.rule}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Certificacoes -->
        <div>
          <h3 class="text-lg font-semibold mb-4" style="color: var(--text-secondary);">Certificacoes</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="p-5 rounded-xl border" style="background: var(--surface-2); border-color: rgba(45, 122, 255, 0.15);">
              <h4 class="text-base font-bold mb-2" style="color: #2D7AFF;">Forjado</h4>
              <p class="text-sm mb-2" style="color: var(--text-secondary);">Completou Z7 Days. Tem oferta vendavel e projeto entregue.</p>
              <p class="text-xs" style="color: var(--text-tertiary);">Formato: "Forjado — Reis IA Builder Z7 Days"</p>
            </div>
            <div class="p-5 rounded-xl border" style="background: var(--surface-2); border-color: rgba(0, 180, 255, 0.15);">
              <h4 class="text-base font-bold mb-2" style="color: #00B4FF;">Time Builder Elite</h4>
              <p class="text-sm mb-2" style="color: var(--text-secondary);">Completou 3+ ciclos de Z7 Months. Profundidade e aceleracao sustentada.</p>
              <p class="text-xs" style="color: var(--text-tertiary);">Sinaliza relacao de longa duracao.</p>
            </div>
          </div>
        </div>

        <!-- Marcos de Receita -->
        <div>
          <h3 class="text-lg font-semibold mb-4" style="color: var(--text-secondary);">Marcos de Reconhecimento</h3>
          <div class="space-y-2">
            {[
              { badge: 'Entregou', req: 'Primeiro projeto de IA entregue' },
              { badge: 'Clube 10K', req: 'R$ 10 mil acumulados com IA' },
              { badge: 'Operador 100K', req: 'R$ 100 mil acumulados com IA' },
              { badge: 'Mestre do Tempo', req: '1.000+ horas recuperadas para clientes' },
            ].map(m => (
              <div class="flex items-center gap-4 p-3 rounded-lg" style="background: var(--surface-2);">
                <span class="font-mono text-sm font-bold flex-shrink-0" style="color: #2D7AFF;">{m.badge}</span>
                <span class="text-sm" style="color: var(--text-tertiary);">{m.req}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Related Pages -->
  <RelatedPages links={relatedLinksMap['/brandbook/products'] || []} />
</BrandbookLayout>
