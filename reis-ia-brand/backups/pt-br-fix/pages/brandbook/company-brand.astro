---
import BrandbookLayout from '../../layouts/BrandbookLayout.astro';
import RelatedPages from '../../components/RelatedPages.astro';
import { relatedLinksMap } from '../../data/navigation';
import SectionLabel from '../../components/SectionLabel.astro';
---

<BrandbookLayout
  title="Reis IA Company Brand"
  pageName="COMPANY BRAND — REIS IA"
  description="Marca empresa Reis IA: essencia, valores, voz, Prisma de Kapferer, arquitetura e posicionamento."
>
  <!-- Title Area -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-2xl);">
      <div class="max-w-[900px]">
        <!-- Layer badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md mb-6" style="background: var(--accent-10); border: 1px solid var(--blue-20);">
          <span class="font-mono text-[11px] font-bold uppercase tracking-wider" style="color: var(--accent-blue);">Marca Mestra</span>
        </div>

        <h1
          class="font-bold tracking-tight mb-6"
          style="font-size: var(--text-display); line-height: 1.05; letter-spacing: -0.03em; color: var(--text-primary); text-wrap: balance;"
        >
          <span style="font-weight: 300;">Reis IA</span> — Marca Empresa
        </h1>
        <p
          class="max-w-[680px]"
          style="font-size: var(--text-body-lg); line-height: 1.6; color: var(--text-secondary); text-wrap: pretty;"
        >
          A identidade mestra do ecossistema. Toda decisao de branding, messaging, design e desenvolvimento deve ser consistente com este framework.
        </p>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 01: Essencia + Promessa -->
  <section style="background: var(--surface-1);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="01" title="Essencia + Promessa" />

      <div class="max-w-[680px] space-y-8">
        <div class="p-8 rounded-xl border text-center" style="background: var(--surface-0); border-color: var(--border-accent);">
          <p class="text-3xl md:text-4xl font-bold mb-4" style="color: var(--text-primary); letter-spacing: -0.02em;">
            "O Tempo e <span style="color: var(--accent-blue);">Rei</span>."
          </p>
          <p class="text-sm max-w-[500px] mx-auto" style="color: var(--text-secondary); line-height: 1.6;">
            Tempo e o nucleo irredutivel. Retire tudo o mais e o que resta e isto: a Reis IA existe para devolver as empresas o recurso mais valioso que possuem. Tempo.
          </p>
        </div>

        <!-- Hierarquia -->
        <div class="flex items-center justify-center gap-4 p-6 rounded-xl" style="background: var(--surface-2);">
          <span class="text-lg font-bold" style="color: var(--accent-blue);">Tempo</span>
          <svg class="w-5 h-5" style="color: var(--text-quaternary);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          <span class="text-lg font-bold" style="color: var(--text-secondary);">Eficiencia</span>
          <svg class="w-5 h-5" style="color: var(--text-quaternary);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          <span class="text-lg font-bold" style="color: var(--text-primary);">Receita</span>
        </div>

        <!-- Promessa -->
        <div class="p-6 rounded-xl border" style="background: var(--surface-2); border-color: var(--border-default);">
          <div class="font-mono text-[11px] font-bold uppercase tracking-wider mb-3" style="color: var(--accent-blue);">Promessa da Marca</div>
          <p class="text-base font-medium" style="color: var(--text-primary); line-height: 1.6;">
            Devolvemos o recurso mais valioso da sua empresa — o seu tempo — e transformamos cada hora recuperada em receita mensuravel.
          </p>
        </div>

        <!-- Posicionamento -->
        <p class="text-sm font-medium" style="color: var(--text-tertiary);">
          <strong style="color: var(--accent-blue);">Posicionamento central:</strong> "O Tempo e Rei, IA e o caminho de controla-lo."
        </p>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 02: Valores -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="02" title="Valores da Marca" />

      <div class="max-w-[900px]">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {[
            {
              name: 'Pensamento Tempo-Primeiro',
              def: 'Toda decisao comeca com: "Onde o tempo esta sendo perdido?"',
              practice: 'Diagnostico de tempo antes de qualquer implementacao.',
              violation: 'Construir algo porque a tecnologia e interessante.',
            },
            {
              name: 'Pragmatismo Radical',
              def: 'O que funciona vence o que impressiona. Resultado acima de teoria.',
              practice: 'Recomendar a solucao mais simples que atinge o resultado.',
              violation: 'Engenharia excessiva. Jargao para parecer sofisticado.',
            },
            {
              name: 'Generosidade de Ecossistema',
              def: 'Quanto mais compartilhado, mais forte o ecossistema.',
              practice: 'Publicar frameworks reais. Ensinar autossuficiencia.',
              violation: 'Reter conhecimento para criar dependencia artificial.',
            },
            {
              name: 'Autoridade Conquistada',
              def: 'Autoridade e construida por resultados, nao reivindicada.',
              practice: 'Liderar com case studies. Dizer "nao sei" quando nao sabe.',
              violation: 'Superlativos sem provas ("o melhor", "lider do setor").',
            },
            {
              name: 'Respeito ao Tempo',
              def: 'Respeito ao tempo nao e politica — e a filosofia operacionalizada.',
              practice: 'Reunioes no horario. Propostas em 48h. Site carrega rapido.',
              violation: 'Fazer clientes esperarem. Comunicacoes inchadas.',
            },
          ].map(v => (
            <div class="p-5 rounded-xl border transition-colors duration-300 hover:border-[var(--border-visible)]" style="background: var(--surface-2); border-color: var(--border-default);">
              <h4 class="text-sm font-semibold mb-3" style="color: var(--text-primary);">{v.name}</h4>
              <p class="text-xs mb-3" style="color: var(--text-secondary); line-height: 1.6;">{v.def}</p>
              <div class="text-xs space-y-1.5">
                <div class="flex items-start gap-2">
                  <span class="flex-shrink-0 mt-0.5 w-1.5 h-1.5 rounded-full" style="background: var(--color-success);"></span>
                  <span style="color: var(--text-tertiary);">{v.practice}</span>
                </div>
                <div class="flex items-start gap-2">
                  <span class="flex-shrink-0 mt-0.5 w-1.5 h-1.5 rounded-full" style="background: var(--color-error);"></span>
                  <span style="color: var(--text-tertiary);">{v.violation}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 03: Personalidade + Voz -->
  <section style="background: var(--surface-1);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="03" title="Personalidade + Voz da Marca" />

      <div class="max-w-[680px] space-y-8">
        <p style="font-size: var(--text-body-lg); color: var(--text-secondary); line-height: 1.6; text-wrap: pretty;">
          Se a Reis IA fosse uma pessoa, seria um empreendedor brasileiro afiado, de gola preta e relogio analogico no pulso — alguem que le relatorios McKinsey e grupos de WhatsApp, que explica conceitos complexos de IA tomando um cafezinho.
        </p>

        <!-- Tracos de Personalidade -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {[
            { trait: 'Estrategico', is: 'Enxerga o tabuleiro do negocio antes da tecnologia.', isNot: 'Nao e academico. Nao e lento para agir.' },
            { trait: 'Direto', is: 'Declara o ponto com clareza. Sem rodeios.', isNot: 'Nao e grosseiro. Nao e arrogante.' },
            { trait: 'Construtor', is: 'Sempre construindo algo. Mostra o processo.', isNot: 'Nao e falador. Nao e teorico.' },
            { trait: 'Sofisticado', is: 'Estetica premium. Linguagem precisa.', isNot: 'Nao e pretensioso. Nao e elitista.' },
          ].map(p => (
            <div class="p-5 rounded-xl border" style="background: var(--surface-2); border-color: var(--border-default);">
              <h4 class="text-sm font-semibold mb-2" style="color: var(--text-primary);">{p.trait}</h4>
              <p class="text-xs mb-1" style="color: var(--text-secondary);">{p.is}</p>
              <p class="text-xs italic" style="color: var(--text-quaternary);">{p.isNot}</p>
            </div>
          ))}
        </div>

        <!-- Voz por Camada -->
        <div>
          <h3 class="text-lg font-semibold mb-4" style="color: var(--text-secondary);">Voz por Camada de Marca</h3>
          <div class="space-y-3">
            {[
              { layer: 'Reis IA (Mestra)', voice: 'Institucional. Autoritativa. Medida. Linguagem de tempo confiante e filosofica.' },
              { layer: 'Time Builders', voice: 'Energetica. Desafiadora. Direta. Linguagem de tempo urgente e tribal.' },
              { layer: 'Systems', voice: 'Tecnico-confiante. Preciso. Linguagem de tempo orientada por metricas.' },
              { layer: 'Moroni Reis', voice: 'Pessoal. Provocativo. Generoso. Linguagem de tempo filosofica e direta.' },
            ].map(v => (
              <div class="flex items-start gap-4 p-4 rounded-lg" style="background: var(--surface-2);">
                <span class="flex-shrink-0 font-mono text-[11px] font-bold w-28" style="color: var(--accent-blue);">{v.layer}</span>
                <p class="text-sm" style="color: var(--text-secondary);">{v.voice}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 04: Prisma de Identidade (Kapferer) -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="04" title="Prisma de Identidade (Kapferer)" />

      <div class="max-w-[900px]">
        <p class="max-w-[680px] mb-8" style="font-size: var(--text-body-lg); color: var(--text-secondary); line-height: 1.6;">
          As 6 facetas do Prisma de Identidade de Marca de Kapferer aplicadas a Reis IA.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {[
            {
              facet: 'Fisico',
              desc: 'Tela escura. Azul #4A90FF com parcimonia. Inter. Minimalismo geometrico. Motivo ampulheta como ancora visual.',
              icon: '◻',
            },
            {
              facet: 'Personalidade',
              desc: 'Pensador estrategico que constroi. Confiante sem arrogancia. Brasileiro no calor, global na ambicao.',
              icon: '◇',
            },
            {
              facet: 'Cultura',
              desc: 'Pensamento tempo-primeiro que flui para receita. Pragmatismo acima de sofisticacao. Ecossistema acima de extracao.',
              icon: '△',
            },
            {
              facet: 'Relacionamento',
              desc: 'Parceria estrategica de tempo, nao relacao de fornecedor. Consultiva — ganhamos o direito de aconselhar recuperando tempo primeiro.',
              icon: '○',
            },
            {
              facet: 'Reflexo',
              desc: 'Clientes se veem como lideres de negocio que escolheram o caminho inteligente — o que comeca pelo tempo.',
              icon: '◈',
            },
            {
              facet: 'Autoimagem',
              desc: '"Recuperei meu tempo." O sentimento interno e libertacao — o alivio de ver horas voltarem para a agenda.',
              icon: '◉',
            },
          ].map(f => (
            <div class="p-5 rounded-xl border transition-colors duration-300 hover:border-[var(--border-visible)]" style="background: var(--surface-2); border-color: var(--border-default);">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-lg" style="color: var(--accent-blue);">{f.icon}</span>
                <h4 class="text-sm font-semibold" style="color: var(--text-primary);">{f.facet}</h4>
              </div>
              <p class="text-xs" style="color: var(--text-tertiary); line-height: 1.6;">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 05: Arquitetura de Marca -->
  <section style="background: var(--surface-1);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="05" title="Arquitetura de Marca" />

      <div class="max-w-[900px] space-y-8">
        <p class="max-w-[680px]" style="font-size: var(--text-body-lg); color: var(--text-secondary); line-height: 1.6;">
          Modelo de sub-marcas endossadas. Cada sub-marca tem identidade propria mas carrega o endosso Reis IA.
        </p>

        <!-- Hierarquia Visual -->
        <div class="space-y-3">
          <!-- Marca Mestra -->
          <div class="p-5 rounded-xl border-l-4" style="background: var(--surface-2); border-color: var(--accent-blue);">
            <div class="flex items-baseline gap-3 mb-2">
              <span class="font-mono text-[11px] font-bold uppercase" style="color: var(--accent-blue);">Mestra</span>
              <h4 class="text-base font-bold" style="color: var(--text-primary);"><span style="font-weight: 300;">Reis IA</span></h4>
            </div>
            <p class="text-sm" style="color: var(--text-secondary);">Endossadora e ancora de credibilidade. Visual: Azul #4A90FF. Filosofia: "O Tempo e Rei."</p>
          </div>

          <!-- Sub-marcas -->
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 ml-6">
            <div class="p-4 rounded-xl border-l-4" style="background: var(--surface-2); border-color: #6AADFF;">
              <span class="font-mono text-[10px] font-bold uppercase" style="color: #6AADFF;">Pessoal</span>
              <h5 class="text-sm font-semibold mt-1" style="color: var(--text-primary);">Moroni Reis</h5>
              <p class="text-xs mt-1" style="color: var(--text-tertiary);">Rosto publico, lider de pensamento. Tagline: "Start with the money."</p>
            </div>
            <div class="p-4 rounded-xl border-l-4" style="background: var(--surface-2); border-color: #2D7AFF;">
              <span class="font-mono text-[10px] font-bold uppercase" style="color: #2D7AFF;">Movimento</span>
              <h5 class="text-sm font-semibold mt-1" style="color: var(--text-primary);">Time Builders</h5>
              <p class="text-xs mt-1" style="color: var(--text-tertiary);">Comunidade, mentoria, educacao. Produtos Z7.</p>
            </div>
            <div class="p-4 rounded-xl border-l-4" style="background: var(--surface-2); border-color: var(--text-tertiary);">
              <span class="font-mono text-[10px] font-bold uppercase" style="color: var(--text-tertiary);">Servico</span>
              <h5 class="text-sm font-semibold mt-1" style="color: var(--text-primary);">Systems</h5>
              <p class="text-xs mt-1" style="color: var(--text-tertiary);">Motor de recuperacao de tempo. Implementacao de IA.</p>
            </div>
          </div>
        </div>

        <!-- Regras de Relacionamento -->
        <div>
          <h3 class="text-lg font-semibold mb-4" style="color: var(--text-secondary);">Regras de Relacionamento</h3>
          <div class="space-y-2">
            {[
              'Marca mestra sempre presente — nao existe "Time Builders" sozinho em contextos formais.',
              'Sub-marcas nao endossam umas as outras — referencias cruzadas passam pela marca mestra.',
              'Audiencia determina a marca lider — quer vender IA? Time Builders. Quer implementar? Systems.',
              'Identidade visual nao cruza — pagina Time Builders nunca parece pagina Systems.',
              'Moroni conecta, empresa ancora — marca pessoal atrai, marca institucional tranquiliza.',
              'Valor flui para cima — todo resultado fortalece a marca mestra.',
              'Filosofia flui para baixo — "O Tempo e Rei" permeia toda sub-marca.',
            ].map((rule, i) => (
              <div class="flex items-start gap-3 p-3 rounded-lg" style="background: var(--surface-2);">
                <span class="font-mono text-[11px] font-bold mt-0.5 flex-shrink-0 w-5 text-center" style="color: var(--accent-blue);">{i + 1}</span>
                <p class="text-sm" style="color: var(--text-secondary);">{rule}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 06: Posicionamento Competitivo -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="06" title="Posicionamento Competitivo" />

      <div class="max-w-[900px] space-y-8">
        <p class="max-w-[680px]" style="font-size: var(--text-body-lg); color: var(--text-secondary); line-height: 1.6;">
          Mapa de 2 eixos: Profundidade de Implementacao (X) vs. Enquadramento de Valor (Y).
        </p>

        <!-- Mapa visual simplificado -->
        <div class="p-6 rounded-xl border" style="background: var(--surface-2); border-color: var(--border-default);">
          <div class="grid grid-cols-2 gap-4">
            <div class="p-4 rounded-lg" style="background: var(--surface-3);">
              <p class="text-xs font-mono uppercase tracking-wider mb-2" style="color: var(--text-quaternary);">Superior Esquerda</p>
              <h4 class="text-sm font-semibold mb-1" style="color: var(--text-secondary);">Grandes Consultorias</h4>
              <p class="text-xs" style="color: var(--text-tertiary);">Estrategia forte, fraca na implementacao. Cara. Lenta.</p>
            </div>
            <div class="p-4 rounded-lg border-2" style="background: var(--surface-3); border-color: var(--accent-blue);">
              <p class="text-xs font-mono uppercase tracking-wider mb-2" style="color: var(--accent-blue);">Superior Direita</p>
              <h4 class="text-sm font-bold mb-1" style="color: var(--accent-blue);">Reis IA</h4>
              <p class="text-xs" style="color: var(--text-secondary);">Diagnostico de tempo + estrategia + implementacao + ecossistema.</p>
            </div>
            <div class="p-4 rounded-lg" style="background: var(--surface-3);">
              <p class="text-xs font-mono uppercase tracking-wider mb-2" style="color: var(--text-quaternary);">Inferior Esquerda</p>
              <h4 class="text-sm font-semibold mb-1" style="color: var(--text-secondary);">Cursos de IA</h4>
              <p class="text-xs" style="color: var(--text-tertiary);">Teoria pesada, sem implementacao. Consomem tempo.</p>
            </div>
            <div class="p-4 rounded-lg" style="background: var(--surface-3);">
              <p class="text-xs font-mono uppercase tracking-wider mb-2" style="color: var(--text-quaternary);">Inferior Direita</p>
              <h4 class="text-sm font-semibold mb-1" style="color: var(--text-secondary);">Agencias IA Genericas</h4>
              <p class="text-xs" style="color: var(--text-tertiary);">Constroem o que pedem, sem estrategia. Tech-first.</p>
            </div>
          </div>
          <div class="mt-4 flex items-center gap-3">
            <span class="text-xs font-mono" style="color: var(--text-quaternary);">Eixo X: Profundidade de Implementacao →</span>
            <span class="text-xs font-mono" style="color: var(--text-quaternary);">Eixo Y: Focado em Tempo e Receita ↑</span>
          </div>
        </div>

        <!-- O Zag -->
        <div class="p-6 rounded-xl border" style="background: var(--surface-2); border-color: var(--border-default);">
          <div class="font-mono text-[11px] font-bold uppercase tracking-wider mb-3" style="color: var(--accent-blue);">O Zag</div>
          <p class="text-sm" style="color: var(--text-secondary); line-height: 1.65;">
            Quando concorrentes zigam na direcao de showcases de tecnologia, Reis IA zaga na direcao de <strong style="color: var(--text-primary);">recuperacao de tempo que produz receita</strong>. A palavra que possuimos na mente do prospect: <strong style="color: var(--accent-blue);">tempo</strong>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 07: Jornada do Cliente -->
  <section style="background: var(--surface-1);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="07" title="Jornada do Cliente" />

      <div class="max-w-[900px]">
        <div class="space-y-3">
          {[
            { stage: 'Inconsciente', emotion: 'Confortavel, sentindo a mudanca', action: 'Conteudo provocativo de Moroni sobre tempo perdido', brand: 'Moroni Reis' },
            { stage: 'Consciente do Problema', emotion: 'Ansioso — "Preciso de IA"', action: 'Custo temporal da inacao. Cases de compressao.', brand: 'Moroni + Reis IA' },
            { stage: 'Consciente da Solucao', emotion: 'Avaliando opcoes', action: 'Meses-de-auto-estudo vs dias-com-Z7-Days. Preview de metodologia.', brand: 'Time Builders' },
            { stage: 'Consciente da Marca', emotion: 'Interessado — "Z7 Days comprime"', action: 'Cases, depoimentos, FAQ, walkthrough detalhado.', brand: 'Time Builders' },
            { stage: 'Cliente', emotion: 'Comprometido, nervoso', action: 'Quick wins, primeiro output em 48h, suporte.', brand: 'Time Builders' },
            { stage: 'Advogado', emotion: 'Confiante — "Mudou minha agencia"', action: 'Destaque de alumni, referral, Z7 Months.', brand: 'Reis IA (mestra)' },
          ].map((s, i) => (
            <div class="flex items-start gap-4 p-4 rounded-lg transition-colors duration-300 hover:bg-[var(--surface-2)]" style="background: var(--surface-1);">
              <span class="font-mono text-2xl font-bold flex-shrink-0 w-8 text-center" style="color: var(--blue-30);">{i + 1}</span>
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-baseline gap-2 mb-1">
                  <h4 class="text-sm font-semibold" style="color: var(--text-primary);">{s.stage}</h4>
                  <span class="text-xs font-mono" style="color: var(--accent-blue);">{s.brand}</span>
                </div>
                <p class="text-xs mb-1" style="color: var(--text-quaternary);">{s.emotion}</p>
                <p class="text-sm" style="color: var(--text-secondary);">{s.action}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 08: Governanca -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="08" title="Governanca + Regras" />

      <div class="max-w-[680px] space-y-6">
