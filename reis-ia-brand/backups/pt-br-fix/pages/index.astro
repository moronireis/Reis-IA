---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import { homeSections } from '../data/navigation';

/* Group sections by category for organized display */
const categories = [
  { key: 'Ecosystem', label: 'Ecossistema de Marca', cols: 'lg:col-span-6', desc: '4 camadas de marca — empresa, pessoal, movimento e produtos' },
  { key: 'Brand', label: 'Brand Foundations', cols: 'lg:col-span-4', desc: 'Identidade visual, estrategia, logo, icones e referencias' },
  { key: 'Tokens', label: 'Design Tokens', cols: 'lg:col-span-4', desc: 'Cores, tipografia, espacamento, superficies e tokens semanticos' },
  { key: 'Visual', label: 'Visual System', cols: 'lg:col-span-4', desc: 'Efeitos, padroes, motion e VFX avancados' },
  { key: 'Components', label: 'Components', cols: 'lg:col-span-4', desc: 'Botoes, cards, forms, secoes e composicoes avancadas' },
  { key: 'Meta', label: 'Meta', cols: 'lg:col-span-6', desc: 'Templates de pagina e regras de SEO' },
];

const totalPages = homeSections.length + 1; /* +1 for the index itself */
---

<BaseLayout title="Reis IA — Brandbook & Design System">
  <!-- Hero -->
  <section
    class="relative overflow-hidden"
    style="background: var(--surface-0);"
  >
    <!-- Ambient glow -->
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[700px] pointer-events-none"
      style="background: var(--gradient-blue-ambient); opacity: 0.5;"
      aria-hidden="true"
    ></div>

    <!-- Z7 watermark -->
    <div
      class="absolute top-1/2 right-[5%] -translate-y-1/2 pointer-events-none select-none hidden lg:block"
      style="font-size: 280px; font-weight: 800; color: rgba(74, 144, 255, 0.03); letter-spacing: -0.05em; line-height: 1;"
      aria-hidden="true"
    >Z7</div>

    <div class="container-standard relative py-24 md:py-32 lg:py-40">
      <div class="max-w-[900px]">
        <!-- Eyebrow -->
        <div class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] mb-6" style="color: var(--accent-blue);">
          Brandbook & Design System v1.0
        </div>

        <!-- Headline -->
        <h1
          class="font-bold tracking-tight mb-6"
          style="font-size: var(--text-display); line-height: 1.05; letter-spacing: -0.03em; color: var(--text-primary);"
        >
          O Tempo <span style="color: var(--accent-blue);">e Rei</span>
        </h1>

        <!-- Description -->
        <p
          class="max-w-[640px] mb-4"
          style="font-size: var(--text-body-lg); line-height: 1.6; color: var(--text-secondary);"
        >
          A fonte unica de verdade para a identidade de marca, design tokens,
          componentes, padroes visuais e diretrizes do ecossistema Reis IA.
        </p>
        <p
          class="max-w-[640px] mb-10"
          style="font-size: var(--text-small); line-height: 1.6; color: var(--text-tertiary);"
        >
          4 camadas de marca. Filosofia Z7. Sistema de design completo.
          Tudo documentado, demonstrado ao vivo e pronto para implementacao.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-wrap gap-3">
          <a
            href="/brandbook/strategy"
            class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold rounded-lg transition-all duration-300"
            style="background: var(--accent-blue); color: #000;"
          >
            Estrategia de Marca
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="/brandbook/foundations"
            class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold rounded-lg border transition-all duration-300 hover:bg-[var(--accent-05)]"
            style="border-color: var(--border-visible); color: var(--text-secondary);"
          >
            Design Tokens
          </a>
          <a
            href="/brandbook/company-brand"
            class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold rounded-lg border transition-all duration-300 hover:bg-[var(--accent-05)]"
            style="border-color: var(--border-visible); color: var(--text-secondary);"
          >
            Ecossistema
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Gradient divider -->
  <div class="gradient-divider"></div>

  <!-- Quick Stats -->
  <section style="background: var(--surface-1);">
    <div class="container-standard py-12 md:py-16">
      <div
        class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-[1px] rounded-xl border overflow-hidden"
        style="background: var(--border-default); border-color: var(--border-default);"
      >
        {[
          { value: String(totalPages), label: 'Paginas' },
          { value: '80+', label: 'Design Tokens' },
          { value: '35+', label: 'Componentes' },
          { value: '16+', label: 'Efeitos VFX' },
          { value: '4', label: 'Camadas de Marca' },
          { value: 'Z7', label: 'Filosofia' },
        ].map((stat) => (
          <div class="p-5 md:p-6 text-center" style="background: var(--surface-1);">
            <div
              class="text-2xl md:text-3xl font-bold mb-1 tabular-nums"
              style="color: var(--accent-blue);"
            >
              {stat.value}
            </div>
            <div class="text-[11px] font-mono uppercase tracking-wider" style="color: var(--text-tertiary);">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Ecosystem Overview Strip -->
  <section style="background: var(--surface-0);">
    <div class="container-standard py-16 md:py-24">
      <SectionLabel number="01" title="Arquitetura de Marca" />

      <div class="max-w-[680px] mb-10">
        <p style="font-size: var(--text-body-lg); color: var(--text-secondary); line-height: 1.6;">
          O ecossistema Reis IA opera em 4 camadas de marca endossadas,
          unificadas pela filosofia <strong style="color: var(--text-primary);">"O Tempo e Rei"</strong> e pelo codigo
          <strong style="color: var(--accent-blue);">Z7</strong>.
        </p>
      </div>

      <!-- 4-Layer Diagram -->
      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-[1px] rounded-xl border overflow-hidden mb-6"
        style="background: var(--border-default); border-color: var(--border-default);"
      >
        {[
          {
            layer: 'Reis IA',
            role: 'Marca Mestra',
            color: '#4A90FF',
            desc: 'Ecossistema. Ancora de credibilidade. Filosofia "O Tempo e Rei".',
            href: '/brandbook/company-brand',
          },
          {
            layer: 'Moroni Reis',
            role: 'Marca Pessoal',
            color: '#6AADFF',
            desc: 'Rosto publico. Governante, Heroi, Rebelde. "Start with the money."',
            href: '/brandbook/personal-brand',
          },
          {
            layer: 'Time Builders',
            role: 'Movimento',
            color: '#2D7AFF',
            desc: 'A tribo. Construtores do tempo. Programas Z7 Hours, Days, Months.',
            href: '/brandbook/movement',
          },
          {
            layer: 'Systems',
            role: 'Servico',
            color: '#00B4FF',
            desc: 'Motor de recuperacao de tempo. Implementacao de IA para empresas.',
            href: '/brandbook/products',
          },
        ].map((item) => (
          <a
            href={item.href}
            class="group p-5 md:p-6 transition-colors duration-300 hover:!bg-[var(--surface-3)]"
            style="background: var(--surface-1);"
          >
            <div class="flex items-center gap-2 mb-3">
              <div
                class="w-2 h-2 rounded-full flex-shrink-0"
                style={`background: ${item.color};`}
              ></div>
              <span class="font-mono text-[10px] font-bold uppercase tracking-wider" style={`color: ${item.color};`}>
                {item.role}
              </span>
            </div>
            <h4
              class="text-base font-semibold mb-2 transition-colors duration-300 group-hover:text-[var(--text-primary)]"
              style="color: var(--text-secondary);"
            >
              {item.layer}
            </h4>
            <p class="text-xs" style="color: var(--text-tertiary); line-height: 1.55;">
              {item.desc}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Complete Site Map Grid -->
  <section style="background: var(--surface-1);">
    <div class="container-standard py-16 md:py-24">
      <SectionLabel number="02" title="Explorar o Sistema" />

      {categories.map((cat, ci) => {
        const items = homeSections.filter((s) => s.category === cat.key);
        if (items.length === 0) return null;
        return (
          <div class:list={["mb-10", ci === categories.length - 1 && "mb-0"]}>
            {/* Category heading */}
            <div class="flex items-center gap-3 mb-4">
              <h3 class="text-sm font-semibold uppercase tracking-wider" style="color: var(--text-tertiary);">
                {cat.label}
              </h3>
              <div class="flex-1 h-px" style="background: var(--border-default);"></div>
              <span class="font-mono text-[11px]" style="color: var(--text-quaternary);">
                {items.length} {items.length === 1 ? 'pagina' : 'paginas'}
              </span>
            </div>

            {/* Cards grid */}
            <div
              class="grid grid-cols-12 gap-[1px] rounded-xl border overflow-hidden"
              style="background: var(--border-default); border-color: var(--border-default);"
            >
              {items.map((section) => (
                <a
                  href={section.href}
                  class:list={[
                    "col-span-12 group relative p-5 md:p-6 transition-colors duration-300 hover:!bg-[var(--surface-3)]",
                    section.span,
                  ]}
                  style="background: var(--surface-2);"
                >
                  {/* Number + New badge */}
                  <div class="flex items-center gap-2 mb-3">
                    <span
                      class="font-mono text-[32px] md:text-[40px] font-bold leading-none transition-colors duration-300 group-hover:text-[var(--accent-blue)]"
                      style="color: var(--text-muted);"
                    >
                      {section.number}
                    </span>
                    {section.isNew && (
                      <span
                        class="inline-block px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider rounded"
                        style="background: var(--accent-10); color: var(--accent-blue); border: 1px solid var(--blue-20);"
                      >
                        Novo
                      </span>
                    )}
                  </div>

                  {/* Title */}
                  <h4
                    class="text-base font-semibold mb-1.5 transition-colors duration-300 group-hover:text-[var(--text-primary)]"
                    style="color: var(--text-secondary);"
                  >
                    {section.title}
                  </h4>

                  {/* Description */}
                  <p class="text-sm max-w-[340px]" style="color: var(--text-tertiary);">
                    {section.description}
                  </p>

                  {/* Arrow indicator */}
                  <div
                    class="absolute top-5 right-5 opacity-0 translate-x-[-4px] transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0"
                    style="color: var(--accent-blue);"
                  >
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </div>
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Token Preview Strip -->
  <div class="gradient-divider"></div>

  <section style="background: var(--surface-0);">
    <div class="container-standard py-16 md:py-24">
      <SectionLabel number="03" title="Preview de Tokens" />

      <!-- Color Palette -->
      <div class="mb-12">
        <h3 class="text-lg font-semibold mb-6" style="color: var(--text-secondary);">
          Paleta Azul por Camada
        </h3>
        <div class="flex flex-wrap gap-3">
          {[
            { name: 'Master', var: '--accent-blue', hex: '#4A90FF', desc: 'Reis IA' },
            { name: 'Hover', var: '--accent-blue-hover', hex: '#6AADFF', desc: 'Moroni' },
            { name: 'Builder', var: '--accent-blue-muted', hex: '#2D7AFF', desc: 'Time Builders' },
            { name: 'Systems', var: '--accent-blue-bright', hex: '#00B4FF', desc: 'Systems' },
          ].map((color) => (
            <div class="flex-shrink-0">
              <div
                class="w-20 h-20 rounded-lg mb-2 border"
                style={`background: ${color.hex}; border-color: var(--border-default);`}
              ></div>
              <div class="text-xs font-medium" style="color: var(--text-secondary);">
                {color.name}
              </div>
              <div class="text-[11px] font-mono" style="color: var(--text-quaternary);">
                {color.hex}
              </div>
              <div class="text-[10px]" style="color: var(--text-tertiary);">
                {color.desc}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Surface Tiers -->
      <div class="mb-12">
        <h3 class="text-lg font-semibold mb-6" style="color: var(--text-secondary);">
          Sistema de Superficies
        </h3>
        <div class="flex flex-wrap gap-3">
          {[
            { name: 'Void', tier: '0', hex: '#000000' },
            { name: 'Base', tier: '1', hex: '#0A0A0A' },
            { name: 'Raised', tier: '2', hex: '#111111' },
            { name: 'Elevated', tier: '3', hex: '#161616' },
            { name: 'Float', tier: '4', hex: '#1A1A1A' },
          ].map((surface) => (
            <div class="flex-shrink-0">
              <div
                class="w-20 h-20 rounded-lg mb-2 border"
                style={`background: var(--surface-${surface.tier}); border-color: var(--border-visible);`}
              ></div>
              <div class="text-xs font-medium" style="color: var(--text-secondary);">
                {surface.name}
              </div>
              <div class="text-[11px] font-mono" style="color: var(--text-quaternary);">
                {surface.hex}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Typography Scale Preview -->
      <div>
        <h3 class="text-lg font-semibold mb-6" style="color: var(--text-secondary);">
          Escala Tipografica
        </h3>
        <div class="space-y-4">
          {[
            { name: 'Display', var: '--text-display', sample: 'O Tempo e Rei' },
            { name: 'H1', var: '--text-h1', sample: 'Design System' },
            { name: 'H2', var: '--text-h2', sample: 'Time Builders' },
            { name: 'H3', var: '--text-h3', sample: 'Componentes' },
            { name: 'Body', var: '--text-body', sample: 'A fonte unica de verdade para experiencias premium.' },
          ].map((type) => (
            <div class="flex items-baseline gap-4 pb-4 border-b" style="border-color: var(--border-subtle);">
              <span class="flex-shrink-0 w-16 font-mono text-[11px]" style="color: var(--text-quaternary);">
                {type.name}
              </span>
              <span
                class="font-semibold truncate"
                style={`font-size: var(${type.var}); color: var(--text-primary); line-height: 1.2;`}
              >
                {type.sample}
              </span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
