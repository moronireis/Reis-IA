---
/**
 * SpacingBar — Visual ruler showing a spacing token value.
 */
import CopyButton from './CopyButton.tsx';

interface Props {
  name: string;
  cssVar: string;
  value: string;
}

const { name, cssVar, value } = Astro.props;
---

<div class="flex items-center gap-4 py-2">
  <div class="w-24 flex-shrink-0 flex items-center gap-1">
    <span class="font-mono text-xs" style="color: var(--text-secondary);">
      {name}
    </span>
    <CopyButton client:visible text={`var(${cssVar})`} />
  </div>
  <div
    class="h-6 rounded-sm"
    style={`width: var(${cssVar}); background: var(--accent-08); border: 1px solid var(--accent-20); min-width: 4px;`}
  ></div>
  <span class="font-mono text-[11px] flex-shrink-0" style="color: var(--text-quaternary);">
    {value}
  </span>
</div>
