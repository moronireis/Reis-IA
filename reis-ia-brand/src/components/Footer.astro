---
import Logo from './Logo.astro';
import { footerColumns } from '../data/navigation';
---

<footer class="border-t" style="background: var(--surface-1); border-color: var(--border-default);">
  <div class="container-standard py-16 md:py-20">
    <!-- Logo + tagline -->
    <div class="mb-12">
      <Logo size={24} />
      <p class="mt-3 text-sm max-w-[340px]" style="color: var(--text-tertiary);">
        Design System v1.0 — the single source of truth for the REIS [IA] brand identity, tokens, components, and patterns.
      </p>
    </div>

    <!-- Navigation columns -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
      {footerColumns.map((column) => (
        <div>
          <div class="text-[11px] font-semibold uppercase tracking-[0.08em] mb-4" style="color: var(--text-quaternary);">
            {column.heading}
          </div>
          <ul class="space-y-2">
            {column.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm transition-colors duration-200 hover:text-[var(--text-primary)]"
                  style="color: var(--text-tertiary);"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Divider -->
    <div class="gradient-divider my-10"></div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
      <p class="text-xs" style="color: var(--text-quaternary);">
        &copy; 2026 REIS [IA]. Design System v1.0
      </p>
      <p class="text-xs font-mono" style="color: var(--text-muted);">
        Built with Astro + Tailwind CSS
      </p>
    </div>
  </div>
</footer>
