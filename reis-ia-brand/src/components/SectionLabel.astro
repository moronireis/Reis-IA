---
/**
 * Section Label — numbered section marker (adapted from AIOX pattern).
 * Format: [01] SECTION TITLE (monospace, uppercase)
 */
interface Props {
  number: string;
  title: string;
  class?: string;
}

const { number, title, class: className = '' } = Astro.props;
---

<div class:list={["font-mono text-[11px] font-bold uppercase tracking-[0.04em] mb-6", className]}>
  <span style="color: var(--accent-blue);">[{number}]</span>
  <span class="ml-2" style="color: var(--text-secondary);">{title}</span>
</div>
