---
/**
 * Page Header Bar — 3-column metadata bar (adapted from AIOX pattern).
 * Used at the top of every token/component page.
 */
interface Props {
  pageName: string;
  version?: string;
}

const { pageName, version = 'DESIGN SYSTEM v1.0' } = Astro.props;
---

<div
  class="border-b"
  style="background: var(--surface-1); border-color: var(--border-default);"
>
  <div class="container-standard flex flex-col sm:flex-row items-start sm:items-center justify-between py-3 gap-2">
    <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.06em]" style="color: var(--text-quaternary);">
      REIS IA
    </span>
    <span class="font-mono text-[11px] font-bold uppercase tracking-[0.06em]" style="color: var(--text-secondary);">
      {pageName}
    </span>
    <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.06em]" style="color: var(--text-quaternary);">
      {version}
    </span>
  </div>
</div>
