---
interface Props {
  size?: number;
  class?: string;
}

const { size = 28, class: className = '' } = Astro.props;
---

<a href="/" class:list={["flex items-center gap-3 group", className]} aria-label="Reis IA Design System Home">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 64 64"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    width={size}
    height={size}
    class="text-[var(--accent-blue)] transition-colors duration-300 group-hover:text-[var(--accent-blue-hover)]"
    aria-hidden="true"
  >
    <line x1="16" y1="8" x2="48" y2="8"/>
    <line x1="16" y1="8" x2="32" y2="32"/>
    <line x1="48" y1="8" x2="32" y2="32"/>
    <line x1="32" y1="32" x2="16" y2="56"/>
    <line x1="32" y1="32" x2="48" y2="56"/>
    <line x1="16" y1="56" x2="48" y2="56"/>
  </svg>
  <span class="font-semibold text-[var(--text-primary)] tracking-tight text-sm">
    REIS IA
  </span>
</a>
