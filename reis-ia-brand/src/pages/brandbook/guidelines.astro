---
import BrandbookLayout from '../../layouts/BrandbookLayout.astro';
import RelatedPages from '../../components/RelatedPages.astro';
import { relatedLinksMap } from '../../data/navigation';
import SectionLabel from '../../components/SectionLabel.astro';
import DosDonts from '../../components/DosDonts.astro';
---

<BrandbookLayout
  title="Diretrizes de Marca"
  pageName="DIRETRIZES DE MARCA"
  description="Arquétipos, voz por camada, regras visuais e diretrizes de marca do ecossistema REIS [IA]."
>
  <!-- Title Area -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-2xl);">
      <div class="max-w-[900px]">
        <div class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] mb-6" style="color: var(--accent-blue);">
          Diretrizes v3.0
        </div>
        <h1
          class="font-bold tracking-tight mb-6"
          style="font-size: var(--text-display); line-height: 1.05; letter-spacing: -0.03em; color: var(--text-primary); text-wrap: balance;"
        >
          Diretrizes de Marca
        </h1>
        <p
          class="max-w-[680px]"
          style="font-size: var(--text-body-lg); line-height: 1.6; color: var(--text-secondary); text-wrap: pretty;"
        >
          As regras que governam como o ecossistema REIS [IA] se apresenta em todo ponto de contato.
          Arquétipos, voz por camada e princípios de design atualizados para v3.0.
        </p>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 01: Filosofia da Marca -->
  <section style="background: var(--surface-1);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="01" title="Filosofia da Marca" />

      <div class="max-w-[680px] space-y-8">
        <p style="font-size: var(--text-body-lg); color: var(--text-secondary); line-height: 1.6; text-wrap: pretty;">
          "O Tempo é Rei" é o slogan decorativo e a âncora filosófica do ecossistema REIS [IA].
          Não é uma headline — é uma declaração de posicionamento que permeia cada decisão
          de design, copy e experiência de marca.
        </p>

        <div
          class="p-8 rounded-xl border text-center"
          style="background: var(--surface-2); border-color: var(--border-accent);"
        >
          <p class="text-3xl font-bold mb-4" style="color: var(--text-primary); letter-spacing: -0.02em;">
            "O Tempo é <span style="color: var(--accent-blue);">Rei</span>."
          </p>
          <p class="text-sm max-w-[480px] mx-auto" style="color: var(--text-tertiary); line-height: 1.6;">
            Slogan decorativo do ecossistema. Nunca use como headline principal de página.
            Sempre em português. Nunca traduzida.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div
            class="p-5 rounded-xl border text-center"
            style="background: var(--surface-2); border-color: var(--border-default);"
          >
            <h4 class="text-sm font-semibold mb-2" style="color: var(--text-primary);">Systems</h4>
            <p class="text-xs" style="color: var(--text-tertiary); line-height: 1.6;">
              Implementação de IA para empresas. Motor de recuperação de tempo e receita mensurável.
            </p>
          </div>
          <div
            class="p-5 rounded-xl border text-center"
            style="background: var(--surface-2); border-color: var(--border-default);"
          >
            <h4 class="text-sm font-semibold mb-2" style="color: var(--text-primary);">Builders</h4>
            <p class="text-xs" style="color: var(--text-tertiary); line-height: 1.6;">
              Comunidade e mentoria para profissionais que dominam IA como instrumento de negócio.
            </p>
          </div>
          <div
            class="p-5 rounded-xl border text-center"
            style="background: var(--surface-2); border-color: var(--border-default);"
          >
            <h4 class="text-sm font-semibold mb-2" style="color: var(--text-primary);">Marketing</h4>
            <p class="text-xs" style="color: var(--text-tertiary); line-height: 1.6;">
              Estratégia e execução de marketing com IA. Do diagnóstico à geração de receita.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 02: "O Tempo é Rei" como Principio -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="02" title='"O Tempo é Rei" — Princípio de Design e Comunicação' />

      <div class="max-w-[680px] space-y-8">
        <p style="font-size: var(--text-body-lg); color: var(--text-secondary); line-height: 1.6; text-wrap: pretty;">
          "O Tempo é Rei" não é apenas um slogan. É o princípio que governa cada decisão
          de design, copy e experiência do ecossistema.
        </p>

        <div class="space-y-6">
          {[
            {
              num: '01',
              title: 'Contenção É o Design',
              desc: 'Cada elemento precisa ganhar seu espaço. Se remover algo não reduz compreensão ou conversão, remova. Espaço preto não é vazio — é o dispositivo visual primário que sinaliza posicionamento premium. Cada segundo do visitante é sagrado.',
            },
            {
              num: '02',
              title: 'Tipografia É Arquitetura',
              desc: 'O sistema tipográfico faz 90% do trabalho de hierarquia. Headlines são grandes, confiantes e com tracking apertado. Body text é generoso e legível. O contraste entre impacto denso e legibilidade aberta cria o ritmo visual.',
            },
            {
              num: '03',
              title: 'Dark Mode como Maestria',
              desc: 'Não é "branco no preto." É um sistema de superfícies em camadas onde profundidade é comunicada através de shifts sutis de background, bordas semi-transparentes e efeitos de glow contidos.',
            },
            {
              num: '04',
              title: 'Conversão pela Clareza',
              desc: 'CTAs devem ser imediatamente visíveis. O fluxo visual guia o olhar para a próxima ação. Azul existe primariamente para elementos de conversão. Toda página leva a /agendar ou /aplicar.',
            },
            {
              num: '05',
              title: 'Precisão Engenhada',
              desc: 'Cada valor é intencional. Sem ease default. Sem espaçamento arbitrário. O design system é engenhado como os sistemas de IA que construímos para clientes.',
            },
          ].map(p => (
            <div
              class="p-6 rounded-xl border transition-colors duration-300 hover:border-[var(--border-visible)]"
              style="background: var(--surface-2); border-color: var(--border-default);"
            >
              <div class="flex items-baseline gap-3 mb-3">
                <span class="font-mono text-[11px] font-bold" style="color: var(--accent-blue);">{p.num}</span>
                <h3 class="text-lg font-semibold" style="color: var(--text-primary);">{p.title}</h3>
              </div>
              <p class="text-sm" style="color: var(--text-secondary); line-height: 1.65; text-wrap: pretty;">
                {p.desc}
              </p>
            </div>
          ))}
        </div>

        <div
          class="p-5 rounded-xl border"
          style="background: var(--surface-2); border-color: var(--border-default);"
        >
          <div class="font-mono text-[11px] font-bold uppercase tracking-wider mb-2" style="color: var(--accent-blue);">
            Teste do Tempo para Design
          </div>
          <p class="text-sm" style="color: var(--text-secondary); line-height: 1.65;">
            "Isso respeita o tempo do visitante?" Um site Reis IA que carrega devagar é uma
            contradição filosófica. Uma página confusa é roubo de tempo. Uma animação que não
            serve propósito é desperdício de atenção.
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 03: Arquétipos de Moroni -->
  <section style="background: var(--surface-1);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="03" title="Arquétipos de Moroni Reis" />

      <div class="max-w-[680px] space-y-8">
        <p style="font-size: var(--text-body-lg); color: var(--text-secondary); line-height: 1.6; text-wrap: pretty;">
          Moroni opera na interseção de três arquétipos junguianos: Governante, Herói e Rebelde.
          Cada arquétipo se expressa em contextos diferentes e todos são unificados pela maestria do tempo.
        </p>

        <div class="space-y-4">
          {[
            {
              archetype: 'Governante',
              color: '#4A90FF',
              expression: 'Autoridade tranquila. Estrutura. Sistemas que funcionam. "O Tempo é Rei" é a declaração do governante — quem domina o tempo, governa.',
              when: 'Comunicações institucionais, propostas, conteúdo estratégico, posicionamento de marca mestra.',
            },
            {
              archetype: 'Herói',
              color: '#2D7AFF',
              expression: 'Construtor incansável. Mostra o caminho. "Eu fui primeiro, e vou te guiar." A prova viva de que a filosofia funciona.',
              when: 'Builders, mentorias, conteúdo de bastidores, compartilhamento de processo.',
            },
            {
              archetype: 'Rebelde',
              color: '#00B4FF',
              expression: 'Desafia o status quo. Recusa a narrativa de que IA é só para engenheiros. "Nós falamos, nós criamos. Eles falam e somem."',
              when: 'Redes sociais, provocações, confronto com falsos profetas, conteúdo polarizador.',
            },
          ].map(a => (
            <div
              class="p-6 rounded-xl border-l-2"
              style={`background: var(--surface-2); border-color: var(--border-default); border-left-color: ${a.color};`}
            >
              <h4 class="text-base font-semibold mb-2" style="color: var(--text-primary);">{a.archetype}</h4>
              <p class="text-sm mb-3" style="color: var(--text-secondary); line-height: 1.65;">
                {a.expression}
              </p>
              <div class="text-xs" style="color: var(--text-tertiary);">
                <strong style="color: var(--text-secondary);">Quando usar:</strong> {a.when}
              </div>
            </div>
          ))}
        </div>

        <div
          class="p-5 rounded-xl border"
          style="background: var(--surface-2); border-color: var(--border-default);"
        >
          <div class="font-mono text-[11px] font-bold uppercase tracking-wider mb-2" style="color: var(--accent-blue);">
            O Líder, Não o Guru
          </div>
          <p class="text-sm" style="color: var(--text-secondary); line-height: 1.65;">
            Moroni não é guru. Não é visionário empoleirado num palco. É um construtor que foi primeiro.
            Como um líder de esquadrão num pelotão — não um general numa sala de guerra. Tem as cicatrizes,
            o mapa e a disposição de voltar para guiar outros. Não acima, mas à frente.
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 04: Builders -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="04" title="Builders — A Comunidade" />

      <div class="max-w-[680px] space-y-8">
        <p style="font-size: var(--text-body-lg); color: var(--text-secondary); line-height: 1.6; text-wrap: pretty;">
          Builders não são alunos. Não são mentorados. São profissionais que dominam
          a IA como instrumento de negócio — construtores que agem enquanto outros esperam.
        </p>

        <!-- Pilares da Comunidade -->
        <div class="space-y-4">
          <h3 class="text-lg font-semibold" style="color: var(--text-secondary);">
            Pilares da Comunidade
          </h3>
          <div
            class="grid grid-cols-1 sm:grid-cols-2 gap-[1px] rounded-xl border overflow-hidden"
            style="background: var(--border-default); border-color: var(--border-default);"
          >
            {[
              { power: 'Mentoria Aplicada', desc: 'Acompanhamento direto de Moroni Reis. Da estratégia à execução.' },
              { power: 'Comunidade Ativa', desc: 'Builders se ajudam. Casos reais, soluções reais, em tempo real.' },
              { power: 'Aprendizado Acelerado', desc: 'Sintetizar décadas de pesquisa em minutos com IA aplicada ao negócio.' },
              { power: 'Multiplicação via IA', desc: 'Trabalhar com múltiplos agentes simultâneos. Mais output, menos horas.' },
            ].map(s => (
              <div class="p-4" style="background: var(--surface-2);">
                <h5 class="text-xs font-semibold mb-1" style="color: var(--text-primary);">{s.power}</h5>
                <p class="text-[11px]" style="color: var(--text-tertiary); line-height: 1.5;">{s.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Identity -->
        <div
          class="p-5 rounded-xl border"
          style="background: var(--surface-2); border-color: var(--border-default);"
        >
          <div class="font-mono text-[11px] font-bold uppercase tracking-wider mb-3" style="color: #2D7AFF;">
            Autoimagem da Comunidade
          </div>
          <p class="text-sm italic" style="color: var(--text-secondary); line-height: 1.65;">
            "Somos os que constroem enquanto outros esperam. Somos profissionais de negócio
            que se tornaram profissionais de IA — não abandonando o que sabemos, mas nos recusando
            a desperdicar mais um dia sem usar a ferramenta mais poderosa da história."
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 05: Voz da Marca por Camada -->
  <section style="background: var(--surface-1);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="05" title="Voz da Marca por Camada" />

      <div class="max-w-[900px] space-y-8">
        <p style="font-size: var(--text-body-lg); color: var(--text-secondary); line-height: 1.6; text-wrap: pretty;">
          Cada camada do ecossistema tem modulação própria de voz. A voz institucional é distinta
          da voz pessoal de Moroni, da energia de Builders e da precisão de Systems.
        </p>

        <div
          class="border rounded-xl overflow-hidden"
          style="border-color: var(--border-default);"
        >
          <!-- Header -->
          <div
            class="grid grid-cols-[1fr_2fr_2fr] gap-0 border-b"
            style="background: var(--surface-2); border-color: var(--border-default);"
          >
            <div class="px-4 py-3 font-mono text-[11px] font-semibold uppercase tracking-wider" style="color: var(--text-tertiary);">
              Camada
            </div>
            <div class="px-4 py-3 font-mono text-[11px] font-semibold uppercase tracking-wider" style="color: var(--text-tertiary);">
              Tom de Voz
            </div>
            <div class="px-4 py-3 font-mono text-[11px] font-semibold uppercase tracking-wider" style="color: var(--text-tertiary);">
              Linguagem de Tempo
            </div>
          </div>
          {[
            { layer: 'Reis IA', tone: 'Institucional. Autoritativa. Medida. A voz do ecossistema.', time: 'Confiante e filosófica. "O Tempo é Rei."', color: '#4A90FF' },
            { layer: 'Moroni Reis', tone: 'Pessoal. Provocativo. Generoso. Direta.', time: 'Filosófica e direta. "Start with the money."', color: '#6AADFF' },
            { layer: 'Builders', tone: 'Energética. Desafiadora. Um mentor empurrando para agir.', time: 'Urgente e direta. "Construa agora."', color: '#2D7AFF' },
            { layer: 'Systems', tone: 'Técnico-confiante. Preciso. Tranquilizador.', time: 'Orientada por métricas. Horas, minutos, percentuais.', color: '#00B4FF' },
          ].map(row => (
            <div
              class="grid grid-cols-[1fr_2fr_2fr] gap-0 border-b last:border-b-0"
              style="border-color: var(--border-subtle);"
            >
              <div class="px-4 py-3 text-xs font-semibold" style={`color: ${row.color}; background: var(--surface-1);`}>
                {row.layer}
              </div>
              <div class="px-4 py-3 text-xs" style="color: var(--text-secondary); background: var(--surface-1);">
                {row.tone}
              </div>
              <div class="px-4 py-3 text-xs" style="color: var(--text-tertiary); background: var(--surface-1);">
                {row.time}
              </div>
            </div>
          ))}
        </div>

        <!-- Words We Own -->
        <div
          class="p-5 rounded-xl border"
          style="background: var(--surface-2); border-color: var(--border-default);"
        >
          <div class="font-mono text-[11px] font-bold uppercase tracking-wider mb-3" style="color: var(--accent-blue);">
            Palavras que Possuímos
          </div>
          <div class="flex flex-wrap gap-2">
            {[
              '"O Tempo é Rei"',
              'REIS [IA]',
              'Builders',
              'Revenue-First',
              'Tempo -> Eficiência -> Receita',
              'Compressão de tempo',
              'Tempo recuperado',
              'Start with the money',
              'Cemitério de Protótipos de IA',
            ].map(word => (
              <span
                class="inline-block px-2 py-1 text-[11px] font-medium rounded"
                style="background: var(--accent-08); color: var(--accent-blue); border: 1px solid var(--blue-20);"
              >
                {word}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 06: Dos & Don'ts -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="06" title="Dos & Don'ts Atualizados" />

      <div class="space-y-8 max-w-[900px]">
        <h3 class="text-lg font-semibold" style="color: var(--text-secondary);">
          Cores e Visual
        </h3>
        <DosDonts items={[
          { type: 'do', text: 'Usar azul #4A90FF para CTAs, ícones de marca e momentos de ênfase. Máximo 2 elementos azuis por viewport.' },
          { type: 'do', text: 'Usar text-secondary (70% branco) para body copy. Branco 100% é apenas para headlines.' },
          { type: 'do', text: 'Alternar seções entre Surface-0 (#000) e Surface-1 (#0A0A0A).' },
          { type: 'do', text: 'Usar a ampulheta como elemento decorativo opcional a 3-5% opacidade atrás de seções-chave.' },
          { type: 'dont', text: 'NUNCA usar gold, amber, terracotta ou qualquer tom quente como cor de destaque. O ecossistema é azul.' },
          { type: 'dont', text: 'NUNCA usar peças de xadrez (cavaleiro, rei, rainha) como elemento visual de marca.' },
          { type: 'dont', text: 'NUNCA usar Azure Whisper, Blue Shimmer, Forge Glow ou efeitos descartados.' },
          { type: 'dont', text: 'NUNCA usar "forja" como metáfora visual ou narrativa de design (descartado na v3.0).' },
          { type: 'dont', text: 'Usar mais de um salto de superfície entre seções adjacentes. Surface-0 direto pra Surface-3 é abrupto demais.' },
        ]} />

        <h3 class="text-lg font-semibold mt-12" style="color: var(--text-secondary);">
          Tipografia
        </h3>
        <DosDonts items={[
          { type: 'do', text: 'Usar text-wrap: balance em headings. Usar text-wrap: pretty em parágrafos de body.' },
          { type: 'do', text: 'Limitar body text a 680px. Limitar headlines a 900px.' },
          { type: 'do', text: 'Apertar letter-spacing conforme font size aumenta (Display: -0.03em, Body: 0).' },
          { type: 'do', text: 'Usar Inter Variable exclusivamente. Nenhuma outra fonte.' },
          { type: 'dont', text: 'Usar ALL CAPS exceto para Label tokens (badges, section labels). Headlines são sentence case.' },
          { type: 'dont', text: 'Permitir body text se estender pela largura total do container de 1200px.' },
          { type: 'dont', text: 'Usar TASA Orbiter, fontes serifadas ou qualquer fonte que não seja Inter.' },
        ]} />

        <h3 class="text-lg font-semibold mt-12" style="color: var(--text-secondary);">
          Símbolos e Motifs
        </h3>
        <DosDonts items={[
          { type: 'do', text: 'Usar a ampulheta como decoração opcional em seções sobre tempo, eficiência e impacto da IA.' },
          { type: 'do', text: 'Manter azul por camada: #4A90FF master, #6AADFF pessoal, #2D7AFF builders, #00B4FF systems.' },
          { type: 'dont', text: 'Animar a ampulheta com rotação ou flip. Quando usada, é estática.' },
          { type: 'dont', text: 'Misturar identidades visuais entre camadas. Uma página Builders nunca deve parecer Systems.' },
        ]} />

        <h3 class="text-lg font-semibold mt-12" style="color: var(--text-secondary);">
          Motion e Efeitos
        </h3>
        <DosDonts items={[
          { type: 'do', text: 'Usar as 5 curvas de easing definidas no design system. Toda animação deve usar uma delas.' },
          { type: 'do', text: 'Manter transições de hover em 200ms. Animações de entrada em 800ms com stagger de 150ms.' },
          { type: 'do', text: 'Usar apenas transform e opacity para manter 60fps.' },
          { type: 'dont', text: 'Usar bounce, spring ou elastic easing. Nada overshoots. Motion é preciso, não brincalhão.' },
          { type: 'dont', text: 'Usar CSS ease default, ease-in-out ou linear para animações interativas.' },
        ]} />
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 07: Coexistência entre Camadas -->
  <section style="background: var(--surface-1);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="07" title="Regras de Coexistência entre Camadas" />

      <div class="max-w-[680px] space-y-8">
        <p style="font-size: var(--text-body-lg); color: var(--text-secondary); line-height: 1.6; text-wrap: pretty;">
          As camadas de marca coexistem com regras claras. Cada uma tem audiência, visual e voz
          próprios, mas todas são unificadas pela filosofia "O Tempo é Rei".
        </p>

        <div class="space-y-4">
          {[
            {
              rule: 'Audiência Determina a Marca Líder',
              desc: 'Se falando para o mercado geral: lidere com REIS [IA]. Para profissionais e comunidade: Builders. Para empresários: Systems. Para redes sociais: Moroni Reis.',
            },
            {
              rule: 'Moroni Conecta, Empresa Ancora',
              desc: 'A marca pessoal cria consciência e confiança. A marca empresa converte e retém. Moroni atrai, Reis IA tranquiliza.',
            },
            {
              rule: 'Valor Flui para Cima',
              desc: 'Resultados de qualquer sub-marca fortalecem a marca mestra. Um case study de Systems também é um case study de Reis IA.',
            },
            {
              rule: 'Filosofia Flui para Baixo',
              desc: '"O Tempo é Rei" flui da marca mestra para toda sub-marca. Nenhuma comunicação pode ser publicável sem ao menos uma referência implícita ao tempo.',
            },
            {
              rule: 'Identidade Visual Não Cruza',
              desc: 'Builders usa visual próprio. Systems usa visual próprio. Marketing usa visual próprio. Compartilham azul #4A90FF como fio conector, mas são visualmente distintas.',
            },
          ].map(item => (
            <div
              class="p-5 rounded-xl border transition-colors duration-300 hover:border-[var(--border-visible)]"
              style="background: var(--surface-2); border-color: var(--border-default);"
            >
              <h4 class="text-sm font-semibold mb-2" style="color: var(--text-primary);">{item.rule}</h4>
              <p class="text-xs" style="color: var(--text-tertiary); line-height: 1.6;">
                {item.desc}
              </p>
            </div>
          ))}
        </div>

        <!-- Audience Decision Matrix -->
        <div
          class="border rounded-xl overflow-hidden"
          style="border-color: var(--border-default);"
        >
          <div
            class="grid grid-cols-3 gap-0 border-b"
            style="background: var(--surface-2); border-color: var(--border-default);"
          >
            <div class="px-4 py-3 font-mono text-[11px] font-semibold uppercase tracking-wider" style="color: var(--text-tertiary);">
              Audiência
            </div>
            <div class="px-4 py-3 font-mono text-[11px] font-semibold uppercase tracking-wider" style="color: var(--text-tertiary);">
              Lidere com
            </div>
            <div class="px-4 py-3 font-mono text-[11px] font-semibold uppercase tracking-wider" style="color: var(--text-tertiary);">
              Endosse com
            </div>
          </div>
          {[
            { audience: 'Mercado geral', lead: 'Reis IA', endorse: '—' },
            { audience: 'Profissionais / comunidade', lead: 'Builders', endorse: 'REIS [IA]' },
            { audience: 'Empresários / C-suite', lead: 'Systems', endorse: 'Reis IA' },
            { audience: 'Mídia / investidores / parceiros', lead: 'Reis IA', endorse: 'Moroni Reis' },
            { audience: 'Redes sociais geral', lead: 'Moroni Reis', endorse: 'Reis IA na bio' },
          ].map(row => (
            <div
              class="grid grid-cols-3 gap-0 border-b last:border-b-0"
              style="border-color: var(--border-subtle);"
            >
              <div class="px-4 py-3 text-xs" style="color: var(--text-secondary); background: var(--surface-1);">
                {row.audience}
              </div>
              <div class="px-4 py-3 text-xs font-semibold" style="color: var(--accent-blue); background: var(--surface-1);">
                {row.lead}
              </div>
              <div class="px-4 py-3 text-xs" style="color: var(--text-tertiary); background: var(--surface-1);">
                {row.endorse}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Related Pages -->
  <RelatedPages links={relatedLinksMap['/brandbook/guidelines'] || []} />
</BrandbookLayout>
