---
import BrandbookLayout from '../../layouts/BrandbookLayout.astro';
import RelatedPages from '../../components/RelatedPages.astro';
import { relatedLinksMap } from '../../data/navigation';
import SectionLabel from '../../components/SectionLabel.astro';
import DosDonts from '../../components/DosDonts.astro';
---

<BrandbookLayout
  title="Sistema de Logo"
  pageName="SISTEMA DE LOGO"
  description="A ampulheta H1-B Open Intersection — construção, área segura, regras de uso e variantes."
>
  <!-- Title Area -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-2xl);">
      <div class="max-w-[900px]">
        <h1
          class="font-bold tracking-tight mb-6"
          style="font-size: var(--text-display); line-height: 1.05; letter-spacing: -0.03em; color: var(--text-primary); text-wrap: balance;"
        >
          Sistema de Logo
        </h1>
        <p
          class="max-w-[680px]"
          style="font-size: var(--text-body-lg); line-height: 1.6; color: var(--text-secondary); text-wrap: pretty;"
        >
          A ampulheta H1-B "Open Intersection" é a única marca visual da Reis IA. Ela representa a escassez do tempo e o poder multiplicador dos sistemas de IA.
        </p>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 01: Brand Mark -->
  <section style="background: var(--surface-1);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="01" title="A Ampulheta H1-B" />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
        <!-- Logo Display -->
        <div class="flex flex-col items-center">
          <div
            class="relative w-full max-w-[400px] aspect-square flex items-center justify-center rounded-2xl border"
            style="background: var(--surface-0); border-color: var(--border-default);"
          >
            <!-- Grid overlay (construction grid hint) -->
            <div
              class="absolute inset-0 pointer-events-none opacity-[0.03]"
              style="background-image: linear-gradient(var(--border-visible) 1px, transparent 1px), linear-gradient(90deg, var(--border-visible) 1px, transparent 1px); background-size: 40px 40px;"
              aria-hidden="true"
            ></div>

            <!-- The H1-B Mark -->
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 64 64"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-40 h-40 md:w-48 md:h-48"
              style="color: var(--accent-blue);"
              role="img"
              aria-label="Reis IA H1-B Hourglass brand mark"
            >
              <line x1="16" y1="8" x2="48" y2="8"/>
              <line x1="16" y1="8" x2="32" y2="32"/>
              <line x1="48" y1="8" x2="32" y2="32"/>
              <line x1="32" y1="32" x2="16" y2="56"/>
              <line x1="32" y1="32" x2="48" y2="56"/>
              <line x1="16" y1="56" x2="48" y2="56"/>
            </svg>
          </div>

          <!-- Label -->
          <div class="text-center mt-4">
            <span class="font-mono text-[11px] uppercase tracking-wider" style="color: var(--text-quaternary);">
              H1-B "Open Intersection" Hourglass
            </span>
          </div>
        </div>

        <!-- Description -->
        <div class="space-y-6">
          <div>
            <h3 class="text-lg font-semibold mb-3" style="color: var(--text-primary);">Construção</h3>
            <p class="text-sm" style="color: var(--text-secondary); line-height: 1.65; text-wrap: pretty;">
              A marca é construída com 6 linhas retas em uma grade de 64x64 unidades. Duas linhas horizontais (topo e base) se conectam a um ponto de interseção central através de quatro linhas diagonais. O design "open intersection" significa que o ponto central é onde todos os caminhos convergem — representando o momento em que a IA encontra a estratégia de negócios.
            </p>
          </div>

          <div>
            <h3 class="text-lg font-semibold mb-3" style="color: var(--text-primary);">Conexão com a Marca</h3>
            <p class="text-sm" style="color: var(--text-secondary); line-height: 1.65; text-wrap: pretty;">
              A ampulheta representa o TEMPO — o recurso mais escasso nos negócios. Sistemas de IA multiplicam o tempo. A precisão geométrica da marca reflete a abordagem sistemática e engenhada que a Reis IA traz para implementação de IA.
            </p>
          </div>

          <div>
            <h3 class="text-lg font-semibold mb-3" style="color: var(--text-primary);">Especificações de Traço</h3>
            <ul class="space-y-2 text-sm" style="color: var(--text-secondary);">
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full flex-shrink-0" style="background: var(--accent-blue);"></span>
                Stroke width: 1.5px
              </li>
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full flex-shrink-0" style="background: var(--accent-blue);"></span>
                Line cap: Round
              </li>
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full flex-shrink-0" style="background: var(--accent-blue);"></span>
                Line join: Round
              </li>
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full flex-shrink-0" style="background: var(--accent-blue);"></span>
                ViewBox: 0 0 64 64
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 02: Logo Variants -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="02" title="Variantes do Logo" />

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Icon + Wordmark (Primary) -->
        <div
          class="p-8 rounded-xl border flex flex-col items-center justify-center min-h-[200px]"
          style="background: var(--surface-0); border-color: var(--border-default);"
        >
          <div class="flex items-center gap-3 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8" style="color: var(--accent-blue);" aria-hidden="true">
              <line x1="16" y1="8" x2="48" y2="8"/><line x1="16" y1="8" x2="32" y2="32"/><line x1="48" y1="8" x2="32" y2="32"/><line x1="32" y1="32" x2="16" y2="56"/><line x1="32" y1="32" x2="48" y2="56"/><line x1="16" y1="56" x2="48" y2="56"/>
            </svg>
            <span class="font-semibold text-sm tracking-tight" style="color: var(--text-primary);">REIS IA</span>
          </div>
          <span class="font-mono text-[10px] uppercase tracking-wider" style="color: var(--text-quaternary);">Primário — Ícone + Wordmark</span>
        </div>

        <!-- Apenas Ícone -->
        <div
          class="p-8 rounded-xl border flex flex-col items-center justify-center min-h-[200px]"
          style="background: var(--surface-0); border-color: var(--border-default);"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12 mb-6" style="color: var(--accent-blue);" aria-hidden="true">
            <line x1="16" y1="8" x2="48" y2="8"/><line x1="16" y1="8" x2="32" y2="32"/><line x1="48" y1="8" x2="32" y2="32"/><line x1="32" y1="32" x2="16" y2="56"/><line x1="32" y1="32" x2="48" y2="56"/><line x1="16" y1="56" x2="48" y2="56"/>
          </svg>
          <span class="font-mono text-[10px] uppercase tracking-wider" style="color: var(--text-quaternary);">Icon Only</span>
        </div>

        <!-- White on dark -->
        <div
          class="p-8 rounded-xl border flex flex-col items-center justify-center min-h-[200px]"
          style="background: var(--surface-0); border-color: var(--border-default);"
        >
          <div class="flex items-center gap-3 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8" style="color: var(--text-primary);" aria-hidden="true">
              <line x1="16" y1="8" x2="48" y2="8"/><line x1="16" y1="8" x2="32" y2="32"/><line x1="48" y1="8" x2="32" y2="32"/><line x1="32" y1="32" x2="16" y2="56"/><line x1="32" y1="32" x2="48" y2="56"/><line x1="16" y1="56" x2="48" y2="56"/>
            </svg>
            <span class="font-semibold text-sm tracking-tight" style="color: var(--text-primary);">REIS IA</span>
          </div>
          <span class="font-mono text-[10px] uppercase tracking-wider" style="color: var(--text-quaternary);">Variante Branca</span>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 03: Safe Space -->
  <section style="background: var(--surface-1);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="03" title="Área Segura e Tamanho Mínimo" />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
        <!-- Safe Space Demo -->
        <div>
          <h3 class="text-lg font-semibold mb-4" style="color: var(--text-primary);">Área Segura</h3>
          <p class="text-sm mb-6" style="color: var(--text-secondary); line-height: 1.65;">
            O espaço mínimo ao redor do logo é igual à altura da barra horizontal superior. Nenhum elemento visual pode invadir essa zona.
          </p>

          <div
            class="relative p-12 rounded-xl border flex items-center justify-center"
            style="background: var(--surface-0); border-color: var(--border-default);"
          >
            <!-- Clearspace indicators -->
            <div
              class="absolute inset-6 border-2 border-dashed rounded-lg"
              style="border-color: var(--accent-20);"
              aria-hidden="true"
            ></div>

            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-20 h-20" style="color: var(--accent-blue);" aria-hidden="true">
              <line x1="16" y1="8" x2="48" y2="8"/><line x1="16" y1="8" x2="32" y2="32"/><line x1="48" y1="8" x2="32" y2="32"/><line x1="32" y1="32" x2="16" y2="56"/><line x1="32" y1="32" x2="48" y2="56"/><line x1="16" y1="56" x2="48" y2="56"/>
            </svg>
          </div>

          <div class="mt-3 text-[10px] font-mono text-center" style="color: var(--text-quaternary);">
            Linha tracejada = limite mínimo de área segura
          </div>
        </div>

        <!-- Minimum Size -->
        <div>
          <h3 class="text-lg font-semibold mb-4" style="color: var(--text-primary);">Tamanhos Mínimos</h3>
          <p class="text-sm mb-6" style="color: var(--text-secondary); line-height: 1.65;">
            Abaixo desses tamanhos, o detalhe do traço da marca se perde. Sempre respeite os tamanhos mínimos para legibilidade.
          </p>

          <div class="space-y-6">
            <div class="flex items-end gap-6">
              <div class="text-center">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8 mx-auto" style="color: var(--accent-blue);" aria-hidden="true">
                  <line x1="16" y1="8" x2="48" y2="8"/><line x1="16" y1="8" x2="32" y2="32"/><line x1="48" y1="8" x2="32" y2="32"/><line x1="32" y1="32" x2="16" y2="56"/><line x1="32" y1="32" x2="48" y2="56"/><line x1="16" y1="56" x2="48" y2="56"/>
                </svg>
                <span class="text-[10px] font-mono mt-2 block" style="color: var(--text-quaternary);">32px — Mínimo digital</span>
              </div>
              <div class="text-center">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 mx-auto" style="color: var(--accent-blue);" aria-hidden="true">
                  <line x1="16" y1="8" x2="48" y2="8"/><line x1="16" y1="8" x2="32" y2="32"/><line x1="48" y1="8" x2="32" y2="32"/><line x1="32" y1="32" x2="16" y2="56"/><line x1="32" y1="32" x2="48" y2="56"/><line x1="16" y1="56" x2="48" y2="56"/>
                </svg>
                <span class="text-[10px] font-mono mt-2 block" style="color: var(--text-quaternary);">24px — Mínimo favicon</span>
              </div>
              <div class="text-center">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 mx-auto opacity-50" style="color: var(--color-error);" aria-hidden="true">
                  <line x1="16" y1="8" x2="48" y2="8"/><line x1="16" y1="8" x2="32" y2="32"/><line x1="48" y1="8" x2="32" y2="32"/><line x1="32" y1="32" x2="16" y2="56"/><line x1="32" y1="32" x2="48" y2="56"/><line x1="16" y1="56" x2="48" y2="56"/>
                </svg>
                <span class="text-[10px] font-mono mt-2 block" style="color: var(--color-error);">16px — Muito pequeno</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 04: Watermark Usage -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="04" title="Uso como Marca d'Água" />

      <div class="max-w-[680px] space-y-6">
        <p class="text-sm" style="color: var(--text-secondary); line-height: 1.65; text-wrap: pretty;">
          A marca da ampulheta é usada como marca d’água de fundo em opacidade de 3-5% (200-300px) atrás de seções-chave. Isso cria uma âncora visual exclusiva da marca Reis IA.
        </p>

        <!-- Watermark Demo -->
        <div
          class="relative p-12 rounded-xl border overflow-hidden min-h-[300px] flex items-center justify-center"
          style="background: var(--surface-1); border-color: var(--border-default);"
        >
          <!-- Watermark -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 64 64"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="absolute w-64 h-64 opacity-[0.04]"
            style="color: var(--text-primary);"
            aria-hidden="true"
          >
            <line x1="16" y1="8" x2="48" y2="8"/><line x1="16" y1="8" x2="32" y2="32"/><line x1="48" y1="8" x2="32" y2="32"/><line x1="32" y1="32" x2="16" y2="56"/><line x1="32" y1="32" x2="48" y2="56"/><line x1="16" y1="56" x2="48" y2="56"/>
          </svg>

          <!-- Content overlaying watermark -->
          <div class="relative text-center">
            <h3
              class="text-2xl font-bold mb-3"
              style="color: var(--text-primary); letter-spacing: -0.02em;"
            >
              O conteúdo fica acima da marca d’água
            </h3>
            <p class="text-sm" style="color: var(--text-tertiary);">
              A marca d’água da ampulheta em 3-5% de opacidade cria profundidade sem competir com o conteúdo.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 05: Dos and Don'ts -->
  <section style="background: var(--surface-1);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="05" title="Regras de Uso do Logo" />

      <div class="max-w-[900px]">
        <DosDonts items={[
          { type: 'do', text: 'Use a ampulheta em seções sobre tempo, eficiência, urgência e impacto da IA.' },
          { type: 'do', text: 'Use como marca d’água em 3-5% de opacidade (200-300px) atrás de seções-chave.' },
          { type: 'do', text: 'Posicione onde reforça a narrativa da seção que ancora.' },
          { type: 'do', text: 'Use apenas azul acento ou branco.' },
          { type: 'dont', text: 'Usar qualquer outro ícone como marca d’água. A ampulheta é a única marca visual.' },
          { type: 'dont', text: 'Animar a ampulheta com rotação ou flip. É um símbolo estático e ancorado.' },
          { type: 'dont', text: 'Forçar a ampulheta em toda seção mecanicamente. Use com intenção.' },
          { type: 'dont', text: 'Usar a ampulheta como bullet em texto corrido. É um elemento arquitetural.' },
          { type: 'dont', text: 'Adicionar sombras, gradientes ou efeitos 3D à marca.' },
          { type: 'dont', text: 'Usar gold, amber ou qualquer cor que não seja azul acento ou branco.' },
        ]} />
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Related Pages -->
  <RelatedPages links={relatedLinksMap['/brandbook/logo'] || []} />
</BrandbookLayout>
