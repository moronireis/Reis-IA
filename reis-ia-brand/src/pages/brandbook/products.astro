---
import BrandbookLayout from '../../layouts/BrandbookLayout.astro';
import RelatedPages from '../../components/RelatedPages.astro';
import { relatedLinksMap } from '../../data/navigation';
import SectionLabel from '../../components/SectionLabel.astro';
---

<BrandbookLayout
  title="Produtos REIS [IA]"
  pageName="PRODUTOS"
  description="Portfólio de produtos REIS [IA] organizado por pilar: Systems (implementação), Builders (mentoria e comunidade) e Marketing (crescimento)."
>
  <!-- Title Area -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-2xl);">
      <div class="max-w-[900px]">
        <!-- Triple badge -->
        <div class="flex flex-wrap gap-2 mb-6">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md" style="background: rgba(255, 255, 255, 0.06); border: 1px solid var(--border-visible);">
            <span class="font-mono text-[11px] font-bold uppercase tracking-wider" style="color: var(--text-secondary);">Systems</span>
          </div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md" style="background: rgba(45, 122, 255, 0.10); border: 1px solid rgba(45, 122, 255, 0.20);">
            <span class="font-mono text-[11px] font-bold uppercase tracking-wider" style="color: #2D7AFF;">Builders</span>
          </div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md" style="background: rgba(255, 255, 255, 0.06); border: 1px solid var(--border-visible);">
            <span class="font-mono text-[11px] font-bold uppercase tracking-wider" style="color: var(--text-secondary);">Marketing</span>
          </div>
        </div>

        <h1
          class="font-bold tracking-tight mb-6"
          style="font-size: var(--text-display); line-height: 1.05; letter-spacing: -0.03em; color: var(--text-primary); text-wrap: balance;"
        >
          Produtos
        </h1>
        <p
          class="max-w-[680px]"
          style="font-size: var(--text-body-lg); line-height: 1.6; color: var(--text-secondary); text-wrap: pretty;"
        >
          Três linhas de produto. Systems implementa IA dentro de empresas. Builders ensina profissionais a lucrar construindo e vendendo IA. Marketing gera crescimento mensurável.
        </p>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 01: Visão Geral dos Pilares -->
  <section style="background: var(--surface-1);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="01" title="Os Três Pilares" />

      <div class="max-w-[900px] space-y-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <!-- Systems -->
          <div class="p-6 rounded-xl border" style="background: var(--surface-2); border-color: var(--border-default);">
            <div class="font-semibold text-xl mb-1" style="color: var(--text-primary);">Systems</div>
            <p class="text-xs font-mono uppercase tracking-wider mb-3" style="color: var(--text-quaternary);">Implementação</p>
            <p class="text-sm" style="color: var(--text-secondary); line-height: 1.6;">
              Implementação de IA dentro de empresas. Para o C-Level e empresário que quer resultado prático, não projeto de tecnologia.
            </p>
            <div class="mt-4 pt-4 border-t" style="border-color: var(--border-default);">
              <p class="text-xs font-mono" style="color: var(--text-quaternary);">Protocol · Agent · Engine</p>
            </div>
          </div>

          <!-- Builders -->
          <div class="p-6 rounded-xl border" style="background: var(--surface-2); border-color: rgba(45, 122, 255, 0.15);">
            <div class="font-semibold text-xl mb-1" style="color: #2D7AFF;">Builders</div>
            <p class="text-xs font-mono uppercase tracking-wider mb-3" style="color: var(--text-quaternary);">Mentoria e Comunidade</p>
            <p class="text-sm" style="color: var(--text-secondary); line-height: 1.6;">
              Programa para profissionais que querem lucrar com IA construindo e vendendo projetos de agentes. Revenue-First.
            </p>
            <div class="mt-4 pt-4 border-t" style="border-color: rgba(45, 122, 255, 0.10);">
              <p class="text-xs font-mono" style="color: #2D7AFF;">Mentoria · Comunidade · Programa</p>
            </div>
          </div>

          <!-- Marketing -->
          <div class="p-6 rounded-xl border" style="background: var(--surface-2); border-color: var(--border-default);">
            <div class="font-semibold text-xl mb-1" style="color: var(--text-primary);">Marketing</div>
            <p class="text-xs font-mono uppercase tracking-wider mb-3" style="color: var(--text-quaternary);">Crescimento</p>
            <p class="text-sm" style="color: var(--text-secondary); line-height: 1.6;">
              Estratégia e execução de marketing com IA. Crescimento mensurável, não entregável genérico.
            </p>
            <div class="mt-4 pt-4 border-t" style="border-color: var(--border-default);">
              <p class="text-xs font-mono" style="color: var(--text-quaternary);">Estratégia · Execução · Crescimento</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 02: Systems — Protocol, Agent, Engine -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="02" title="Systems — Produtos" />

      <div class="max-w-[900px] space-y-8">
        <p class="max-w-[680px]" style="font-size: var(--text-body-lg); color: var(--text-secondary); line-height: 1.6;">
          O motor de implementação de IA. Para o empresário e C-Level que quer resultado prático — não projeto de tecnologia. Filosofia visual: sofisticação pela ausência de cor.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <!-- Protocol -->
          <div class="p-6 rounded-xl border" style="background: var(--surface-2); border-color: var(--border-default);">
            <div class="font-semibold text-xl mb-1" style="color: var(--text-primary);">Protocol</div>
            <p class="text-xs font-mono uppercase tracking-wider mb-3" style="color: var(--text-quaternary);">Diagnóstico</p>
            <p class="text-sm mb-4" style="color: var(--text-secondary); line-height: 1.6;">
              Diagnóstico estruturado. Mapeia onde o negócio está perdendo tempo e onde a IA pode recuperá-lo com maior retorno.
            </p>
            <div class="space-y-1 text-xs" style="color: var(--text-tertiary);">
              <p>Identifica 20-100+ h/mês de tempo recuperável</p>
              <p>Entregue em 1-2 semanas</p>
            </div>
          </div>

          <!-- Agent -->
          <div class="p-6 rounded-xl border" style="background: var(--surface-2); border-color: var(--border-default);">
            <div class="font-semibold text-xl mb-1" style="color: var(--text-primary);">Agent</div>
            <p class="text-xs font-mono uppercase tracking-wider mb-3" style="color: var(--text-quaternary);">Implementação Focada</p>
            <p class="text-sm mb-4" style="color: var(--text-secondary); line-height: 1.6;">
              Agente de IA único que elimina um dreno de tempo específico. Um problema, uma solução, deploy rápido.
            </p>
            <div class="space-y-1 text-xs" style="color: var(--text-tertiary);">
              <p>Recupera 10-40 h/mês</p>
              <p>Entregue em 2-4 semanas</p>
            </div>
          </div>

          <!-- Engine -->
          <div class="p-6 rounded-xl border" style="background: var(--surface-2); border-color: var(--border-default);">
            <div class="font-semibold text-xl mb-1" style="color: var(--text-primary);">Engine</div>
            <p class="text-xs font-mono uppercase tracking-wider mb-3" style="color: var(--text-quaternary);">Sistema Integrado</p>
            <p class="text-sm mb-4" style="color: var(--text-secondary); line-height: 1.6;">
              Sistema de IA integrado. Múltiplos agentes trabalhando juntos como infraestrutura unificada de recuperação de tempo.
            </p>
            <div class="space-y-1 text-xs" style="color: var(--text-tertiary);">
              <p>Recupera 40-100+ h/mês</p>
              <p>Entregue em 4-8 semanas</p>
            </div>
          </div>
        </div>

        <!-- Exemplos de Nomenclatura -->
        <div class="p-5 rounded-xl border" style="background: var(--surface-2); border-color: var(--border-default);">
          <div class="font-mono text-[11px] font-bold uppercase tracking-wider mb-3" style="color: var(--text-tertiary);">Exemplos de Nomenclatura</div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            {[
              { name: 'Revenue Engine', time: '60+ h/mês recuperadas' },
              { name: 'Support Agent', time: '47 h/mês recuperadas' },
              { name: 'Qualification Agent', time: '20 h/mês recuperadas' },
              { name: 'Revenue Protocol', time: 'Mapeia perdas em 2 semanas' },
            ].map(ex => (
              <div class="flex items-center justify-between p-3 rounded-lg" style="background: var(--surface-3);">
                <span class="text-sm font-medium" style="color: var(--text-primary);">REIS [IA] Systems {ex.name}</span>
                <span class="text-xs font-mono" style="color: var(--text-quaternary);">{ex.time}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 03: Builders — Programa e Comunidade -->
  <section style="background: var(--surface-1);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="03" title="Builders — Programa e Comunidade" />

      <div class="max-w-[900px] space-y-8">
        <div class="max-w-[680px]">
          <p style="font-size: var(--text-body-lg); color: var(--text-secondary); line-height: 1.6;">
            Para profissionais que querem lucrar com IA. Não como especialistas técnicos — como construtores de negócios que usam IA para criar e vender projetos com resultado financeiro real.
          </p>
        </div>

        <!-- Produto Principal -->
        <div class="p-6 rounded-xl border" style="background: var(--surface-2); border-color: rgba(45, 122, 255, 0.15);">
          <div class="font-mono text-[11px] font-bold uppercase tracking-wider mb-3" style="color: #2D7AFF;">Produto Principal</div>
          <h3 class="text-2xl font-bold mb-2" style="color: var(--text-primary);">Programa Builders</h3>
          <p class="text-sm mb-6" style="color: var(--text-secondary); line-height: 1.6;">
            Mentoria intensiva com construção real. O participante sai com um projeto entregue, uma oferta vendável e o primeiro cliente. Revenue-First do começo ao fim.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            {[
              { label: 'Foco', value: 'Projeto entregue a cliente real' },
              { label: 'Filosofia', value: 'Revenue-First. Construção antes de perfeição.' },
              { label: 'Resultado', value: 'Oferta vendável + receita ativa' },
            ].map(item => (
              <div class="p-4 rounded-lg" style="background: var(--surface-3);">
                <p class="text-xs font-mono uppercase tracking-wider mb-1" style="color: var(--text-quaternary);">{item.label}</p>
                <p class="text-sm font-medium" style="color: var(--text-primary);">{item.value}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Marcos de Reconhecimento -->
        <div>
          <h3 class="text-lg font-semibold mb-4" style="color: var(--text-secondary);">Marcos de Reconhecimento</h3>
          <div class="space-y-2">
            {[
              { badge: 'Entregou', req: 'Primeiro projeto de IA entregue a cliente real' },
              { badge: 'Clube 10K', req: 'R$ 10 mil acumulados com projetos de IA' },
              { badge: 'Operador 100K', req: 'R$ 100 mil acumulados com projetos de IA' },
              { badge: 'Referência', req: 'Alumni reconhecido no mercado. Mentora novos Builders.' },
            ].map(m => (
              <div class="flex items-center gap-4 p-3 rounded-lg" style="background: var(--surface-2);">
                <span class="font-mono text-sm font-bold flex-shrink-0" style="color: #2D7AFF;">{m.badge}</span>
                <span class="text-sm" style="color: var(--text-tertiary);">{m.req}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 04: Marketing — Estratégia e Crescimento -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="04" title="Marketing — Estratégia e Crescimento" />

      <div class="max-w-[900px] space-y-8">
        <div class="max-w-[680px]">
          <p style="font-size: var(--text-body-lg); color: var(--text-secondary); line-height: 1.6;">
            Estratégia e execução de marketing com IA. Para empresas que querem crescimento mensurável — não relatório de impressões.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {[
            {
              name: 'Estratégia',
              sub: 'Posicionamento e Plano',
              desc: 'Diagnóstico de posicionamento, mapeamento de canais, estratégia de aquisição com IA integrada. Começa pelo resultado financeiro esperado.',
            },
            {
              name: 'Execução',
              sub: 'Criação e Distribuição',
              desc: 'Produção e distribuição de conteúdo com IA. Funis, copy, automações de marketing. Velocidade de produção sem perda de qualidade.',
            },
            {
              name: 'Crescimento',
              sub: 'Escala e Otimização',
              desc: 'Otimização contínua baseada em dados. Escala de canais que funcionam. Eliminação do que não gera receita.',
            },
          ].map(p => (
            <div class="p-6 rounded-xl border" style="background: var(--surface-2); border-color: var(--border-default);">
              <div class="font-semibold text-xl mb-1" style="color: var(--text-primary);">{p.name}</div>
              <p class="text-xs font-mono uppercase tracking-wider mb-3" style="color: var(--text-quaternary);">{p.sub}</p>
              <p class="text-sm" style="color: var(--text-secondary); line-height: 1.6;">{p.desc}</p>
            </div>
          ))}
        </div>

        <!-- Exemplos de Nomenclatura -->
        <div class="p-5 rounded-xl border" style="background: var(--surface-2); border-color: var(--border-default);">
          <div class="font-mono text-[11px] font-bold uppercase tracking-wider mb-3" style="color: var(--text-tertiary);">Exemplos de Nomenclatura</div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            {[
              { name: 'Growth Strategy', desc: 'Posicionamento + plano de canais' },
              { name: 'Content Engine', desc: 'Produção de conteúdo com IA em escala' },
              { name: 'Acquisition System', desc: 'Funil de aquisição automatizado' },
              { name: 'Growth Protocol', desc: 'Diagnóstico de crescimento em 2 semanas' },
            ].map(ex => (
              <div class="flex items-center justify-between p-3 rounded-lg" style="background: var(--surface-3);">
                <span class="text-sm font-medium" style="color: var(--text-primary);">REIS [IA] Marketing {ex.name}</span>
                <span class="text-xs font-mono" style="color: var(--text-quaternary);">{ex.desc}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 05: Naming -->
  <section style="background: var(--surface-1);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="05" title="Naming" />

      <div class="max-w-[680px] space-y-8">
        <!-- Nomes Travados -->
        <div>
          <h3 class="text-lg font-semibold mb-4" style="color: var(--text-secondary);">Nomes Travados</h3>
          <div class="space-y-2">
            {[
              { name: 'REIS [IA]', rule: 'Sempre com colchetes em contextos formais. Nunca "Reis IA" sem os colchetes na marca principal.' },
              { name: 'Builders', rule: 'Sempre em inglês. Nunca traduzir para "Construtores." Sempre com B maiúsculo.' },
              { name: 'Systems', rule: 'Sempre "REIS [IA] Systems" como nome completo em contextos formais.' },
              { name: 'Marketing', rule: 'Sempre "REIS [IA] Marketing" como nome completo em contextos formais.' },
              { name: 'Protocol', rule: 'Sempre com P maiúsculo. Produto Systems.' },
              { name: 'Agent', rule: 'Sempre com A maiúsculo. Produto Systems.' },
              { name: 'Engine', rule: 'Sempre com E maiúsculo. Produto Systems.' },
            ].map(n => (
              <div class="flex items-start gap-4 p-3 rounded-lg" style="background: var(--surface-2);">
                <span class="font-mono text-sm font-bold flex-shrink-0 w-28" style="color: var(--text-primary);">{n.name}</span>
                <span class="text-sm" style="color: var(--text-tertiary);">{n.rule}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Related Pages -->
  <RelatedPages links={relatedLinksMap['/brandbook/products'] || []} />
</BrandbookLayout>
