---
import BrandbookLayout from '../../layouts/BrandbookLayout.astro';
import RelatedPages from '../../components/RelatedPages.astro';
import { relatedLinksMap } from '../../data/navigation';
import SectionLabel from '../../components/SectionLabel.astro';
import CopyButton from '../../components/CopyButton.tsx';
---

<BrandbookLayout
  title="Sistema de Ícones"
  pageName="SISTEMA DE ÍCONES"
  description="Especificação Lucide Icons — 5 tamanhos, 5 variantes de cor e diretrizes de uso."
>
  <!-- Title Area -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-2xl);">
      <div class="max-w-[900px]">
        <h1
          class="font-bold tracking-tight mb-6"
          style="font-size: var(--text-display); line-height: 1.05; letter-spacing: -0.03em; color: var(--text-primary); text-wrap: balance;"
        >
          Sistema de Ícones
        </h1>
        <p
          class="max-w-[680px]"
          style="font-size: var(--text-body-lg); line-height: 1.6; color: var(--text-secondary); text-wrap: pretty;"
        >
          A Reis IA usa Lucide Icons — uma biblioteca de ícones com traço consistente,
          viewBox 24x24, traço 2px e terminações arredondadas. A estética apenas traço complementa nossa marca de arte minimalista.
        </p>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 01: Icon Sizes -->
  <section style="background: var(--surface-1);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="01" title="Tamanhos de Ícones" />

      <p class="text-sm mb-8 max-w-[680px]" style="color: var(--text-tertiary); text-wrap: pretty;">
        Cinco tokens de tamanho de 12px a 32px. A largura do traço permanece em 2px em todos os tamanhos. Cada tamanho tem um caso de uso específico.
      </p>

      <div
        class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-[1px] rounded-xl border overflow-hidden mb-8"
        style="background: var(--border-default); border-color: var(--border-default);"
      >
        {[
          { name: 'XS', size: '12', px: '12px', cssVar: '--icon-xs', cssClass: '.icon-xs', usage: 'Inline with small text' },
          { name: 'SM', size: '16', px: '16px', cssVar: '--icon-sm', cssClass: '.icon-sm', usage: 'Buttons, badges' },
          { name: 'MD', size: '20', px: '20px', cssVar: '--icon-md', cssClass: '.icon-md', usage: 'Default UI, nav' },
          { name: 'LG', size: '24', px: '24px', cssVar: '--icon-lg', cssClass: '.icon-lg', usage: 'Card headers' },
          { name: 'XL', size: '32', px: '32px', cssVar: '--icon-xl', cssClass: '.icon-xl', usage: 'Hero features' },
        ].map(icon => (
          <div class="p-6 flex flex-col items-center text-center" style="background: var(--surface-1);">
            <!-- Live icon at the specified size -->
            <div class="h-12 flex items-center justify-center mb-4">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                style={`width: ${icon.px}; height: ${icon.px}; color: var(--accent-blue);`}
                aria-hidden="true"
              >
                <circle cx="11" cy="11" r="8" />
                <path d="m21 21-4.3-4.3" />
              </svg>
            </div>
            <div class="font-mono text-[11px] font-bold mb-1" style="color: var(--text-primary);">
              {icon.name}
            </div>
            <div class="font-mono text-[10px] mb-1" style="color: var(--text-quaternary);">
              {icon.px}
            </div>
            <div class="flex items-center justify-center gap-1 mb-2">
              <code class="text-[10px]" style="background: none; border: none; padding: 0; color: var(--text-tertiary);">
                {icon.cssClass}
              </code>
              <CopyButton client:visible text={icon.cssClass} />
            </div>
            <span class="text-[10px]" style="color: var(--text-quaternary);">{icon.usage}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 02: Color Variants -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="02" title="Variantes de Cor" />

      <p class="text-sm mb-8 max-w-[680px]" style="color: var(--text-tertiary); text-wrap: pretty;">
        Ícones herdam a cor do elemento pai via <code>currentColor</code>. Cinco classes CSS fornecem variantes de cor semânticas.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
        {[
          { name: 'Default', cssClass: '.icon-default', colorVar: '--text-secondary', desc: '70% white', usage: 'Standard UI icons' },
          { name: 'Primary', cssClass: '.icon-primary', colorVar: '--text-primary', desc: '#FFFFFF', usage: 'Emphasized, active' },
          { name: 'Accent', cssClass: '.icon-accent', colorVar: '--accent-blue', desc: '#4A90FF', usage: 'Brand, CTA indicators' },
          { name: 'Muted', cssClass: '.icon-muted', colorVar: '--text-quaternary', desc: '35% white', usage: 'Decorative, disabled' },
          { name: 'Error', cssClass: '.icon-error', colorVar: '--color-error', desc: '#EF4444', usage: 'Error indicators' },
        ].map(variant => (
          <div
            class="p-5 rounded-xl border text-center"
            style="background: var(--surface-2); border-color: var(--border-default);"
          >
            <div class="flex justify-center mb-4">
              <!-- Demo: multiple icons in this color -->
              <div class="flex gap-3" style={`color: var(${variant.colorVar});`}>
                <svg class="icon-lg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10" />
                </svg>
                <svg class="icon-lg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                </svg>
                <svg class="icon-lg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 2L2 7l10 5 10-5-10-5z" /><path d="M2 17l10 5 10-5" /><path d="M2 12l10 5 10-5" />
                </svg>
              </div>
            </div>
            <div class="font-mono text-xs font-semibold mb-1" style="color: var(--text-primary);">
              {variant.name}
            </div>
            <div class="flex items-center justify-center gap-1 mb-1">
              <code class="text-[10px]" style="background: none; border: none; padding: 0; color: var(--text-tertiary);">
                {variant.cssClass}
              </code>
              <CopyButton client:visible text={variant.cssClass} />
            </div>
            <div class="text-[10px]" style="color: var(--text-quaternary);">{variant.desc}</div>
            <div class="text-[10px] mt-1" style="color: var(--text-tertiary);">{variant.usage}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 03: Usage Rules -->
  <section style="background: var(--surface-1);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="03" title="Regras de Uso" />

      <div class="max-w-[680px] space-y-6">
        <div
          class="p-6 rounded-xl border"
          style="background: var(--surface-2); border-color: var(--border-default);"
        >
          <h4 class="text-sm font-semibold mb-4" style="color: var(--text-primary);">Icon System Rules</h4>
          <ul class="space-y-3 text-sm" style="color: var(--text-secondary);">
            <li class="flex items-start gap-3">
              <span class="font-mono text-[11px] font-bold flex-shrink-0 mt-0.5" style="color: var(--accent-blue);">01</span>
              <span><strong>Stroke width</strong>: 2px at all sizes (Lucide default). Do not adjust stroke-width per size.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="font-mono text-[11px] font-bold flex-shrink-0 mt-0.5" style="color: var(--accent-blue);">02</span>
              <span><strong>Line caps and joins</strong>: Round caps, round joins. No square or butt caps.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="font-mono text-[11px] font-bold flex-shrink-0 mt-0.5" style="color: var(--accent-blue);">03</span>
              <span><strong>Color inheritance</strong>: Icons use <code>currentColor</code> to inherit from parent text color.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="font-mono text-[11px] font-bold flex-shrink-0 mt-0.5" style="color: var(--accent-blue);">04</span>
              <span><strong>Minimum touch target</strong>: 44x44px container for interactive icons (the icon itself may be smaller).</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="font-mono text-[11px] font-bold flex-shrink-0 mt-0.5" style="color: var(--accent-blue);">05</span>
              <span><strong>Rendering</strong>: Inline SVG preferred over icon fonts (better accessibility, no FOUT).</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="font-mono text-[11px] font-bold flex-shrink-0 mt-0.5" style="color: var(--accent-blue);">06</span>
              <span><strong>Alignment</strong>: Icons align to the center of adjacent text's x-height, not the baseline. Use the <code>.icon-inline</code> helper class.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 04: Sample Icons -->
  <section style="background: var(--surface-0);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="04" title="Conjunto de Ícones" />

      <p class="text-sm mb-8 max-w-[680px]" style="color: var(--text-tertiary); text-wrap: pretty;">
        Uma seleção de ícones Lucide comumente usados no ecossistema Reis IA. Todos os ícones renderizam no tamanho padrão MD (20px) com cor de acento.
      </p>

      <div
        class="grid grid-cols-4 sm:grid-cols-6 md:grid-cols-8 gap-[1px] rounded-xl border overflow-hidden"
        style="background: var(--border-default); border-color: var(--border-default);"
      >
        {[
          { name: 'ArrowRight', path: '<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>' },
          { name: 'Check', path: '<polyline points="20 6 9 17 4 12"/>' },
          { name: 'ChevronDown', path: '<path d="m6 9 6 6 6-6"/>' },
          { name: 'Copy', path: '<rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>' },
          { name: 'Search', path: '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>' },
          { name: 'Menu', path: '<line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/>' },
          { name: 'X', path: '<path d="M18 6 6 18"/><path d="m6 6 12 12"/>' },
          { name: 'Settings', path: '<path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/>' },
          { name: 'Shield', path: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/>' },
          { name: 'Zap', path: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>' },
          { name: 'Layers', path: '<path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/>' },
          { name: 'Activity', path: '<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>' },
          { name: 'Eye', path: '<path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/>' },
          { name: 'Clock', path: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>' },
          { name: 'Calendar', path: '<path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/>' },
          { name: 'Brain', path: '<path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/><path d="M3.477 10.896a4 4 0 0 1 .585-.396"/><path d="M19.938 10.5a4 4 0 0 1 .585.396"/><path d="M6 18a4 4 0 0 1-1.967-.516"/><path d="M19.967 17.484A4 4 0 0 1 18 18"/>' },
        ].map(icon => (
          <div
            class="p-4 flex flex-col items-center justify-center min-h-[80px] transition-colors duration-200 hover:bg-[var(--surface-2)]"
            style="background: var(--surface-1);"
          >
            <svg
              class="icon-md icon-accent mb-2"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              set:html={icon.path}
            />
            <span class="text-[9px] font-mono" style="color: var(--text-quaternary);">{icon.name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Section 05: Code Example -->
  <section style="background: var(--surface-1);">
    <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-3xl);">
      <SectionLabel number="05" title="Implementação" />

      <div class="max-w-[680px]">
        <h3 class="text-lg font-semibold mb-4" style="color: var(--text-primary);">Inline SVG Pattern</h3>
        <div
          class="rounded-xl border overflow-hidden"
          style="border-color: var(--border-default);"
        >
          <div
            class="px-4 py-2 border-b font-mono text-[11px]"
            style="background: var(--surface-3); border-color: var(--border-default); color: var(--text-tertiary);"
          >
            Astro / HTML
          </div>
          <pre
            class="p-4 overflow-x-auto text-sm"
            style="background: var(--surface-2); color: var(--text-secondary);"
          ><code class="font-mono text-[13px]" style="background: none; border: none; padding: 0;">&lt;svg
  class="icon-md icon-accent"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
&gt;
  &lt;polyline points="20 6 9 17 4 12" /&gt;
&lt;/svg&gt;</code></pre>
        </div>

        <h3 class="text-lg font-semibold mt-8 mb-4" style="color: var(--text-primary);">CSS Classes</h3>
        <div
          class="rounded-xl border overflow-hidden"
          style="border-color: var(--border-default);"
        >
          <div
            class="px-4 py-2 border-b font-mono text-[11px]"
            style="background: var(--surface-3); border-color: var(--border-default); color: var(--text-tertiary);"
          >
            CSS
          </div>
          <pre
            class="p-4 overflow-x-auto text-sm"
            style="background: var(--surface-2); color: var(--text-secondary);"
          ><code class="font-mono text-[13px]" style="background: none; border: none; padding: 0;">/* Sizes */
.icon-xs  &#123; width: 12px; height: 12px; &#125;
.icon-sm  &#123; width: 16px; height: 16px; &#125;
.icon-md  &#123; width: 20px; height: 20px; &#125;
.icon-lg  &#123; width: 24px; height: 24px; &#125;
.icon-xl  &#123; width: 32px; height: 32px; &#125;

/* Colors */
.icon-default &#123; color: var(--text-secondary); &#125;
.icon-primary &#123; color: var(--text-primary); &#125;
.icon-accent  &#123; color: var(--accent-blue); &#125;
.icon-muted   &#123; color: var(--text-quaternary); &#125;
.icon-error   &#123; color: var(--color-error); &#125;

/* Inline alignment */
.icon-inline &#123;
  display: inline-flex;
  align-items: center;
  vertical-align: -0.125em;
&#125;</code></pre>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-divider"></div>

  <!-- Related Pages -->
  <RelatedPages links={relatedLinksMap['/brandbook/icons'] || []} />
</BrandbookLayout>
