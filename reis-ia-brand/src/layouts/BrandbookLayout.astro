---
/**
 * Layout for brandbook/design-system pages.
 * Adds the Page Header Bar and consistent section padding.
 */
import BaseLayout from './BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

interface Props {
  title: string;
  pageName: string;
  description?: string;
}

const { title, pageName, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <PageHeader pageName={pageName} />
  <slot />
</BaseLayout>
