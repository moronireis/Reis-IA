---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '@fontsource-variable/inter';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Reis IA Design System — the single source of truth for brand identity, design tokens, components, and patterns.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark" />
    <title>{title} — Reis IA Design System</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen" style="background: var(--surface-0); color: var(--text-primary);">
    <Header />
    <!-- Spacer for fixed header -->
    <div class="h-[60px]" aria-hidden="true"></div>
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
