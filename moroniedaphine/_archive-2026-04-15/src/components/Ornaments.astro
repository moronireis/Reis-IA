---
// Collection of SVG ornaments used across the site
---

<svg xmlns="http://www.w3.org/2000/svg" style="display:none">
  <!-- Monogram M&D -->
  <symbol id="orn-monogram" viewBox="0 0 120 120">
    <circle cx="60" cy="60" r="56" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.5"/>
    <circle cx="60" cy="60" r="52" fill="none" stroke="currentColor" stroke-width="0.3" opacity="0.3"/>
    <g font-family="Pinyon Script, cursive" font-size="58" fill="currentColor" text-anchor="middle">
      <text x="42" y="72">M</text>
      <text x="78" y="72">D</text>
    </g>
    <path d="M 30 94 Q 60 102 90 94" fill="none" stroke="currentColor" stroke-width="0.6" opacity="0.6"/>
  </symbol>

  <!-- Floral divider -->
  <symbol id="orn-floral-divider" viewBox="0 0 300 40">
    <line x1="10" y1="20" x2="120" y2="20" stroke="currentColor" stroke-width="0.6"/>
    <line x1="180" y1="20" x2="290" y2="20" stroke="currentColor" stroke-width="0.6"/>
    <g transform="translate(150 20)">
      <circle r="3" fill="currentColor"/>
      <g fill="none" stroke="currentColor" stroke-width="0.8">
        <path d="M 0 -12 Q 4 -6 0 0 Q -4 -6 0 -12"/>
        <path d="M 0 12 Q 4 6 0 0 Q -4 6 0 12"/>
        <path d="M -12 0 Q -6 -4 0 0 Q -6 4 -12 0"/>
        <path d="M 12 0 Q 6 -4 0 0 Q 6 4 12 0"/>
        <path d="M -8 -8 Q -3 -5 0 0 Q -5 -3 -8 -8"/>
        <path d="M 8 8 Q 3 5 0 0 Q 5 3 8 8"/>
        <path d="M -8 8 Q -3 5 0 0 Q -5 3 -8 8"/>
        <path d="M 8 -8 Q 3 -5 0 0 Q 5 -3 8 -8"/>
      </g>
      <circle r="1.5" fill="currentColor"/>
    </g>
    <circle cx="120" cy="20" r="1.5" fill="currentColor"/>
    <circle cx="180" cy="20" r="1.5" fill="currentColor"/>
  </symbol>

  <!-- Diamond divider -->
  <symbol id="orn-diamond-divider" viewBox="0 0 240 20">
    <line x1="5" y1="10" x2="105" y2="10" stroke="currentColor" stroke-width="0.5"/>
    <line x1="135" y1="10" x2="235" y2="10" stroke="currentColor" stroke-width="0.5"/>
    <g transform="translate(120 10)">
      <path d="M 0 -6 L 6 0 L 0 6 L -6 0 Z" fill="none" stroke="currentColor" stroke-width="0.7"/>
      <circle r="1" fill="currentColor"/>
    </g>
  </symbol>

  <!-- Large floral ornament (background) -->
  <symbol id="orn-floral-large" viewBox="0 0 200 200">
    <g fill="none" stroke="currentColor" stroke-width="0.6" opacity="0.8">
      <circle cx="100" cy="100" r="6"/>
      <g transform="translate(100 100)">
        <path d="M 0 -80 Q 20 -40 0 0 Q -20 -40 0 -80"/>
        <path d="M 0 80 Q 20 40 0 0 Q -20 40 0 80"/>
        <path d="M -80 0 Q -40 -20 0 0 Q -40 20 -80 0"/>
        <path d="M 80 0 Q 40 -20 0 0 Q 40 20 80 0"/>
        <path d="M -56 -56 Q -20 -30 0 0 Q -30 -20 -56 -56"/>
        <path d="M 56 56 Q 20 30 0 0 Q 30 20 56 56"/>
        <path d="M -56 56 Q -20 30 0 0 Q -30 20 -56 56"/>
        <path d="M 56 -56 Q 20 -30 0 0 Q 30 -20 56 -56"/>
        <circle r="30"/>
        <circle r="50"/>
      </g>
    </g>
  </symbol>

  <!-- Scroll indicator -->
  <symbol id="orn-scroll" viewBox="0 0 20 40">
    <rect x="6" y="2" width="8" height="24" rx="4" fill="none" stroke="currentColor" stroke-width="0.8"/>
    <circle cx="10" cy="10" r="1.5" fill="currentColor">
      <animate attributeName="cy" values="8;16;8" dur="2s" repeatCount="indefinite"/>
    </circle>
    <path d="M 4 32 L 10 38 L 16 32" fill="none" stroke="currentColor" stroke-width="0.8"/>
  </symbol>
</svg>
