---
import Layout from '../layouts/Layout.astro';

const historia = [
  { ano: 'Capítulo I',   titulo: 'Onde tudo começou',     texto: 'Placeholder — conte aqui como se conheceram. Esse texto será substituído quando você enviar a versão real. Deixe-o pessoal, curto, e com um detalhe que só vocês dois lembrariam.' },
  { ano: 'Capítulo II',  titulo: 'O primeiro olhar',      texto: 'Placeholder — o momento em que perceberam que algo havia mudado. Um parágrafo que faça quem lê sorrir sem entender bem por quê.' },
  { ano: 'Capítulo III', titulo: 'Construindo juntos',    texto: 'Placeholder — os anos em que a vida começou a caber no plural. As escolhas, as mudanças, o "nós" tomando forma.' },
  { ano: 'Capítulo IV',  titulo: 'O pedido',              texto: 'Placeholder — como foi o pedido. Onde, quando, a reação. Esse é o capítulo que vira a virada de página definitiva.' },
  { ano: 'Capítulo V',   titulo: 'O sim',                 texto: '12 de junho de 2026. O dia em que dizemos sim diante das pessoas que construíram essa história com a gente.' },
];

const presentes = [
  { nome: 'Lua de Mel',         descricao: 'Contribua com a viagem dos nossos sonhos',    valor: 'Qualquer valor' },
  { nome: 'Jantar Especial',    descricao: 'Um jantar inesquecível na nossa nova casa',   valor: 'R$ 250' },
  { nome: 'Cozinha',            descricao: 'Panelas, eletrodomésticos e utensílios',       valor: 'R$ 500' },
  { nome: 'Enxoval',            descricao: 'Cama, mesa e banho',                           valor: 'R$ 350' },
  { nome: 'Decoração',          descricao: 'Para deixar nosso lar com a nossa cara',       valor: 'R$ 400' },
  { nome: 'Presente Livre',     descricao: 'Contribua com o que sentir no coração',        valor: 'Qualquer valor' },
];

const chavePix = 'chave-pix-aqui@email.com';

const nomeMoroni = 'Moroni'.split('');
const nomeDaphine = 'Daphine'.split('');
---

<Layout>
  <main class="overflow-x-hidden bg-[var(--color-ivory)]">

    <!-- ━━━━━━━━━━━━━━━━ HERO ━━━━━━━━━━━━━━━━ -->
    <section class="relative min-h-screen flex flex-col items-center justify-center px-6 text-center grain">
      <!-- Background ornament -->
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-[0.06]">
        <svg class="w-[900px] h-[900px] text-[var(--color-wine-700)]" aria-hidden="true">
          <use href="#orn-floral-large" />
        </svg>
      </div>

      <!-- Corner frames -->
      <div class="absolute top-8 left-8 right-8 bottom-8 corner-frame pointer-events-none hidden md:block"></div>

      <div class="relative z-10 max-w-5xl py-20">
        <!-- Monogram -->
        <div class="flex justify-center mb-10">
          <svg class="w-20 h-20 text-[var(--color-gold-700)]" aria-hidden="true">
            <use href="#orn-monogram" />
          </svg>
        </div>

        <p class="label mb-12 reveal in">Save the Date</p>

        <!-- Names with letter reveal -->
        <h1 class="font-display text-[clamp(4rem,14vw,11rem)] leading-[0.88] text-[var(--color-wine-700)] font-[300]">
          <span class="block">
            {nomeMoroni.map((l, i) => (
              <span class="letter-mask"><span style={`animation-delay: ${i * 60}ms`}>{l}</span></span>
            ))}
          </span>
          <span class="block my-2 md:my-4">
            <span class="font-script text-[var(--color-gold-700)] text-[0.7em] inline-block gold-shimmer">&amp;</span>
          </span>
          <span class="block">
            {nomeDaphine.map((l, i) => (
              <span class="letter-mask"><span style={`animation-delay: ${(i + 2) * 60 + 400}ms`}>{l}</span></span>
            ))}
          </span>
        </h1>

        <!-- Floral divider -->
        <div class="flex justify-center my-14 reveal reveal-delay-3 in">
          <svg class="w-[280px] h-10 text-[var(--color-gold-700)] ornament-draw" aria-hidden="true">
            <use href="#orn-floral-divider" />
          </svg>
        </div>

        <!-- Date in Roman numerals + arabic -->
        <div class="reveal reveal-delay-3 in">
          <p class="font-display italic text-2xl md:text-3xl text-[var(--color-wine-800)] tracking-[0.3em]">
            XII · VI · MMXXVI
          </p>
          <p class="mt-2 text-sm text-[var(--color-ink)]/50 tracking-[0.35em] uppercase">12 de Junho de 2026</p>
        </div>

        <!-- Countdown -->
        <div id="countdown" class="mt-16 grid grid-cols-4 gap-2 md:gap-8 max-w-xl mx-auto reveal reveal-delay-4 in"></div>

        <!-- Invite note -->
        <p class="mt-16 max-w-md mx-auto font-display italic text-lg text-[var(--color-ink)]/60 leading-relaxed reveal reveal-delay-4 in">
          "O convite chegará às suas mãos. Por ora, guarde a data — guarde o coração."
        </p>

        <!-- Scroll indicator -->
        <a href="#historia" class="inline-block mt-20 text-[var(--color-wine-700)]/50 hover:text-[var(--color-wine-700)] transition">
          <svg class="w-5 h-10 mx-auto" aria-hidden="true"><use href="#orn-scroll"/></svg>
          <span class="block mt-3 text-[0.6rem] uppercase tracking-[0.4em]">Nossa história</span>
        </a>
      </div>
    </section>

    <!-- ━━━━━━━━━━━━━━━━ MARQUEE ━━━━━━━━━━━━━━━━ -->
    <div class="bg-[var(--color-wine-800)] py-6 border-y border-[var(--color-gold-700)]/30 overflow-hidden">
      <div class="marquee">
        <div class="marquee__track font-display italic text-3xl md:text-5xl text-[var(--color-gold-500)]">
          {Array.from({length: 8}).map(() => (
            <span class="flex items-center gap-12">
              Moroni <span class="font-script gold-shimmer">&amp;</span> Daphine
              <span class="text-[var(--color-gold-700)]">✦</span>
              12 · VI · 2026
              <span class="text-[var(--color-gold-700)]">✦</span>
            </span>
          ))}
        </div>
      </div>
    </div>

    <!-- ━━━━━━━━━━━━━━━━ HISTÓRIA ━━━━━━━━━━━━━━━━ -->
    <section id="historia" class="py-32 md:py-48 px-6 bg-[var(--color-cream)] relative grain">
      <div class="max-w-6xl mx-auto relative">
        <!-- Section header -->
        <div class="text-center mb-24 reveal">
          <p class="label mb-6">Uma história em capítulos</p>
          <h2 class="font-display italic text-[clamp(3rem,7vw,5.5rem)] text-[var(--color-wine-700)] mb-8 font-[300]">
            Nossa história
          </h2>
          <svg class="w-[240px] h-5 mx-auto text-[var(--color-gold-700)]" aria-hidden="true">
            <use href="#orn-diamond-divider" />
          </svg>
        </div>

        <!-- Timeline -->
        <div class="relative">
          <div class="absolute left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-[var(--color-gold-700)]/40 to-transparent hidden md:block"></div>

          {historia.map((item, i) => (
            <div class={`relative mb-24 md:mb-40 flex flex-col ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'} items-center gap-10 reveal`}>
              <div class="md:w-1/2 md:px-12">
                <div class={`${i % 2 === 0 ? 'md:text-right' : 'md:text-left'}`}>
                  <p class="font-script text-4xl text-[var(--color-gold-700)] mb-3">{item.ano}</p>
                  <h3 class="font-display italic text-4xl md:text-5xl text-[var(--color-wine-700)] mb-6 font-[300]">{item.titulo}</h3>
                  <div class="flex mb-6 ${i % 2 === 0 ? 'justify-end' : 'justify-start'}">
                    <svg class={`w-32 h-4 text-[var(--color-gold-700)] ${i % 2 === 0 ? 'ml-auto' : ''}`} aria-hidden="true">
                      <use href="#orn-diamond-divider" />
                    </svg>
                  </div>
                  <p class="drop-cap text-[var(--color-ink)]/75 leading-[1.9] text-[1.05rem]">{item.texto}</p>
                </div>
              </div>
              <div class="md:w-1/2 md:px-12">
                <div class="relative corner-frame p-3">
                  <div class="aspect-[4/5] bg-gradient-to-br from-[var(--color-wine-700)]/8 via-[var(--color-parchment)] to-[var(--color-gold-700)]/10 flex items-center justify-center relative overflow-hidden grain">
                    <div class="text-center">
                      <svg class="w-16 h-16 mx-auto text-[var(--color-wine-700)]/30 mb-4" aria-hidden="true">
                        <use href="#orn-monogram" />
                      </svg>
                      <span class="font-display italic text-[var(--color-wine-700)]/40 text-lg">em breve</span>
                    </div>
                  </div>
                </div>
              </div>
              <!-- Timeline dot -->
              <div class="hidden md:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 items-center justify-center">
                <div class="w-3 h-3 rounded-full bg-[var(--color-gold-700)]"></div>
                <div class="absolute w-8 h-8 rounded-full border border-[var(--color-gold-700)]/40"></div>
                <div class="absolute w-14 h-14 rounded-full border border-[var(--color-gold-700)]/15"></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ━━━━━━━━━━━━━━━━ SAVE THE DATE ━━━━━━━━━━━━━━━━ -->
    <section class="py-32 md:py-48 px-6 bg-[var(--color-wine-900)] text-[var(--color-ivory)] relative overflow-hidden grain">
      <!-- Background ornament -->
      <div class="absolute inset-0 flex items-center justify-center opacity-[0.08]">
        <svg class="w-[1100px] h-[1100px] text-[var(--color-gold-500)]" aria-hidden="true">
          <use href="#orn-floral-large" />
        </svg>
      </div>

      <div class="max-w-4xl mx-auto text-center relative z-10">
        <p class="label mb-8" style="color: var(--color-gold-500)">O grande dia</p>

        <!-- Ornamental date -->
        <div class="inline-block relative py-12 px-16">
          <div class="absolute inset-0 corner-frame" style="--tw-border-opacity: 1"></div>

          <p class="font-display italic text-[clamp(1.5rem,3vw,2.5rem)] text-[var(--color-gold-500)] mb-4">Sábado</p>

          <div class="font-display text-[clamp(8rem,22vw,18rem)] leading-[0.85] font-[300] gold-shimmer">
            12
          </div>

          <p class="font-script text-[clamp(3rem,7vw,5rem)] text-[var(--color-gold-500)] -mt-4">Junho</p>

          <p class="mt-6 font-display italic text-2xl md:text-3xl text-[var(--color-ivory)]/80 tracking-[0.3em]">MMXXVI</p>
        </div>

        <div class="flex justify-center my-14">
          <svg class="w-[280px] h-10 text-[var(--color-gold-500)]" aria-hidden="true">
            <use href="#orn-floral-divider" />
          </svg>
        </div>

        <p class="font-display italic text-xl md:text-2xl leading-[1.7] text-[var(--color-ivory)]/90 max-w-2xl mx-auto">
          Decidimos celebrar esse momento de forma íntima, ao lado das pessoas que fazem parte da nossa história.
        </p>
        <p class="mt-8 text-sm text-[var(--color-gold-300)]/80 tracking-[0.2em] uppercase">
          O convite será enviado individualmente
        </p>
      </div>
    </section>

    <!-- ━━━━━━━━━━━━━━━━ GALERIA ━━━━━━━━━━━━━━━━ -->
    <section class="py-32 md:py-48 px-6 bg-[var(--color-ivory)] grain relative">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-20 reveal">
          <p class="label mb-6">Momentos</p>
          <h2 class="font-display italic text-[clamp(3rem,7vw,5.5rem)] text-[var(--color-wine-700)] mb-8 font-[300]">
            Em imagens
          </h2>
          <svg class="w-[240px] h-5 mx-auto text-[var(--color-gold-700)]" aria-hidden="true">
            <use href="#orn-diamond-divider" />
          </svg>
        </div>

        <div class="grid grid-cols-12 gap-4 md:gap-6">
          {[
            'col-span-12 md:col-span-7 row-span-2 aspect-[4/5]',
            'col-span-6 md:col-span-5 aspect-square',
            'col-span-6 md:col-span-5 aspect-square',
            'col-span-6 md:col-span-4 aspect-[3/4]',
            'col-span-6 md:col-span-4 aspect-[3/4]',
            'col-span-12 md:col-span-4 aspect-[3/4]',
          ].map((cls, i) => (
            <div class={`${cls} corner-frame p-2 reveal`}>
              <div class="w-full h-full bg-gradient-to-br from-[var(--color-wine-700)]/10 via-[var(--color-parchment)] to-[var(--color-gold-700)]/15 flex items-center justify-center grain relative">
                <span class="font-display italic text-[var(--color-wine-700)]/30 text-xl">momento {String(i+1).padStart(2,'0')}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ━━━━━━━━━━━━━━━━ PRESENTES ━━━━━━━━━━━━━━━━ -->
    <section id="presentes" class="py-32 md:py-48 px-6 bg-[var(--color-cream)] grain relative">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-20 reveal">
          <p class="label mb-6">Com carinho</p>
          <h2 class="font-display italic text-[clamp(3rem,7vw,5.5rem)] text-[var(--color-wine-700)] mb-8 font-[300]">
            Lista de presentes
          </h2>
          <svg class="w-[280px] h-10 mx-auto text-[var(--color-gold-700)]" aria-hidden="true">
            <use href="#orn-floral-divider" />
          </svg>
          <p class="mt-10 max-w-2xl mx-auto font-display italic text-xl text-[var(--color-ink)]/65 leading-[1.7]">
            Sua presença é o que mais importa. Mas, se quiser contribuir com o início da nossa vida a dois, preparamos uma pequena lista com carinho.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {presentes.map(p => (
            <article class="group corner-frame p-4 bg-[var(--color-ivory)] reveal hover:translate-y-[-4px] transition-transform duration-700">
              <div class="border border-[var(--color-gold-700)]/20 p-6">
                <div class="aspect-square bg-gradient-to-br from-[var(--color-wine-700)]/8 via-[var(--color-parchment)] to-[var(--color-gold-700)]/15 mb-6 flex items-center justify-center grain relative">
                  <svg class="w-14 h-14 text-[var(--color-wine-700)]/30" aria-hidden="true">
                    <use href="#orn-monogram" />
                  </svg>
                </div>
                <p class="label text-center mb-3">{p.valor}</p>
                <h3 class="font-display italic text-3xl text-[var(--color-wine-700)] text-center mb-3 font-[400]">{p.nome}</h3>
                <div class="flex justify-center mb-4">
                  <svg class="w-24 h-3 text-[var(--color-gold-700)]" aria-hidden="true"><use href="#orn-diamond-divider" /></svg>
                </div>
                <p class="text-sm text-[var(--color-ink)]/60 text-center leading-relaxed mb-8 italic">{p.descricao}</p>
                <button
                  data-presente={p.nome}
                  class="presentear-btn w-full py-4 border border-[var(--color-wine-700)] text-[var(--color-wine-700)] text-[0.65rem] uppercase tracking-[0.3em] hover:bg-[var(--color-wine-700)] hover:text-[var(--color-ivory)] transition-all duration-500"
                >
                  Presentear via Pix
                </button>
              </div>
            </article>
          ))}
        </div>

        <p class="text-center mt-16 text-sm text-[var(--color-ink)]/50 italic font-display">
          Em breve disponibilizaremos também pagamento via cartão de crédito.
        </p>
      </div>
    </section>

    <!-- ━━━━━━━━━━━━━━━━ RECADOS ━━━━━━━━━━━━━━━━ -->
    <section class="py-32 md:py-48 px-6 bg-[var(--color-ivory)] grain relative">
      <div class="max-w-2xl mx-auto text-center">
        <p class="label mb-6 reveal">Deixe um recado</p>
        <h2 class="font-display italic text-[clamp(3rem,7vw,5.5rem)] text-[var(--color-wine-700)] mb-8 font-[300] reveal">
          Mensagem aos noivos
        </h2>
        <svg class="w-[240px] h-5 mx-auto text-[var(--color-gold-700)] mb-12 reveal" aria-hidden="true">
          <use href="#orn-diamond-divider" />
        </svg>

        <div class="corner-frame p-8 md:p-12 reveal">
          <form class="space-y-8 text-left">
            <div>
              <label class="label block mb-3">Seu nome</label>
              <input type="text" class="w-full px-0 py-3 bg-transparent border-0 border-b border-[var(--color-gold-700)]/40 focus:border-[var(--color-wine-700)] outline-none font-display text-xl transition" />
            </div>
            <div>
              <label class="label block mb-3">Sua mensagem</label>
              <textarea rows="5" class="w-full px-0 py-3 bg-transparent border-0 border-b border-[var(--color-gold-700)]/40 focus:border-[var(--color-wine-700)] outline-none font-display italic text-lg resize-none transition"></textarea>
            </div>
            <button type="submit" class="w-full py-5 bg-[var(--color-wine-700)] text-[var(--color-ivory)] text-[0.7rem] uppercase tracking-[0.4em] hover:bg-[var(--color-wine-900)] transition-all duration-500">
              Enviar com carinho
            </button>
          </form>
        </div>
        <p class="text-[0.7rem] text-[var(--color-ink)]/40 mt-6 italic tracking-wider">
          Integração em breve — este formulário será ativado antes do envio dos convites.
        </p>
      </div>
    </section>

    <!-- ━━━━━━━━━━━━━━━━ FOOTER ━━━━━━━━━━━━━━━━ -->
    <footer class="py-24 px-6 bg-[var(--color-wine-900)] text-[var(--color-ivory)] text-center relative overflow-hidden grain">
      <div class="absolute inset-0 flex items-center justify-center opacity-[0.04] pointer-events-none">
        <svg class="w-[700px] h-[700px] text-[var(--color-gold-500)]" aria-hidden="true">
          <use href="#orn-floral-large" />
        </svg>
      </div>
      <div class="relative z-10 max-w-2xl mx-auto">
        <svg class="w-16 h-16 mx-auto text-[var(--color-gold-500)] mb-8" aria-hidden="true">
          <use href="#orn-monogram" />
        </svg>

        <p class="font-display italic text-4xl md:text-5xl text-[var(--color-gold-500)] mb-4 font-[300]">
          Moroni <span class="font-script">&amp;</span> Daphine
        </p>

        <div class="flex justify-center my-8">
          <svg class="w-[280px] h-10 text-[var(--color-gold-500)]" aria-hidden="true">
            <use href="#orn-floral-divider" />
          </svg>
        </div>

        <p class="font-display italic text-xl text-[var(--color-ivory)]/70">
          XII · VI · MMXXVI
        </p>
        <p class="mt-8 text-xs text-[var(--color-ivory)]/40 tracking-[0.3em] uppercase">
          Feito com amor
        </p>
      </div>
    </footer>

    <!-- ━━━━━━━━━━━━━━━━ Pix Modal ━━━━━━━━━━━━━━━━ -->
    <div id="pix-modal" class="fixed inset-0 bg-[var(--color-wine-900)]/80 backdrop-blur-sm z-50 hidden items-center justify-center p-6">
      <div class="bg-[var(--color-ivory)] max-w-md w-full relative grain">
        <div class="corner-frame p-4">
          <div class="p-8 text-center">
            <button id="close-modal" class="absolute top-6 right-6 text-[var(--color-wine-700)] text-2xl font-display hover:rotate-90 transition-transform duration-500">×</button>

            <svg class="w-12 h-12 mx-auto text-[var(--color-gold-700)] mb-4" aria-hidden="true">
              <use href="#orn-monogram" />
            </svg>
            <p class="label mb-4">Presentear</p>
            <h3 id="modal-presente" class="font-display italic text-3xl text-[var(--color-wine-700)] mb-8">—</h3>

            <svg class="w-32 h-4 mx-auto text-[var(--color-gold-700)] mb-8" aria-hidden="true">
              <use href="#orn-diamond-divider" />
            </svg>

            <div class="bg-[var(--color-cream)] p-6 border border-[var(--color-gold-700)]/20 mb-6">
              <p class="label mb-3">Chave Pix</p>
              <p id="pix-key" class="font-mono text-[var(--color-wine-700)] text-sm break-all">{chavePix}</p>
            </div>

            <button id="copy-pix" class="w-full py-4 bg-[var(--color-wine-700)] text-[var(--color-ivory)] text-[0.65rem] uppercase tracking-[0.4em] hover:bg-[var(--color-wine-900)] transition mb-4">
              Copiar chave Pix
            </button>
            <p class="font-display italic text-sm text-[var(--color-ink)]/60">
              Obrigado por fazer parte desse momento.
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script define:vars={{ chavePix }}>
    // Countdown
    const target = new Date('2026-06-12T00:00:00-03:00').getTime();
    const el = document.getElementById('countdown');
    function tick() {
      const d = Math.max(0, target - Date.now());
      const days = Math.floor(d / 86400000);
      const hours = Math.floor((d % 86400000) / 3600000);
      const mins = Math.floor((d % 3600000) / 60000);
      const secs = Math.floor((d % 60000) / 1000);
      if (el) {
        el.innerHTML = [
          ['Dias', days], ['Horas', hours], ['Minutos', mins], ['Segundos', secs]
        ].map(([l, v]) => `
          <div class="text-center border-x border-[var(--color-gold-700)]/20 px-2">
            <div class="font-display italic text-4xl md:text-6xl text-[var(--color-wine-700)] font-[300] tabular-nums">${String(v).padStart(2,'0')}</div>
            <div class="text-[0.55rem] md:text-[0.65rem] uppercase tracking-[0.35em] text-[var(--color-gold-700)] mt-2">${l}</div>
          </div>
        `).join('');
      }
    }
    tick(); setInterval(tick, 1000);

    // Reveal on scroll
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('in');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -60px 0px' });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));

    // Pix modal
    const modal = document.getElementById('pix-modal');
    const modalName = document.getElementById('modal-presente');
    const openModal = (name) => {
      modalName.textContent = name;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    };
    const closeModal = () => {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
    };
    document.querySelectorAll('.presentear-btn').forEach(btn => {
      btn.addEventListener('click', () => openModal(btn.dataset.presente));
    });
    document.getElementById('close-modal')?.addEventListener('click', closeModal);
    modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
    document.getElementById('copy-pix')?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(chavePix);
        const btn = document.getElementById('copy-pix');
        const original = btn.textContent;
        btn.textContent = 'Copiado!';
        setTimeout(() => { btn.textContent = original; }, 2000);
      } catch (e) {}
    });
  </script>
</Layout>
