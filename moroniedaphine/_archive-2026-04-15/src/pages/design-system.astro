---
const colors = [
  { group: 'Burgundy (dominante 60%)', tokens: [
    { name: 'burgundy-950', hex: '#0F0307' },
    { name: 'burgundy-900', hex: '#1A050A' },
    { name: 'burgundy-800', hex: '#2E0810' },
    { name: 'burgundy-700', hex: '#4A0E1C' },
    { name: 'burgundy-600', hex: '#6B1527' },
    { name: 'burgundy-500', hex: '#8E4B4E' },
  ]},
  { group: 'Rose Gold (metal 30%)', tokens: [
    { name: 'rose-gold-900', hex: '#6B3A3F' },
    { name: 'rose-gold-700', hex: '#B76E79' },
    { name: 'rose-gold-500', hex: '#D4A5A5' },
    { name: 'rose-gold-300', hex: '#EFD0CC' },
  ]},
  { group: 'Champagne (accent 10%)', tokens: [
    { name: 'champagne-700', hex: '#8E6B3A' },
    { name: 'champagne-500', hex: '#D4B996' },
    { name: 'champagne-300', hex: '#EFE2CC' },
  ]},
  { group: 'Parchment (light sections)', tokens: [
    { name: 'parchment-300', hex: '#FBF6EB' },
    { name: 'parchment-500', hex: '#F5EEE0' },
    { name: 'parchment-700', hex: '#E8DCC2' },
  ]},
  { group: 'Noir (secondary tier)', tokens: [
    { name: 'noir-950', hex: '#050505' },
    { name: 'noir-900', hex: '#0D0A08' },
    { name: 'noir-800', hex: '#181512' },
  ]},
  { group: 'Ivory (noir tier text)', tokens: [
    { name: 'ivory-100', hex: '#FFFDF7' },
    { name: 'ivory-300', hex: '#F4ECD6' },
  ]},
  { group: 'Gold Yellow (noir tier)', tokens: [
    { name: 'gold-900', hex: '#5E4511' },
    { name: 'gold-700', hex: '#A7842E' },
    { name: 'gold-500', hex: '#D4B24C' },
    { name: 'gold-300', hex: '#F0D98C' },
  ]},
];
---

<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Moroni & Daphine — Design System v5 · Velvet Chamber</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,300;1,400;1,500&family=Cormorant+SC:wght@400;500&family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=Great+Vibes&display=swap" rel="stylesheet" />
<style>
  :root {
    /* BURGUNDY */
    --burgundy-950: #0F0307;
    --burgundy-900: #1A050A;
    --burgundy-800: #2E0810;
    --burgundy-700: #4A0E1C;
    --burgundy-600: #6B1527;
    --burgundy-500: #8E4B4E;
    /* ROSE GOLD */
    --rose-gold-900: #6B3A3F;
    --rose-gold-700: #B76E79;
    --rose-gold-500: #D4A5A5;
    --rose-gold-300: #EFD0CC;
    /* CHAMPAGNE */
    --champagne-700: #8E6B3A;
    --champagne-500: #D4B996;
    --champagne-300: #EFE2CC;
    /* PARCHMENT */
    --parchment-300: #FBF6EB;
    --parchment-500: #F5EEE0;
    --parchment-700: #E8DCC2;
    /* NOIR */
    --noir-950: #050505;
    --noir-900: #0D0A08;
    --noir-800: #181512;
    /* IVORY */
    --ivory-100: #FFFDF7;
    --ivory-300: #F4ECD6;
    /* GOLD */
    --gold-900: #5E4511;
    --gold-700: #A7842E;
    --gold-500: #D4B24C;
    --gold-300: #F0D98C;
    /* INK */
    --ink-on-burgundy: #F4ECD6;
    --ink-on-burgundy-muted: rgba(244, 236, 214, 0.66);
    --ink-on-noir: #F4ECD6;
    --ink-on-noir-muted: rgba(244, 236, 214, 0.58);
    --ink-on-parchment: #1F0610;
    --ink-on-parchment-muted: rgba(31, 6, 16, 0.64);
    /* FONTS */
    --font-display: "Cormorant Garamond", Georgia, serif;
    --font-sc: "Cormorant SC", Georgia, serif;
    --font-script: "Great Vibes", "Cormorant Garamond", cursive;
    --font-body: "EB Garamond", Georgia, serif;
    /* EASE */
    --ease-expo: cubic-bezier(0.22, 1, 0.36, 1);
    --ease-back: cubic-bezier(0.34, 1.56, 0.64, 1);
    /* GRADIENTS */
    --grad-rose-gold-foil: linear-gradient(135deg, #8E4B4E 0%, #D4A5A5 28%, #EFD0CC 48%, #D4B996 62%, #B76E79 85%, #6B3A3F 100%);
    --grad-gold-foil: linear-gradient(135deg, #5E4511 0%, #D4B24C 35%, #F0D98C 55%, #A7842E 100%);
    --grad-candle-glow: radial-gradient(ellipse 80% 60% at 50% 45%, #4A0E1C 0%, #2E0810 42%, #1A050A 72%, #0F0307 100%);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: var(--font-body);
    background: var(--burgundy-950);
    color: var(--ink-on-burgundy);
    -webkit-font-smoothing: antialiased;
    line-height: 1.8;
    font-weight: 400;
  }

  /* ═══ GRAIN ═══ */
  .grain::before {
    content: '';
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence baseFrequency='0.9' numOctaves='2'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.5'/%3E%3C/svg%3E");
    opacity: 0.08;
    mix-blend-mode: overlay;
    pointer-events: none;
    z-index: 1;
  }
  .grain { position: relative; }
  .grain > * { position: relative; z-index: 2; }

  /* ═══ ROSE GOLD FOIL ═══ */
  .rose-foil {
    background: var(--grad-rose-gold-foil);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    transition: background-position 1.8s var(--ease-expo);
  }
  .rose-foil:hover { background-position: 100% 100%; }

  .gold-foil {
    background: var(--grad-gold-foil);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    transition: background-position 1.8s var(--ease-expo);
  }
  .gold-foil:hover { background-position: 100% 100%; }

  /* ═══ LABEL (Cormorant SC) ═══ */
  .label {
    font-family: var(--font-sc);
    font-size: 11px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--rose-gold-500);
    font-weight: 500;
  }
  .label-gold { color: var(--gold-500); }

  /* ═══ CANDLE GLOW (signature motion) ═══ */
  .candle {
    position: absolute;
    width: 480px; height: 480px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(212, 185, 150, 0.22) 0%, rgba(183, 110, 121, 0.09) 35%, transparent 70%);
    filter: blur(50px);
    animation: candle-pulse 6s ease-in-out infinite;
    pointer-events: none;
    mix-blend-mode: screen;
  }
  .candle-gold {
    background: radial-gradient(circle, rgba(240, 217, 140, 0.18) 0%, rgba(167, 132, 46, 0.08) 35%, transparent 70%);
  }
  @keyframes candle-pulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50%      { opacity: 1;   transform: scale(1.08); }
  }

  /* ═══ VELVET CARD (north star) ═══ */
  .velvet-card {
    position: relative;
    background: radial-gradient(ellipse 85% 70% at 50% 40%, #4A0E1C 0%, #2E0810 45%, #1A050A 100%);
    border: 1px solid rgba(183, 110, 121, 0.18);
    box-shadow:
      inset 0 1px 0 rgba(239, 208, 204, 0.08),
      inset 0 0 80px rgba(15, 3, 7, 0.55),
      0 40px 120px -30px rgba(15, 3, 7, 0.8),
      0 0 0 1px rgba(183, 110, 121, 0.08);
    padding: clamp(4rem, 8vw, 8rem) clamp(2rem, 6vw, 6rem);
    overflow: hidden;
  }
  .velvet-card::before {
    content: '';
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence baseFrequency='0.9'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.35'/%3E%3C/svg%3E");
    opacity: 0.08;
    mix-blend-mode: overlay;
    pointer-events: none;
  }
  .velvet-card > * { position: relative; z-index: 1; }

  /* ═══ NOIR CARD ═══ */
  .noir-card {
    position: relative;
    background: radial-gradient(ellipse 90% 75% at 50% 40%, #181512 0%, #0D0A08 55%, #050505 100%);
    border: 1px solid rgba(212, 178, 76, 0.22);
    box-shadow:
      inset 0 1px 0 rgba(240, 217, 140, 0.1),
      inset 0 0 90px rgba(0, 0, 0, 0.7),
      0 50px 140px -40px #000;
    padding: clamp(4rem, 8vw, 8rem) clamp(2rem, 6vw, 6rem);
    overflow: hidden;
  }
  .noir-card::before {
    content: '';
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence baseFrequency='0.9'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.4'/%3E%3C/svg%3E");
    opacity: 0.1;
    mix-blend-mode: overlay;
    pointer-events: none;
  }
  .noir-card > * { position: relative; z-index: 1; }

  /* ═══ IVORY CARD ═══ */
  .ivory-card {
    position: relative;
    background: radial-gradient(ellipse at top, #FBF6EB 0%, #F5EEE0 60%, #E8DCC2 100%);
    border: 1px solid rgba(183, 110, 121, 0.2);
    box-shadow: 0 30px 80px -20px rgba(74, 14, 28, 0.18);
    padding: clamp(3rem, 6vw, 6rem);
    color: var(--ink-on-parchment);
  }

  /* ═══ NAV ═══ */
  nav.top {
    position: sticky; top: 0; z-index: 50;
    background: rgba(15, 3, 7, 0.88);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid rgba(183, 110, 121, 0.15);
    padding: 18px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  nav.top .logo {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 22px;
    color: var(--ink-on-burgundy);
    letter-spacing: -0.01em;
  }
  nav.top .logo .amp {
    font-family: var(--font-script);
    font-style: normal;
    font-size: 28px;
    color: var(--rose-gold-500);
    vertical-align: -2px;
    margin: 0 2px;
  }
  nav.top .links a {
    font-family: var(--font-sc);
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--rose-gold-500);
    text-decoration: none;
    margin-left: 28px;
    transition: color 0.5s;
  }
  nav.top .links a:hover { color: var(--rose-gold-300); }

  /* ═══ LAYOUT ═══ */
  .container { max-width: 1120px; margin: 0 auto; padding: 0 40px; }
  section.ds-section {
    padding: clamp(6rem, 14vw, 14rem) 0;
    position: relative;
    overflow: hidden;
  }
  .section-velvet {
    background: radial-gradient(ellipse 80% 60% at 50% 45%, #2E0810 0%, #1A050A 45%, #0F0307 100%);
  }
  .section-velvet::before {
    content: '';
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence baseFrequency='0.9'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.35'/%3E%3C/svg%3E");
    opacity: 0.08;
    mix-blend-mode: overlay;
    pointer-events: none;
  }
  .section-velvet > * { position: relative; z-index: 2; }

  /* ═══ SECTION HEADER ═══ */
  .section-header {
    text-align: center;
    margin-bottom: clamp(4rem, 8vw, 8rem);
  }
  .section-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(2.5rem, 6vw, 5.5rem);
    background: var(--grad-rose-gold-foil);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    line-height: 1;
    margin: 2rem 0;
    letter-spacing: -0.01em;
  }
  .section-subtitle {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.15rem, 1.6vw, 1.5rem);
    color: var(--ink-on-burgundy-muted);
    max-width: 58ch;
    margin: 0 auto;
    font-weight: 400;
  }

  /* ═══ REVEAL ═══ */
  .reveal { opacity: 0; transform: translateY(40px); transition: opacity 1.2s var(--ease-expo), transform 1.2s var(--ease-expo); }
  .reveal.in { opacity: 1; transform: translateY(0); }
  .delay-1 { transition-delay: 0.15s; }
  .delay-2 { transition-delay: 0.3s; }
  .delay-3 { transition-delay: 0.45s; }
  .delay-4 { transition-delay: 0.6s; }

  /* ═══ CURSOR HALO ═══ */
  .cursor-halo {
    position: fixed;
    width: 400px; height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(212, 165, 165, 0.08) 0%, transparent 70%);
    pointer-events: none;
    transform: translate(-50%, -50%);
    z-index: 999;
    mix-blend-mode: screen;
    transition: opacity 0.6s;
  }

  /* ═══ HERO HEADER ═══ */
  header.ds-hero {
    position: relative;
    padding: clamp(8rem, 16vw, 14rem) 40px clamp(6rem, 12vw, 10rem);
    text-align: center;
    overflow: hidden;
  }
  header.ds-hero::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 45%, #2E0810 0%, #1A050A 45%, #0F0307 100%);
  }
  header.ds-hero::after {
    content: '';
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence baseFrequency='0.9'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.35'/%3E%3C/svg%3E");
    opacity: 0.08;
    mix-blend-mode: overlay;
    pointer-events: none;
  }
  header.ds-hero > * { position: relative; z-index: 2; }

  header.ds-hero h1 {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(3rem, 10vw, 8rem);
    line-height: 0.92;
    letter-spacing: -0.015em;
    margin: 2rem 0;
  }
  header.ds-hero h1 .amp {
    font-family: var(--font-script);
    font-style: normal;
    font-size: 1.1em;
    line-height: 0.5;
    display: block;
    margin: 0.4rem 0;
    color: var(--rose-gold-500);
  }

  /* ═══ TYPE ROW ═══ */
  .type-row {
    padding: 56px 0;
    border-top: 1px solid rgba(183, 110, 121, 0.12);
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 48px;
    align-items: baseline;
  }
  .type-row:first-of-type { border-top: none; }
  .type-row .meta {
    font-family: var(--font-sc);
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--rose-gold-500);
  }
  .type-row .meta .note {
    display: block;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 14px;
    letter-spacing: 0;
    text-transform: none;
    color: var(--ink-on-burgundy-muted);
    margin-top: 10px;
    line-height: 1.6;
  }
  .type-row .sample {
    color: var(--ink-on-burgundy);
  }

  /* ═══ COLOR SWATCHES ═══ */
  .color-group { margin-bottom: 56px; }
  .color-group h3 {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 1.75rem;
    color: var(--rose-gold-500);
    margin-bottom: 28px;
  }
  .swatches {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 20px;
  }
  .swatch {
    background: rgba(26, 5, 10, 0.5);
    border: 1px solid rgba(183, 110, 121, 0.15);
    transition: transform 0.7s var(--ease-expo), border-color 0.7s;
  }
  .swatch:hover { transform: translateY(-6px); border-color: rgba(212, 165, 165, 0.4); }
  .swatch .block { height: 120px; border-bottom: 1px solid rgba(183, 110, 121, 0.15); }
  .swatch .meta {
    padding: 14px 16px;
    font-family: var(--font-sc);
    font-size: 10px;
    color: var(--ink-on-burgundy);
  }
  .swatch .meta .name { letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 3px; }
  .swatch .meta .hex { color: var(--ink-on-burgundy-muted); font-family: ui-monospace, monospace; font-size: 10px; text-transform: none; letter-spacing: 0; }

  /* ═══ COMPONENT GRID ═══ */
  .component-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 48px;
    margin-top: 72px;
  }
  .component-demo { text-align: center; }
  .component-demo .demo-area {
    position: relative;
    min-height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 64px 32px;
    background: rgba(26, 5, 10, 0.5);
    border: 1px solid rgba(183, 110, 121, 0.15);
    overflow: hidden;
  }
  .component-demo .demo-label {
    margin-top: 20px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--rose-gold-500);
  }

  /* ═══ WAX SEAL ═══ */
  .wax-seal-wrap {
    width: 120px; height: 120px;
    filter: drop-shadow(0 8px 24px rgba(15, 3, 7, 0.7));
    transform: scale(0.9) rotate(-4deg);
    opacity: 0;
    transition: transform 1s var(--ease-back), opacity 0.8s;
  }
  .in .wax-seal-wrap, .wax-seal-wrap.in { transform: scale(1) rotate(0); opacity: 1; }
  .wax-seal-wrap:hover { transform: scale(1.04) rotate(2deg); transition-duration: 0.6s; }

  /* ═══ ORNAMENT RULE ═══ */
  .ornament-rule {
    width: clamp(220px, 40vw, 320px);
    height: 18px;
    display: block;
    margin: 24px auto;
  }

  .ornament-divider {
    width: clamp(320px, 60vw, 600px);
    height: 80px;
    display: block;
    margin: 40px auto;
  }

  /* ═══ HERO COMPOSITION PREVIEW ═══ */
  .hero-preview {
    position: relative;
    padding: clamp(8rem, 16vw, 16rem) 40px;
    text-align: center;
    overflow: hidden;
    background: radial-gradient(ellipse 80% 60% at 50% 45%, #4A0E1C 0%, #2E0810 45%, #1A050A 100%);
  }
  .hero-preview::before {
    content: '';
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence baseFrequency='0.9'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.4'/%3E%3C/svg%3E");
    opacity: 0.09;
    mix-blend-mode: overlay;
    pointer-events: none;
  }
  .hero-preview > * { position: relative; z-index: 2; }

  .hero-names {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(3.5rem, 10vw, 9rem);
    line-height: 0.92;
    letter-spacing: -0.02em;
    margin: 3rem 0;
  }
  .hero-names .line {
    display: block;
    background: var(--grad-rose-gold-foil);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: names-shimmer 2.8s var(--ease-expo) both;
  }
  @keyframes names-shimmer {
    from { background-position: 0% 50%; }
    to   { background-position: 100% 50%; }
  }
  .hero-names .amp {
    font-family: var(--font-script);
    font-style: normal;
    font-size: 0.8em;
    line-height: 0.5;
    display: block;
    margin: -0.5rem 0;
    color: var(--rose-gold-500);
  }

  .hero-lead {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    color: var(--ink-on-burgundy-muted);
    max-width: 42ch;
    margin: 3rem auto 4rem;
    font-weight: 400;
    line-height: 1.5;
  }

  .hero-date {
    margin: 4rem 0;
  }
  .hero-date .twelve {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(7rem, 20vw, 16rem);
    line-height: 0.85;
    letter-spacing: -0.02em;
    background: var(--grad-rose-gold-foil);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    display: block;
  }
  .hero-date .junho {
    font-family: var(--font-script);
    font-size: clamp(3.5rem, 8vw, 6rem);
    line-height: 0.6;
    color: var(--rose-gold-500);
    display: block;
    margin-top: -1.5rem;
  }
  .hero-date .roman {
    font-family: var(--font-sc);
    font-size: 14px;
    letter-spacing: 0.4em;
    color: var(--rose-gold-500);
    margin-top: 2.5rem;
    display: block;
  }

  .btn-ghost {
    display: inline-block;
    font-family: var(--font-sc);
    font-size: 11px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--rose-gold-500);
    background: transparent;
    border: 1px solid rgba(212, 165, 165, 0.4);
    padding: 1.25rem 3rem;
    cursor: pointer;
    transition: all 700ms var(--ease-expo);
    text-decoration: none;
  }
  .btn-ghost:hover {
    border-color: var(--rose-gold-500);
    background: rgba(183, 110, 121, 0.1);
    color: var(--rose-gold-300);
    transform: translateY(-2px);
    box-shadow: 0 20px 40px -20px rgba(183, 110, 121, 0.4);
  }

  .btn-primary {
    display: inline-block;
    background: linear-gradient(135deg, #6B1527 0%, #4A0E1C 50%, #2E0810 100%);
    color: var(--ink-on-burgundy);
    border: 1px solid rgba(212, 165, 165, 0.4);
    padding: 1.25rem 3rem;
    font-family: var(--font-sc);
    font-size: 11px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    text-decoration: none;
    box-shadow:
      inset 0 1px 0 rgba(239, 208, 204, 0.15),
      0 12px 40px -12px rgba(15, 3, 7, 0.9);
    cursor: pointer;
    transition: all 700ms var(--ease-expo);
  }
  .btn-primary:hover {
    background: linear-gradient(135deg, #8E4B4E 0%, #6B1527 50%, #4A0E1C 100%);
    box-shadow:
      inset 0 1px 0 rgba(239, 208, 204, 0.25),
      0 18px 50px -12px #000,
      0 0 60px rgba(183, 110, 121, 0.3);
    transform: translateY(-2px);
  }

  /* ═══ INPUT ═══ */
  .input-demo {
    width: 100%;
    max-width: 400px;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(212, 165, 165, 0.35);
    padding: 0.75rem 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.25rem;
    color: var(--ink-on-burgundy);
    outline: none;
    transition: border-color 500ms;
  }
  .input-demo::placeholder { color: rgba(244, 236, 214, 0.4); font-style: italic; }
  .input-demo:focus { border-bottom-color: var(--rose-gold-500); }

  /* ═══ FOOTER ═══ */
  footer.ds-footer {
    position: relative;
    padding: clamp(6rem, 12vw, 10rem) 40px;
    text-align: center;
    background: radial-gradient(ellipse 90% 75% at 50% 40%, #181512 0%, #0D0A08 55%, #050505 100%);
    overflow: hidden;
  }
  footer.ds-footer::before {
    content: '';
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence baseFrequency='0.9'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.4'/%3E%3C/svg%3E");
    opacity: 0.1;
    mix-blend-mode: overlay;
    pointer-events: none;
  }
  footer.ds-footer > * { position: relative; z-index: 2; }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 720px) {
    .type-row { grid-template-columns: 1fr; gap: 20px; }
    .container { padding: 0 24px; }
    nav.top .links a { margin-left: 14px; font-size: 9px; }
    nav.top { padding: 14px 20px; }
    .cursor-halo { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
</head>
<body>

<!-- ═══════════════════════════════════════════════ SVG SPRITE ═══════════════════════════════════════════════ -->
<svg xmlns="http://www.w3.org/2000/svg" style="display:none" aria-hidden="true">
  <defs>
    <linearGradient id="rgf" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0" stop-color="#B76E79" stop-opacity="0"/>
      <stop offset="0.5" stop-color="#D4A5A5"/>
      <stop offset="1" stop-color="#B76E79" stop-opacity="0"/>
    </linearGradient>
    <linearGradient id="gf" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0" stop-color="#A7842E" stop-opacity="0"/>
      <stop offset="0.5" stop-color="#F0D98C"/>
      <stop offset="1" stop-color="#A7842E" stop-opacity="0"/>
    </linearGradient>
    <radialGradient id="flameFill" cx="50%" cy="70%">
      <stop offset="0%" stop-color="#F0D98C" stop-opacity="0.95"/>
      <stop offset="35%" stop-color="#D4B996" stop-opacity="0.9"/>
      <stop offset="75%" stop-color="#B76E79" stop-opacity="0.85"/>
      <stop offset="100%" stop-color="#6B3A3F" stop-opacity="0.7"/>
    </radialGradient>
    <radialGradient id="flameGold" cx="50%" cy="70%">
      <stop offset="0%" stop-color="#F0D98C"/>
      <stop offset="50%" stop-color="#D4B24C"/>
      <stop offset="100%" stop-color="#5E4511"/>
    </radialGradient>
    <radialGradient id="wax" cx="35%" cy="30%">
      <stop offset="0%" stop-color="#8E4B4E"/>
      <stop offset="55%" stop-color="#4A0E1C"/>
      <stop offset="100%" stop-color="#1A050A"/>
    </radialGradient>
  </defs>

  <!-- La Flamme (signature ornament) -->
  <symbol id="la-flamme" viewBox="0 0 60 120">
    <!-- Wick cup serif -->
    <line x1="24" y1="101" x2="36" y2="101" stroke="#D4A5A5" stroke-width="0.6" opacity="0.7"/>
    <!-- Wick base ellipse -->
    <ellipse cx="30" cy="105" rx="6" ry="1.5" fill="#6B3A3F" opacity="0.8"/>
    <!-- Main flame body -->
    <path d="M30 100 C 22 85, 22 60, 26 42 C 28 28, 30 18, 30 14 C 30 18, 32 28, 34 42 C 38 60, 38 85, 30 100 Z"
          fill="url(#flameFill)"/>
    <!-- Inner flame -->
    <path d="M30 92 C 26 82, 26 66, 28 52 C 29 42, 30 34, 30 28 C 30 34, 31 42, 32 52 C 34 66, 34 82, 30 92 Z"
          fill="rgba(255, 253, 230, 0.55)"/>
    <!-- Hottest core -->
    <ellipse cx="30" cy="72" rx="2" ry="6" fill="rgba(255, 253, 230, 0.9)"/>
    <!-- Calligraphic swash leaving the base -->
    <path d="M34 107 C 42 106, 46 102, 48 96 C 46 100, 42 102, 38 101"
          fill="none" stroke="#B76E79" stroke-width="0.8" stroke-linecap="round"/>
    <path d="M26 107 C 18 106, 14 102, 12 96 C 14 100, 18 102, 22 101"
          fill="none" stroke="#B76E79" stroke-width="0.8" stroke-linecap="round"/>
  </symbol>

  <!-- La Flamme Gold (noir tier) -->
  <symbol id="la-flamme-gold" viewBox="0 0 60 120">
    <line x1="24" y1="101" x2="36" y2="101" stroke="#D4B24C" stroke-width="0.6" opacity="0.7"/>
    <ellipse cx="30" cy="105" rx="6" ry="1.5" fill="#5E4511" opacity="0.8"/>
    <path d="M30 100 C 22 85, 22 60, 26 42 C 28 28, 30 18, 30 14 C 30 18, 32 28, 34 42 C 38 60, 38 85, 30 100 Z"
          fill="url(#flameGold)"/>
    <path d="M30 92 C 26 82, 26 66, 28 52 C 29 42, 30 34, 30 28 C 30 34, 31 42, 32 52 C 34 66, 34 82, 30 92 Z"
          fill="rgba(255, 253, 230, 0.6)"/>
    <ellipse cx="30" cy="72" rx="2" ry="6" fill="rgba(255, 253, 230, 0.95)"/>
    <path d="M34 107 C 42 106, 46 102, 48 96 C 46 100, 42 102, 38 101"
          fill="none" stroke="#A7842E" stroke-width="0.8" stroke-linecap="round"/>
    <path d="M26 107 C 18 106, 14 102, 12 96 C 14 100, 18 102, 22 101"
          fill="none" stroke="#A7842E" stroke-width="0.8" stroke-linecap="round"/>
  </symbol>

  <!-- Ornament Rule (line + flourish + dot) -->
  <symbol id="ornament-rule" viewBox="0 0 320 18">
    <line x1="10" y1="9" x2="140" y2="9" stroke="url(#rgf)" stroke-width="0.8"/>
    <line x1="180" y1="9" x2="310" y2="9" stroke="url(#rgf)" stroke-width="0.8"/>
    <path d="M140 9 Q150 2, 160 9 T180 9" fill="none" stroke="#D4A5A5" stroke-width="1.2"/>
    <circle cx="160" cy="9" r="2.2" fill="#D4A5A5"/>
    <circle cx="142" cy="9" r="1.1" fill="#B76E79" opacity="0.7"/>
    <circle cx="178" cy="9" r="1.1" fill="#B76E79" opacity="0.7"/>
  </symbol>

  <symbol id="ornament-rule-gold" viewBox="0 0 320 18">
    <line x1="10" y1="9" x2="140" y2="9" stroke="url(#gf)" stroke-width="0.8"/>
    <line x1="180" y1="9" x2="310" y2="9" stroke="url(#gf)" stroke-width="0.8"/>
    <path d="M140 9 Q150 2, 160 9 T180 9" fill="none" stroke="#F0D98C" stroke-width="1.2"/>
    <circle cx="160" cy="9" r="2.2" fill="#F0D98C"/>
    <circle cx="142" cy="9" r="1.1" fill="#A7842E" opacity="0.7"/>
    <circle cx="178" cy="9" r="1.1" fill="#A7842E" opacity="0.7"/>
  </symbol>

  <!-- Ornament Divider (flowing bezier ribbon) -->
  <symbol id="ornament-divider" viewBox="0 0 600 80">
    <path d="M20 40 C 100 10, 200 70, 300 40 S 500 10, 580 40"
          fill="none" stroke="url(#rgf)" stroke-width="1.4" stroke-linecap="round"/>
    <path d="M20 44 C 100 14, 200 74, 300 44 S 500 14, 580 44"
          fill="none" stroke="url(#rgf)" stroke-width="0.6" opacity="0.5"/>
    <circle cx="300" cy="40" r="3.5" fill="#D4A5A5"/>
    <circle cx="300" cy="40" r="8" fill="none" stroke="#B76E79" stroke-width="0.5" opacity="0.6"/>
  </symbol>

  <symbol id="ornament-divider-gold" viewBox="0 0 600 80">
    <path d="M20 40 C 100 10, 200 70, 300 40 S 500 10, 580 40"
          fill="none" stroke="url(#gf)" stroke-width="1.4" stroke-linecap="round"/>
    <path d="M20 44 C 100 14, 200 74, 300 44 S 500 14, 580 44"
          fill="none" stroke="url(#gf)" stroke-width="0.6" opacity="0.5"/>
    <circle cx="300" cy="40" r="3.5" fill="#F0D98C"/>
    <circle cx="300" cy="40" r="8" fill="none" stroke="#A7842E" stroke-width="0.5" opacity="0.6"/>
  </symbol>

  <!-- Wax Seal (M + D overlapping in Cormorant italic) -->
  <symbol id="wax-seal" viewBox="0 0 120 120">
    <circle cx="60" cy="60" r="56" fill="url(#wax)"
            stroke="#B76E79" stroke-width="0.6" stroke-opacity="0.5"/>
    <circle cx="60" cy="60" r="50" fill="none"
            stroke="#D4A5A5" stroke-width="0.4" stroke-opacity="0.3"/>
    <circle cx="60" cy="60" r="45" fill="none"
            stroke="#B76E79" stroke-width="0.3" stroke-opacity="0.25" stroke-dasharray="1 3"/>
    <text x="42" y="78" font-family="Cormorant Garamond, serif" font-style="italic"
          font-weight="500" font-size="58" fill="#EFD0CC" opacity="0.95">M</text>
    <text x="62" y="78" font-family="Cormorant Garamond, serif" font-style="italic"
          font-weight="500" font-size="58" fill="#D4A5A5" opacity="0.95">D</text>
  </symbol>

  <!-- Wax Seal Gold -->
  <symbol id="wax-seal-gold" viewBox="0 0 120 120">
    <circle cx="60" cy="60" r="56" fill="url(#wax)"
            stroke="#D4B24C" stroke-width="0.6" stroke-opacity="0.5"/>
    <circle cx="60" cy="60" r="50" fill="none"
            stroke="#F0D98C" stroke-width="0.4" stroke-opacity="0.3"/>
    <circle cx="60" cy="60" r="45" fill="none"
            stroke="#D4B24C" stroke-width="0.3" stroke-opacity="0.25" stroke-dasharray="1 3"/>
    <text x="42" y="78" font-family="Cormorant Garamond, serif" font-style="italic"
          font-weight="500" font-size="58" fill="#F0D98C" opacity="0.95">M</text>
    <text x="62" y="78" font-family="Cormorant Garamond, serif" font-style="italic"
          font-weight="500" font-size="58" fill="#D4B24C" opacity="0.95">D</text>
  </symbol>
</svg>

<div class="cursor-halo" id="cursor-halo"></div>

<nav class="top">
  <span class="logo">moroni <span class="amp">&amp;</span> daphine</span>
  <div class="links">
    <a href="#tokens">Tokens</a>
    <a href="#tipografia">Tipografia</a>
    <a href="#ornamentos">Ornamentos</a>
    <a href="#cards">Cards</a>
    <a href="#hero">Hero</a>
    <a href="#noir">Noir</a>
    <a href="/">Site</a>
  </div>
</nav>

<!-- ══════════ HEADER ══════════ -->
<header class="ds-hero">
  <!-- Candles -->
  <div class="candle" style="top: -10%; left: -5%;"></div>
  <div class="candle" style="bottom: -10%; right: -5%; animation-delay: -2s;"></div>
  <div class="candle" style="top: 30%; left: 50%; transform: translateX(-50%); animation-delay: -4s;"></div>

  <div class="reveal">
    <p class="label">Design System · v5</p>
    <svg class="ornament-rule" style="margin: 1.5rem auto;"><use href="#ornament-rule"/></svg>

    <!-- La Flamme above names -->
    <svg width="56" height="112" viewBox="0 0 60 120" style="margin: 2rem auto; display: block; filter: drop-shadow(0 0 16px rgba(212, 185, 150, 0.35));"><use href="#la-flamme"/></svg>

    <h1>
      <span class="rose-foil" style="display: block;">moroni reis</span>
      <span class="amp">&amp;</span>
      <span class="rose-foil" style="display: block;">daphine oliveira</span>
    </h1>

    <svg class="ornament-divider"><use href="#ornament-divider"/></svg>

    <p style="font-family: var(--font-display); font-style: italic; font-size: clamp(1.15rem, 1.6vw, 1.5rem); color: var(--ink-on-burgundy-muted); max-width: 52ch; margin: 2rem auto 0; line-height: 1.6;">
      Uma câmara iluminada por velas. Burgundy velvet, rose gold líquido, Cormorant italic como sussurro caligráfico. A spec v5 ao vivo.
    </p>
    <p style="font-family: var(--font-sc); font-size: 10px; letter-spacing: 0.4em; color: var(--rose-gold-500); margin-top: 56px; text-transform: uppercase;">
      XV · iv · mmxxvi &nbsp;·&nbsp; iteração v5
    </p>
  </div>
</header>

<!-- ══════════ TIPOGRAFIA ══════════ -->
<section id="tipografia" class="ds-section section-velvet">
  <div class="container">
    <div class="section-header reveal">
      <p class="label">01 · Sistema Tipográfico</p>
      <svg class="ornament-rule"><use href="#ornament-rule"/></svg>
      <h2 class="section-title">Tipografia</h2>
      <p class="section-subtitle">Quatro fontes. Nenhuma a mais. Cormorant italic no coração.</p>
    </div>

    <div style="margin-top: 96px;">
      <div class="type-row reveal">
        <div class="meta">Display · Nomes<span class="note">Cormorant Garamond italic 500 · o coração. Nomes, títulos, números gigantes. Lowercase sempre.</span></div>
        <div class="sample rose-foil" style="font-family: var(--font-display); font-weight: 500; font-style: italic; font-size: 3.5rem; line-height: 1;">moroni reis</div>
      </div>
      <div class="type-row reveal">
        <div class="meta">Display · Números<span class="note">Mesma fonte, escala cinematográfica. Aplicada no "12" do hero.</span></div>
        <div class="sample rose-foil" style="font-family: var(--font-display); font-weight: 500; font-style: italic; font-size: 6rem; line-height: 0.9;">12</div>
      </div>
      <div class="type-row reveal">
        <div class="meta">Script · & e Junho<span class="note">Great Vibes 400 · APENAS para ampersand e "Junho". Nunca frases longas.</span></div>
        <div class="sample" style="font-family: var(--font-script); font-size: 5rem; line-height: 0.8; color: var(--rose-gold-500);">&amp; &nbsp; Junho</div>
      </div>
      <div class="type-row reveal">
        <div class="meta">Labels · SC<span class="note">Cormorant SC 11px · labels uppercase, tracking 0.35em, cor rose-gold-500</span></div>
        <div class="sample label" style="font-size: 13px;">Save the Date · Capítulo II</div>
      </div>
      <div class="type-row reveal">
        <div class="meta">Lead · Italic<span class="note">Cormorant Garamond italic 400 · subtítulos, citações, legendas</span></div>
        <div class="sample" style="font-family: var(--font-display); font-style: italic; font-weight: 400; font-size: 1.75rem; color: var(--ink-on-burgundy);">"o tempo, como um sopro, nos trouxe até aqui."</div>
      </div>
      <div class="type-row reveal">
        <div class="meta">Body · Leitura<span class="note">EB Garamond roman 17px · parágrafos, história, descrições. Line-height 1.8.</span></div>
        <div class="sample" style="font-family: var(--font-body); font-size: 17px; line-height: 1.8; max-width: 58ch; color: var(--ink-on-burgundy);">Decidimos celebrar esse momento de forma íntima, rodeados das pessoas que construíram essa história conosco. O convite chegará às suas mãos.</div>
      </div>
    </div>
  </div>
</section>

<!-- ══════════ TOKENS / CORES ══════════ -->
<section id="tokens" class="ds-section section-velvet">
  <div class="container">
    <div class="section-header reveal">
      <p class="label">02 · Paleta</p>
      <svg class="ornament-rule"><use href="#ornament-rule"/></svg>
      <h2 class="section-title">Cores</h2>
      <p class="section-subtitle">Burgundy 60% · Rose gold 30% · Champagne 10% · Noir & Or como tier secundário</p>
    </div>

    <div style="margin-top: 96px;">
      {colors.map(group => (
        <div class="color-group reveal">
          <h3>{group.group}</h3>
          <div class="swatches">
            {group.tokens.map(t => (
              <div class="swatch">
                <div class="block" style={`background: ${t.hex};`}></div>
                <div class="meta">
                  <div class="name">{t.name}</div>
                  <div class="hex">{t.hex}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══════════ ORNAMENTOS ══════════ -->
<section id="ornamentos" class="ds-section section-velvet">
  <div class="candle" style="top: 20%; left: -5%; animation-delay: -1s;"></div>
  <div class="candle" style="bottom: 15%; right: -5%; animation-delay: -3s;"></div>

  <div class="container">
    <div class="section-header reveal">
      <p class="label">03 · Ornamentos</p>
      <svg class="ornament-rule"><use href="#ornament-rule"/></svg>
      <h2 class="section-title">Ornamentos</h2>
      <p class="section-subtitle">La Flamme é o fingerprint. Tudo mais serve a ela.</p>
    </div>

    <div class="component-grid">

      <!-- La Flamme -->
      <div class="component-demo reveal">
        <div class="demo-area">
          <svg width="90" height="180" viewBox="0 0 60 120" style="filter: drop-shadow(0 0 24px rgba(212, 185, 150, 0.4));"><use href="#la-flamme"/></svg>
        </div>
        <p class="demo-label">La Flamme · Signature</p>
      </div>

      <!-- Wax Seal -->
      <div class="component-demo reveal">
        <div class="demo-area">
          <div class="wax-seal-wrap">
            <svg viewBox="0 0 120 120" width="120" height="120"><use href="#wax-seal"/></svg>
          </div>
        </div>
        <p class="demo-label">Wax Seal · M + D</p>
      </div>

      <!-- Ornament Rule -->
      <div class="component-demo reveal">
        <div class="demo-area">
          <svg width="280" height="18"><use href="#ornament-rule"/></svg>
        </div>
        <p class="demo-label">Ornament Rule</p>
      </div>

      <!-- Ornament Divider -->
      <div class="component-demo reveal" style="grid-column: span 2;">
        <div class="demo-area">
          <svg width="540" height="80"><use href="#ornament-divider"/></svg>
        </div>
        <p class="demo-label">Ornament Divider · flowing bezier</p>
      </div>

      <!-- Label -->
      <div class="component-demo reveal">
        <div class="demo-area">
          <p class="label">Save the Date</p>
        </div>
        <p class="demo-label">Label (Cormorant SC)</p>
      </div>

    </div>
  </div>
</section>

<!-- ══════════ CARDS ══════════ -->
<section id="cards" class="ds-section section-velvet">
  <div class="container">
    <div class="section-header reveal">
      <p class="label">04 · Cards</p>
      <svg class="ornament-rule"><use href="#ornament-rule"/></svg>
      <h2 class="section-title">Primitives</h2>
      <p class="section-subtitle">Três tipos de superfície: velvet (norte), noir (tier premium), ivory (leveza)</p>
    </div>

    <!-- Velvet Card -->
    <div class="reveal" style="margin-top: 96px;">
      <p class="label" style="text-align: center; margin-bottom: 28px;">Velvet Card · North Star</p>
      <div class="velvet-card" style="max-width: 780px; margin: 0 auto; text-align: center;">
        <p class="label">Capítulo II</p>
        <svg class="ornament-rule" style="margin-top: 20px;"><use href="#ornament-rule"/></svg>
        <h3 class="rose-foil" style="font-family: var(--font-display); font-style: italic; font-weight: 500; font-size: clamp(2.5rem, 5vw, 4rem); line-height: 1; margin: 32px 0;">
          Nossa História
        </h3>
        <svg width="400" height="60" viewBox="0 0 600 80" style="margin: 24px auto; display: block;"><use href="#ornament-divider"/></svg>
        <p style="font-family: var(--font-body); font-size: 17px; line-height: 1.85; color: var(--ink-on-burgundy); max-width: 56ch; margin: 32px auto 0;">
          Tudo começou numa noite de inverno em Brasília. O tipo de noite em que o frio faz o café parecer quente de um jeito diferente. Ela chegou atrasada, e ele fingiu não ter notado.
        </p>
        <div style="margin-top: 56px;">
          <a href="#" class="btn-ghost">Leia a história</a>
        </div>
      </div>
    </div>

    <!-- Ivory Card -->
