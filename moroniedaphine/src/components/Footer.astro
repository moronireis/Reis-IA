---
// Footer.astro — Shared footer, burgundy bg, all pages
---

<footer class="site-footer">
  <p class="site-footer__wordmark">Moroni &amp; Daphine</p>
  <span class="site-footer__rule" aria-hidden="true"></span>
  <p class="site-footer__date">doze · junho · mmxxvi</p>
</footer>

<style>
  .site-footer {
    background: var(--burgundy);
    color: var(--white);
    padding: clamp(56px, 8vh, 96px) var(--site-gutter);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .site-footer__wordmark {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-style: italic;
    font-variation-settings: "opsz" 14;
    font-size: 18px;
    letter-spacing: 0.02em;
    color: var(--white);
  }

  .site-footer__rule {
    display: block;
    width: 40px;
    height: 1px;
    background: var(--gold);
    opacity: 0.40;
  }

  .site-footer__date {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.40em;
    color: rgba(255, 255, 255, 0.45);
  }
</style>
