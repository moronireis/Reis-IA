---
// Nav.astro — Fixed topbar, shared across all pages
// Props: activePage — 'inicio' | 'sobre-nos' | 'presentes' | 'faq'
interface Props {
  activePage?: string;
}
const { activePage = '' } = Astro.props;
---

<nav class="site-nav" role="navigation" aria-label="Navegação principal">
  <div class="site-nav__inner">

    <!-- Logo wordmark -->
    <a href="/" class="site-nav__logo" aria-label="Moroni &amp; Daphine — página inicial">
      Moroni &amp; Daphine
    </a>

    <!-- Desktop nav links -->
    <ul class="site-nav__links" role="list">
      <li>
        <a href="/" class={`site-nav__link ${activePage === 'inicio' ? 'site-nav__link--active' : ''}`}>
          Início
        </a>
      </li>
      <li>
        <a href="/sobre-nos" class={`site-nav__link ${activePage === 'sobre-nos' ? 'site-nav__link--active' : ''}`}>
          Sobre Nós
        </a>
      </li>
      <li>
        <a href="/presentes" class={`site-nav__link ${activePage === 'presentes' ? 'site-nav__link--active' : ''}`}>
          Presentes
        </a>
      </li>
      <li>
        <a href="/faq" class={`site-nav__link ${activePage === 'faq' ? 'site-nav__link--active' : ''}`}>
          FAQ
        </a>
      </li>
    </ul>

    <!-- Mobile hamburger -->
    <button class="site-nav__hamburger" aria-label="Abrir menu" aria-expanded="false" aria-controls="mobile-menu">
      <span></span>
      <span></span>
      <span></span>
    </button>

  </div>

  <!-- Mobile drawer -->
  <div class="site-nav__drawer" id="mobile-menu" aria-hidden="true">
    <ul role="list">
      <li><a href="/" class={activePage === 'inicio' ? 'active' : ''}>Início</a></li>
      <li><a href="/sobre-nos" class={activePage === 'sobre-nos' ? 'active' : ''}>Sobre Nós</a></li>
      <li><a href="/presentes" class={activePage === 'presentes' ? 'active' : ''}>Presentes</a></li>
      <li><a href="/faq" class={activePage === 'faq' ? 'active' : ''}>FAQ</a></li>
    </ul>
  </div>
</nav>

<style>
  /* ─── Nav shell ─────────────────────────────── */
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-height);
    /* Subtle backdrop — transparent enough to show bg color beneath */
    background: transparent;
  }

  /* On white-background pages the text is burgundy; we use CSS classes for variant pages */
  /* Default: white text (works on burgundy sections & hero overlays) */
  /* Index page hero is full-bleed photo — white text is safe */
  .site-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding: 0 var(--site-gutter);
    max-width: var(--site-max);
    margin: 0 auto;
  }

  /* ─── Logo ──────────────────────────────────── */
  .site-nav__logo {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-style: italic;
    font-variation-settings: "opsz" 14;
    font-size: 14px;
    letter-spacing: 0.02em;
    color: var(--white);
    text-decoration: none;
    flex-shrink: 0;
    transition: opacity 300ms ease;
  }

  .site-nav__logo:hover {
    opacity: 0.72;
  }

  /* Light variant — for white-bg pages */
  .site-nav--light .site-nav__logo {
    color: var(--burgundy);
  }

  /* ─── Links ─────────────────────────────────── */
  .site-nav__links {
    display: flex;
    gap: clamp(24px, 4vw, 48px);
    list-style: none;
    align-items: center;
  }

  .site-nav__link {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: var(--white);
    text-decoration: none;
    position: relative;
    padding-bottom: 4px;
    transition: opacity 300ms ease;
  }

  .site-nav__link:hover {
    opacity: 0.72;
  }

  /* Active state: gold underline 1px, 40% opacity */
  .site-nav__link--active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--gold);
    opacity: 0.40;
  }

  /* Light variant */
  .site-nav--light .site-nav__link {
    color: var(--burgundy);
  }

  .site-nav--light .site-nav__link--active::after {
    background: var(--burgundy);
    opacity: 0.30;
  }

  /* ─── Hamburger ─────────────────────────────── */
  .site-nav__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    width: 40px;
    height: 40px;
  }

  .site-nav__hamburger span {
    display: block;
    width: 22px;
    height: 1px;
    background: var(--white);
    transition: transform 300ms ease, opacity 300ms ease;
  }

  .site-nav--light .site-nav__hamburger span {
    background: var(--burgundy);
  }

  .site-nav__hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .site-nav__hamburger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .site-nav__hamburger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* ─── Mobile drawer ─────────────────────────── */
  .site-nav__drawer {
    position: fixed;
    top: var(--nav-height);
    right: 0;
    bottom: 0;
    width: min(320px, 88vw);
    background: var(--burgundy);
    padding: 48px 32px;
    transform: translateX(100%);
    transition: transform 400ms cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
    z-index: 101;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .site-nav__drawer[aria-hidden="false"] {
    transform: translateX(0);
    pointer-events: all;
  }

  .site-nav__drawer ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .site-nav__drawer a {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-style: italic;
    font-variation-settings: "opsz" 14;
    font-size: clamp(24px, 5vw, 30px);
    color: var(--white);
    text-decoration: none;
    display: flex;
    align-items: center;
    min-height: 56px;
    padding: 8px 0;
    transition: opacity 200ms ease, padding-left 300ms ease;
  }

  .site-nav__drawer a:hover {
    opacity: 0.65;
  }

  .site-nav__drawer a.active {
    color: var(--gold);
    opacity: 0.90;
  }

  /* ─── Responsive ─────────────────────────────── */
  @media (max-width: 768px) {
    .site-nav__links {
      display: none;
    }

    .site-nav__hamburger {
      display: flex;
      min-width: 44px;
      min-height: 44px;
    }
  }
</style>

<script>
  // Motion layer — Lenis, reveals, nav scroll, hero entrance, countdown,
  // drawer behavior (scroll-lock, backdrop, inert, escape). See src/scripts/motion.ts.
  import '../scripts/motion.ts';
</script>
