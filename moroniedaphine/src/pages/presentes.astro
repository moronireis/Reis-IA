---
// presentes.astro — Lista de presentes + Pix + QR placeholder
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Lista de presentes — Moroni & Daphine" />
    <title>Presentes · Moroni &amp; Daphine</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,200;0,9..144,300;0,9..144,400;1,9..144,200;1,9..144,300;1,9..144,400&family=Inter:wght@300;400&display=swap" rel="stylesheet" />
    
  </head>
  <body class="page-dark">

    <a href="#main-content" class="sr-only skip-link">Ir para o conteúdo principal</a>

    <!-- Nav white text — entire page is burgundy -->
    <Nav activePage="presentes" />

    <main id="main-content" class="presentes-main">

      <div class="presentes-inner container">

        <!-- Left column: text + Pix -->
        <div class="presentes-text reveal">

          <h1 class="presentes-heading f-display-xl">PRESENTES</h1>

          <div class="f-body presentes-body">
            {/* PLACEHOLDER — copy sobre lista de presentes */}
            <p>
              Casar é um sonho que se constrói junto — e começar uma vida nova envolve
              muito mais do que uma cerimônia. Se quiserem nos ajudar nesse começo,
              ficamos profundamente gratos por qualquer contribuição.
            </p>
            <p>
              Montamos uma lista com itens que vão entrar no nosso lar com cuidado e intenção.
              Nada foi escolhido por obrigação — cada peça tem um lugar pensado.
            </p>
            <p>
              {/* PLACEHOLDER — url da lista */}
              Se preferir contribuir diretamente, a chave Pix ao lado resolve com facilidade.
              O que importa é o gesto, não o tamanho.
            </p>
          </div>

          <!-- Lista link -->
          <a href="#" class="presentes-lista-link i-micro" target="_blank" rel="noopener">
            Acessar a lista de presentes
          </a>

          <!-- Pix divider + key -->
          <span class="presentes-rule gold-rule" aria-hidden="true"></span>

          <p class="presentes-pix-label i-micro">Chave Pix (CPF)</p>
          {/* PLACEHOLDER — substituir pela chave Pix real */}
          <p class="presentes-pix-key f-body-italic">000.000.000-00</p>

        </div>

        <!-- Right column: QR placeholder -->
        <div class="presentes-qr reveal" aria-label="QR Code para pagamento via Pix (placeholder)">
          <div class="presentes-qr__box" aria-hidden="true">
            <!-- CSS QR-like pattern via repeating-conic-gradient -->
          </div>
          <p class="presentes-qr__label i-nano">qr · pix placeholder</p>
        </div>

      </div>

    </main>

    <Footer />

  </body>
</html>

<style>
  .skip-link:focus {
    position: fixed;
    top: 16px;
    left: 16px;
    z-index: 9999;
    background: var(--white);
    color: var(--burgundy);
    padding: 8px 16px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
  }

  /* ─── Page dark shell ────────────────────────── */
  .page-dark {
    background: var(--burgundy);
    color: var(--white);
  }

  .presentes-main {
    min-height: 85vh;
    display: flex;
    align-items: center;
    padding: calc(var(--nav-height) + var(--section-v-desktop)) var(--site-gutter) var(--section-v-desktop);
  }

  @media (max-width: 768px) {
    .presentes-main {
      padding: calc(var(--nav-height) + var(--section-v-mobile)) var(--site-gutter) var(--section-v-mobile);
      align-items: flex-start;
    }
  }

  /* ─── Inner layout ───────────────────────────── */
  .presentes-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(48px, 8vw, 112px);
    align-items: center;
    width: 100%;
  }

  @media (max-width: 768px) {
    .presentes-inner {
      grid-template-columns: 1fr;
      gap: 56px;
      justify-items: center;
    }
    .presentes-text {
      text-align: center;
    }
    .presentes-body {
      margin-left: auto;
      margin-right: auto;
    }
    .presentes-rule {
      margin-left: auto;
      margin-right: auto;
    }
  }

  /* ─── Text column ────────────────────────────── */
  .presentes-heading {
    font-size: clamp(56px, 11vw, 160px);
    color: var(--white);
    margin-bottom: clamp(32px, 5vh, 56px);
    line-height: 0.9;
    word-break: break-word;
  }

  .presentes-body {
    color: rgba(255, 255, 255, 0.85);
    max-width: 520px;
  }

  .presentes-body p + p {
    margin-top: 1.5em;
  }

  /* Lista link — gold underline */
  .presentes-lista-link {
    display: inline-block;
    margin-top: 32px;
    color: var(--gold);
    text-decoration: none;
    letter-spacing: 0.28em;
    border-bottom: 1px solid var(--gold);
    padding-bottom: 3px;
    transition: opacity 300ms ease;
  }

  .presentes-lista-link:hover {
    opacity: 0.65;
  }

  /* Pix divider */
  .presentes-rule {
    display: block;
    margin-top: 36px;
    margin-bottom: 20px;
    /* left-aligned */
  }

  .presentes-pix-label {
    color: rgba(212, 175, 55, 0.70);
    margin-bottom: 8px;
    display: block;
  }

  .presentes-pix-key {
    color: var(--white);
    font-size: 20px;
    letter-spacing: 0.04em;
  }

  /* ─── QR column ──────────────────────────────── */
  .presentes-qr {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .presentes-qr__box {
    width: 320px;
    height: 320px;
    border: 1px solid rgba(255, 255, 255, 0.30);
    /* QR-like repeating pattern via CSS */
    background-image:
      repeating-conic-gradient(
        rgba(255, 255, 255, 0.08) 0% 25%,
        transparent 0% 50%
      );
    background-size: 12px 12px;
    position: relative;
  }

  /* Corner marks — top-left, top-right, bottom-left (like a real QR) */
  .presentes-qr__box::before,
  .presentes-qr__box::after {
    content: '';
    position: absolute;
    width: 64px;
    height: 64px;
    border: 3px solid rgba(255, 255, 255, 0.40);
  }

  .presentes-qr__box::before {
    top: 16px;
    left: 16px;
  }

  .presentes-qr__box::after {
    top: 16px;
    right: 16px;
  }

  @media (max-width: 768px) {
    .presentes-qr__box {
      width: min(240px, 72vw);
      height: min(240px, 72vw);
    }
  }

  .presentes-qr__label {
    color: rgba(255, 255, 255, 0.35);
  }
</style>
