---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Convite de casamento — Moroni Reis & Daphine Oliveira — 12 de junho de 2026" />
  <title>Convite · Moroni & Daphine</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,200;0,9..144,300;0,9..144,400;1,9..144,200;1,9..144,300;1,9..144,400&family=Inter:wght@300;400&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- ══════ COVER — fullscreen photo + monogram + ghost button ══════ -->
  <div class="cover" id="cover" role="dialog" aria-label="Capa do convite">
    <div class="cover-photo">
      <img src="/photos/templo-costas.jpg" alt="Moroni e Daphine no templo" fetchpriority="high" />
    </div>
    <div class="cover-overlay"></div>
    <div class="cover-content">
      <div class="cover-monogram">
        <img src="/brand/monogram-framed-botanical-v3.svg" alt="M & D" />
      </div>
      <button class="cover-btn" id="cover-btn" aria-label="Abrir o convite">
        <span>Abrir convite</span>
      </button>
    </div>
  </div>

  <!-- ══════ INVITATION — dark scroll ══════ -->
  <main class="page" id="page">

    <!-- 1 · Names -->
    <section class="sec sec--names rv" aria-label="Nomes dos noivos">
      <img src="/brand/botanicals/botanical-leaf-branch-v1.svg" alt="" class="bot-accent bot-accent--top" aria-hidden="true" />
      <p class="lbl lbl--cream">Convidam você para celebrar</p>
      <h1 class="names">Moroni Reis</h1>
      <p class="amp">&amp;</p>
      <h1 class="names">Daphine Oliveira</h1>
    </section>

    <img src="/brand/botanicals/botanical-divider-v1.svg" alt="" class="divider rv" aria-hidden="true" />

    <!-- 2 · Date -->
    <section class="sec rv" aria-label="Data do casamento">
      <div class="date-row">
        <span class="date-num">12</span>
        <div class="date-col">
          <span class="lbl lbl--gold">Junho</span>
          <span class="gold-line"></span>
          <span class="lbl lbl--dim">2026</span>
        </div>
      </div>
      <p class="lbl lbl--cream" style="margin-top:12px">Sexta-feira &middot; 21h00</p>
      <p class="lbl lbl--dim" style="margin-top:4px;font-size:8px">Chegada recomendada às 20h20</p>
    </section>

    <img src="/brand/botanicals/botanical-divider-v1.svg" alt="" class="divider rv" aria-hidden="true" />

    <!-- 3 · Message -->
    <section class="sec rv" aria-label="Mensagem dos noivos">
      <p class="body-it">
        Gostaríamos de compartilhar com você um dos momentos
        mais especiais das nossas vidas. Será uma honra ter sua
        presença neste dia que esperamos há tanto tempo.
      </p>
    </section>

    <img src="/brand/botanicals/botanical-divider-v1.svg" alt="" class="divider rv" aria-hidden="true" />

    <!-- 4 · Venue — heritage heading style -->
    <section class="sec sec--venue rv" aria-label="Local da cerimônia">
      <p class="lbl lbl--gold" style="margin-bottom:20px">Local</p>
      <h2 class="venue-name">Castelo dos Lagos</h2>
      <p class="venue-addr">R. Bonfim, 754 — Jardim Planteucal</p>
      <p class="venue-addr">Ribeirão Pires — SP, 09414-200</p>

      <div class="venue-video rv">
        <div class="frame frame--lg">
          <video autoplay muted loop playsinline>
            <source src="/videos/vista-frente.mp4" type="video/mp4" />
          </video>
          <div class="frame-ornament frame-ornament--tl"></div>
          <div class="frame-ornament frame-ornament--tr"></div>
          <div class="frame-ornament frame-ornament--bl"></div>
          <div class="frame-ornament frame-ornament--br"></div>
          <div class="frame-shine"></div>
        </div>
      </div>
    </section>

    <!-- 5 · More venue videos — aerial pair -->
    <section class="sec rv" aria-label="Vistas aéreas do castelo">
      <div class="frame-pair">
        <div class="frame frame--sm">
          <video autoplay muted loop playsinline class="video-aerial">
            <source src="/videos/vista-cima-1.mp4" type="video/mp4" />
          </video>
          <div class="frame-ornament frame-ornament--tl"></div>
          <div class="frame-ornament frame-ornament--tr"></div>
          <div class="frame-ornament frame-ornament--bl"></div>
          <div class="frame-ornament frame-ornament--br"></div>
          <div class="frame-shine"></div>
        </div>
        <div class="frame frame--sm">
          <video autoplay muted loop playsinline class="video-aerial">
            <source src="/videos/vista-cima-2.mp4" type="video/mp4" />
          </video>
          <div class="frame-ornament frame-ornament--tl"></div>
          <div class="frame-ornament frame-ornament--tr"></div>
          <div class="frame-ornament frame-ornament--bl"></div>
          <div class="frame-ornament frame-ornament--br"></div>
          <div class="frame-shine"></div>
        </div>
      </div>
    </section>

    <img src="/brand/botanicals/botanical-divider-v1.svg" alt="" class="divider rv" aria-hidden="true" />

    <!-- 6 · Dress code -->
    <section class="sec rv" aria-label="Traje">
      <p class="lbl lbl--gold" style="margin-bottom:14px">Traje</p>
      <p class="det-name">Esporte fino</p>
      <p class="det-sub" style="margin-top:4px">Tons elegantes e discretos</p>

      <div class="color-row" style="margin-top:18px">
        <div class="swatch-wrap">
          <div class="color-swatch" style="background:#1a1a1a"></div>
          <span class="swatch-label">Preto</span>
        </div>
        <div class="swatch-wrap">
          <div class="color-swatch" style="background:#4A1619"></div>
          <span class="swatch-label">Burgundy</span>
        </div>
        <div class="swatch-wrap">
          <div class="color-swatch" style="background:#1a2744"></div>
          <span class="swatch-label">Marinho</span>
        </div>
        <div class="swatch-wrap">
          <div class="color-swatch" style="background:#c4a882"></div>
          <span class="swatch-label">Nude</span>
        </div>
        <div class="swatch-wrap">
          <div class="color-swatch" style="background:#3d3d3d"></div>
          <span class="swatch-label">Chumbo</span>
        </div>
      </div>
      <p class="lbl lbl--dim" style="margin-top:14px;font-size:8px;letter-spacing:.3em">Evitem branco e creme</p>
    </section>

    <img src="/brand/botanicals/botanical-divider-v1.svg" alt="" class="divider rv" aria-hidden="true" />

    <!-- 7 · Photos — 2:1:1 editorial grid -->
    <section class="sec rv" aria-label="Fotos dos noivos">
      <p class="lbl lbl--gold" style="margin-bottom:24px">Nossa história</p>

      <div class="photo-grid">
        <div class="photo-grid__hero">
          <img src="/photos/templo-abraco-frente.jpg" alt="Moroni e Daphine se abraçando no templo" loading="lazy" />
        </div>
        <div class="photo-grid__side photo-grid__side--top">
          <img src="/photos/olhar-elegante.jpg" alt="Moroni e Daphine — olhar elegante" loading="lazy" />
        </div>
        <div class="photo-grid__side photo-grid__side--bottom">
          <img src="/photos/sorriso-juntos.jpg" alt="Moroni e Daphine sorrindo" loading="lazy" />
        </div>
      </div>

      <div class="photo-pair rv">
        <div class="photo-pair__item">
          <img src="/photos/noivos-braco.jpg" alt="Moroni e Daphine" loading="lazy" />
        </div>
        <div class="photo-pair__item">
          <img src="/photos/foto-heic1.jpg" alt="Moroni e Daphine" loading="lazy" />
        </div>
      </div>
    </section>

    <img src="/brand/botanicals/botanical-divider-v1.svg" alt="" class="divider rv" aria-hidden="true" />

    <!-- 8 · Closing message -->
    <section class="sec rv" aria-label="Mensagem final">
      <img src="/brand/botanicals/botanical-tulip-v1.svg" alt="" class="bot-accent" aria-hidden="true" style="width:40px;margin-bottom:16px" />
      <p class="body-it closing-msg">
        Queremos vocês presentes,<br/>mais do que presentes.
      </p>
    </section>

    <img src="/brand/botanicals/botanical-divider-v1.svg" alt="" class="divider rv" aria-hidden="true" />

    <!-- 9 · Countdown -->
    <section class="sec rv" aria-label="Contagem regressiva">
      <p class="lbl lbl--gold" style="margin-bottom:16px">Faltam</p>
      <div class="cd-grid">
        <div class="cd-u"><span class="cd-n" id="d">--</span><span class="lbl lbl--dim">Dias</span></div>
        <div class="cd-u"><span class="cd-n" id="h">--</span><span class="lbl lbl--dim">Horas</span></div>
        <div class="cd-u"><span class="cd-n" id="m">--</span><span class="lbl lbl--dim">Min</span></div>
        <div class="cd-u"><span class="cd-n" id="s">--</span><span class="lbl lbl--dim">Seg</span></div>
      </div>
    </section>

    <img src="/brand/botanicals/botanical-divider-v1.svg" alt="" class="divider rv" aria-hidden="true" />

    <!-- 10 · RSVP -->
    <section class="sec rv" aria-label="Confirmação de presença">
      <h2 class="rsvp-h">Confirme sua presença</h2>
      <form id="form" class="form" novalidate>
        <div class="f">
          <label class="lbl lbl--dim" for="rsvp-name">Nome completo</label>
          <input type="text" id="rsvp-name" name="name" required placeholder="Seu nome" autocomplete="name" />
        </div>
        <div class="f-row">
          <div class="f">
            <label class="lbl lbl--dim" for="rsvp-guests">Acompanhantes</label>
            <select id="rsvp-guests" name="guests">
              <option value="0">Sozinho(a)</option>
              <option value="1">+1</option>
              <option value="2">+2</option>
              <option value="3">+3</option>
            </select>
          </div>
          <div class="f">
            <label class="lbl lbl--dim" for="rsvp-confirm">Presença</label>
            <select id="rsvp-confirm" name="confirm" required>
              <option value="sim">Confirmo</option>
              <option value="talvez">Talvez</option>
              <option value="nao">Não poderei</option>
            </select>
          </div>
        </div>
        <div class="f">
          <label class="lbl lbl--dim" for="rsvp-message">Mensagem (opcional)</label>
          <textarea id="rsvp-message" name="message" rows="2" placeholder="Uma palavra para os noivos..."></textarea>
        </div>
        <button type="submit" class="submit-btn lbl lbl--cream">Enviar confirmação</button>
      </form>

      <!-- Post-RSVP emotional moment -->
      <div id="ok" class="ok" hidden>
        <div class="ok-photo">
          <img src="/photos/templo-abraco-frente.jpg" alt="Moroni e Daphine" loading="lazy" />
        </div>
        <img src="/brand/botanicals/botanical-divider-v1.svg" alt="" class="ok-divider" aria-hidden="true" />
        <p class="ok-h">Obrigado!</p>
        <p class="body-it">Estamos ansiosos para celebrar com você.</p>
      </div>
    </section>

    <!-- 11 · Links -->
    <section class="sec rv" style="margin-top:12px" aria-label="Links úteis">
      <div class="lnk">
        <a href="/" class="lbl lbl--cream">Nosso site</a>
        <span class="lnk-dot">&middot;</span>
        <a href="/presentes" class="lbl lbl--cream">Presentes</a>
        <span class="lnk-dot">&middot;</span>
        <a href="/faq" class="lbl lbl--cream">FAQ</a>
      </div>
    </section>

    <!-- 12 · Footer -->
    <footer class="sec rv" style="margin-top:40px;padding-bottom:24px">
      <img src="/brand/botanicals/botanical-rose-spray-v1.svg" alt="" class="bot-footer" aria-hidden="true" />
      <p class="lbl lbl--dim" style="margin-top:16px">doze &middot; junho &middot; mmxxvi</p>
    </footer>

  </main>

</body>
</html>

<style>
  /* ═══════════════════════════════════════════
     CONVITE — DARK BURGUNDY CRIMSON ATELIER
     Moroni Reis & Daphine Oliveira · 12.06.2026
  ═══════════════════════════════════════════ */

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    margin: 0;
    background: #3A1013;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }


  /* ── Utility classes ───────────────── */
  .lbl {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: .45em;
    margin: 0;
  }
  .lbl--cream { color: rgba(255,254,251,.50); }
  .lbl--gold  { color: rgba(212,175,55,.55); }
  .lbl--dim   { color: rgba(255,254,251,.28); }

  .body-it {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-style: italic;
    font-variation-settings: "opsz" 14;
    font-size: 15px;
    line-height: 1.85;
    color: rgba(255,254,251,.50);
    text-align: center;
    max-width: 360px;
    margin: 0 auto;
  }

  .sec {
    text-align: center;
    width: 100%;
    padding: 0 24px;
  }

  .gold-line {
    display: block;
    width: 26px;
    height: 1px;
    background: #D4AF37;
    opacity: .25;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border-width: 0;
  }


  /* ═══════════════════════════════
     COVER — fullscreen photo + monogram + ghost button
     Three-beat: ARRIVE → HOLD → OPEN
  ═══════════════════════════════ */
  .cover {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: opacity 1200ms cubic-bezier(.22,1,.36,1);
  }
  .cover.out { opacity: 0; pointer-events: none; }

  .cover-photo {
    position: absolute;
    inset: 0;
  }
  .cover-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    filter: sepia(.12) saturate(.82) contrast(.90) brightness(1.03);
    transform: scale(1.02);
    transition: transform 1200ms cubic-bezier(.22,1,.36,1);
  }
  .cover.out .cover-photo img { transform: scale(1.06); }

  .cover-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom,
      rgba(58,16,19,.40) 0%,
      rgba(58,16,19,.20) 25%,
      rgba(58,16,19,.25) 50%,
      rgba(58,16,19,.55) 75%,
      rgba(58,16,19,.75) 100%);
  }

  .cover-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 32px;
    text-align: center;
  }

  .cover-monogram {
    width: clamp(200px, 50vw, 320px);
    color: rgba(255,254,251,.80);
    filter: drop-shadow(0 2px 30px rgba(0,0,0,.40));
  }
  .cover-monogram img {
    width: 100%;
    height: auto;
  }

  .cover-btn {
    margin-top: 36px;
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: .45em;
    color: rgba(255,255,255,.55);
    background: transparent;
    border: 1px solid rgba(255,255,255,.20);
    padding: 14px 36px;
    min-height: 48px;
    cursor: pointer;
    transition: border-color 600ms, color 600ms, background 600ms;
    -webkit-tap-highlight-color: transparent;
  }
  .cover-btn:hover,
  .cover-btn:focus-visible {
    border-color: rgba(255,255,255,.45);
    color: rgba(255,255,255,.80);
    background: rgba(255,255,255,.05);
  }
  .cover-btn:focus-visible {
    outline: 2px solid rgba(255,255,255,.40);
    outline-offset: 3px;
  }


  /* ═══════════════════════════════
     INVITATION — dark scroll card
  ═══════════════════════════════ */
  .page {
    max-width: 520px;
    margin: 0 auto;
    padding: 60px 0 48px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 1000ms 200ms cubic-bezier(.22,1,.36,1),
                transform 1000ms 200ms cubic-bezier(.22,1,.36,1);
    pointer-events: none;
  }
  .page.show { opacity: 1; transform: none; pointer-events: all; }
  @media (min-width: 640px) { .page { padding: 80px 16px 64px; } }


  /* ── Botanical accents ─────────── */
  .bot-accent {
    width: 60px;
    height: auto;
    opacity: .12;
    filter: brightness(3) sepia(.2);
    margin-bottom: 12px;
  }
  .bot-accent--top { transform: rotate(180deg); }

  .bot-footer {
    width: 80px;
    height: auto;
    opacity: .10;
    filter: brightness(3) sepia(.2);
  }


  /* ── Botanical dividers ─────────── */
  .divider {
    width: min(140px, 35%);
    height: auto;
    opacity: .08;
    filter: brightness(3) sepia(.2);
  }


  /* ── Names section ─────────────── */
  .sec--names { padding-top: 8px; }

  .names {
    font-family: 'Fraunces', serif;
    font-weight: 200;
    font-style: italic;
    font-variation-settings: "opsz" 144, "SOFT" 50;
    font-size: clamp(28px, 7vw, 44px);
    color: #FFFEFB;
    letter-spacing: .03em;
    line-height: 1.1;
    margin: 0;
  }

  .amp {
    font-family: 'Fraunces', serif;
    font-weight: 200;
    font-style: italic;
    font-variation-settings: "opsz" 144, "SOFT" 50;
    font-size: clamp(14px, 3vw, 20px);
    color: rgba(212,175,55,.50);
    margin: 6px 0;
  }


  /* ── Date ───────────────────────── */
  .date-row {
    display: flex;
    align-items: center;
    gap: 18px;
    justify-content: center;
  }
  .date-num {
    font-family: 'Fraunces', serif;
    font-weight: 200;
    font-variation-settings: "opsz" 144, "SOFT" 50;
    font-size: clamp(56px, 13vw, 80px);
    line-height: 1;
    color: rgba(255,254,251,.75);
  }
  .date-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 5px;
  }


  /* ── Venue — heritage heading ──── */
  .sec--venue { padding-top: 4px; }

  .venue-name {
    font-family: 'Fraunces', serif;
    font-weight: 200;
    font-style: italic;
    font-variation-settings: "opsz" 144, "SOFT" 50;
    font-size: clamp(24px, 5.5vw, 34px);
    color: rgba(255,254,251,.75);
    letter-spacing: .02em;
    line-height: 1.15;
    margin: 0 0 10px;
  }

  .venue-addr {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 10px;
    line-height: 1.7;
    letter-spacing: .08em;
    color: rgba(255,254,251,.28);
    margin: 0;
  }

  .venue-video {
    margin-top: 24px;
    width: 100%;
    padding: 0;
  }


  /* ── Dress code ───────────────── */
  .det-name {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-variation-settings: "opsz" 14;
    font-size: 15px;
    color: rgba(255,254,251,.70);
    margin: 0;
  }
  .det-sub {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 11px;
    line-height: 1.85;
    color: rgba(255,254,251,.30);
    margin: 0;
  }


  /* ── Color swatches (with labels) ── */
  .color-row {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .swatch-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }
  .color-swatch {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid rgba(255,254,251,.12);
    transition: transform 300ms ease;
  }
  .color-swatch:hover { transform: scale(1.15); }

  .swatch-label {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 7px;
    text-transform: uppercase;
    letter-spacing: .25em;
    color: rgba(255,254,251,.22);
  }


  /* ── Portrait frames (gold ornate) ─ */
  .frame {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(212,175,55,.20);
    background: rgba(212,175,55,.04);
    transition: border-color 500ms;
  }
  .frame:hover { border-color: rgba(212,175,55,.35); }

  .frame video,
  .frame img {
    width: 100%;
    display: block;
    object-fit: cover;
    filter: sepia(.12) saturate(.82) contrast(.90) brightness(1.03);
  }

  /* Aerial video — slightly different color grade */
  .video-aerial {
    filter: sepia(.08) saturate(.90) contrast(.88) brightness(1.04) !important;
  }

  .frame--lg { margin-bottom: 8px; }
  .frame--lg video { aspect-ratio: 16 / 9; }
  .frame--sm video { aspect-ratio: 16 / 10; }

  .frame-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    width: 100%;
    padding: 0 24px;
  }

  /* Gold corner L-brackets */
  .frame-ornament {
    position: absolute;
    width: 16px;
    height: 16px;
    border-color: rgba(212,175,55,.30);
    border-style: solid;
    border-width: 0;
    pointer-events: none;
    z-index: 2;
  }
  .frame-ornament--tl { top: 6px; left: 6px; border-top-width: 1px; border-left-width: 1px; }
  .frame-ornament--tr { top: 6px; right: 6px; border-top-width: 1px; border-right-width: 1px; }
  .frame-ornament--bl { bottom: 6px; left: 6px; border-bottom-width: 1px; border-left-width: 1px; }
  .frame-ornament--br { bottom: 6px; right: 6px; border-bottom-width: 1px; border-right-width: 1px; }

  /* Shimmer / shine sweep */
  .frame-shine {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    background: linear-gradient(105deg,
      transparent 42%,
      rgba(255,255,255,.04) 48%,
      rgba(212,175,55,.03) 50%,
      rgba(255,255,255,.04) 52%,
      transparent 58%);
    animation: shim 8s 3s ease-in-out infinite;
  }
  @keyframes shim {
    0%, 100% { transform: translateX(-120%); }
    50% { transform: translateX(220%); }
  }


  /* ── Photo grid — 2:1:1 editorial ── */
  .photo-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 6px;
    width: 100%;
  }

  .photo-grid__hero {
    grid-row: 1 / 3;
  }

  .photo-grid img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: sepia(.12) saturate(.82) contrast(.90) brightness(1.03);
    border: 1px solid rgba(212,175,55,.12);
    display: block;
  }

  .photo-grid__hero img {
    aspect-ratio: 3 / 4;
  }
  .photo-grid__side img {
    aspect-ratio: 1 / 1;
  }

  /* Photo pair — below grid */
  .photo-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
    width: 100%;
    margin-top: 6px;
  }

  .photo-pair__item img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    filter: sepia(.12) saturate(.82) contrast(.90) brightness(1.03);
    border: 1px solid rgba(212,175,55,.12);
    display: block;
  }

  /* Golden hour warmth overlay on photos */
  .photo-grid__hero,
  .photo-grid__side,
  .photo-pair__item {
    position: relative;
    overflow: hidden;
  }
  .photo-grid__hero::after,
  .photo-grid__side::after,
  .photo-pair__item::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 40% 40%,
      rgba(212,175,55,.06) 0%,
      transparent 70%);
    pointer-events: none;
  }

  @media (max-width: 400px) {
    .photo-grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }
    .photo-grid__hero {
      grid-row: auto;
    }
    .photo-grid__hero img {
      aspect-ratio: 3 / 4;
    }
    .photo-grid__side img {
      aspect-ratio: 3 / 2;
    }
    .photo-pair {
      grid-template-columns: 1fr;
    }
  }


  /* ── Closing message ───────────── */
  .closing-msg {
    font-size: 16px;
    line-height: 1.9;
    max-width: 320px;
  }


  /* ── Countdown ─────────────────── */
  .cd-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
    max-width: 280px;
    margin: 0 auto;
  }
  .cd-u {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .cd-n {
    font-family: 'Fraunces', serif;
    font-weight: 200;
    font-variation-settings: "opsz" 144, "SOFT" 50;
    font-size: clamp(28px, 6vw, 38px);
    line-height: 1;
    color: rgba(255,254,251,.65);
    font-variant-numeric: tabular-nums;
  }


  /* ── RSVP form ─────────────────── */
  .rsvp-h {
    font-family: 'Fraunces', serif;
    font-weight: 200;
    font-style: italic;
    font-variation-settings: "opsz" 144, "SOFT" 50;
    font-size: clamp(20px, 4.5vw, 28px);
    color: #FFFEFB;
    margin: 0 0 24px;
  }
  .form { text-align: left; width: 100%; }
  .f { margin-bottom: 14px; }
  .f label { display: block; margin-bottom: 5px; }
  .f input,
  .f select,
  .f textarea {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid rgba(255,254,251,.08);
    border-radius: 0;
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-size: 14px;
    color: #FFFEFB;
    background: rgba(255,255,255,.04);
    outline: none;
    transition: border-color 300ms, box-shadow 300ms;
    -webkit-appearance: none;
  }
  .f input::placeholder,
  .f textarea::placeholder {
    color: rgba(255,254,251,.15);
  }
  .f input:focus,
  .f select:focus,
  .f textarea:focus {
    border-color: rgba(212,175,55,.25);
    box-shadow: 0 0 0 3px rgba(212,175,55,.04);
  }
  .f select {
    color: rgba(255,254,251,.70);
  }
  .f select option {
    background: #3A1013;
    color: #FFFEFB;
  }
  .f textarea { resize: vertical; min-height: 50px; }
  .f-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  @media (max-width: 400px) { .f-row { grid-template-columns: 1fr; } }

  .submit-btn {
    width: 100%;
    padding: 14px;
    min-height: 48px;
    background: rgba(212,175,55,.12);
    color: rgba(255,254,251,.60);
    border: 1px solid rgba(212,175,55,.20);
    cursor: pointer;
    letter-spacing: .35em;
    margin-top: 6px;
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 9px;
    text-transform: uppercase;
    transition: background 300ms, color 300ms, border-color 300ms;
  }
  .submit-btn:hover {
    background: rgba(212,175,55,.20);
    color: rgba(255,254,251,.80);
    border-color: rgba(212,175,55,.35);
  }
  .submit-btn:focus-visible {
    outline: 2px solid rgba(212,175,55,.40);
    outline-offset: 3px;
  }


  /* ── Post-RSVP emotional moment ── */
  .ok {
    text-align: center;
    padding: 28px 0;
    animation: okFade 900ms cubic-bezier(.22,1,.36,1) forwards;
  }
  @keyframes okFade {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: none; }
  }
  .ok-photo {
    width: 100%;
    max-width: 320px;
    margin: 0 auto 20px;
    overflow: hidden;
    border: 1px solid rgba(212,175,55,.15);
  }
  .ok-photo img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    filter: sepia(.12) saturate(.82) contrast(.90) brightness(1.03);
    display: block;
  }
  .ok-divider {
    width: min(100px, 28%);
    height: auto;
    opacity: .08;
    filter: brightness(3) sepia(.2);
    margin-bottom: 16px;
  }
  .ok-h {
    font-family: 'Fraunces', serif;
    font-weight: 200;
    font-style: italic;
    font-variation-settings: "opsz" 144, "SOFT" 50;
    font-size: 26px;
    color: #FFFEFB;
    margin-bottom: 8px;
  }


  /* ── Links ─────────────────────── */
  .lnk {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .lnk-dot { color: rgba(255,254,251,.10); font-size: 12px; }
  .lnk a {
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 300ms, border-bottom-color 300ms;
  }
  .lnk a:hover {
    color: rgba(255,254,251,.75) !important;
    border-bottom-color: rgba(212,175,55,.20);
  }


  /* ── Scroll reveals ────────────── */
  .rv {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 900ms cubic-bezier(.22,1,.36,1),
                transform 900ms cubic-bezier(.22,1,.36,1);
  }
  .rv.show { opacity: 1; transform: none; }


  /* ── Reduced motion ────────────── */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: .01ms !important;
      transition-duration: .01ms !important;
    }
    .rv { opacity: 1; transform: none; }
    .page { opacity: 1; transform: none; pointer-events: all; }
    .cover { display: none; }
  }
</style>

<script>
  // ── Cover open (three-beat: ARRIVE → HOLD → OPEN) ──
  document.getElementById('cover-btn')?.addEventListener('click', () => {
    const cover = document.getElementById('cover')!;
    const page = document.getElementById('page')!;
    cover.classList.add('out');
    setTimeout(() => {
      page.classList.add('show');
      document.body.style.overflow = '';
    }, 400);
    setTimeout(() => cover.remove(), 2000);
  });

  // Lock scroll while cover is visible
  document.body.style.overflow = 'hidden';

  // ── Scroll reveals ────────────────
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).classList.add('show');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: .1 });
  document.querySelectorAll('.rv').forEach(el => obs.observe(el));

  // ── Countdown ─────────────────────
  const WEDDING = new Date('2026-06-12T21:00:00-03:00').getTime();
  const $ = (id: string) => document.getElementById(id)!;

  function tick() {
    const r = WEDDING - Date.now();
    if (r <= 0) {
      $('d').textContent = '0';
      $('h').textContent = '00';
      $('m').textContent = '00';
      $('s').textContent = '00';
      return;
    }
    $('d').textContent = String(Math.floor(r / 864e5));
    $('h').textContent = String(Math.floor((r % 864e5) / 36e5)).padStart(2, '0');
    $('m').textContent = String(Math.floor((r % 36e5) / 6e4)).padStart(2, '0');
    $('s').textContent = String(Math.floor((r % 6e4) / 1e3)).padStart(2, '0');
  }
  tick();
  setInterval(tick, 1000);

  // ── RSVP ──────────────────────────
  const form = document.getElementById('form') as HTMLFormElement;
  form?.addEventListener('submit', e => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(form));
    const list = JSON.parse(localStorage.getItem('rsvp') || '[]');
    list.push({ ...data, timestamp: new Date().toISOString() });
    localStorage.setItem('rsvp', JSON.stringify(list));
    form.hidden = true;
    document.getElementById('ok')!.hidden = false;
  });
</script>
