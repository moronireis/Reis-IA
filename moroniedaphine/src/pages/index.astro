---
// index.astro — Moroni & Daphine · Página inicial
// Architecture: hero (full-bleed photo) · história intro · photo grid · O grande dia · photo break · countdown · CTA presentes
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Moroni Reis & Daphine Oliveira — 12 de junho de 2026" />
    <title>Moroni Reis & Daphine Oliveira · 12 de junho de 2026</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,200;0,9..144,300;0,9..144,400;1,9..144,200;1,9..144,300;1,9..144,400&family=Inter:wght@300;400&display=swap" rel="stylesheet" />
    
  </head>
  <body>

    <a href="#main-content" class="sr-only skip-link">Ir para o conteúdo principal</a>

    <!-- Nav: white text — hero is dark photo overlay -->
    <Nav activePage="inicio" />

    <main id="main-content">

      <!-- ═══════════════════════════════════════════
           SECTION 1 · HERO — full-bleed photo
      ═══════════════════════════════════════════ -->
      <section class="hero" aria-label="Moroni Reis e Daphine Oliveira">

        <!-- Photo placeholder — full viewport -->
        <div class="hero__photo photo-placeholder photo-placeholder--light" aria-hidden="true">
          <span class="photo-placeholder__label">fotografia · hero</span>
        </div>

        <!-- Overlay — bottom-center text -->
        <div class="hero__overlay">
          <p class="hero__eyebrow i-micro">12 de junho de 2026</p>
          <h1 class="hero__wordmark">
            Moroni Reis &amp; Daphine Oliveira
          </h1>
        </div>

      </section>


      <!-- ═══════════════════════════════════════════
           SECTION 2 · NOSSA HISTÓRIA INTRO
           Burgundy bg, centered, short 2-paragraph copy
      ═══════════════════════════════════════════ -->
      <section class="historia reveal" aria-labelledby="historia-heading">
        <div class="content-narrow">
          <p class="i-micro historia__eyebrow" aria-hidden="true">Nossa história</p>

          <div class="f-body-italic historia__body">
            {/* PLACEHOLDER — substituir por texto real do casal */}
            <p>
              Nós nos conhecemos numa tarde que começou como qualquer outra — e terminou diferente de todas.
              Foi algo mais quieto do que amor à primeira vista: a sensação de reconhecer alguém que você
              ainda não conhecia.
            </p>
            <p>
              Hoje chegamos aqui com uma data marcada, uma lista de presentes e a certeza de que
              cada pessoa neste site faz parte do que construímos — e do que ainda vamos construir juntos.
            </p>
          </div>

          <a href="/sobre-nos" class="historia__cta i-micro">
            Saiba mais sobre nós →
          </a>
        </div>
      </section>


      <!-- ═══════════════════════════════════════════
           SECTION 3 · PHOTO GRID — 4 photos horizontal
      ═══════════════════════════════════════════ -->
      <section class="photo-grid reveal" aria-label="Fotos do casal" aria-hidden="true">
        <div class="photo-grid__track">
          <div class="photo-grid__cell photo-placeholder photo-placeholder--light">
            <span class="photo-placeholder__label">fotografia</span>
          </div>
          <div class="photo-grid__cell photo-placeholder photo-placeholder--light">
            <span class="photo-placeholder__label">fotografia</span>
          </div>
          <div class="photo-grid__cell photo-placeholder photo-placeholder--light">
            <span class="photo-placeholder__label">fotografia</span>
          </div>
          <div class="photo-grid__cell photo-placeholder photo-placeholder--light">
            <span class="photo-placeholder__label">fotografia</span>
          </div>
        </div>
      </section>


      <!-- ═══════════════════════════════════════════
           SECTION 4 · O GRANDE DIA — 2×2 info blocks
      ═══════════════════════════════════════════ -->
      <section class="grande-dia" aria-labelledby="grande-dia-heading">
        <div class="container">

          <h2 class="grande-dia__heading f-display reveal" id="grande-dia-heading">O grande dia</h2>

          <div class="grande-dia__grid reveal-group reveal-stagger">

            <!-- Block 01 · Data -->
            <div class="info-block">
              <span class="info-block__number f-h2-italic" aria-hidden="true">01</span>
              <span class="info-block__rule gold-rule" aria-hidden="true"></span>
              <p class="info-block__title i-label">Data</p>
              <p class="info-block__body f-body">
                {/* PLACEHOLDER */}
                12 de junho de 2026 · 16h00
              </p>
            </div>

            <!-- Block 02 · Cerimônia -->
            <div class="info-block">
              <span class="info-block__number f-h2-italic" aria-hidden="true">02</span>
              <span class="info-block__rule gold-rule" aria-hidden="true"></span>
              <p class="info-block__title i-label">Cerimônia</p>
              <p class="info-block__body f-body">
                {/* PLACEHOLDER — endereço a confirmar */}
                O local será enviado junto ao convite. Reservem a data e aguardem mais detalhes em breve.
              </p>
            </div>

            <!-- Block 03 · Traje -->
            <div class="info-block">
              <span class="info-block__number f-h2-italic" aria-hidden="true">03</span>
              <span class="info-block__rule gold-rule" aria-hidden="true"></span>
              <p class="info-block__title i-label">Traje</p>
              <p class="info-block__body f-body">
                {/* PLACEHOLDER — confirmar com casal */}
                Esporte fino. Tons pretos, burgundy e neutros são bem-vindos. Por gentileza, evitem branco e creme.
              </p>
            </div>

            <!-- Block 04 · Mensagem -->
            <div class="info-block">
              <span class="info-block__number f-h2-italic" aria-hidden="true">04</span>
              <span class="info-block__rule gold-rule" aria-hidden="true"></span>
              <p class="info-block__title i-label">Mensagem</p>
              <p class="info-block__body f-body">
                {/* PLACEHOLDER */}
                Queremos vocês presentes, mais do que presentes. A sua presença já é o maior presente que podemos receber.
              </p>
            </div>

          </div>
        </div>
      </section>


      <!-- ═══════════════════════════════════════════
           SECTION 5 · PHOTO BREAK — full width, burgundy bg
      ═══════════════════════════════════════════ -->
      <section class="photo-break reveal" aria-hidden="true">
        <div class="photo-break__image photo-placeholder photo-placeholder--on-dark">
          <span class="photo-placeholder__label">fotografia</span>
        </div>
      </section>


      <!-- ═══════════════════════════════════════════
           SECTION 6 · COUNTDOWN
      ═══════════════════════════════════════════ -->
      <section class="countdown reveal" aria-labelledby="countdown-heading">
        <div class="container">
          <p class="countdown__label f-h2-italic" id="countdown-heading" aria-live="off">Falta</p>

          <div class="countdown__grid" id="countdown-display" aria-label="Contagem regressiva para o casamento">
            <div class="countdown__unit">
              <span class="countdown__number f-display" id="cd-days">—</span>
              <span class="countdown__name i-micro">Dias</span>
            </div>
            <div class="countdown__unit">
              <span class="countdown__number f-display" id="cd-hours">—</span>
              <span class="countdown__name i-micro">Horas</span>
            </div>
            <div class="countdown__unit">
              <span class="countdown__number f-display" id="cd-minutes">—</span>
              <span class="countdown__name i-micro">Minutos</span>
            </div>
            <div class="countdown__unit">
              <span class="countdown__number f-display" id="cd-seconds">—</span>
              <span class="countdown__name i-micro">Segundos</span>
            </div>
          </div>

          <!-- Shown if wedding date has passed -->
          <p class="countdown__done f-h2-italic" id="countdown-done" hidden>
            Hoje é o grande dia
          </p>
        </div>
      </section>


      <!-- ═══════════════════════════════════════════
           SECTION 7 · CTA PRESENTES — burgundy bg
      ═══════════════════════════════════════════ -->
      <section class="cta-presentes reveal" aria-labelledby="cta-presentes-heading">
        <div class="content-narrow">
          <h2 class="cta-presentes__heading f-display" id="cta-presentes-heading">
            Lista de presentes
          </h2>
          <p class="f-body-italic cta-presentes__body">
            {/* PLACEHOLDER */}
            Receber vocês já é o presente maior. Mas se quiserem nos dar algo além da presença,
            preparamos uma lista com cuidado.
          </p>
          <a href="/presentes" class="btn-ghost btn-ghost--white cta-presentes__btn">
            Ver lista
          </a>
        </div>
      </section>

    </main>

    <Footer />

  </body>
</html>

<style>
  /* ─── Skip link ──────────────────────────────── */
  .skip-link:focus {
    position: fixed;
    top: 16px;
    left: 16px;
    z-index: 9999;
    background: var(--white);
    color: var(--burgundy);
    padding: 8px 16px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
  }

  /* ─── HERO ───────────────────────────────────── */
  .hero {
    position: relative;
    height: 100svh;
    min-height: 600px;
    overflow: hidden;
  }

  @supports not (height: 100svh) {
    .hero { height: 100vh; }
  }

  .hero__photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    /* Slightly deeper burgundy tint over the placeholder */
    background: rgba(74, 22, 25, 0.06);
  }

  /* Dark scrim at bottom for text legibility */
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 40%,
      rgba(0, 0, 0, 0.52) 100%
    );
    pointer-events: none;
  }

  .hero__overlay {
    position: absolute;
    bottom: clamp(48px, 8vh, 96px);
    left: 0;
    right: 0;
    text-align: center;
    z-index: 2;
    padding: 0 var(--site-gutter);
  }

  .hero__eyebrow {
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 20px;
    display: block;
  }

  .hero__wordmark {
    font-family: 'Fraunces', serif;
    font-weight: 200;
    font-variation-settings: "opsz" 144, "SOFT" 50;
    font-size: clamp(40px, 7vw, 96px);
    letter-spacing: 0.02em;
    line-height: 1.0;
    color: var(--white);
  }

  /* ─── HISTÓRIA ───────────────────────────────── */
  .historia {
    background: var(--burgundy);
    padding: var(--section-v-desktop) var(--site-gutter);
    text-align: center;
  }

  @media (max-width: 768px) {
    .historia { padding: var(--section-v-mobile) var(--site-gutter); }
  }

  .historia__eyebrow {
    color: rgba(255, 255, 255, 0.55);
    display: block;
    margin-bottom: 28px;
  }

  .historia__body {
    color: rgba(255, 255, 255, 0.85);
  }

  .historia__body p + p {
    margin-top: 1.6em;
  }

  .historia__cta {
    display: inline-block;
    margin-top: 40px;
    color: rgba(212, 175, 55, 0.70);
    text-decoration: none;
    transition: opacity 300ms ease;
    letter-spacing: 0.28em;
  }

  .historia__cta:hover {
    opacity: 0.55;
  }

  /* ─── PHOTO GRID ─────────────────────────────── */
  .photo-grid {
    background: var(--white);
    line-height: 0; /* collapse inline gap */
  }

  .photo-grid__track {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  @media (max-width: 768px) {
    .photo-grid__track {
      grid-template-columns: 1fr;
    }
  }

  .photo-grid__cell {
    height: 280px;
    border-right: 1px solid var(--white);
    line-height: 1;
  }

  @media (max-width: 768px) {
    .photo-grid__cell {
      height: 320px;
      border-right: none;
      border-bottom: 1px solid var(--white);
    }
    .photo-grid__cell:last-child { border-bottom: none; }
  }

  .photo-grid__cell:last-child {
    border-right: none;
  }

  /* ─── O GRANDE DIA ───────────────────────────── */
  .grande-dia {
    background: var(--white);
    padding: var(--section-v-desktop) var(--site-gutter);
  }

  @media (max-width: 768px) {
    .grande-dia { padding: var(--section-v-mobile) var(--site-gutter); }
  }

  .grande-dia__heading {
    color: var(--burgundy);
    text-align: center;
    margin-bottom: clamp(48px, 7vh, 80px);
  }

  .grande-dia__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border: 1px solid rgba(74, 22, 25, 0.10);
  }

  @media (max-width: 640px) {
    .grande-dia__grid {
      grid-template-columns: 1fr;
    }
  }

  .info-block {
    padding: clamp(40px, 5vh, 56px) clamp(28px, 4vw, 56px);
    border-right: 1px solid rgba(74, 22, 25, 0.08);
    border-bottom: 1px solid rgba(74, 22, 25, 0.08);
  }

  /* Remove right border on even cells, bottom on last row */
  .info-block:nth-child(2n) {
    border-right: none;
  }

  .info-block:nth-last-child(-n+2) {
    border-bottom: none;
  }

  @media (max-width: 640px) {
    .info-block {
      border-right: none;
    }
    .info-block:nth-last-child(-n+2) {
      border-bottom: 1px solid rgba(74, 22, 25, 0.08);
    }
    .info-block:last-child {
      border-bottom: none;
    }
  }

  .info-block__number {
    display: block;
    color: var(--burgundy);
    font-size: 32px;
    margin-bottom: 12px;
    line-height: 1;
  }

  .info-block__rule {
    margin-bottom: 16px;
    /* left-aligned */
    margin-left: 0;
  }

  .info-block__title {
    display: block;
    color: rgba(74, 22, 25, 0.65);
    margin-bottom: 12px;
  }

  .info-block__body {
    color: rgba(74, 22, 25, 0.85);
    font-size: 16px;
  }

  /* ─── PHOTO BREAK ────────────────────────────── */
  .photo-break {
    background: var(--burgundy);
    padding: 0;
  }

  .photo-break__image {
    height: 60vh;
    min-height: 320px;
    width: 100%;
    background: rgba(74, 22, 25, 0.90);
  }

  /* ─── COUNTDOWN ──────────────────────────────── */
  .countdown {
    background: var(--white);
    padding: var(--section-v-desktop) var(--site-gutter);
    text-align: center;
  }

  @media (max-width: 768px) {
    .countdown { padding: var(--section-v-mobile) var(--site-gutter); }
  }

  .countdown__label {
    color: rgba(74, 22, 25, 0.70);
    margin-bottom: clamp(32px, 5vh, 56px);
    font-size: 24px;
  }

  .countdown__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(16px, 4vw, 48px);
    max-width: 800px;
    margin: 0 auto;
  }

  @media (max-width: 640px) {
    .countdown__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px 16px;
    }
  }

  .countdown__unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .countdown__number {
    color: var(--burgundy);
    font-size: clamp(56px, 8vw, 96px);
    line-height: 1;
    font-variant-numeric: tabular-nums;
    min-width: 2ch;
    display: block;
    text-align: center;
  }

  .countdown__name {
    color: rgba(74, 22, 25, 0.55);
  }

  .countdown__done {
    color: var(--burgundy);
    font-size: clamp(28px, 4vw, 48px);
    text-align: center;
  }

  /* ─── CTA PRESENTES ──────────────────────────── */
  .cta-presentes {
    background: var(--burgundy);
    padding: var(--section-v-desktop) var(--site-gutter);
    text-align: center;
  }

  @media (max-width: 768px) {
    .cta-presentes { padding: var(--section-v-mobile) var(--site-gutter); }
  }

  .cta-presentes__heading {
    color: var(--white);
    margin-bottom: 28px;
    font-size: clamp(48px, 7vw, 96px);
  }

  .cta-presentes__body {
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 40px;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-presentes__btn {
    margin-top: 0;
  }
</style>

<!-- Countdown logic is handled globally in src/scripts/motion.ts
     (includes initial 0→target animation on IO entry). -->
