---
// Internal review hub — Moroni & Daphine wedding site
// Access at /hub for internal decision tracking
const items = [
  {
    title: "Tipografia · Fraunces",
    description: "Opção 03 aprovada — Fraunces variable, soft optical, peso 300, mixed case. Identidade vem da tipografia apenas, sem elementos desenhados.",
    href: "/tipografia.html",
    status: "Aprovado",
  },
  {
    title: "Paleta · Burgundy + White + Gold",
    description: "3 cores travadas — #4A1619 · #FFFFFF · #D4AF37. Gold é terciário (bordas, hairlines, pequenos destaques). Sem cream, blush ou variações.",
    href: "/tipografia.html",
    status: "Aprovado",
  },
  {
    title: "Monogramas",
    description: "Preview dos monogramas M&D em variações geométricas e serifa.",
    href: "/monogramas.html",
    status: "Em revisão",
  },
];
---

<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Hub Interno · Moroni & Daphine</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,200;9..144,300;9..144,400;9..144,500&family=Inter:wght@300;400&display=swap" rel="stylesheet" />
    <style>
      :root {
        --burgundy: #4A1619;
        --white: #FFFFFF;
        --gold: #D4AF37;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body {
        background: var(--burgundy);
        color: var(--white);
        font-family: 'Fraunces', Georgia, serif;
        font-weight: 300;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      .hero {
        padding: 12vh 6vw 8vh;
        text-align: center;
        border-bottom: 1px solid rgba(212, 175, 55, 0.2);
      }
      .names {
        font-family: 'Fraunces', serif;
        font-weight: 300;
        font-size: clamp(28px, 4vw, 48px);
        letter-spacing: 0.015em;
        font-variation-settings: "opsz" 144, "SOFT" 50;
        color: var(--white);
        line-height: 1.1;
      }
      .names em {
        font-style: italic;
        opacity: 0.72;
        padding: 0 .12em;
      }
      .date {
        font-family: 'Inter', sans-serif;
        font-weight: 300;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.48em;
        color: rgba(212, 175, 55, 0.7);
        margin-top: 1.5rem;
      }
      .eyebrow {
        font-family: 'Inter', sans-serif;
        font-weight: 300;
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.48em;
        color: rgba(255, 255, 255, 0.45);
        margin-top: 4rem;
      }
      .hub-title {
        font-family: 'Fraunces', serif;
        font-weight: 300;
        font-variation-settings: "opsz" 144, "SOFT" 50;
        font-size: clamp(28px, 4vw, 48px);
        letter-spacing: 0.01em;
        margin-top: 0.75rem;
        color: var(--white);
      }
      .hub-sub {
        font-family: 'Fraunces', serif;
        font-style: italic;
        font-weight: 300;
        font-variation-settings: "opsz" 14;
        font-size: 18px;
        margin-top: 1rem;
        color: rgba(255, 255, 255, 0.6);
        max-width: 560px;
        margin-left: auto;
        margin-right: auto;
      }
      .grid {
        max-width: 1200px;
        margin: 0 auto;
        padding: 8vh 6vw;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 2rem;
      }
      .card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(212, 175, 55, 0.2);
        padding: 3rem 2.5rem;
        text-decoration: none;
        color: inherit;
        transition: all 700ms cubic-bezier(0.19, 1, 0.22, 1);
        display: flex;
        flex-direction: column;
        min-height: 260px;
      }
      .card:hover {
        background: rgba(212, 175, 55, 0.04);
        border-color: rgba(212, 175, 55, 0.5);
      }
      .card-status {
        font-family: 'Inter', sans-serif;
        font-weight: 300;
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.36em;
        color: rgba(212, 175, 55, 0.65);
      }
      .card-title {
        font-family: 'Fraunces', serif;
        font-weight: 300;
        font-variation-settings: "opsz" 144, "SOFT" 50;
        font-size: 30px;
        letter-spacing: 0.01em;
        margin-top: 1.25rem;
        color: var(--white);
      }
      .card-desc {
        font-family: 'Fraunces', serif;
        font-style: italic;
        font-weight: 300;
        font-variation-settings: "opsz" 14;
        font-size: 16px;
        line-height: 1.65;
        color: rgba(255, 255, 255, 0.6);
        margin-top: 1rem;
        flex-grow: 1;
      }
      .card-cta {
        font-family: 'Inter', sans-serif;
        font-weight: 300;
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.36em;
        color: rgba(212, 175, 55, 0.65);
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(212, 175, 55, 0.18);
      }
      footer {
        padding: 5vh 6vw;
        text-align: center;
        border-top: 1px solid rgba(212, 175, 55, 0.12);
      }
      .footer-note {
        font-family: 'Fraunces', serif;
        font-style: italic;
        font-weight: 300;
        font-variation-settings: "opsz" 14;
        font-size: 14px;
        color: rgba(255, 255, 255, 0.4);
      }
    </style>
  </head>
  <body>
    <section class="hero">
      <div class="names">Moroni Reis <em>&amp;</em> Daphine Oliveira</div>
      <div class="date">12 · vi · mmxxvi</div>
      <div class="eyebrow">Hub Interno</div>
      <h1 class="hub-title">Decisões de design</h1>
      <p class="hub-sub">Cada peça abaixo espera revisão antes de avançar para a próxima fase.</p>
    </section>

    <section class="grid">
      {items.map(item => (
        <a class="card" href={item.href}>
          <span class="card-status">{item.status}</span>
          <h2 class="card-title">{item.title}</h2>
          <p class="card-desc">{item.description}</p>
          <span class="card-cta">Ver preview →</span>
        </a>
      ))}
    </section>

    <footer>
      <p class="footer-note">Preview interno · atualizado 15.04.2026</p>
    </footer>
  </body>
</html>
