---
import '../styles/global.css';

interface Props {
  title?: string;
  activePage?: string;
}

const { title = 'Funnil Hacker', activePage = 'dashboard' } = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Funnil Hacker</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-surface-0 text-text-primary min-h-screen">
    <div class="flex h-screen overflow-hidden">
      <!-- Sidebar -->
      <aside class="w-60 bg-surface-1 border-r border-border flex flex-col shrink-0">
        <!-- Logo -->
        <div class="h-14 flex items-center px-5 border-b border-border">
          <span class="text-sm font-semibold tracking-wider">FUNNIL</span>
          <span class="text-sm font-semibold tracking-wider text-accent ml-1">HACKER</span>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 py-4 px-3 space-y-1 overflow-y-auto">
          <a
            href="/"
            class:list={[
              'flex items-center gap-3 px-3 py-2 rounded-md text-sm transition-colors',
              activePage === 'dashboard'
                ? 'bg-accent-muted text-accent'
                : 'text-text-secondary hover:text-text-primary hover:bg-surface-3',
            ]}
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25a2.25 2.25 0 01-2.25-2.25v-2.25z" />
            </svg>
            Dashboard
          </a>

          <a
            href="/project/new"
            class:list={[
              'flex items-center gap-3 px-3 py-2 rounded-md text-sm transition-colors',
              activePage === 'new'
                ? 'bg-accent-muted text-accent'
                : 'text-text-secondary hover:text-text-primary hover:bg-surface-3',
            ]}
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Novo Projeto
          </a>

          <div class="pt-4 pb-2 px-3">
            <span class="text-[10px] uppercase tracking-widest text-text-muted font-medium">Projetos</span>
          </div>

          <div id="sidebar-projects" class="space-y-0.5">
            <!-- Populated by React or SSR -->
            <p class="px-3 py-2 text-xs text-text-muted">Nenhum projeto ainda</p>
          </div>

          <div class="pt-4 pb-2 px-3">
            <span class="text-[10px] uppercase tracking-widest text-text-muted font-medium">Ferramentas</span>
          </div>

          <a
            href="/compare"
            class:list={[
              'flex items-center gap-3 px-3 py-2 rounded-md text-sm transition-colors',
              activePage === 'compare'
                ? 'bg-accent-muted text-accent'
                : 'text-text-secondary hover:text-text-primary hover:bg-surface-3',
            ]}
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
            </svg>
            Comparar
          </a>

          <a
            href="/swipefile"
            class:list={[
              'flex items-center gap-3 px-3 py-2 rounded-md text-sm transition-colors',
              activePage === 'swipefile'
                ? 'bg-accent-muted text-accent'
                : 'text-text-secondary hover:text-text-primary hover:bg-surface-3',
            ]}
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
            Swipe File
          </a>
        </nav>
      </aside>

      <!-- Main Content -->
      <main class="flex-1 overflow-y-auto">
        <slot />
      </main>
    </div>
  </body>
</html>
