# ─── Supabase ─────────────────────────────────────────────────
PUBLIC_SUPABASE_URL=your-supabase-url
PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Resend (transactional email) ─────────────────────────────
RESEND_API_KEY=your-resend-api-key

# ─── Generic webhook key (legacy /api/leads/webhook) ──────────
WEBHOOK_KEY=your-webhook-key

# ─── Ticto (AGENTES [IA] low-ticket product) ──────────────────
# Token shown by Ticto when creating the webhook in dash.ticto.com.br.
# The webhook accepts this in any of: X-Webhook-Token header,
# `token` field in JSON body (Ticto v2.0 default), or `hash` field.
TICTO_WEBHOOK_TOKEN=

# Optional HMAC secret if Ticto starts supporting it. Leave blank otherwise.
TICTO_WEBHOOK_SECRET=

# Map of Ticto product IDs -> internal product codes.
# Format: "12345=agentes_ia,67890=comunidade_497"
# Default fallback for unknown ids: agentes_ia
TICTO_PRODUCT_MAP=

# Public URL of the AGENTES [IA] members area. Used as redirectTo for
# the Supabase magic link sent in the welcome email.
AGENTES_IA_AREA_URL=https://area.agentesia.moronireis.com.br
