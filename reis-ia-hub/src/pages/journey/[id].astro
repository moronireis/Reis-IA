---
import JourneyLayout from '../../layouts/JourneyLayout.astro';
import JourneyExperience from '../../components/journey/JourneyExperience.tsx';
import { createServerClient } from '../../lib/supabase-server';

export const prerender = false;

const profile = Astro.locals.profile;
if (!profile?.id) {
  return Astro.redirect('/login');
}

const { id } = Astro.params;
if (!id) {
  return Astro.redirect('/journey');
}

const supabase = createServerClient();
const isAdmin = profile.role === 'admin';

// Fetch journey
const { data: journey, error: journeyError } = await supabase
  .from('student_journeys')
  .select(`
    *,
    student:profiles!student_journeys_student_id_fkey(id, full_name, avatar_url, email)
  `)
  .eq('id', id)
  .single();

if (journeyError) {
  console.error('[journey/id] Query error:', journeyError.message, journeyError.details);
}

if (!journey) {
  return Astro.redirect('/journey');
}

// Access check
if (!isAdmin && journey.student_id !== profile.id) {
  return Astro.redirect('/journey');
}

// Fetch phases with nodes
const { data: phases } = await supabase
  .from('student_journey_phases')
  .select(`
    *,
    nodes:student_journey_nodes(*)
  `)
  .eq('journey_id', id)
  .order('sort_order', { ascending: true });

if (phases) {
  phases.forEach((p: any) => {
    if (p.nodes) {
      p.nodes.sort((a: any, b: any) => a.sort_order - b.sort_order);
    }
  });
}

const fullJourney = { ...journey, phases: phases || [] };
---

<JourneyLayout title={journey.title} journeyTitle={journey.title}>
  <JourneyExperience client:load journey={fullJourney} isAdmin={isAdmin} />
</JourneyLayout>
