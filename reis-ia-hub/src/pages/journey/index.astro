---
import AppLayout from '../../layouts/AppLayout.astro';
import JourneyDashboard from '../../components/JourneyDashboard.tsx';
import { createServerClient } from '../../lib/supabase-server';

export const prerender = false;

const profile = Astro.locals.profile;
if (!profile?.id) {
  return Astro.redirect('/login');
}

const supabase = createServerClient();
const isAdmin = profile.role === 'admin';

// Fetch active journeys for this student (or all for admin)
let query = supabase
  .from('student_journeys')
  .select(`
    *,
    student:profiles!student_journeys_student_id_fkey(id, full_name, avatar_url, email),
    phases:student_journey_phases(
      id, title, sort_order, status,
      nodes:student_journey_nodes(id, status, is_required)
    )
  `)
  .order('created_at', { ascending: false });

if (!isAdmin) {
  query = query.eq('student_id', profile.id);
}

const { data: journeys } = await query;

// Sort phases within each journey
if (journeys) {
  journeys.forEach((j: any) => {
    if (j.phases) {
      j.phases.sort((a: any, b: any) => a.sort_order - b.sort_order);
    }
  });
}

// Fetch students list for admin user selector
let students: any[] = [];
if (isAdmin) {
  const { data: studentData } = await supabase
    .from('profiles')
    .select('id, full_name, email')
    .neq('role', 'admin')
    .order('full_name', { ascending: true });
  students = studentData || [];
}
---

<AppLayout title="Journey" activeSection="journey">
  <JourneyDashboard
    client:load
    journeys={journeys || []}
    isAdmin={isAdmin}
    students={students}
    currentUserId={profile.id}
  />
</AppLayout>
