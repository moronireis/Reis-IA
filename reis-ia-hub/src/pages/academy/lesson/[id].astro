---
import AppLayout from '../../../layouts/AppLayout.astro';
import LessonView from '../../../components/LessonView.tsx';
import { createServerClient } from '../../../lib/supabase-server';

export const prerender = false;

const { id } = Astro.params;
const supabase = createServerClient();
const profile = Astro.locals.profile;

// Fetch the lesson
const { data: lesson, error: lessonError } = await supabase
  .from('lessons')
  .select('*')
  .eq('id', id)
  .single();

if (lessonError || !lesson) {
  return Astro.redirect('/academy');
}

// Fetch the parent course
const { data: course, error: courseError } = await supabase
  .from('courses')
  .select('*')
  .eq('id', lesson.course_id)
  .single();

if (courseError || !course) {
  return Astro.redirect('/academy');
}

// Non-admins can only see published content
if (profile?.role !== 'admin') {
  if (course.status !== 'published' || lesson.status !== 'published') {
    return Astro.redirect('/academy');
  }
}

// Fetch all lessons in this course
let allLessonsQuery = supabase
  .from('lessons')
  .select('*')
  .eq('course_id', lesson.course_id)
  .order('sort_order', { ascending: true });

if (profile?.role !== 'admin') {
  allLessonsQuery = allLessonsQuery.eq('status', 'published');
}

const { data: allLessons } = await allLessonsQuery;

// Fetch user progress for this course
let userProgress: any[] = [];
if (profile?.id) {
  const { data: progress } = await supabase
    .from('user_progress')
    .select('*')
    .eq('user_id', profile.id)
    .eq('course_id', lesson.course_id);
  userProgress = progress || [];
}
---

<AppLayout title={lesson.title} activeSection="academy">
  <LessonView
    client:load
    lesson={lesson}
    course={course}
    allLessons={allLessons || []}
    progress={userProgress}
    currentUserId={profile?.id || ''}
    currentUserName={profile?.full_name || 'Você'}
  />
</AppLayout>
