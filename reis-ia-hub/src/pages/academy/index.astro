---
import AppLayout from '../../layouts/AppLayout.astro';
import AcademyCatalog from '../../components/AcademyCatalog.tsx';
import { createServerClient } from '../../lib/supabase-server';

export const prerender = false;

let courses: any[] = [];
let userProgress: any[] = [];
let debugError = '';

try {
  const supabase = createServerClient();
  const { data, error } = await supabase
    .from('courses')
    .select('*')
    .eq('status', 'published')
    .order('sort_order', { ascending: true });

  if (error) {
    debugError = 'Courses error: ' + error.message;
  } else {
    courses = data || [];
  }

  const profile = Astro.locals.profile;
  if (profile?.id) {
    const { data: progress } = await supabase
      .from('user_progress')
      .select('*')
      .eq('user_id', profile.id);
    userProgress = progress || [];
  }
} catch (e: any) {
  debugError = 'Exception: ' + (e?.message || String(e));
}
---

<AppLayout title="Academy" activeSection="academy">
  <div class="mb-6">
    <h2 class="text-xl font-semibold mb-1" style="color: var(--text-primary);">Academy</h2>
    <p style="color: var(--text-tertiary); font-size: var(--text-body-sm);">
      Formações, masterclasses e workshops sobre AI para negócios.
    </p>
    {debugError && <p style="color: var(--color-error); margin-top: 8px; font-size: 12px;">{debugError}</p>}
  </div>

  <AcademyCatalog
    client:load
    courses={courses}
    userProgress={userProgress}
    userRole={Astro.locals.profile?.role || 'starter'}
  />
</AppLayout>
