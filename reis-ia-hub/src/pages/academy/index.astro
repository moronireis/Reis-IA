---
import AppLayout from '../../layouts/AppLayout.astro';
import { createServerClient } from '../../lib/supabase-server';

export const prerender = false;

const profile = Astro.locals.profile;
const isAdmin = profile?.role === 'admin';
const supabase = createServerClient();

// RLS gates this query: members only see courses they are entitled to
// (access_level = 'all' OR they hold an active entitlement matching product_code).
let courses: any[] = [];
try {
  const { data } = await supabase
    .from('courses')
    .select('id, title, description, thumbnail_url, pillar, category, access_level, status, product_code, slug')
    .eq('status', 'published')
    .order('sort_order', { ascending: true });
  courses = data || [];
} catch {}

// Admin-only drafts
if (isAdmin) {
  const { data: drafts } = await supabase
    .from('courses')
    .select('id, title, description, thumbnail_url, pillar, category, access_level, status, product_code, slug')
    .neq('status', 'published')
    .order('sort_order', { ascending: true });
  if (drafts) courses = [...courses, ...drafts];
}
---

<AppLayout title="Academy" activeSection="academy">
  <div class="mb-6">
    <h2 class="text-xl font-semibold mb-1" style="color: var(--text-primary);">Academy</h2>
    <p style="color: var(--text-tertiary); font-size: var(--text-body-sm);">
      Formações, masterclasses e workshops sobre AI para negócios.
    </p>
  </div>

  {courses.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {courses.map(course => (
        <a
          href={`/academy/${course.id}`}
          style="display: block; border-radius: 12px; background: var(--surface-1); border: 1px solid var(--border-subtle); overflow: hidden; text-decoration: none; transition: transform 0.18s ease, border-color 0.18s ease;"
          onmouseover="this.style.transform='translateY(-2px)';this.style.borderColor='rgba(74,144,255,0.30)'"
          onmouseout="this.style.transform='translateY(0)';this.style.borderColor='var(--border-subtle)'"
        >
          {/* Thumbnail */}
          <div style={`height: 140px; background: ${course.thumbnail_url ? `url(${course.thumbnail_url}) center/cover` : 'linear-gradient(135deg, rgba(74,144,255,0.10) 0%, rgba(45,122,255,0.05) 100%)'}; display: flex; align-items: center; justify-content: center; position: relative;`}>
            {!course.thumbnail_url && (
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.20)" stroke-width="1.5">
                <polygon points="5,3 19,12 5,21" />
              </svg>
            )}
            {course.status !== 'published' && isAdmin && (
              <div style="position: absolute; top: 10px; right: 10px; padding: 3px 8px; border-radius: 6px; background: rgba(245,158,11,0.20); font-size: 10px; color: #F59E0B;">
                Rascunho
              </div>
            )}
          </div>
          {/* Content */}
          <div style="padding: 16px;">
            {(course.pillar || course.category) && (
              <span style="font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--accent-blue); background: var(--blue-10); padding: 2px 8px; border-radius: 9999px; display: inline-block; margin-bottom: 8px;">
                {course.pillar || course.category}
              </span>
            )}
            <h3 style="font-size: 15px; font-weight: 600; color: var(--text-primary); margin: 0 0 6px; line-height: 1.3;">
              {course.title}
            </h3>
            {course.description && (
              <p style="font-size: 12px; color: var(--text-quaternary); margin: 0; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                {course.description}
              </p>
            )}
          </div>
        </a>
      ))}
    </div>
  ) : (
    <div style="text-align: center; padding: 48px 0;">
      <p style="color: var(--text-secondary); font-size: 15px; font-weight: 500; margin-bottom: 6px;">
        Nenhum curso disponível ainda.
      </p>
      <p style="color: var(--text-quaternary); font-size: 13px;">
        Quando você desbloquear conteúdos novos, eles aparecem aqui.
      </p>
    </div>
  )}
</AppLayout>
