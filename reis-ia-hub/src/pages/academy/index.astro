---
import AppLayout from '../../layouts/AppLayout.astro';
import { createServerClient } from '../../lib/supabase-server';

export const prerender = false;

const profile = Astro.locals.profile;
const isAdmin = profile?.role === 'admin';
const supabase = createServerClient();

let courses: any[] = [];
try {
  const { data } = await supabase
    .from('courses')
    .select('id, title, description, thumbnail_url, pillar, access_level, status')
    .eq('status', 'published')
    .order('sort_order', { ascending: true });
  courses = data || [];
} catch {}

// For admin, also get drafts
if (isAdmin) {
  const { data: drafts } = await supabase
    .from('courses')
    .select('id, title, description, thumbnail_url, pillar, access_level, status')
    .neq('status', 'published')
    .order('sort_order', { ascending: true });
  if (drafts) courses = [...courses, ...drafts];
}
---

<AppLayout title="Academy" activeSection="academy">
  <div class="mb-6">
    <h2 class="text-xl font-semibold mb-1" style="color: var(--text-primary);">Academy</h2>
    <p style="color: var(--text-tertiary); font-size: var(--text-body-sm);">
      Formações, masterclasses e workshops sobre AI para negócios.
    </p>
  </div>

  {!isAdmin && (
    <div style="padding: 14px 16px; border-radius: 10px; background: rgba(74,144,255,0.04); border: 1px solid rgba(74,144,255,0.10); margin-bottom: 24px; display: flex; align-items: center; gap: 10px;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4A90FF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
      </svg>
      <p style="font-size: 13px; color: var(--accent-blue); margin: 0;">
        As trilhas da Academy estão sendo preparadas. Em breve você terá acesso a aulas gravadas e conteúdos complementares.
      </p>
    </div>
  )}

  {courses.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {courses.map(course => (
        <div style={`border-radius: 12px; background: var(--surface-1); border: 1px solid var(--border-subtle); overflow: hidden; ${!isAdmin ? 'opacity: 0.5; pointer-events: none;' : ''}`}>
          {/* Thumbnail */}
          <div style="height: 120px; background: linear-gradient(135deg, rgba(74,144,255,0.08) 0%, rgba(139,92,246,0.08) 100%); display: flex; align-items: center; justify-content: center; position: relative;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1.5">
              <polygon points="5,3 19,12 5,21" />
            </svg>
            {!isAdmin && (
              <div style="position: absolute; top: 10px; right: 10px; padding: 3px 8px; border-radius: 6px; background: rgba(0,0,0,0.6); display: flex; align-items: center; gap: 4px;">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="2">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                  <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
                <span style="font-size: 10px; color: rgba(255,255,255,0.5);">Em breve</span>
              </div>
            )}
            {course.status !== 'published' && isAdmin && (
              <div style="position: absolute; top: 10px; right: 10px; padding: 3px 8px; border-radius: 6px; background: rgba(245,158,11,0.2); font-size: 10px; color: #F59E0B;">
                Rascunho
              </div>
            )}
          </div>
          {/* Content */}
          <div style="padding: 16px;">
            {course.pillar && (
              <span style="font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--accent-blue); background: var(--blue-10); padding: 2px 8px; border-radius: 9999px; display: inline-block; margin-bottom: 8px;">
                {course.pillar}
              </span>
            )}
            <h3 style="font-size: 15px; font-weight: 600; color: var(--text-primary); margin: 0 0 6px; line-height: 1.3;">
              {course.title}
            </h3>
            {course.description && (
              <p style="font-size: 12px; color: var(--text-quaternary); margin: 0; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                {course.description}
              </p>
            )}
          </div>
        </div>
      ))}
    </div>
  ) : (
    <div style="text-align: center; padding: 40px 0;">
      <p style="color: var(--text-tertiary); font-size: 14px;">Nenhum curso disponível ainda.</p>
    </div>
  )}
</AppLayout>
