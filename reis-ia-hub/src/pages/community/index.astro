---
import AppLayout from '../../layouts/AppLayout.astro';
import CommunityFeed from '../../components/CommunityFeed.tsx';
import { createServerClient } from '../../lib/supabase-server';

export const prerender = false;

const supabase = createServerClient();
const profile = Astro.locals.profile;
const isAdmin = profile?.role === 'admin';
const userRole = profile?.role || 'starter';

// Fetch ALL spaces — access control handled in the component
const { data: spaces } = await supabase
  .from('spaces')
  .select('*')
  .order('sort_order', { ascending: true });

const allSpaces = spaces || [];
const firstSpace = allSpaces[0];

// Fetch initial posts (first space)
let initialPosts: any[] = [];
if (firstSpace) {
  const { data: posts } = await supabase
    .from('posts')
    .select(`
      *,
      author:profiles!posts_author_id_fkey(id, full_name, role)
    `)
    .eq('space_id', firstSpace.id)
    .order('pinned', { ascending: false })
    .order('created_at', { ascending: false });

  initialPosts = posts || [];
}
---

<AppLayout title="Comunidade" activeSection="community">
  <div class="mb-6">
    <h2 class="text-xl font-semibold mb-1" style="color: var(--text-primary);">Comunidade</h2>
    <p style="color: var(--text-tertiary); font-size: var(--text-body-sm);">
      Compartilhe progresso, tire dúvidas e conecte-se com outros membros.
    </p>
  </div>

  {allSpaces.length > 0 ? (
    <CommunityFeed
      client:load
      spaces={allSpaces}
      initialPosts={initialPosts}
      initialSpace={firstSpace?.slug || 'geral'}
      currentUserId={profile?.id || ''}
      isAdmin={isAdmin}
      userRole={userRole}
    />
  ) : (
    <div style="text-align: center; padding: 60px 0;">
      <p style="color: var(--text-secondary); font-size: 15px; font-weight: 500; margin-bottom: 6px;">Comunidade em breve</p>
      <p style="color: var(--text-quaternary); font-size: 13px;">Os espaços da comunidade estão sendo preparados.</p>
    </div>
  )}
</AppLayout>
