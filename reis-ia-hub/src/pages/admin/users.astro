---
import AppLayout from '../../layouts/AppLayout.astro';
import { createServerClient } from '../../lib/supabase-server';

export const prerender = false;

const supabase = createServerClient();
const profile = Astro.locals.profile;

const { data: users } = await supabase
  .from('profiles')
  .select('id, full_name, email, role, company, phone, created_at')
  .order('created_at', { ascending: false });

const allUsers = users || [];

const ROLE_STYLES: Record<string, { bg: string; color: string }> = {
  admin: { bg: 'rgba(34,197,94,0.1)', color: '#22C55E' },
  mentoria: { bg: 'rgba(139,92,246,0.1)', color: '#8B5CF6' },
  builder: { bg: 'var(--blue-10)', color: 'var(--accent-blue)' },
  starter: { bg: 'var(--surface-3)', color: 'var(--text-quaternary)' },
};

const impersonating = Astro.locals.impersonating;
const impersonateAs = Astro.cookies.get('sb-impersonate-as')?.value;
---

<AppLayout title="Usuarios" activeSection="admin-users">

  {impersonating && (
    <div style="background: rgba(245,158,11,0.08); border: 1px solid rgba(245,158,11,0.20); border-radius: 10px; padding: 12px 16px; margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between; gap: 12px;">
      <div style="display: flex; align-items: center; gap: 8px;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F59E0B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
          <circle cx="12" cy="12" r="3" />
        </svg>
        <span style="font-size: 13px; color: #F59E0B; font-weight: 500;">
          Visualizando como: {profile?.full_name}
        </span>
      </div>
      <button
        id="stop-impersonate-btn"
        style="padding: 6px 14px; border-radius: 6px; background: rgba(245,158,11,0.12); border: 1px solid rgba(245,158,11,0.25); color: #F59E0B; font-size: 12px; font-weight: 500; cursor: pointer;"
      >
        Voltar ao admin
      </button>
    </div>
  )}

  <div style="margin-bottom: 24px;">
    <h2 style="font-size: 18px; font-weight: 600; color: var(--text-primary); margin: 0 0 6px 0;">Usuários</h2>
    <p style="font-size: 13px; color: var(--text-tertiary); margin: 0;">{allUsers.length} usuários cadastrados</p>
  </div>

  <div style="display: flex; flex-direction: column; gap: 6px;">
    {allUsers.map(user => {
      const roleStyle = ROLE_STYLES[user.role] || ROLE_STYLES.starter;
      const initials = user.full_name
        ? user.full_name.split(' ').map((p: string) => p[0]).join('').slice(0, 2).toUpperCase()
        : 'U';
      const isCurrentImpersonated = impersonateAs === user.id;

      return (
        <div
          style={`display: flex; align-items: center; gap: 14px; padding: 14px 16px; border-radius: 10px; background: ${isCurrentImpersonated ? 'rgba(245,158,11,0.04)' : 'var(--surface-1)'}; border: 1px solid ${isCurrentImpersonated ? 'rgba(245,158,11,0.15)' : 'var(--border-subtle)'}; transition: all 150ms;`}
          class="user-row"
        >
          <div style={`width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 600; flex-shrink: 0; background: ${roleStyle.bg}; color: ${roleStyle.color};`}>
            {initials}
          </div>

          <div style="flex: 1; min-width: 0;">
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 2px;">
              <span style="font-size: 14px; font-weight: 500; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                {user.full_name || 'Sem nome'}
              </span>
              <span style={`font-size: 10px; font-weight: 600; padding: 2px 8px; border-radius: 9999px; text-transform: uppercase; letter-spacing: 0.04em; background: ${roleStyle.bg}; color: ${roleStyle.color};`}>
                {user.role}
              </span>
            </div>
            <div style="font-size: 12px; color: var(--text-tertiary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
              {user.email}{user.company ? ` — ${user.company}` : ''}
            </div>
          </div>

          <div style="display: flex; gap: 8px; flex-shrink: 0;">
            {user.role !== 'admin' && (
              <button
                class="impersonate-btn"
                data-user-id={user.id}
                style="padding: 6px 12px; border-radius: 6px; background: var(--blue-10); border: 1px solid rgba(74,144,255,0.15); color: var(--accent-blue); font-size: 11px; font-weight: 500; cursor: pointer; white-space: nowrap;"
              >
                Entrar como
              </button>
            )}
          </div>
        </div>
      );
    })}
  </div>
</AppLayout>

<style>
  .user-row:hover {
    border-color: var(--border-visible) !important;
    background: var(--surface-2) !important;
  }
  .impersonate-btn:hover {
    background: rgba(74,144,255,0.15) !important;
  }
</style>

<script>
  document.addEventListener('click', async (e) => {
    const target = e.target as HTMLElement;

    // Impersonate button
    const impBtn = target.closest('.impersonate-btn') as HTMLElement;
    if (impBtn) {
      const userId = impBtn.dataset.userId;
      if (!userId) return;

      impBtn.textContent = 'Entrando...';
      impBtn.style.pointerEvents = 'none';

      try {
        const res = await fetch('/api/admin/impersonate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ user_id: userId }),
        });
        if (res.ok) {
          window.location.href = '/dashboard';
        } else {
          impBtn.textContent = 'Erro';
          setTimeout(() => { impBtn.textContent = 'Entrar como'; impBtn.style.pointerEvents = ''; }, 2000);
        }
      } catch {
        impBtn.textContent = 'Erro';
        setTimeout(() => { impBtn.textContent = 'Entrar como'; impBtn.style.pointerEvents = ''; }, 2000);
      }
      return;
    }

    // Stop impersonation button
    if (target.closest('#stop-impersonate-btn')) {
      try {
        const res = await fetch('/api/admin/impersonate', { method: 'DELETE' });
        if (res.ok) {
          window.location.href = '/admin/users';
        }
      } catch {}
    }
  });
</script>
