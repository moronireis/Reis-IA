---
import AppLayout from '../../layouts/AppLayout.astro';
import { createServerClient } from '../../lib/supabase-server';

export const prerender = false;

const supabase = createServerClient();
const { data: projects } = await supabase
  .from('projects')
  .select('*')
  .order('created_at', { ascending: false });

const statusStyles: Record<string, { bg: string; color: string }> = {
  'em_andamento': { bg: 'var(--color-success-bg)', color: 'var(--color-success)' },
  'pendente': { bg: 'rgba(245,158,11,0.1)', color: '#F59E0B' },
  'concluido': { bg: 'rgba(255,255,255,0.05)', color: 'rgba(255,255,255,0.5)' },
  'cancelado': { bg: 'rgba(239,68,68,0.1)', color: '#EF4444' },
};

function statusLabel(status: string) {
  const labels: Record<string, string> = {
    em_andamento: 'Em andamento',
    pendente: 'Pendente',
    concluido: 'Concluído',
    cancelado: 'Cancelado',
  };
  return labels[status] || status;
}
---

<AppLayout title="Gerenciar Projetos" activeSection="admin-projects">
  <div class="flex items-center justify-between mb-6">
    <p style="color: var(--text-tertiary); font-size: var(--text-body-sm);">Crie e gerencie projetos de clientes.</p>
    <button id="btn-new-project" class="px-4 py-2.5 rounded-lg text-sm font-medium" style="background: var(--accent-blue); color: #fff;">
      + Novo Projeto
    </button>
  </div>

  <!-- New Project Form (hidden by default) -->
  <div id="new-project-form" class="hidden mb-8 rounded-xl p-6" style="background: var(--surface-1); border: 1px solid var(--border-subtle);">
    <h3 class="font-medium mb-4" style="color: var(--text-primary);">Novo Projeto</h3>
    <div id="form-error" class="hidden mb-4 p-3 rounded-lg text-sm" style="background: rgba(239,68,68,0.1); color: #EF4444; border: 1px solid rgba(239,68,68,0.25);"></div>
    <form id="project-form" class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="flex flex-col gap-2">
        <label class="text-xs" style="color: var(--text-tertiary);">Nome do Projeto</label>
        <input type="text" name="name" required class="w-full px-4 py-3 rounded-lg text-sm outline-none input-field" style="background: var(--surface-2); border: 1px solid var(--border-default); color: var(--text-primary);" placeholder="Ex: AI Sales Agent" />
      </div>
      <div class="flex flex-col gap-2">
        <label class="text-xs" style="color: var(--text-tertiary);">Tipo</label>
        <select name="type" class="w-full px-4 py-3 rounded-lg text-sm input-field" style="background: var(--surface-2); border: 1px solid var(--border-default); color: var(--text-secondary);">
          <option value="systems">Systems</option>
          <option value="marketing">Marketing</option>
          <option value="builders">Builders</option>
        </select>
      </div>
      <div class="flex flex-col gap-2">
        <label class="text-xs" style="color: var(--text-tertiary);">Nome do Cliente</label>
        <input type="text" name="client_name" required class="w-full px-4 py-3 rounded-lg text-sm outline-none input-field" style="background: var(--surface-2); border: 1px solid var(--border-default); color: var(--text-primary);" placeholder="Nome do cliente" />
      </div>
      <div class="flex flex-col gap-2">
        <label class="text-xs" style="color: var(--text-tertiary);">Email do Cliente</label>
        <input type="email" name="client_email" class="w-full px-4 py-3 rounded-lg text-sm outline-none input-field" style="background: var(--surface-2); border: 1px solid var(--border-default); color: var(--text-primary);" placeholder="cliente@empresa.com" />
      </div>
      <div class="flex flex-col gap-2">
        <label class="text-xs" style="color: var(--text-tertiary);">Data de Início</label>
        <input type="date" name="start_date" class="w-full px-4 py-3 rounded-lg text-sm input-field" style="background: var(--surface-2); border: 1px solid var(--border-default); color: var(--text-secondary);" />
      </div>
      <div class="flex flex-col gap-2">
        <label class="text-xs" style="color: var(--text-tertiary);">Valor (R$)</label>
        <input type="number" name="value" class="w-full px-4 py-3 rounded-lg text-sm outline-none input-field" style="background: var(--surface-2); border: 1px solid var(--border-default); color: var(--text-primary);" placeholder="15000" />
      </div>
      <div class="md:col-span-2 flex gap-3 mt-2">
        <button type="submit" id="btn-submit" class="px-5 py-2.5 rounded-lg text-sm font-medium" style="background: var(--accent-blue); color: #fff;">Criar Projeto</button>
        <button type="button" id="btn-cancel" class="px-5 py-2.5 rounded-lg text-sm" style="background: transparent; color: var(--text-tertiary); border: 1px solid var(--border-default);">Cancelar</button>
      </div>
    </form>
  </div>

  <!-- Existing Projects Table -->
  <div class="rounded-xl overflow-hidden" style="background: var(--surface-1); border: 1px solid var(--border-subtle);">
    <table class="w-full" style="border-collapse: collapse;">
      <thead>
        <tr style="border-bottom: 1px solid var(--border-subtle);">
          <th class="text-left px-5 py-3 text-xs font-medium" style="color: var(--text-quaternary);">Projeto</th>
          <th class="text-left px-5 py-3 text-xs font-medium" style="color: var(--text-quaternary);">Cliente</th>
          <th class="text-left px-5 py-3 text-xs font-medium" style="color: var(--text-quaternary);">Tipo</th>
          <th class="text-left px-5 py-3 text-xs font-medium" style="color: var(--text-quaternary);">Status</th>
          <th class="text-left px-5 py-3 text-xs font-medium" style="color: var(--text-quaternary);">Progresso</th>
        </tr>
      </thead>
      <tbody id="projects-tbody">
        {projects && projects.length > 0 ? projects.map(project => (
          <tr style="border-bottom: 1px solid var(--border-subtle);">
            <td class="px-5 py-4">
              <a href={`/projects/${project.id}`} class="text-sm font-medium project-link" style="color: var(--text-primary);">{project.name}</a>
            </td>
            <td class="px-5 py-4 text-sm" style="color: var(--text-secondary);">{project.client_name || '—'}</td>
            <td class="px-5 py-4">
              <span class="text-xs px-2.5 py-1 rounded-md" style="background: var(--blue-10); color: var(--accent-blue);">{project.type}</span>
            </td>
            <td class="px-5 py-4">
              <span
                class="text-xs px-2.5 py-1 rounded-md"
                style={`background: ${statusStyles[project.status]?.bg || 'rgba(255,255,255,0.05)'}; color: ${statusStyles[project.status]?.color || 'rgba(255,255,255,0.5)'};`}
              >
                {statusLabel(project.status)}
              </span>
            </td>
            <td class="px-5 py-4">
              <div class="flex items-center gap-3">
                <div class="w-24 h-1.5 rounded-full" style="background: var(--surface-4);">
                  <div class="h-full rounded-full" style={`width: ${project.progress || 0}%; background: var(--accent-blue);`}></div>
                </div>
                <span class="text-xs" style="color: var(--text-quaternary);">{project.progress || 0}%</span>
              </div>
            </td>
          </tr>
        )) : (
          <tr>
            <td colspan="5" class="px-5 py-10 text-center text-sm" style="color: var(--text-quaternary);">Nenhum projeto criado ainda.</td>
          </tr>
        )}
      </tbody>
    </table>
  </div>
</AppLayout>

<script>
  const btnNew = document.getElementById('btn-new-project');
  const btnCancel = document.getElementById('btn-cancel');
  const formContainer = document.getElementById('new-project-form');
  const form = document.getElementById('project-form') as HTMLFormElement;
  const formError = document.getElementById('form-error') as HTMLDivElement;
  const btnSubmit = document.getElementById('btn-submit') as HTMLButtonElement;

  btnNew?.addEventListener('click', () => formContainer?.classList.toggle('hidden'));
  btnCancel?.addEventListener('click', () => formContainer?.classList.add('hidden'));

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    formError.classList.add('hidden');
    btnSubmit.disabled = true;
    btnSubmit.textContent = 'Criando...';

    const fd = new FormData(form);
    const body: Record<string, unknown> = {
      name: fd.get('name'),
      type: fd.get('type'),
      client_name: fd.get('client_name'),
      client_email: fd.get('client_email') || null,
      start_date: fd.get('start_date') || null,
      value: fd.get('value') ? parseFloat(fd.get('value') as string) : null,
      status: 'em_andamento',
      progress: 0,
    };

    try {
      const res = await fetch('/api/projects', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      if (!res.ok) {
        const err = await res.json();
        formError.textContent = err.error || 'Erro ao criar projeto';
        formError.classList.remove('hidden');
        btnSubmit.disabled = false;
        btnSubmit.textContent = 'Criar Projeto';
        return;
      }

      // Reload page to show the new project in the table
      window.location.reload();
    } catch {
      formError.textContent = 'Erro de conexão';
      formError.classList.remove('hidden');
      btnSubmit.disabled = false;
      btnSubmit.textContent = 'Criar Projeto';
    }
  });
</script>

<style>
  .project-link:hover {
    color: var(--accent-blue) !important;
  }
  .input-field:focus {
    border-color: var(--border-accent) !important;
  }
</style>
