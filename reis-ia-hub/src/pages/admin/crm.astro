---
import AppLayout from '../../layouts/AppLayout.astro';
import CRMBoard from '../../components/CRMBoard.tsx';
import { createServerClient } from '../../lib/supabase-server';

export const prerender = false;

const supabase = createServerClient();

const [dealsResult, contactsResult, countResult] = await Promise.all([
  supabase.from('deals').select('*').order('created_at', { ascending: false }),
  supabase.from('contacts').select('*').order('created_at', { ascending: false }).range(0, 49),
  supabase.from('contacts').select('*', { count: 'exact', head: true }),
]);

const deals = dealsResult.data || [];
const initialContacts = contactsResult.data || [];
const totalContacts = countResult.count || 0;
---

<AppLayout title="CRM" activeSection="crm">
  <CRMBoard
    client:load
    initialDeals={deals}
    initialContacts={initialContacts}
    totalContacts={totalContacts}
  />
</AppLayout>
