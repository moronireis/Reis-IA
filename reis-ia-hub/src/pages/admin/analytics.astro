---
import AppLayout from '../../layouts/AppLayout.astro';
import { createServerClient } from '../../lib/supabase-server';

export const prerender = false;

const supabase = createServerClient();

// Members
const { count: totalMembers } = await supabase
  .from('profiles')
  .select('*', { count: 'exact', head: true });

const { count: activeMembers } = await supabase
  .from('profiles')
  .select('*', { count: 'exact', head: true })
  .neq('role', 'admin');

// Courses & Lessons
const { count: totalCourses } = await supabase
  .from('courses')
  .select('*', { count: 'exact', head: true })
  .eq('status', 'published');

const { count: totalLessons } = await supabase
  .from('lessons')
  .select('*', { count: 'exact', head: true });

const { count: lessonsCompleted } = await supabase
  .from('user_progress')
  .select('*', { count: 'exact', head: true })
  .eq('completed', true);

// Community
const { count: totalPosts } = await supabase
  .from('posts')
  .select('*', { count: 'exact', head: true });

const { count: totalSpaces } = await supabase
  .from('spaces')
  .select('*', { count: 'exact', head: true });

const { count: totalComments } = await supabase
  .from('comments')
  .select('*', { count: 'exact', head: true });

// CRM
const { data: deals } = await supabase
  .from('deals')
  .select('value, stage');

const allDeals = deals || [];
const pipelineTotal = allDeals
  .filter(d => !['won', 'lost'].includes(d.stage))
  .reduce((s, d) => s + Number(d.value || 0), 0);
const wonTotal = allDeals
  .filter(d => d.stage === 'won')
  .reduce((s, d) => s + Number(d.value || 0), 0);

const stageOrder = ['lead', 'qualified', 'proposal', 'negotiation', 'won', 'lost'];
const stageLabelMap: Record<string, string> = {
  lead: 'Lead',
  qualified: 'Qualificado',
  proposal: 'Proposta',
  negotiation: 'Negociação',
  won: 'Fechado',
  lost: 'Perdido',
};
const stageColorMap: Record<string, string> = {
  lead: '#4A90FF',
  qualified: '#8DC4FF',
  proposal: '#F59E0B',
  negotiation: '#8B5CF6',
  won: '#22C55E',
  lost: '#EF4444',
};

interface StageData {
  stage: string;
  label: string;
  count: number;
  total: number;
  color: string;
}

const stageData: StageData[] = stageOrder.map(stage => {
  const stageDeals = allDeals.filter(d => d.stage === stage);
  return {
    stage,
    label: stageLabelMap[stage] || stage,
    count: stageDeals.length,
    total: stageDeals.reduce((s, d) => s + Number(d.value || 0), 0),
    color: stageColorMap[stage] || '#4A90FF',
  };
});

const maxStageTotal = Math.max(...stageData.map(s => s.total), 1);

// Tasks
const { data: allTasks } = await supabase
  .from('tasks')
  .select('status');

const tasksDone = allTasks?.filter(t => t.status === 'done').length || 0;
const tasksInProgress = allTasks?.filter(t => t.status === 'in_progress').length || 0;
const tasksTodo = allTasks?.filter(t => t.status === 'todo').length || 0;
const totalTasks = allTasks?.length || 0;
const taskProgress = totalTasks > 0 ? Math.round((tasksDone / totalTasks) * 100) : 0;

// Mentorships
const { count: activeMentorships } = await supabase
  .from('mentorships')
  .select('*', { count: 'exact', head: true })
  .eq('status', 'active');

// Resources
const { count: totalResources } = await supabase
  .from('vault_resources')
  .select('*', { count: 'exact', head: true });

// Top courses by lesson count (proxy for richness)
const { data: coursesData } = await supabase
  .from('courses')
  .select('id, title, status')
  .eq('status', 'published')
  .limit(5);

function formatCurrency(value: number): string {
  if (value >= 1000) {
    return `R$${(value / 1000).toFixed(0)}K`;
  }
  return `R$${value.toFixed(0)}`;
}
---

<AppLayout title="Analytics" activeSection="admin-analytics">
  <!-- Page Header -->
  <div class="mb-8">
    <h2 style="font-size: var(--text-h4); font-weight: 600; color: var(--text-primary); margin-bottom: 4px;">
      Analytics
    </h2>
    <p style="color: var(--text-tertiary); font-size: var(--text-body-sm);">
      Visão geral do ecossistema REIS IA [HUB]
    </p>
  </div>

  <!-- Overview Cards -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <!-- Members -->
    <div class="rounded-xl p-5" style="background: var(--surface-2); border: 1px solid var(--border-subtle);">
      <div style="font-size: var(--text-label); color: var(--text-quaternary); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px;">Membros</div>
      <div style="font-size: 28px; font-weight: 600; color: var(--text-primary); line-height: 1; margin-bottom: 4px;">{activeMembers ?? 0}</div>
      <div style="font-size: var(--text-caption); color: var(--text-tertiary);">{totalMembers ?? 0} total incl. admins</div>
    </div>

    <!-- Pipeline -->
    <div class="rounded-xl p-5" style="background: var(--surface-2); border: 1px solid var(--border-subtle);">
      <div style="font-size: var(--text-label); color: var(--text-quaternary); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px;">Pipeline</div>
      <div style="font-size: 28px; font-weight: 600; color: var(--text-primary); line-height: 1; margin-bottom: 4px;">{formatCurrency(pipelineTotal)}</div>
      <div style="font-size: var(--text-caption); color: var(--text-tertiary);">{allDeals.filter(d => !['won','lost'].includes(d.stage)).length} deals ativos</div>
    </div>

    <!-- Won -->
    <div class="rounded-xl p-5" style="background: var(--surface-2); border: 1px solid var(--border-subtle);">
      <div style="font-size: var(--text-label); color: var(--text-quaternary); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px;">Fechados</div>
      <div style="font-size: 28px; font-weight: 600; color: var(--color-success); line-height: 1; margin-bottom: 4px;">{formatCurrency(wonTotal)}</div>
      <div style="font-size: var(--text-caption); color: var(--text-tertiary);">{allDeals.filter(d => d.stage === 'won').length} deal{allDeals.filter(d => d.stage === 'won').length !== 1 ? 's' : ''}</div>
    </div>

    <!-- Mentorships -->
    <div class="rounded-xl p-5" style="background: var(--surface-2); border: 1px solid var(--border-subtle);">
      <div style="font-size: var(--text-label); color: var(--text-quaternary); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px;">Mentorias</div>
      <div style="font-size: 28px; font-weight: 600; color: var(--text-primary); line-height: 1; margin-bottom: 4px;">{activeMentorships ?? 0}</div>
      <div style="font-size: var(--text-caption); color: var(--text-tertiary);">ativas</div>
    </div>
  </div>

  <!-- Two-column grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
    <!-- Academy Stats -->
    <div class="rounded-xl p-6" style="background: var(--surface-1); border: 1px solid var(--border-subtle);">
      <div class="flex items-center gap-2 mb-5">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent-blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="5,3 19,12 5,21" />
        </svg>
        <span style="font-size: var(--text-body-sm); font-weight: 600; color: var(--text-primary);">Academy</span>
      </div>

      <div class="flex flex-col gap-3 mb-5">
        <div class="flex items-center justify-between">
          <span style="font-size: var(--text-body-sm); color: var(--text-secondary);">Cursos publicados</span>
          <span style="font-size: var(--text-body-sm); font-weight: 600; color: var(--text-primary);">{totalCourses ?? 0}</span>
        </div>
        <div class="flex items-center justify-between">
          <span style="font-size: var(--text-body-sm); color: var(--text-secondary);">Total de aulas</span>
          <span style="font-size: var(--text-body-sm); font-weight: 600; color: var(--text-primary);">{totalLessons ?? 0}</span>
        </div>
        <div class="flex items-center justify-between">
          <span style="font-size: var(--text-body-sm); color: var(--text-secondary);">Aulas completadas</span>
          <span style="font-size: var(--text-body-sm); font-weight: 600; color: var(--color-success);">{lessonsCompleted ?? 0}</span>
        </div>
      </div>

      {coursesData && coursesData.length > 0 && (
        <div style="border-top: 1px solid var(--border-subtle); padding-top: 16px;">
          <div style="font-size: var(--text-caption); color: var(--text-quaternary); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 10px;">Cursos</div>
          <div class="flex flex-col gap-2">
            {coursesData.map((course, i) => (
              <div class="flex items-center gap-2">
                <span style={`font-size: var(--text-caption); color: var(--text-quaternary); width: 16px; text-align: right;`}>{i + 1}.</span>
                <span style="font-size: var(--text-caption); color: var(--text-secondary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{course.title}</span>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>

    <!-- Tasks Overview -->
    <div class="rounded-xl p-6" style="background: var(--surface-1); border: 1px solid var(--border-subtle);">
      <div class="flex items-center gap-2 mb-5">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent-blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 11 12 14 22 4" />
          <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
        </svg>
        <span style="font-size: var(--text-body-sm); font-weight: 600; color: var(--text-primary);">Tasks</span>
      </div>

      <!-- Progress bar -->
      <div class="mb-5">
        <div class="flex items-center justify-between mb-2">
          <span style="font-size: var(--text-caption); color: var(--text-tertiary);">{tasksDone} de {totalTasks} concluídas</span>
          <span style="font-size: var(--text-caption); font-weight: 600; color: var(--text-primary);">{taskProgress}%</span>
        </div>
        <div class="w-full rounded-full" style="height: 6px; background: var(--surface-4);">
          <div class="rounded-full" style={`width: ${taskProgress}%; height: 100%; background: var(--accent-blue); transition: width 0.3s ease;`}></div>
        </div>
      </div>

      <div class="flex flex-col gap-3">
        <div class="flex items-center justify-between p-3 rounded-lg" style="background: var(--surface-3);">
          <div class="flex items-center gap-2">
            <div style="width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.3);"></div>
            <span style="font-size: var(--text-body-sm); color: var(--text-secondary);">A Fazer</span>
          </div>
          <span style="font-size: var(--text-body-sm); font-weight: 600; color: var(--text-primary);">{tasksTodo}</span>
        </div>
        <div class="flex items-center justify-between p-3 rounded-lg" style="background: var(--surface-3);">
          <div class="flex items-center gap-2">
            <div style="width: 8px; height: 8px; border-radius: 50%; background: #F59E0B;"></div>
            <span style="font-size: var(--text-body-sm); color: var(--text-secondary);">Em Progresso</span>
          </div>
          <span style="font-size: var(--text-body-sm); font-weight: 600; color: var(--text-primary);">{tasksInProgress}</span>
        </div>
        <div class="flex items-center justify-between p-3 rounded-lg" style="background: var(--surface-3);">
          <div class="flex items-center gap-2">
            <div style="width: 8px; height: 8px; border-radius: 50%; background: var(--color-success);"></div>
            <span style="font-size: var(--text-body-sm); color: var(--text-secondary);">Concluído</span>
          </div>
          <span style="font-size: var(--text-body-sm); font-weight: 600; color: var(--color-success);">{tasksDone}</span>
        </div>
      </div>
    </div>

    <!-- Community Stats -->
    <div class="rounded-xl p-6" style="background: var(--surface-1); border: 1px solid var(--border-subtle);">
      <div class="flex items-center gap-2 mb-5">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent-blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
          <circle cx="9" cy="7" r="4" />
          <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
          <path d="M16 3.13a4 4 0 0 1 0 7.75" />
        </svg>
        <span style="font-size: var(--text-body-sm); font-weight: 600; color: var(--text-primary);">Comunidade</span>
      </div>

      <div class="flex flex-col gap-3 mb-5">
        <div class="flex items-center justify-between">
          <span style="font-size: var(--text-body-sm); color: var(--text-secondary);">Posts</span>
          <span style="font-size: var(--text-body-sm); font-weight: 600; color: var(--text-primary);">{totalPosts ?? 0}</span>
        </div>
        <div class="flex items-center justify-between">
          <span style="font-size: var(--text-body-sm); color: var(--text-secondary);">Espaços</span>
          <span style="font-size: var(--text-body-sm); font-weight: 600; color: var(--text-primary);">{totalSpaces ?? 0}</span>
        </div>
        <div class="flex items-center justify-between">
          <span style="font-size: var(--text-body-sm); color: var(--text-secondary);">Comentários</span>
          <span style="font-size: var(--text-body-sm); font-weight: 600; color: var(--text-primary);">{totalComments ?? 0}</span>
        </div>
      </div>

      <div style="border-top: 1px solid var(--border-subtle); padding-top: 16px;">
        <div class="flex items-center gap-2 mb-2">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--accent-blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 8v13H3V8" />
            <path d="M1 3h22v5H1z" />
            <path d="M10 12h4" />
          </svg>
          <span style="font-size: var(--text-caption); color: var(--text-secondary); font-weight: 500;">Vault</span>
        </div>
        <div class="flex items-center justify-between">
          <span style="font-size: var(--text-body-sm); color: var(--text-secondary);">Recursos disponíveis</span>
          <span style="font-size: var(--text-body-sm); font-weight: 600; color: var(--text-primary);">{totalResources ?? 0}</span>
        </div>
      </div>
    </div>

    <!-- CRM Pipeline -->
    <div class="rounded-xl p-6" style="background: var(--surface-1); border: 1px solid var(--border-subtle);">
      <div class="flex items-center gap-2 mb-5">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent-blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="7" width="20" height="14" rx="2" ry="2" />
          <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" />
          <path d="M2 12h20" />
        </svg>
        <span style="font-size: var(--text-body-sm); font-weight: 600; color: var(--text-primary);">CRM Pipeline</span>
      </div>

      <div class="flex flex-col gap-3">
        {stageData.map(s => (
          <div>
            <div class="flex items-center justify-between mb-1">
              <div class="flex items-center gap-2">
                <div style={`width: 8px; height: 8px; border-radius: 50%; background: ${s.color}; flex-shrink: 0;`}></div>
                <span style="font-size: var(--text-caption); color: var(--text-secondary);">{s.label}</span>
                {s.count > 0 && (
                  <span style="font-size: 11px; color: var(--text-quaternary);">({s.count})</span>
                )}
              </div>
              <span style={`font-size: var(--text-caption); font-weight: 600; color: ${s.count > 0 ? 'var(--text-primary)' : 'var(--text-quaternary)'};`}>
                {s.total > 0 ? formatCurrency(s.total) : '—'}
              </span>
            </div>
            {s.total > 0 && (
              <div class="w-full rounded-full" style="height: 3px; background: var(--surface-4);">
                <div class="rounded-full" style={`width: ${Math.round((s.total / maxStageTotal) * 100)}%; height: 100%; background: ${s.color};`}></div>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</AppLayout>
