---
import AppLayout from '../../layouts/AppLayout.astro';
import { createServerClient } from '../../lib/supabase-server';

export const prerender = false;

const { id } = Astro.params;
const profile = Astro.locals.profile;
const isAdmin = profile?.role === 'admin';

const supabase = createServerClient();

// Fetch project
const { data: project, error: projectError } = await supabase
  .from('projects')
  .select('*')
  .eq('id', id)
  .single();

// 404 or access denied
if (!project || projectError) {
  return Astro.redirect('/projects');
}

// Non-admin can only view their own project
if (!isAdmin && project.client_id !== profile?.id) {
  return Astro.redirect('/projects');
}

// Fetch phases
const { data: phases } = await supabase
  .from('project_phases')
  .select('*')
  .eq('project_id', id)
  .order('sort_order', { ascending: true });

// Fetch client actions
const { data: clientActions } = await supabase
  .from('client_actions')
  .select('*')
  .eq('project_id', id)
  .order('created_at', { ascending: true });

function statusLabel(status: string) {
  const labels: Record<string, string> = {
    em_andamento: 'Em andamento',
    pendente: 'Pendente',
    concluido: 'Concluído',
    cancelado: 'Cancelado',
  };
  return labels[status] || status;
}

function formatDate(dateStr: string | null) {
  if (!dateStr) return null;
  return new Date(dateStr).toLocaleDateString('pt-BR', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<AppLayout title={project.name} activeSection="projects">
  <!-- Project Header -->
  <div class="flex items-start justify-between mb-8">
    <div>
      <div class="flex items-center gap-3 mb-3">
        <a href="/projects" class="text-sm transition-colors back-link" style="color: var(--text-tertiary);">← Projetos</a>
      </div>
      <div class="flex items-center gap-3 mb-2">
        <span class="px-2.5 py-1 rounded-md text-xs font-medium" style="background: var(--blue-10); color: var(--accent-blue);">{project.type}</span>
        <span class="px-2.5 py-1 rounded-md text-xs font-medium" style="background: var(--color-success-bg); color: var(--color-success);">{statusLabel(project.status)}</span>
      </div>
      <h2 class="text-xl font-medium" style="color: var(--text-primary);">{project.name}</h2>
      <p class="text-sm mt-1" style="color: var(--text-quaternary);">
        {project.start_date && `Início: ${formatDate(project.start_date)}`}
        {project.start_date && project.estimated_end_date && ' · '}
        {project.estimated_end_date && `Previsão: ${formatDate(project.estimated_end_date)}`}
      </p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Timeline (2/3 width) -->
    <div class="lg:col-span-2">
      <div class="rounded-xl p-6" style="background: var(--surface-1); border: 1px solid var(--border-subtle);">
        <h3 class="font-medium mb-6" style="color: var(--text-primary);">Timeline do Projeto</h3>

        {phases && phases.length > 0 ? (
          <div class="flex flex-col gap-0">
            {phases.map((phase, i) => (
              <div class="flex gap-4">
                <!-- Timeline indicator -->
                <div class="flex flex-col items-center">
                  <div
                    class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-medium shrink-0"
                    style={
                      phase.status === 'done'
                        ? 'background: var(--color-success-bg); color: var(--color-success); border: 1px solid rgba(34,197,94,0.25);'
                        : phase.status === 'current'
                        ? 'background: var(--blue-10); color: var(--accent-blue); border: 1px solid var(--border-accent);'
                        : 'background: var(--surface-3); color: var(--text-quaternary); border: 1px solid var(--border-subtle);'
                    }
                  >
                    {phase.status === 'done' ? (
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 6 9 17l-5-5"/>
                      </svg>
                    ) : (
                      <span>{i + 1}</span>
                    )}
                  </div>
                  {i < phases.length - 1 && (
                    <div
                      class="w-px flex-1 min-h-[40px]"
                      style={`background: ${phase.status === 'done' ? 'rgba(34,197,94,0.25)' : 'var(--border-subtle)'};`}
                    ></div>
                  )}
                </div>

                <!-- Phase content -->
                <div class="pb-6 flex-1">
                  <div class="flex items-center gap-2">
                    <h4
                      class="font-medium text-sm"
                      style={`color: ${phase.status === 'current' ? 'var(--accent-blue)' : phase.status === 'done' ? 'var(--text-secondary)' : 'var(--text-quaternary)'};`}
                    >
                      {phase.name}
                    </h4>
                    {phase.status === 'current' && phase.progress != null && (
                      <span class="text-xs px-2 py-0.5 rounded-full" style="background: var(--blue-10); color: var(--accent-blue);">{phase.progress}%</span>
                    )}
                  </div>
                  {phase.description && (
                    <p class="text-sm mt-1" style="color: var(--text-quaternary);">{phase.description}</p>
                  )}
                  {phase.deliverable && (
                    <div class="flex items-center gap-2 mt-2 text-xs" style="color: var(--text-tertiary);">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <path d="M14 2v6h6"/>
                      </svg>
                      <span>{phase.deliverable}</span>
                    </div>
                  )}
                  {phase.status === 'current' && phase.progress != null && (
                    <div class="mt-3 w-full h-1.5 rounded-full" style="background: var(--surface-4);">
                      <div class="h-full rounded-full" style={`width: ${phase.progress}%; background: var(--accent-blue);`}></div>
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="text-center py-8">
            <p style="color: var(--text-quaternary); font-size: var(--text-body-sm);">Nenhuma fase configurada ainda.</p>
          </div>
        )}
      </div>
    </div>

    <!-- Sidebar (1/3 width) -->
    <div class="flex flex-col gap-6">
      <!-- Client Actions -->
      <div class="rounded-xl p-6" style="background: var(--surface-1); border: 1px solid var(--border-subtle);">
        <h3 class="font-medium mb-4 text-sm" style="color: var(--text-primary);">
          Ações pendentes
          <span class="text-xs ml-1" style="color: var(--text-quaternary);">(depende de você)</span>
        </h3>
        {clientActions && clientActions.length > 0 ? (
          <div class="flex flex-col gap-3">
            {clientActions.filter(a => !a.completed).map(action => (
              <div
                class="flex items-start gap-3 p-3 rounded-lg"
                style={`background: ${action.urgent ? 'var(--color-warning-bg)' : 'var(--surface-2)'}; border: 1px solid ${action.urgent ? 'rgba(245,158,11,0.25)' : 'var(--border-subtle)'};`}
              >
                {action.urgent && (
                  <span class="text-xs font-bold mt-0.5 shrink-0" style="color: var(--color-warning);">!</span>
                )}
                <span class="text-sm" style={`color: ${action.urgent ? 'var(--color-warning)' : 'var(--text-secondary)'};`}>
                  {action.text}
                </span>
              </div>
            ))}
            {clientActions.filter(a => !a.completed).length === 0 && (
              <p class="text-sm" style="color: var(--text-quaternary);">Nenhuma acao pendente.</p>
            )}
          </div>
        ) : (
          <p class="text-sm" style="color: var(--text-quaternary);">Nenhuma acao pendente.</p>
        )}
      </div>

      <!-- Messages -->
      <div class="rounded-xl p-6" style="background: var(--surface-1); border: 1px solid var(--border-subtle);">
        <h3 class="font-medium mb-4 text-sm" style="color: var(--text-primary);">Mensagens</h3>
        <div class="text-center py-4">
          <p class="text-sm" style="color: var(--text-quaternary);">Chat em breve</p>
        </div>
      </div>
    </div>
  </div>
</AppLayout>

<style>
  .back-link:hover {
    color: var(--text-secondary) !important;
  }
</style>
