---
import AppLayout from '../../layouts/AppLayout.astro';
import VaultLibrary from '../../components/VaultLibrary.tsx';
import UpgradeCTA from '../../components/UpgradeCTA.tsx';
import { createServerClient } from '../../lib/supabase-server';
import { hasAccess } from '../../lib/access';
import type { UserRole } from '../../lib/access';

export const prerender = false;

const supabase = createServerClient();
const profile = Astro.locals.profile;
const isAdmin = profile?.role === 'admin';
const userRole = (profile?.role || 'starter') as UserRole;
const canAccessVault = hasAccess(userRole, 'builder');

let categories: any[] = [];
let resources: any[] = [];

if (canAccessVault) {
  // Fetch categories
  const categoriesResult = await supabase
    .from('vault_categories')
    .select('*')
    .order('sort_order', { ascending: true });
  categories = categoriesResult.data || [];

  // Fetch resources
  let resourcesQuery = supabase
    .from('vault_resources')
    .select('*')
    .order('created_at', { ascending: false });

  if (!isAdmin) {
    // builder, mentoria: access all resources; legacy role handling preserved
    resourcesQuery = resourcesQuery.neq('access_level', 'admin');
  }

  const resourcesResult = await resourcesQuery;
  resources = resourcesResult.data || [];
}
---

<AppLayout title="Vault" activeSection="vault">
  {!canAccessVault ? (
    <UpgradeCTA
      client:load
      title="Vault — Recursos Exclusivos"
      description="Templates, frameworks, prompts e playbooks para acelerar seus projetos de AI."
      features={[
        'Templates de proposta comercial prontos',
        'Frameworks de precificacao de projetos AI',
        'Prompts prontos para agentes autonomos',
        'Playbooks de implementacao passo a passo',
      ]}
      ctaText="Fazer upgrade para Builder"
      ctaHref="/agendar"
      currentRole={userRole}
      requiredRole="builder"
    />
  ) : (
    <>
      <div class="mb-6">
        <h2 class="text-xl font-semibold mb-1" style="color: var(--text-primary);">Vault</h2>
        <p style="color: var(--text-tertiary); font-size: var(--text-body-sm);">
          Templates, frameworks, prompts e recursos exclusivos para seu negocio.
        </p>
      </div>

      <VaultLibrary
        client:load
        categories={categories}
        initialResources={resources}
      />
    </>
  )}
</AppLayout>
