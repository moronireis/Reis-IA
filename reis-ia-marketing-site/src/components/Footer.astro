---
/**
 * Footer — Minimal footer with brand + legal.
 */
---

<footer style="background: var(--surface-0); border-top: 1px solid var(--border-subtle); padding: 48px 0;">
  <div class="container-standard" style="display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 16px;">
    <div style="display: flex; align-items: center; gap: 0;">
      <span style="font-weight: 300; font-size: 16px; color: var(--text-primary);">REIS</span>
      <span style="font-weight: 300; font-size: 16px; color: var(--accent-blue); margin-left: 4px;">[IA]</span>
      <span style="color: var(--text-tertiary); font-weight: 400; font-size: 12px; margin-left: 8px; letter-spacing: 0.04em;">MARKETING</span>
    </div>
    <p style="font-size: 12px; color: var(--text-quaternary);">
      &copy; {new Date().getFullYear()} REIS [IA]. Todos os direitos reservados.
    </p>
  </div>
</footer>
