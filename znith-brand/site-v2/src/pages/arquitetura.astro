---
import Layout from '../layouts/Layout.astro';
const currentPath = '/arquitetura';

const subBrands = [
  {
    name: 'ZNITH.AI',
    desc: 'Plataforma de Tecnologia e IA',
    detail: 'IA aplicada a operações comerciais — atendimento, qualificação, agendamento, automação, produtividade.',
    audience: 'Diretores comerciais, líderes de RevOps, fundadores implementando IA',
    accent: '#4A78C8',
    accentLabel: 'Tech Blue',
    tone: 'Técnico-estratégico, preciso, orientado a resultado',
    lockup: 'ZNITH.AI — Inteligência Comercial',
  },
  {
    name: 'ZNITH Consulting',
    desc: 'Consultoria Estratégica',
    detail: 'Expansão comercial, RevOps, crescimento previsível — entregue como assessoria estratégica.',
    audience: 'Fundadores, CEOs e diretores comerciais que buscam assessoria estratégica',
    accent: '#253D66',
    accentLabel: 'Navy — autoridade por contenção',
    tone: 'Consultivo premium, direto, estratégico, peer-level',
    lockup: 'ZNITH Consulting — Expansão Comercial com IA',
  },
  {
    name: 'ZNITH.AI OS',
    desc: 'Produto Flagship',
    detail: 'Sistema de Arquitetura Comercial — CRM, fluxos, playbooks, automação, inteligência, design de crescimento previsível.',
    audience: 'B2B de serviços, R$1M–R$50M, já vendendo mas sem estrutura repetível',
    accent: '#C49738',
    accentLabel: 'Gold + Tech Blue',
    tone: 'Sistêmico, arquitetural, premium, mensurável',
    lockup: 'ZNITH.AI OS — Arquitetura Comercial Inteligente',
  },
  {
    name: 'Líderes Leões',
    desc: 'Movimento e Comunidade',
    detail: 'Desenvolvimento de líderes, consciência, coragem, direção — o único contexto onde o dourado é acento ativo irrestrito.',
    audience: 'Líderes, empresários e gestores que desejam governar com propósito',
    accent: '#EDD297',
    accentLabel: 'Gold intenso + Navy profundo',
    tone: 'Provocativo, forte, inspirador com profundidade, comunitário',
    lockup: 'Líderes Leões — Coragem para governar. Consciência para permanecer.',
  },
  {
    name: 'Z-PAY',
    desc: 'Futuro — Reservado',
    detail: 'Infraestrutura de Pagamentos e Expansão Internacional. Nenhuma execução visual ou de messaging até o lançamento formal.',
    audience: 'A definir',
    accent: '#3A5585',
    accentLabel: 'TBD',
    tone: 'TBD',
    lockup: 'Z-PAY (nomenclatura reservada)',
    future: true,
  },
];
---

<Layout title="Arquitetura de Marca" currentPath={currentPath}>
  <div class="page-header">
    <span class="page-overline">Capítulo 2</span>
    <h1 class="page-title">Arquitetura de Marca</h1>
    <p class="page-subtitle">Hierarquia, sub-marcas, ecossistema e convenções de nomenclatura.</p>
    <span class="gold-line"></span>
  </div>

  <!-- Hierarquia visual -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">2.1 Hierarquia</h2>
    <div style="margin-bottom:24px;"></div>

    <!-- Architecture diagram -->
    <div style="background:#132140;border:1px solid #253D66;border-radius:16px;padding:32px;font-family:'JetBrains Mono','Fira Code','Courier New',monospace;font-size:13px;color:#BBBBBB;line-height:1.8;margin-bottom:40px;overflow-x:auto;">
      <div style="color:#C49738;font-weight:600;">ZNITH (Marca Master)</div>
      <div style="color:#BBBBBB;">│&nbsp;&nbsp; "Arquitetura de Crescimento Comercial com IA"</div>
      <div style="color:#BBBBBB;">│&nbsp;&nbsp; Direção. Consciência. Legado.</div>
      <div style="color:#BBBBBB;">│</div>
      <div><span style="color:#BBBBBB;">├── </span><span style="color:#FFFFFF;">ZNITH.AI</span></div>
      <div style="color:#7A7A7A;">│&nbsp;&nbsp; Plataforma de Tecnologia e IA</div>
      <div style="color:#BBBBBB;">│</div>
      <div><span style="color:#BBBBBB;">├── </span><span style="color:#FFFFFF;">ZNITH Consulting</span></div>
      <div style="color:#7A7A7A;">│&nbsp;&nbsp; Consultoria Estratégica</div>
      <div style="color:#BBBBBB;">│</div>
      <div><span style="color:#BBBBBB;">├── </span><span style="color:#C49738;font-weight:600;">ZNITH.AI OS  ← Produto Flagship</span></div>
      <div style="color:#7A7A7A;">│&nbsp;&nbsp; Sistema de Arquitetura Comercial</div>
      <div style="color:#BBBBBB;">│</div>
      <div><span style="color:#BBBBBB;">├── </span><span style="color:#EDD297;">Líderes Leões</span></div>
      <div style="color:#7A7A7A;">│&nbsp;&nbsp; Movimento e Comunidade</div>
      <div style="color:#BBBBBB;">│</div>
      <div><span style="color:#BBBBBB;">└── </span><span style="color:#3A5585;">Z-PAY  [Futuro]</span></div>
      <div style="color:#3A5585;">&nbsp;&nbsp;&nbsp; Infraestrutura de Pagamentos</div>
      <div style="color:#BBBBBB;">&nbsp;</div>
      <div style="color:#253D66;">─────────────────────────────────</div>
      <div style="color:#BBBBBB;">&nbsp;</div>
      <div><span style="color:#D4A84C;font-weight:600;">LEILAINE CAMPIOTO</span><span style="color:#7A7A7A;"> (Marca Pessoal — Fundadora)</span></div>
      <div style="color:#7A7A7A;">&nbsp;&nbsp;&nbsp; CEO/Fundadora da ZNITH</div>
      <div style="color:#7A7A7A;">&nbsp;&nbsp;&nbsp; Arquétipos: Mentor · Visionário · Estrategista · Autoridade</div>
    </div>

    <p style="font-family:'Montserrat',sans-serif;font-size:15px;color:#BBBBBB;line-height:1.7;">
      A ZNITH opera como uma <strong style="color:#FFFFFF;">arquitetura de marca endossada</strong>: a marca master ZNITH carrega autoridade e clareza suficientes para endossar cada sub-marca, enquanto cada sub-marca atende a um público distinto. Leilaine Campioto funciona como o tecido conjuntivo — uma marca pessoal que é inseparável da identidade ZNITH mas não está subordinada a ela.
    </p>
  </section>

  <!-- Sub-marcas -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">2.2 Sub-marcas e Ecossistema</h2>
    <div style="margin-bottom:24px;"></div>

    <div style="display:flex;flex-direction:column;gap:16px;">
      {subBrands.map(brand => (
        <div class="card" style={brand.future ? 'opacity:0.5;' : ''}>
          <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:16px;flex-wrap:wrap;margin-bottom:16px;">
            <div>
              <div style={`font-family:'Cinzel',serif;font-size:20px;font-weight:400;color:#FFFFFF;margin-bottom:4px;`}>{brand.name}</div>
              <div style="font-family:'Montserrat',sans-serif;font-size:12px;font-weight:500;text-transform:uppercase;letter-spacing:0.1em;color:#C49738;">{brand.desc}</div>
            </div>
            {brand.future && <span class="badge badge-navy">Em desenvolvimento</span>}
          </div>
          <p style="font-family:'Montserrat',sans-serif;font-size:14px;color:#BBBBBB;line-height:1.6;margin-bottom:16px;">{brand.detail}</p>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px;font-size:13px;">
            <div>
              <div style="font-family:'Montserrat',sans-serif;font-weight:600;color:#7A7A7A;font-size:11px;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:4px;">Público</div>
              <div style="font-family:'Montserrat',sans-serif;color:#BBBBBB;line-height:1.5;">{brand.audience}</div>
            </div>
            <div>
              <div style="font-family:'Montserrat',sans-serif;font-weight:600;color:#7A7A7A;font-size:11px;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:4px;">Acento</div>
              <div style="display:flex;align-items:center;gap:8px;">
                <div style={`width:16px;height:16px;border-radius:4px;background:${brand.accent};flex-shrink:0;`}></div>
                <span style="font-family:'Montserrat',sans-serif;color:#BBBBBB;">{brand.accentLabel}</span>
              </div>
            </div>
            <div>
              <div style="font-family:'Montserrat',sans-serif;font-weight:600;color:#7A7A7A;font-size:11px;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:4px;">Tom</div>
              <div style="font-family:'Montserrat',sans-serif;color:#BBBBBB;line-height:1.5;">{brand.tone}</div>
            </div>
          </div>
          <div style="margin-top:16px;padding-top:16px;border-top:1px solid #253D66;">
            <div style="font-family:'Montserrat',sans-serif;font-weight:600;color:#7A7A7A;font-size:11px;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:6px;">Lockup exemplo</div>
            <div style={`font-family:'Cinzel',serif;font-size:13px;color:${brand.accent};letter-spacing:0.06em;`}>{brand.lockup}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Convenções de Nomenclatura -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">2.4 Convenções de Nomenclatura</h2>
    <div style="margin-bottom:24px;"></div>

    <table class="brand-table">
      <thead>
        <tr>
          <th>Marca</th>
          <th>Convenção</th>
          <th>Correto</th>
          <th>Incorreto</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td style="color:#FFFFFF;font-weight:600;">ZNITH</td>
          <td>Sempre maiúsculas</td>
          <td style="color:#C49738;">ZNITH</td>
          <td style="color:#A03A3A;">Znith, znith</td>
        </tr>
        <tr>
          <td style="color:#FFFFFF;font-weight:600;">ZNITH.AI</td>
          <td>Maiúsculas com ponto</td>
          <td style="color:#C49738;">ZNITH.AI</td>
          <td style="color:#A03A3A;">ZNITH AI, Znith.AI</td>
        </tr>
        <tr>
          <td style="color:#FFFFFF;font-weight:600;">ZNITH.AI OS</td>
          <td>Sempre maiúsculas</td>
          <td style="color:#C49738;">ZNITH.AI OS</td>
          <td style="color:#A03A3A;">Znith.AI OS, ZNITH.AI Os</td>
        </tr>
        <tr>
          <td style="color:#FFFFFF;font-weight:600;">Líderes Leões</td>
          <td>Title case; nunca abreviado</td>
          <td style="color:#C49738;">Líderes Leões</td>
          <td style="color:#A03A3A;">LL, Líderes leões, lideres leoes</td>
        </tr>
        <tr>
          <td style="color:#FFFFFF;font-weight:600;">Z-PAY</td>
          <td>Maiúsculas com hífen</td>
          <td style="color:#C49738;">Z-PAY</td>
          <td style="color:#A03A3A;">Zpay, Z Pay</td>
        </tr>
      </tbody>
    </table>
  </section>

  <!-- Modelo de Relacionamento -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">2.5 Modelo de Relacionamento</h2>
    <div style="margin-bottom:16px;"></div>
    <p style="font-family:'Montserrat',sans-serif;font-size:15px;color:#BBBBBB;line-height:1.7;">
      O mercado não deve ver fragmentos. Deve ver um sistema coerente com uma entrada única — <strong style="color:#FFFFFF;">arquitetura de crescimento comercial</strong> — e caminhos específicos dependendo do perfil do cliente e do momento da empresa.
    </p>
  </section>
</Layout>
