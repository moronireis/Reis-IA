---
import Layout from '../layouts/Layout.astro';
const currentPath = '/movimento';

const levels = [
  { num: '1', name: 'Entrada / Alinhamento', criteria: 'Conhecimento da causa, identificação com os valores, filtragem de perfil' },
  { num: '2', name: 'Membro', criteria: 'Participação ativa, comprometimento com rituais e cultura da tribo' },
  { num: '3', name: 'Líder', criteria: 'Reconhecido por coerência, constância, serviço, maturidade e influência saudável — não por tempo de casa' },
];

const rituals = [
  { name: 'Encontro semanal', desc: 'Pulso da tribo — calls ao vivo com toda a comunidade' },
  { name: 'Desafio mensal', desc: 'Aplicação prática com prestação de contas entre pares' },
  { name: 'Celebração de conquistas', desc: 'Não de esforço, mas de postura e resultado com postura' },
  { name: 'Onboarding', desc: 'Entrada estruturada com alinhamento de valores e expectativas claras' },
  { name: 'Mentoria entre pares', desc: 'Membros mais avançados apoiando os mais novos na tribo' },
  { name: 'Ranking', desc: 'Reconhecimento de compromisso, coerência e constância' },
];

const vocabulary = [
  { term: 'Governo', context: 'Liderança como governança — autoridade ativa, responsável e proposital' },
  { term: 'Chamado', context: 'A missão mais alta que motiva o líder além dos resultados financeiros' },
  { term: 'Postura', context: 'Conduta e presença — como um líder se apresenta, não apenas o que diz' },
  { term: 'Fortalecimento', context: 'O fortalecimento do caráter, clareza e convicção do líder' },
  { term: 'Alinhamento', context: 'Alinhamento interno entre valores, decisões e ações concretas' },
  { term: 'Território', context: 'O domínio que um líder governa — equipe, mercado, família, comunidade' },
];
---

<Layout title="Líderes Leões" currentPath={currentPath}>
  <div class="page-header">
    <span class="page-overline">Capítulo 8</span>
    <h1 class="page-title">Líderes Leões</h1>
    <p class="page-subtitle">Um movimento para líderes que foram chamados para governar sem se perder.</p>
    <span class="gold-line"></span>
  </div>

  <!-- Manifesto -->
  <section class="content-section" data-reveal>
    <div class="manifesto-block" style="background:linear-gradient(180deg,rgba(196,151,56,0.04) 0%,rgba(6,14,31,0.95) 100%);border:1px solid rgba(196,151,56,0.1);border-radius:16px;padding:40px;margin-bottom:16px;position:relative;overflow:hidden;">
      <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.15em;color:#EDD297;margin-bottom:24px;">Manifesto</div>
      <div style="font-family:'Cinzel',serif;font-size:clamp(15px,2vw,20px);color:#FFFFFF;line-height:1.8;">
        <p style="margin-bottom:20px;">Líderes Leões representa uma geração de líderes que se recusa a viver de aparência, improviso e força performática.</p>
        <p style="margin-bottom:20px;">É um movimento para homens e mulheres que entenderam que liderar não é apenas influenciar pessoas, bater metas ou ocupar espaço. <strong class="manifesto-highlight">É governar com consciência, coragem, verdade e propósito.</strong></p>
        <p style="margin-bottom:20px;">Não é cargo. Não é carisma. Não é aparência de força. É governo.</p>
        <p style="margin-bottom:20px;">Não basta chegar ao topo. É preciso chegar sem se perder, permanecer com integridade e gerar legado.</p>
        <p style="margin-bottom:32px;">Acontece na construção. Na disciplina. Na verdade que confronta antes de libertar.</p>
        <div style="border-top:1px solid rgba(196,151,56,0.3);padding-top:24px;">
          <p style="font-family:'Montserrat',sans-serif;font-size:14px;font-weight:600;text-transform:uppercase;letter-spacing:0.15em;color:#EDD297;">
            Líderes Leões existe para fortalecer quem foi chamado para governar sem se perder.
          </p>
          <p style="font-family:'Cinzel',serif;font-size:18px;color:#FFFFFF;margin-top:16px;font-style:italic;">
            Coragem para governar. Consciência para permanecer.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- A Causa -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">8.1 A Causa</h2>
    <div style="margin-bottom:16px;"></div>
    <p style="font-family:'Montserrat',sans-serif;font-size:15px;color:#BBBBBB;line-height:1.7;margin-bottom:16px;">
      Líderes Leões existe para despertar, fortalecer e alinhar líderes que foram chamados para governar sem se perder.
    </p>
    <p style="font-family:'Montserrat',sans-serif;font-size:15px;color:#BBBBBB;line-height:1.7;">
      O movimento defende que empresas, equipes e negócios precisam de líderes fortes por dentro, maduros para decidir, firmes para governar e conscientes para construir algo que permaneça. Que fé, estratégia, inteligência, vendas, liderança e tecnologia podem caminhar juntas.
    </p>
  </section>

  <!-- Os Inimigos -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">8.4 Os Inimigos</h2>
    <div style="margin-bottom:20px;"></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
      <div class="card" style="border-color:rgba(196,151,56,0.2);">
        <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#EDD297;margin-bottom:12px;">Inimigo Externo</div>
        <p style="font-family:'Montserrat',sans-serif;font-size:14px;color:#BBBBBB;line-height:1.7;">
          A cultura da liderança fraca disfarçada de performance. O sistema que exalta imagem, pressa, discurso bonito e resultado aparente, mas não forma líderes com caráter, direção, coragem e responsabilidade.
        </p>
      </div>
      <div class="card" style="border-color:rgba(196,151,56,0.2);">
        <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#EDD297;margin-bottom:12px;">Inimigo Interno</div>
        <p style="font-family:'Montserrat',sans-serif;font-size:14px;color:#BBBBBB;line-height:1.7;">
          A mistura de medo, confusão, autoengano e enfraquecimento da identidade. Quando o líder sabe que foi chamado para mais, mas está cansado, disperso, inseguro e preso entre a pressão de performar e a dificuldade de se posicionar com firmeza.
        </p>
      </div>
    </div>
  </section>

  <!-- A Tribo -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">8.5 A Tribo</h2>
    <div style="margin-bottom:20px;"></div>
    <div style="background:#132140;border:1px solid rgba(196,151,56,0.25);border-radius:10px;padding:24px;margin-bottom:16px;">
      <p style="font-family:'Montserrat',sans-serif;font-size:15px;color:#BBBBBB;line-height:1.7;margin-bottom:16px;">
        A tribo Líderes Leões é formada por líderes, empresários, gestores, fundadores e profissionais em posição de influência que entendem que foram chamados para mais do que sobreviver, repetir rotina ou apenas performar resultados.
      </p>
      <p style="font-family:'Montserrat',sans-serif;font-size:15px;color:#BBBBBB;line-height:1.7;">
        Em comum: valorizam fé, verdade, responsabilidade, clareza, liderança, maturidade emocional, estratégia e legado. O membro ideal é ensinável, forte o suficiente para confrontar a própria realidade e humilde o suficiente para reconhecer que ainda precisa ser lapidado.
      </p>
    </div>
    <blockquote class="brand-blockquote" style="border-left-color:#EDD297;">
      "Líderes Leões não é uma tribo para espectadores. É uma tribo para quem aceita ser lapidado para governar melhor."
    </blockquote>
  </section>

  <!-- Symbols -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">8.6 Símbolos e Vocabulário</h2>
    <div style="margin-bottom:20px;"></div>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px;margin-bottom:32px;">
      {[
        { symbol: 'O Leão', desc: 'Governo, coragem, vigilância, presença, autoridade, proteção e consciência de território. O leão não performa presença. Ele carrega presença.', color: '#EDD297' },
        { symbol: 'A Coroa', desc: 'Autoridade, responsabilidade e governo. Não como troféu, mas como peso. Quem carrega uma coroa carrega uma responsabilidade.', color: '#C49738' },
        { symbol: 'O Dourado', desc: 'Legado, honra e autoridade. Contexto único na marca onde o dourado é acento ativo irrestrito.', color: '#C49738' },
        { symbol: 'O Azul Navy', desc: 'Profundidade, firmeza e maturidade. Fundação que sustenta a intensidade do dourado.', color: '#3A5585' },
      ].map((s, i) => (
        <div class="symbol-card" data-reveal-stagger style={`background:#132140;border:1px solid rgba(196,151,56,0.15);border-radius:10px;padding:20px;border-top:3px solid ${s.color};--stagger:${i};`}>
          <div style="font-family:'Cinzel',serif;font-size:16px;color:#FFFFFF;margin-bottom:8px;">{s.symbol}</div>
          <p style="font-family:'Montserrat',sans-serif;font-size:12px;color:#BBBBBB;line-height:1.6;">{s.desc}</p>
        </div>
      ))}
    </div>

    <h3 class="section-h3" style="margin-bottom:16px;">Vocabulário Central</h3>
    <table class="brand-table">
      <thead>
        <tr>
          <th>Termo</th>
          <th>Contexto</th>
        </tr>
      </thead>
      <tbody>
        {vocabulary.map(v => (
          <tr>
            <td style="color:#EDD297;font-weight:600;font-family:'Cinzel',serif;white-space:nowrap;">{v.term}</td>
            <td>{v.context}</td>
          </tr>
        ))}
      </tbody>
    </table>

    <div style="margin-top:24px;">
      <div style="font-family:'Montserrat',sans-serif;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#7A7A7A;margin-bottom:12px;">Expressões do grupo</div>
      <div style="display:flex;flex-wrap:wrap;gap:8px;">
        {['Permaneça firme.','Governe com consciência.','Sem essência, não há legado.','Força com direção.','Menos performance, mais verdade.'].map(exp => (
          <span style="font-family:'Cinzel',serif;font-size:13px;color:#FFFFFF;padding:8px 14px;background:#132140;border:1px solid rgba(196,151,56,0.2);border-radius:6px;">{exp}</span>
        ))}
      </div>
    </div>

    <div style="margin-top:24px;padding:20px;background:rgba(196,151,56,0.06);border:1px solid rgba(196,151,56,0.2);border-radius:8px;">
      <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#EDD297;margin-bottom:8px;">Call and Response</div>
      <div style="font-family:'Cinzel',serif;font-size:16px;color:#FFFFFF;">"Quem governa?" — <span style="color:#EDD297;">"Quem permanece."</span></div>
    </div>
  </section>

  <!-- Levels -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">8.8 Níveis e Rituais</h2>
    <div style="margin-bottom:20px;"></div>

    <h3 class="section-h3" style="margin-bottom:16px;font-size:18px;">Estrutura de Progressão</h3>
    <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:32px;">
      {levels.map(l => (
        <div style="display:flex;gap:16px;align-items:flex-start;padding:16px;background:#132140;border:1px solid rgba(196,151,56,0.15);border-radius:8px;">
          <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#C49738,#EDD297);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <span style="font-family:'Cinzel',serif;font-size:13px;font-weight:700;color:#000;">{l.num}</span>
          </div>
          <div>
            <div style="font-family:'Cinzel',serif;font-size:15px;color:#FFFFFF;margin-bottom:4px;">{l.name}</div>
            <div style="font-family:'Montserrat',sans-serif;font-size:13px;color:#BBBBBB;line-height:1.5;">{l.criteria}</div>
          </div>
        </div>
      ))}
    </div>

    <h3 class="section-h3" style="margin-bottom:16px;font-size:18px;">Rituais do Movimento</h3>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:12px;">
      {rituals.map((r, i) => (
        <div data-reveal-stagger style={`background:#132140;border:1px solid rgba(196,151,56,0.12);border-radius:8px;padding:16px;--stagger:${i};`}>
          <div style="font-family:'Cinzel',serif;font-size:14px;color:#EDD297;margin-bottom:6px;">{r.name}</div>
          <div style="font-family:'Montserrat',sans-serif;font-size:13px;color:#BBBBBB;line-height:1.5;">{r.desc}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Meta -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">8.9 Meta</h2>
    <div style="margin-bottom:16px;"></div>
    <div style="background:linear-gradient(135deg,rgba(196,151,56,0.08),transparent);border:1px solid rgba(196,151,56,0.25);border-radius:10px;padding:32px;text-align:center;">
      <div style="font-family:'Cinzel',serif;font-size:48px;font-weight:400;color:#EDD297;margin-bottom:8px;">
        <span data-count-to="100">0</span>
      </div>
      <div style="font-family:'Montserrat',sans-serif;font-size:16px;font-weight:600;color:#FFFFFF;margin-bottom:12px;">Líderes ativos e comprometidos</div>
      <div style="font-family:'Montserrat',sans-serif;font-size:13px;color:#7A7A7A;">nos próximos 24 meses</div>
      <div style="width:80px;height:2px;background:#EDD297;margin:24px auto;"></div>
      <p style="font-family:'Montserrat',sans-serif;font-size:14px;color:#BBBBBB;line-height:1.7;max-width:500px;margin:0 auto;">
        A intenção não é apenas reunir pessoas, mas desenvolver uma comunidade viva de líderes que participem dos encontros, atravessem desafios, fortaleçam uns aos outros e se tornem referência de liderança com consciência, integridade e propósito.
      </p>
      <p style="font-family:'Montserrat',sans-serif;font-size:13px;color:#C49738;margin-top:16px;font-style:italic;">
        Quantidade é consequência. Qualidade de governo é o objetivo.
      </p>
    </div>
  </section>
</Layout>

<style>
  /* =========================================
     COMPONENT: Movimento Page VFX
     TRIGGER: scroll (IntersectionObserver)
     TIMING: 500ms ease-out (reveals), 1500ms easeOutCubic (counter)
     TIERS: all tiers (CSS transitions + lightweight JS)
     prefers-reduced-motion: instant visibility, counter shows final value
     ========================================= */

  /* Manifesto highlight glow */
  .manifesto-highlight {
    color: #EDD297;
    text-shadow: 0 0 20px rgba(237, 210, 151, 0.12);
  }

  /* Symbol card border pulse on reveal */
  .symbol-card.revealed {
    animation: border-pulse 1.5s ease-out;
  }

  @keyframes border-pulse {
    0% { border-color: rgba(196, 151, 56, 0.15); }
    40% { border-color: rgba(196, 151, 56, 0.4); }
    100% { border-color: rgba(37, 61, 102, 1); }
  }

  /* Scroll reveal system */
  [data-reveal] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 500ms ease-out, transform 500ms ease-out;
  }

  [data-reveal].revealed {
    opacity: 1;
    transform: translateY(0);
  }

  [data-reveal-stagger] {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 400ms ease-out, transform 400ms ease-out;
    transition-delay: calc(var(--stagger, 0) * 60ms);
  }

  [data-reveal].revealed [data-reveal-stagger],
  [data-reveal-stagger].revealed {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal],
    [data-reveal-stagger] {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .symbol-card.revealed {
      animation: none !important;
    }
  }
</style>

<script>
  // Scroll reveal via Intersection Observer
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('[data-reveal]').forEach(el => revealObserver.observe(el));

  // Symbol cards — observe individually for border-pulse
  const symbolCards = document.querySelectorAll('.symbol-card');
  const symbolObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
        symbolObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.3 });

  symbolCards.forEach(c => symbolObserver.observe(c));

  // Counter animation for "100 Leaders"
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const counters = document.querySelectorAll('[data-count-to]');
  const counterObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const target = parseInt(el.getAttribute('data-count-to') || '0');

        if (prefersReducedMotion) {
          el.textContent = String(target);
          counterObserver.unobserve(el);
          return;
        }

        const duration = 1500;
        const start = performance.now();
        const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);

        const animate = (now: number) => {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const value = Math.floor(easeOutCubic(progress) * target);
          el.textContent = String(value);
          if (progress < 1) requestAnimationFrame(animate);
          else el.textContent = String(target);
        };

        requestAnimationFrame(animate);
        counterObserver.unobserve(el);
      }
    });
  }, { threshold: 0.5 });

  counters.forEach(c => counterObserver.observe(c));
</script>
