---
import Layout from '../layouts/Layout.astro';
const currentPath = '/componentes';
---

<Layout title="Componentes" currentPath={currentPath}>
  <div class="page-header">
    <span class="page-overline">Capítulo 4.2</span>
    <h1 class="page-title">Componentes</h1>
    <p class="page-subtitle">Sistema de design em ação — botões, cards, formulários e elementos de UI.</p>
    <span class="gold-line"></span>
  </div>

  <!-- Buttons -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">1. Botões</h2>
    <div style="margin-bottom:8px;"></div>
    <p style="font-family:'Montserrat',sans-serif;font-size:14px;color:#BBBBBB;line-height:1.7;margin-bottom:32px;">
      Quatro variantes com propósito específico. Três tamanhos: sm (32px), md (40px), lg (48px).
    </p>

    <!-- Primary Button -->
    <h3 class="section-h3" style="margin-bottom:16px;">1.1 Primary — Ação de conversão principal</h3>
    <div class="card" style="margin-bottom:24px;">
      <div style="display:flex;flex-wrap:wrap;gap:16px;align-items:center;margin-bottom:24px;">
        <button style="height:32px;padding:0 12px;background:linear-gradient(135deg,#C49738,#EDD297);color:#030810;font-family:'Cinzel',serif;font-weight:700;font-size:12px;text-transform:uppercase;letter-spacing:0.08em;border:none;border-radius:6px;cursor:pointer;box-shadow:0 0 24px rgba(196,151,56,0.25);transition:all 0.2s;">
          Pequeno
        </button>
        <button style="height:40px;padding:0 20px;background:linear-gradient(135deg,#C49738,#EDD297);color:#030810;font-family:'Cinzel',serif;font-weight:700;font-size:13px;text-transform:uppercase;letter-spacing:0.08em;border:none;border-radius:8px;cursor:pointer;box-shadow:0 0 24px rgba(196,151,56,0.25);transition:all 0.2s;">
          Médio
        </button>
        <button style="height:48px;padding:0 28px;background:linear-gradient(135deg,#C49738,#EDD297);color:#030810;font-family:'Cinzel',serif;font-weight:700;font-size:14px;text-transform:uppercase;letter-spacing:0.1em;border:none;border-radius:8px;cursor:pointer;box-shadow:0 0 24px rgba(196,151,56,0.25);transition:all 0.2s;">
          Grande
        </button>
        <button disabled style="height:40px;padding:0 20px;background:linear-gradient(135deg,#C49738,#EDD297);color:#030810;font-family:'Cinzel',serif;font-weight:700;font-size:13px;text-transform:uppercase;letter-spacing:0.08em;border:none;border-radius:8px;cursor:not-allowed;opacity:0.4;">
          Desabilitado
        </button>
      </div>
      <div style="background:#060E1F;border-radius:8px;padding:16px;border:1px solid #253D66;">
        <table class="brand-table" style="margin:0;">
          <thead><tr><th>Estado</th><th>Especificação</th></tr></thead>
          <tbody>
            <tr><td style="color:#FFFFFF;">Default</td><td>Gradient #C49738 → #EDD297, shadow gold 0.3</td></tr>
            <tr><td style="color:#FFFFFF;">Hover</td><td>Gradient invertido, scale(1.02), shadow 0.5</td></tr>
            <tr><td style="color:#FFFFFF;">Active</td><td>scale(0.98), shadow reduzido</td></tr>
            <tr><td style="color:#FFFFFF;">Focus</td><td>outline 2px solid #EDD297, offset 3px</td></tr>
            <tr><td style="color:#FFFFFF;">Disabled</td><td>opacity 0.4, cursor not-allowed</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Secondary Button -->
    <h3 class="section-h3" style="margin-bottom:16px;">1.2 Secondary — Ações secundárias</h3>
    <div class="card" style="margin-bottom:24px;">
      <div style="display:flex;flex-wrap:wrap;gap:16px;align-items:center;margin-bottom:24px;">
        <button style="height:32px;padding:0 12px;background:transparent;border:1px solid #C49738;color:#C49738;font-family:'Montserrat',sans-serif;font-weight:500;font-size:12px;text-transform:uppercase;letter-spacing:0.06em;border-radius:6px;cursor:pointer;transition:all 0.2s;">
          Pequeno
        </button>
        <button style="height:40px;padding:0 20px;background:transparent;border:1px solid #C49738;color:#C49738;font-family:'Montserrat',sans-serif;font-weight:500;font-size:13px;text-transform:uppercase;letter-spacing:0.06em;border-radius:8px;cursor:pointer;transition:all 0.2s;">
          Médio
        </button>
        <button style="height:48px;padding:0 28px;background:transparent;border:1px solid #C49738;color:#C49738;font-family:'Montserrat',sans-serif;font-weight:500;font-size:14px;text-transform:uppercase;letter-spacing:0.08em;border-radius:8px;cursor:pointer;transition:all 0.2s;">
          Grande
        </button>
      </div>
      <p style="font-family:'Montserrat',sans-serif;font-size:13px;color:#7A7A7A;">Hover: preenche com #C49738, texto preto. Active: fundo #B8860B.</p>
    </div>

    <!-- Ghost Button -->
    <h3 class="section-h3" style="margin-bottom:16px;">1.3 Ghost — Ações de baixa ênfase</h3>
    <div class="card" style="margin-bottom:24px;">
      <div style="display:flex;flex-wrap:wrap;gap:16px;align-items:center;">
        <button style="height:40px;padding:0 16px;background:transparent;border:none;color:#C49738;font-family:'Montserrat',sans-serif;font-size:14px;cursor:pointer;transition:all 0.2s;">
          Cancelar
        </button>
        <button style="height:40px;padding:0 16px;background:transparent;border:none;color:#C49738;font-family:'Montserrat',sans-serif;font-size:14px;cursor:pointer;text-decoration:underline;">
          Ver mais (hover)
        </button>
      </div>
    </div>

    <!-- Danger Button -->
    <h3 class="section-h3" style="margin-bottom:16px;">1.4 Danger — Ações destrutivas</h3>
    <div class="card" style="margin-bottom:24px;">
      <div style="display:flex;flex-wrap:wrap;gap:16px;align-items:center;">
        <button style="height:40px;padding:0 20px;background:#7F1D1D;border:1px solid #991B1B;color:#FFFFFF;font-family:'Montserrat',sans-serif;font-weight:500;font-size:13px;border-radius:8px;cursor:pointer;transition:all 0.2s;">
          Excluir
        </button>
        <button style="height:40px;padding:0 20px;background:#7F1D1D;border:1px solid #991B1B;color:#FFFFFF;font-family:'Montserrat',sans-serif;font-weight:500;font-size:13px;border-radius:8px;cursor:pointer;opacity:0.4;" disabled>
          Desabilitado
        </button>
      </div>
      <p style="font-family:'Montserrat',sans-serif;font-size:13px;color:#7A7A7A;margin-top:16px;">Usar apenas para: exclusão, revogação, cancelamento de contrato. Hover: #991B1B.</p>
    </div>
  </section>

  <!-- Cards -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">2. Cards</h2>
    <div style="margin-bottom:24px;"></div>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px;margin-bottom:32px;">
      <!-- Content Card -->
      <div data-reveal-stagger style="--stagger: 0">
        <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#C49738;margin-bottom:10px;">Content Card</div>
        <div class="card">
          <h4 style="font-family:'Cinzel',serif;font-size:18px;color:#FFFFFF;margin-bottom:10px;">Título do Card</h4>
          <p style="font-family:'Montserrat',sans-serif;font-size:14px;color:#BBBBBB;line-height:1.6;margin-bottom:16px;">Container geral de conteúdo. Background #132140, borda #253D66. Hover: borda dourada + brilho sutil.</p>
          <a href="#" style="font-family:'Montserrat',sans-serif;font-size:13px;color:#C49738;">Saiba mais &rarr;</a>
        </div>
      </div>

      <!-- Feature Card -->
      <div data-reveal-stagger style="--stagger: 1">
        <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#C49738;margin-bottom:10px;">Feature Card</div>
        <div class="card">
          <div style="width:48px;height:48px;background:#1A2D52;border-radius:8px;display:flex;align-items:center;justify-content:center;margin-bottom:20px;">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
              <path d="M11 2L14 8H20L15 12L17 18L11 14L5 18L7 12L2 8H8L11 2Z" stroke="#C49738" stroke-width="1.5" stroke-linejoin="round"/>
            </svg>
          </div>
          <h4 style="font-family:'Cinzel',serif;font-size:18px;color:#FFFFFF;margin-bottom:10px;">Diagnóstico</h4>
          <p style="font-family:'Montserrat',sans-serif;font-size:14px;color:#BBBBBB;line-height:1.6;">Leitura profunda da operação comercial. Identificamos onde a receita está travando.</p>
        </div>
      </div>

      <!-- Stat Card -->
      <div data-reveal-stagger style="--stagger: 2">
        <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#C49738;margin-bottom:10px;">Stat Card</div>
        <div class="card" style="text-align:center;">
          <p style="font-family:'Cinzel',serif;font-weight:700;font-size:52px;line-height:1;color:#C49738;margin-bottom:8px;">R$500M<span style="font-size:28px;">+</span></p>
          <p style="font-family:'Montserrat',sans-serif;font-weight:600;font-size:13px;color:#FFFFFF;margin-bottom:4px;">Em participação em vendas</p>
          <p style="font-family:'Montserrat',sans-serif;font-size:11px;color:#7A7A7A;">direta e indiretamente</p>
        </div>
      </div>
    </div>

    <!-- Testimonial Card -->
    <div style="margin-bottom:16px;">
      <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#C49738;margin-bottom:10px;">Testimonial Card</div>
      <div class="card">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" style="margin-bottom:16px;">
          <path d="M3 21C3 21 4.5 15 9 12C9 12 3 12 3 6C3 3 6 1.5 9 3C12 4.5 12 9 12 12C12 15 10 19.5 3 21Z" fill="#C49738" opacity="0.6"/>
          <path d="M15 21C15 21 16.5 15 21 12C21 12 15 12 15 6C15 3 18 1.5 21 3C24 4.5 24 9 24 12C24 15 22 19.5 15 21Z" fill="#C49738" opacity="0.6"/>
        </svg>
        <blockquote style="font-family:'Cinzel',serif;font-style:italic;font-size:17px;color:#FFFFFF;line-height:1.7;margin-bottom:20px;">
          "A ZNITH não entregou um projeto. Entregou uma operação que funciona sem eu estar em cada decisão."
        </blockquote>
        <hr style="border:none;border-top:1px solid #253D66;margin-bottom:16px;" />
        <div style="display:flex;align-items:center;gap:12px;">
          <div style="width:40px;height:40px;border-radius:50%;background:#1A2D52;border:1px solid #253D66;display:flex;align-items:center;justify-content:center;">
            <span style="font-family:'Cinzel',serif;font-size:14px;color:#C49738;">C</span>
          </div>
          <div>
            <p style="font-family:'Montserrat',sans-serif;font-weight:700;font-size:14px;color:#FFFFFF;">Carlos M.</p>
            <p style="font-family:'Montserrat',sans-serif;font-size:12px;color:#7A7A7A;">CEO, Empresa B2B — R$12M/ano</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Form Elements -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">3. Elementos de Formulário</h2>
    <div style="margin-bottom:24px;"></div>

    <div class="card" style="max-width:480px;">
      <div style="margin-bottom:20px;">
        <label style="display:block;font-family:'Montserrat',sans-serif;font-size:12px;font-weight:500;text-transform:uppercase;letter-spacing:0.08em;color:#BBBBBB;margin-bottom:8px;">Nome</label>
        <input type="text" placeholder="Leilaine Campioto" style="width:100%;height:44px;background:#132140;border:1px solid #253D66;border-radius:8px;padding:0 16px;font-family:'Montserrat',sans-serif;font-size:14px;color:#FFFFFF;outline:none;transition:border-color 0.2s;" />
      </div>
      <div style="margin-bottom:20px;">
        <label style="display:block;font-family:'Montserrat',sans-serif;font-size:12px;font-weight:500;text-transform:uppercase;letter-spacing:0.08em;color:#BBBBBB;margin-bottom:8px;">Email</label>
        <input type="email" placeholder="leilaine@znith.com.br" style="width:100%;height:44px;background:#132140;border:1px solid #C49738;border-radius:8px;padding:0 16px;font-family:'Montserrat',sans-serif;font-size:14px;color:#FFFFFF;outline:none;" />
        <p style="font-family:'Montserrat',sans-serif;font-size:11px;color:#7A7A7A;margin-top:6px;">Estado de foco: borda #C49738</p>
      </div>
      <div style="margin-bottom:20px;">
        <label style="display:block;font-family:'Montserrat',sans-serif;font-size:12px;font-weight:500;text-transform:uppercase;letter-spacing:0.08em;color:#BBBBBB;margin-bottom:8px;">Mensagem</label>
        <textarea rows="3" placeholder="Descreva sua operação comercial..." style="width:100%;background:#132140;border:1px solid #253D66;border-radius:8px;padding:12px 16px;font-family:'Montserrat',sans-serif;font-size:14px;color:#FFFFFF;outline:none;resize:vertical;"></textarea>
      </div>
      <div style="margin-bottom:24px;">
        <label style="display:block;font-family:'Montserrat',sans-serif;font-size:12px;font-weight:500;text-transform:uppercase;letter-spacing:0.08em;color:#BBBBBB;margin-bottom:8px;">Faturamento</label>
        <select style="width:100%;height:44px;background:#132140;border:1px solid #A03A3A;border-radius:8px;padding:0 16px;font-family:'Montserrat',sans-serif;font-size:14px;color:#FFFFFF;outline:none;appearance:none;">
          <option>R$1M – R$5M</option>
          <option>R$5M – R$20M</option>
          <option>R$20M – R$50M</option>
        </select>
        <p style="font-family:'Montserrat',sans-serif;font-size:11px;color:#A03A3A;margin-top:6px;">Estado de erro: borda vermelha escura #A03A3A</p>
      </div>
      <button style="width:100%;height:44px;background:linear-gradient(135deg,#C49738,#EDD297);color:#030810;font-family:'Cinzel',serif;font-weight:700;font-size:13px;text-transform:uppercase;letter-spacing:0.1em;border:none;border-radius:8px;cursor:pointer;box-shadow:0 0 24px rgba(196,151,56,0.25);">
        Solicitar Diagnóstico
      </button>
    </div>
  </section>

  <!-- Badges -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">4. Badges & Tags</h2>
    <div style="margin-bottom:20px;"></div>
    <div style="display:flex;flex-wrap:wrap;gap:10px;align-items:center;">
      <span class="badge badge-gold">ZNITH.AI OS</span>
      <span class="badge badge-gold">Flagship</span>
      <span class="badge badge-navy">Versão 1.0</span>
      <span class="badge badge-navy">Abril 2026</span>
      <span class="badge" style="background:rgba(42,107,74,0.15);border:1px solid rgba(42,107,74,0.4);color:#3A8A60;">Ativo</span>
      <span class="badge" style="background:rgba(122,42,42,0.15);border:1px solid rgba(122,42,42,0.4);color:#A03A3A;">Restrito</span>
      <span class="badge" style="background:rgba(122,90,32,0.15);border:1px solid rgba(122,90,32,0.4);color:#A07030;">Em avaliação</span>
    </div>
  </section>

  <!-- Navigation -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">5. Padrões de Navegação</h2>
    <div style="margin-bottom:16px;"></div>
    <p style="font-family:'Montserrat',sans-serif;font-size:14px;color:#BBBBBB;line-height:1.7;margin-bottom:24px;">
      Navbar: background #132140, altura 64px desktop / 56px mobile, borda inferior #253D66.
    </p>
    <div style="background:#132140;border:1px solid #253D66;border-radius:10px;overflow:hidden;">
      <div style="height:64px;padding:0 24px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid #253D66;">
        <div style="display:flex;align-items:center;gap:12px;">
          <img src="/logos/Z-3.png" alt="Z" style="height:32px;width:32px;object-fit:contain;" />
          <span style="font-family:'Cinzel',serif;font-size:16px;color:#FFFFFF;letter-spacing:0.1em;">ZNITH</span>
        </div>
        <nav style="display:flex;gap:4px;">
          {['A Marca', 'Serviços', 'ZNITH.AI OS', 'Contato'].map((item, i) => (
            <a href="#" style={`font-family:'Montserrat',sans-serif;font-size:13px;font-weight:500;color:${i === 0 ? '#C49738' : '#DDDDDD'};padding:8px 14px;border-radius:6px;text-decoration:none;transition:color 0.2s;`}>{item}</a>
          ))}
        </nav>
        <button style="height:36px;padding:0 16px;background:linear-gradient(135deg,#C49738,#EDD297);color:#030810;font-family:'Cinzel',serif;font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:0.1em;border:none;border-radius:6px;cursor:pointer;">
          Diagnóstico
        </button>
      </div>
    </div>
  </section>
</Layout>
