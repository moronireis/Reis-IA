---
import '../styles/global.css';

const navSections = [
  { href: '/marca', label: 'A Marca', desc: 'Origem, missao, valores e promessa central' },
  { href: '/arquitetura', label: 'Arquitetura de Marca', desc: 'Hierarquia, sub-marcas, ecossistema' },
  { href: '/identidade', label: 'Identidade Visual', desc: 'Logo system, area de protecao, uso correto' },
  { href: '/cores', label: 'Paleta de Cores', desc: 'Navy, dourado, neutros, semanticas, superficies' },
  { href: '/tipografia', label: 'Tipografia', desc: 'Cinzel, Montserrat, escala e pares tipograficos' },
  { href: '/grafismos', label: 'Grafismos & Patterns', desc: 'Seis elementos graficos e suas aplicacoes' },
  { href: '/componentes', label: 'Componentes', desc: 'Botoes, cards, forms — demos interativos' },
  { href: '/voz', label: 'Tom de Voz', desc: 'Perfis de voz por camada, vocabulario, proibicoes' },
  { href: '/personal', label: 'Leilaine Campioto', desc: 'Marca pessoal, arquetipos, pilares de conteudo' },
  { href: '/produto', label: 'ZNITH.AI OS', desc: 'Produto flagship, 5 fases, ICP, promessa' },
  { href: '/movimento', label: 'Lideres Leoes', desc: 'Manifesto, simbolos, rituais, tribo' },
  { href: '/aplicacoes', label: 'Aplicacoes', desc: 'Website, redes sociais, documentos, print' },
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ZNITH Brandbook — Versao 2.0</title>
    <link rel="icon" type="image/png" href="/logos/Z-3.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
      /* =========================================
         COMPONENT: Cover Page — Cinematic Entrance v2.0
         TRIGGER: page-load (sequenced)
         TIMING: 0-2800ms staggered, cubic-bezier(0.16, 1, 0.3, 1)
         TIERS: full (particles + all anims) | reduced (no particles) | minimal (no anims)
         prefers-reduced-motion: all elements visible immediately, no animation
         ========================================= */

      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body {
        background: #030810;
        color: #B0B8C8;
        font-family: 'Montserrat', sans-serif;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* --- Hero Section --- */
      .hero {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 64px 24px 120px;
        position: relative;
        overflow: hidden;
      }

      /* Subtle bottom radial glow */
      .hero::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 60%;
        background: radial-gradient(ellipse at 50% 80%, rgba(196, 151, 56, 0.02) 0%, transparent 60%);
        pointer-events: none;
        z-index: 0;
      }

      /* --- Radial Glow behind logo --- */
      .hero-glow {
        position: absolute;
        top: 30%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 600px;
        height: 400px;
        background: radial-gradient(ellipse, rgba(196, 151, 56, 0.06) 0%, transparent 70%);
        opacity: 0;
        animation: glow-appear 600ms ease-in 400ms forwards;
        pointer-events: none;
        z-index: 0;
      }

      @keyframes glow-appear {
        to { opacity: 1; }
      }

      /* --- Logo Materialize --- */
      .hero-logo {
        width: 180px;
        height: auto;
        margin-bottom: 48px;
        position: relative;
        z-index: 2;
        opacity: 0;
        transform: scale(0.96);
        animation: logo-materialize 800ms cubic-bezier(0.16, 1, 0.3, 1) 800ms forwards;
      }

      @keyframes logo-materialize {
        to { opacity: 1; transform: scale(1); }
      }

      .hero-logo img {
        width: 100%;
        height: auto;
        animation: glow-pulse 4s ease-in-out infinite 2s;
      }

      @keyframes glow-pulse {
        0%, 100% { filter: drop-shadow(0 0 40px rgba(196, 151, 56, 0.10)); }
        50% { filter: drop-shadow(0 0 50px rgba(196, 151, 56, 0.20)); }
      }

      /* --- Version badge --- */
      .hero-version {
        font-family: 'Montserrat', sans-serif;
        font-size: 12px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: #D4A84C;
        margin-bottom: 20px;
        position: relative;
        z-index: 2;
        opacity: 0;
        animation: text-appear 500ms ease-out 600ms forwards;
      }

      /* --- Title with gradient --- */
      .hero-title {
        font-family: 'Cinzel', serif;
        font-size: clamp(40px, 6vw, 80px);
        font-weight: 400;
        color: #FFFFFF;
        letter-spacing: 0.02em;
        line-height: 1.1;
        margin-bottom: 12px;
        position: relative;
        z-index: 2;
        opacity: 0;
        animation: text-appear 500ms ease-out 1200ms forwards;
        background: linear-gradient(180deg, #FFFFFF 30%, #E2BD6E 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .hero-tagline {
        font-family: 'Montserrat', sans-serif;
        font-size: clamp(12px, 1.4vw, 15px);
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.25em;
        color: #D4A84C;
        margin-bottom: 16px;
        position: relative;
        z-index: 2;
        opacity: 0;
        animation: text-appear 500ms ease-out 1400ms forwards;
      }

      .hero-sub {
        font-family: 'Montserrat', sans-serif;
        font-size: 14px;
        color: #636D82;
        margin-bottom: 56px;
        letter-spacing: 0.04em;
        position: relative;
        z-index: 2;
        opacity: 0;
        animation: text-appear 500ms ease-out 1600ms forwards;
      }

      @keyframes text-appear {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
      }

      /* --- Gold Line --- */
      .hero-gold-line {
        height: 1px;
        background: linear-gradient(90deg, #C49738, #E2BD6E, #C49738);
        margin: 0 auto 48px;
        position: relative;
        z-index: 2;
        width: 0;
        opacity: 0.7;
        animation: line-draw 600ms cubic-bezier(0.16, 1, 0.3, 1) 1800ms forwards;
      }

      @keyframes line-draw {
        to { width: 100px; }
      }

      /* --- Nav Grid + Staggered Cards --- */
      .nav-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 12px;
        max-width: 960px;
        width: 100%;
        text-align: left;
        position: relative;
        z-index: 2;
      }

      .nav-card {
        background: rgba(14, 26, 50, 0.6);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(37, 61, 102, 0.4);
        border-radius: 14px;
        padding: 22px 24px;
        text-decoration: none;
        display: block;
        opacity: 0;
        transform: translateY(16px);
        animation: card-enter 500ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
        transition: transform 300ms cubic-bezier(0.16, 1, 0.3, 1),
                    border-color 300ms ease,
                    box-shadow 300ms ease;
      }

      @keyframes card-enter {
        to { opacity: 1; transform: translateY(0); }
      }

      .nav-card:hover {
        transform: translateY(-4px);
        border-color: rgba(196, 151, 56, 0.3);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3),
                    0 0 20px rgba(196, 151, 56, 0.06),
                    inset 0 1px 0 rgba(196, 151, 56, 0.1);
      }

      .nav-card-label {
        font-family: 'Cinzel', serif;
        font-size: 14px;
        color: #FFFFFF;
        margin-bottom: 4px;
      }

      .nav-card-desc {
        font-family: 'Montserrat', sans-serif;
        font-size: 12px;
        color: #636D82;
        line-height: 1.5;
      }

      /* --- Particles (desktop only, more subtle) --- */
      .particles {
        position: fixed;
        inset: 0;
        pointer-events: none;
        overflow: hidden;
        z-index: 1;
      }

      .particle {
        position: absolute;
        bottom: -10px;
        left: var(--x);
        width: 3px;
        height: 3px;
        background: #C49738;
        border-radius: 50%;
        opacity: 0;
        animation: particle-rise var(--duration) ease-in-out var(--delay) infinite;
      }

      @keyframes particle-rise {
        0% { transform: translateY(0); opacity: 0; }
        10% { opacity: 0.08; }
        90% { opacity: 0.04; }
        100% { transform: translateY(-100vh); opacity: 0; }
      }

      @media (max-width: 767px) {
        .particles { display: none; }
      }

      /* --- Footer Bar --- */
      .footer-bar {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: rgba(3, 8, 16, 0.95);
        border-top: 1px solid rgba(37, 61, 102, 0.3);
        padding: 14px 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 16px;
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        z-index: 10;
      }

      .footer-enter {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-family: 'Cinzel', serif;
        font-size: 12px;
        color: #000000;
        background: #C49738;
        padding: 10px 28px;
        border-radius: 6px;
        text-decoration: none;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        font-weight: 700;
        transition: filter 0.2s ease, transform 0.15s ease;
        box-shadow: 0 0 24px rgba(196, 151, 56, 0.25);
      }

      .footer-enter:hover {
        filter: brightness(1.1);
        transform: scale(1.02);
      }

      /* --- prefers-reduced-motion --- */
      @media (prefers-reduced-motion: reduce) {
        .particles { display: none; }
        .hero-glow,
        .hero-logo,
        .hero-version,
        .hero-title,
        .hero-tagline,
        .hero-sub,
        .nav-card {
          opacity: 1 !important;
          transform: none !important;
          animation: none !important;
        }
        .hero-title {
          -webkit-text-fill-color: unset;
          background: none;
          color: #FFFFFF;
        }
        .hero-logo img {
          animation: none !important;
          filter: drop-shadow(0 0 40px rgba(196, 151, 56, 0.10));
        }
        .hero-gold-line {
          width: 100px !important;
          animation: none !important;
        }
        .footer-enter {
          animation: none !important;
        }
      }
    </style>
  </head>
  <body>
    <!-- Particles (desktop only, 4 particles, more subtle) -->
    <div class="particles" aria-hidden="true">
      <div class="particle" style="--x: 15%; --delay: 0s; --duration: 26s;"></div>
      <div class="particle" style="--x: 40%; --delay: 4s; --duration: 28s;"></div>
      <div class="particle" style="--x: 65%; --delay: 2s; --duration: 24s;"></div>
      <div class="particle" style="--x: 85%; --delay: 7s; --duration: 30s;"></div>
    </div>

    <section class="hero">
      <!-- Radial glow behind logo -->
      <div class="hero-glow" aria-hidden="true"></div>

      <div class="hero-version">Brandbook &amp; Design System</div>

      <div class="hero-logo">
        <img
          src="/logos/ZINITH_oficial_png.png"
          alt="ZNITH — Direcao. Consciencia. Legado."
        />
      </div>

      <h1 class="hero-title">ZNITH</h1>
      <p class="hero-tagline">Direcao. Consciencia. Legado.</p>
      <p class="hero-sub">Versao 2.0 &mdash; Abril 2026</p>

      <div class="hero-gold-line"></div>

      <nav class="nav-grid">
        {navSections.map((section, i) => (
          <a href={section.href} class="nav-card" style={`animation-delay: calc(2000ms + (${i} * 60ms));`}>
            <div class="nav-card-label">{section.label}</div>
            <div class="nav-card-desc">{section.desc}</div>
          </a>
        ))}
      </nav>
    </section>

    <div class="footer-bar">
      <a href="/marca" class="footer-enter">
        Entrar no Brandbook
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M7 1L13 7L7 13M13 7H1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </body>
</html>
