---
import Layout from '../layouts/Layout.astro';
const currentPath = '/tipografia';

const typeScale = [
  { name: 'xs', px: '12px', rem: '0.75rem', usage: 'Captions, labels pequenos' },
  { name: 'sm', px: '14px', rem: '0.875rem', usage: 'Body small, nav items' },
  { name: 'base', px: '16px', rem: '1rem', usage: 'Body default' },
  { name: 'md', px: '18px', rem: '1.125rem', usage: 'Body large' },
  { name: 'lg', px: '20px', rem: '1.25rem', usage: 'Card descriptions' },
  { name: 'xl', px: '24px', rem: '1.5rem', usage: 'Tagline, card titles' },
  { name: '2xl', px: '30px', rem: '1.875rem', usage: 'Sub-headings' },
  { name: '3xl', px: '36px', rem: '2.25rem', usage: 'Section H2' },
  { name: '4xl', px: '48px', rem: '3rem', usage: 'Page H1' },
  { name: '5xl', px: '60px', rem: '3.75rem', usage: 'Hero H1' },
  { name: '6xl', px: '72px', rem: '4.5rem', usage: 'Display' },
  { name: '7xl', px: '96px', rem: '6rem', usage: 'Máximo display' },
];

const pairings = [
  { role: 'Hero H1', font: 'Cinzel', size: '7xl / 6xl', weight: '400', spacing: '-0.05em', color: '#FFFFFF', sample: 'ZNITH', sampleColor: '#FFFFFF' },
  { role: 'Hero H1 Accent', font: 'Cinzel', size: '6xl', weight: '400', spacing: '-0.04em', color: '#C49738', sample: 'ZNITH', sampleColor: '#C49738' },
  { role: 'Page H1', font: 'Cinzel', size: '4xl / 5xl', weight: '400', spacing: '-0.03em', color: '#FFFFFF', sample: 'Arquitetura Comercial', sampleColor: '#FFFFFF' },
  { role: 'Section H2', font: 'Cinzel', size: '3xl / 4xl', weight: '400', spacing: '-0.03em', color: '#FFFFFF', sample: 'Sistema de Design', sampleColor: '#FFFFFF' },
  { role: 'Subsection H3', font: 'Montserrat', size: '2xl', weight: '600', spacing: '-0.02em', color: '#FFFFFF', sample: 'Tokens de Fundação', sampleColor: '#FFFFFF' },
  { role: 'Card Title', font: 'Montserrat', size: 'xl', weight: '600', spacing: '-0.02em', color: '#FFFFFF', sample: 'Diagnóstico Estratégico', sampleColor: '#FFFFFF' },
  { role: 'Tagline', font: 'Cinzel', size: 'xl', weight: '400', spacing: '0.15em', color: '#C49738', sample: 'DIREÇÃO. CONSCIÊNCIA. LEGADO.', sampleColor: '#C49738' },
  { role: 'Body Default', font: 'Montserrat', size: 'base', weight: '400', spacing: '0', color: '#BBBBBB', sample: 'Estruturar operações comerciais para crescimento previsível com IA como alavanca.', sampleColor: '#BBBBBB' },
  { role: 'Nav Item', font: 'Montserrat', size: 'sm', weight: '500', spacing: '0.04em', color: '#DDDDDD', sample: 'A Marca', sampleColor: '#DDDDDD' },
  { role: 'Caption', font: 'Montserrat', size: 'xs', weight: '400', spacing: '0.02em', color: '#7A7A7A', sample: 'Versão 1.0 — Abril 2026', sampleColor: '#7A7A7A' },
];
---

<Layout title="Tipografia" currentPath={currentPath}>
  <div class="page-header">
    <span class="page-overline">Capítulo 3.3 — Tokens</span>
    <h1 class="page-title">Tipografia</h1>
    <p class="page-subtitle">Cinzel e Montserrat — duas fontes. Zero ornamentos desnecessários. Cada uma com função clara.</p>
    <span class="gold-line"></span>
  </div>

  <!-- Font Families -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">Famílias Tipográficas</h2>
    <div style="margin-bottom:24px;"></div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:40px;">
      <!-- Cinzel -->
      <div class="card" data-reveal-stagger style="--stagger: 0">
        <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#C49738;margin-bottom:16px;">Display / Headings</div>
        <div style="font-family:'Cinzel',serif;font-size:48px;font-weight:400;color:#FFFFFF;line-height:1;margin-bottom:16px;">Cinzel</div>
        <div style="font-family:'Cinzel',serif;font-size:18px;color:#BBBBBB;letter-spacing:0.08em;margin-bottom:16px;">ABCDEFGHIJKLMNOPQRSTUVWXYZ</div>
        <div style="font-family:'Cinzel',serif;font-size:18px;color:#BBBBBB;letter-spacing:0.08em;margin-bottom:16px;">0123456789</div>
        <p style="font-family:'Montserrat',sans-serif;font-size:13px;color:#7A7A7A;line-height:1.6;">
          Projetada para evocar escultura romana em pedra. Usada exclusivamente para headings, nome da marca, títulos de seção e CTAs de alta autoridade.
        </p>
        <div style="margin-top:16px;padding-top:16px;border-top:1px solid #253D66;">
          <div style="font-family:'Montserrat',sans-serif;font-size:11px;color:#7A7A7A;margin-bottom:6px;">Pesos</div>
          <div style="display:flex;gap:12px;flex-wrap:wrap;">
            <span style="font-family:'Cinzel',serif;font-size:14px;font-weight:400;color:#FFFFFF;">Regular 400</span>
            <span style="font-family:'Cinzel',serif;font-size:14px;font-weight:600;color:#FFFFFF;">SemiBold 600</span>
            <span style="font-family:'Cinzel',serif;font-size:14px;font-weight:700;color:#FFFFFF;">Bold 700</span>
          </div>
        </div>
      </div>

      <!-- Montserrat -->
      <div class="card" data-reveal-stagger style="--stagger: 1">
        <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#C49738;margin-bottom:16px;">Body / UI</div>
        <div style="font-family:'Montserrat',sans-serif;font-size:48px;font-weight:700;color:#FFFFFF;line-height:1;margin-bottom:16px;">Montserrat</div>
        <div style="font-family:'Montserrat',sans-serif;font-size:16px;color:#BBBBBB;margin-bottom:16px;">Aa Bb Cc Dd Ee Ff Gg Hh Ii Jj</div>
        <div style="font-family:'Montserrat',sans-serif;font-size:16px;color:#BBBBBB;margin-bottom:16px;">0123456789 !@#$%&amp;*()</div>
        <p style="font-family:'Montserrat',sans-serif;font-size:13px;color:#7A7A7A;line-height:1.6;">
          Fonte geométrica sans-serif. O cavalo de batalha do sistema. Usada para todo o corpo de texto, labels de UI, navegação, legendas e formulários.
        </p>
        <div style="margin-top:16px;padding-top:16px;border-top:1px solid #253D66;">
          <div style="font-family:'Montserrat',sans-serif;font-size:11px;color:#7A7A7A;margin-bottom:6px;">Pesos</div>
          <div style="display:flex;gap:12px;flex-wrap:wrap;">
            <span style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:300;color:#BBBBBB;">Light 300</span>
            <span style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:400;color:#BBBBBB;">Regular 400</span>
            <span style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:500;color:#BBBBBB;">Medium 500</span>
            <span style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600;color:#FFFFFF;">SemiBold 600</span>
            <span style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:700;color:#FFFFFF;">Bold 700</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Type Scale -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">Escala Tipográfica</h2>
    <div style="margin-bottom:8px;"></div>
    <p style="font-family:'Montserrat',sans-serif;font-size:14px;color:#BBBBBB;line-height:1.7;margin-bottom:24px;">
      Base: 16px (1rem). Fator de escala: 1.25 (Major Third).
    </p>
    <table class="brand-table">
      <thead>
        <tr>
          <th>Nome</th>
          <th>px</th>
          <th>rem</th>
          <th>Uso típico</th>
          <th>Specimen</th>
        </tr>
      </thead>
      <tbody>
        {typeScale.map(t => (
          <tr>
            <td><code>{t.name}</code></td>
            <td style="color:#FFFFFF;font-weight:500;">{t.px}</td>
            <td style="color:#7A7A7A;">{t.rem}</td>
            <td>{t.usage}</td>
            <td style={`font-family:'Cinzel',serif;font-size:${t.px};color:#FFFFFF;line-height:1.2;`}>Aa</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <!-- Live Specimens -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">Pares Recomendados — Specimens ao Vivo</h2>
    <div style="margin-bottom:24px;"></div>

    <div style="display:flex;flex-direction:column;gap:12px;">
      {pairings.map(p => (
        <div style="background:#132140;border:1px solid #253D66;border-radius:10px;padding:20px;display:grid;grid-template-columns:180px 1fr;gap:24px;align-items:center;">
          <div>
            <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;color:#C49738;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:4px;">{p.role}</div>
            <div style="font-family:'Montserrat',sans-serif;font-size:11px;color:#7A7A7A;margin-bottom:2px;">{p.font} {p.weight}</div>
            <div style="font-family:'JetBrains Mono','Courier New',monospace;font-size:10px;color:#3A5585;">{p.size}</div>
          </div>
          <div style={`font-family:${p.font === 'Cinzel' ? "'Cinzel',serif" : "'Montserrat',sans-serif"};font-size:${p.role.includes('Hero') ? '36px' : p.role.includes('Page H1') ? '28px' : p.role.includes('Section H2') ? '24px' : p.role.includes('Subsection') ? '20px' : p.role.includes('Card') ? '18px' : p.role.includes('Tagline') ? '14px' : p.role.includes('Body') ? '16px' : p.role.includes('Nav') ? '14px' : '12px'};font-weight:${p.weight};color:${p.sampleColor};letter-spacing:${p.spacing};line-height:1.3;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;`}>
            {p.sample}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Usage rules -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">Regras de Uso</h2>
    <div style="margin-bottom:20px;"></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
      <div>
        <div style="font-family:'Montserrat',sans-serif;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#C49738;margin-bottom:12px;">Cinzel — usar para</div>
        <ul class="prose-list">
          <li>Todos os headings (H1, H2, H3)</li>
          <li>Nome da marca ZNITH</li>
          <li>Títulos de seção</li>
          <li>CTAs de alta autoridade</li>
          <li>Tagline "Direção. Consciência. Legado."</li>
        </ul>
      </div>
      <div>
        <div style="font-family:'Montserrat',sans-serif;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#C49738;margin-bottom:12px;">Cinzel — não usar para</div>
        <ul class="prose-list" style="opacity:0.7;">
          <li>Corpo de texto longo</li>
          <li>Labels de UI em tamanhos pequenos</li>
          <li>Parágrafos e descrições</li>
          <li>Navigation items</li>
          <li>Elementos de formulário</li>
        </ul>
      </div>
    </div>
  </section>
</Layout>
