---
import Layout from '../layouts/Layout.astro';
const currentPath = '/produto';

const phases = [
  {
    num: '01',
    title: 'Diagnóstico e Direção Estratégica',
    desc: 'Leitura profunda da operação comercial atual: funil, processo de vendas, atendimento, follow-up, CRM, equipe, rotina, marketing e gargalos de conversão. Identificamos onde a receita está travando, quais perdas são estruturais e quais mudanças precisam acontecer primeiro. O cliente para de operar no escuro.',
    deliverable: 'Diagnóstico estratégico da operação comercial',
  },
  {
    num: '02',
    title: 'Arquitetura Comercial',
    desc: 'Desenho da nova estrutura comercial: etapas do funil, responsabilidades, critérios de qualificação, cadências, lógica de CRM, playbooks, fluxos de atendimento, rotina de gestão e oportunidades de automação com IA. O crescimento deixa de ser improvisado e começa a ganhar forma de sistema.',
    deliverable: 'Arquitetura do funil + mapa de gargalos',
  },
  {
    num: '03',
    title: 'Implantação e Organização Operacional',
    desc: 'Implementação da estrutura definida: organização do CRM, padronização do processo, criação de playbooks, configuração de rotinas, estruturação de cadências, ajustes na jornada comercial e ativação dos elementos de inteligência e automação previstos no escopo.',
    deliverable: 'CRM organizado + playbooks + cadências + automações',
  },
  {
    num: '04',
    title: 'Acompanhamento, Ajustes e Otimização',
    desc: 'Acompanhamento da execução, leitura dos primeiros resultados, correção de falhas, ajustes finos no processo, reforço de aderência da equipe e amadurecimento da operação. Essa fase garante que o projeto não morra na teoria.',
    deliverable: 'Relatórios de execução + ajustes finos',
  },
  {
    num: '05',
    title: 'Governança e Escala',
    desc: 'Com a base implantada, a empresa passa a operar com mais previsibilidade, clareza e controle. A lógica é otimizar indicadores, fortalecer a governança comercial e preparar a operação para escalar sem ampliar o caos.',
    deliverable: 'Governança comercial + plano de escala',
  },
];

const alternatives = [
  { alt: 'Consultoria tradicional', delivers: 'Estratégia', missing: 'Implementação' },
  { alt: 'Implementador de CRM', delivers: 'Ferramenta', missing: 'Estratégia comercial' },
  { alt: 'Empresa de automação', delivers: 'Automação', missing: 'Processo e arquitetura' },
  { alt: 'Treinador de vendas', delivers: 'Performance individual', missing: 'Estrutura operacional' },
  { alt: 'Agência de marketing', delivers: 'Leads', missing: 'Operação para convertê-los' },
];
---

<Layout title="ZNITH.AI OS" currentPath={currentPath}>
  <div class="page-header">
    <span class="page-overline">Capítulo 7</span>
    <h1 class="page-title">ZNITH.AI OS</h1>
    <p class="page-subtitle">Produto flagship — Arquitetura de Crescimento Comercial com IA.</p>
    <span class="gold-line"></span>
  </div>

  <!-- Product Overview -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">7.1 O Produto</h2>
    <div style="margin-bottom:24px;"></div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:32px;">
      <div class="card" style="border-color:rgba(196,151,56,0.35);box-shadow:0 0 24px rgba(196,151,56,0.1);">
        <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#C49738;margin-bottom:8px;">Nome</div>
        <div style="font-family:'Cinzel',serif;font-size:22px;color:#FFFFFF;margin-bottom:4px;">ZNITH.AI OS</div>
        <div style="font-family:'Montserrat',sans-serif;font-size:13px;color:#7A7A7A;">Arquitetura de Crescimento Comercial com IA</div>
      </div>
      <div class="card">
        <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#C49738;margin-bottom:8px;">Modelo</div>
        <p style="font-family:'Montserrat',sans-serif;font-size:13px;color:#BBBBBB;line-height:1.6;">Híbrido — diagnóstico estratégico + desenho da arquitetura comercial + implantação de processos/CRM/playbooks/automações + acompanhamento recorrente</p>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:40px;">
      <div style="background:#132140;border:1px solid #253D66;border-radius:10px;padding:20px;text-align:center;">
        <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#7A7A7A;margin-bottom:8px;">Setup</div>
        <div style="font-family:'Cinzel',serif;font-size:28px;color:#C49738;">R$50K – R$150K</div>
      </div>
      <div style="background:#132140;border:1px solid #253D66;border-radius:10px;padding:20px;text-align:center;">
        <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#7A7A7A;margin-bottom:8px;">Recorrência mensal</div>
        <div style="font-family:'Cinzel',serif;font-size:28px;color:#C49738;">R$5K – R$15K</div>
      </div>
    </div>

    <blockquote class="brand-blockquote">
      "Transformar uma operação comercial desorganizada em um sistema de crescimento mais previsível, estruturado e escalável com estratégia, processo e inteligência artificial."
    </blockquote>
  </section>

  <!-- 5 Phases -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">7.2 As 5 Fases</h2>
    <div style="margin-bottom:8px;"></div>
    <p style="font-family:'Montserrat',sans-serif;font-size:14px;color:#BBBBBB;line-height:1.7;margin-bottom:32px;">
      O ZNITH.AI OS é organizado em fases claras e sequenciais. Não é possível pular etapas. Cada fase tem propósito e entregáveis específicos.
    </p>

    <div style="display:flex;flex-direction:column;gap:0;">
      {phases.map((phase, i) => (
        <div class="phase-block" data-reveal-stagger style={`display:flex;gap:0;--stagger:${i};`}>
          <!-- Timeline line -->
          <div style="display:flex;flex-direction:column;align-items:center;width:60px;flex-shrink:0;">
            <div class="phase-node" style="width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,#C49738,#EDD297);display:flex;align-items:center;justify-content:center;flex-shrink:0;z-index:1;position:relative;">
              <span style="font-family:'Cinzel',serif;font-size:13px;font-weight:700;color:#000;">{phase.num}</span>
            </div>
            {i < phases.length - 1 && (
              <div style="width:2px;flex:1;min-height:16px;background:linear-gradient(to bottom,#C49738,rgba(196,151,56,0.2));margin:4px 0;"></div>
            )}
          </div>
          <!-- Content -->
          <div style={`flex:1;padding-left:20px;padding-bottom:${i < phases.length - 1 ? '24px' : '0'};`}>
            <h3 style="font-family:'Cinzel',serif;font-size:17px;font-weight:400;color:#FFFFFF;margin-bottom:8px;">{phase.title}</h3>
            <p style="font-family:'Montserrat',sans-serif;font-size:14px;color:#BBBBBB;line-height:1.7;margin-bottom:10px;">{phase.desc}</p>
            <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(196,151,56,0.08);border:1px solid rgba(196,151,56,0.25);border-radius:6px;padding:6px 12px;">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6L5 9L10 3" stroke="#C49738" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span style="font-family:'Montserrat',sans-serif;font-size:12px;color:#C49738;">{phase.deliverable}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ICP -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">7.3 ICP do Produto</h2>
    <div style="margin-bottom:20px;"></div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
      <div>
        <div style="font-family:'Montserrat',sans-serif;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#C49738;margin-bottom:12px;">Para quem é</div>
        <ul class="prose-list">
          <li>Empresa B2B de serviços ou venda consultiva</li>
          <li>Faturamento entre R$1M e R$50M/ano</li>
          <li>Time comercial existente (SDR, vendedores, atendimento)</li>
          <li>Já vende, mas opera com desorganização comercial</li>
          <li>Leads perdidos, follow-up inconsistente, CRM mal utilizado</li>
          <li>Dependência excessiva do dono para fechar negócios</li>
        </ul>
      </div>
      <div>
        <div style="font-family:'Montserrat',sans-serif;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#7A7A7A;margin-bottom:12px;">Para quem NÃO é</div>
        <ul class="prose-list" style="opacity:0.7;">
          <li>Empresas começando do zero sem oferta validada</li>
          <li>Quem quer apenas automação sem revisar processo</li>
          <li>Empresas sem equipe mínima ou disponibilidade</li>
          <li>Negócios que querem resultado sem envolvimento da liderança</li>
          <li>Quem está comparando com freelancer operacional</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Differentiation -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">7.5 Diferencial Competitivo</h2>
    <div style="margin-bottom:16px;"></div>
    <p style="font-family:'Montserrat',sans-serif;font-size:14px;color:#BBBBBB;line-height:1.7;margin-bottom:24px;">
      Enquanto o mercado entrega pedaços, o ZNITH.AI OS combina tudo em uma entrega integrada.
    </p>
    <table class="brand-table">
      <thead>
        <tr>
          <th>Alternativa</th>
          <th>O que entrega</th>
          <th>O que falta</th>
        </tr>
      </thead>
      <tbody>
        {alternatives.map(a => (
          <tr>
            <td style="color:#FFFFFF;font-weight:500;">{a.alt}</td>
            <td style="color:#3A8A60;">{a.delivers}</td>
            <td style="color:#A03A3A;">{a.missing}</td>
          </tr>
        ))}
        <tr class="znith-row" style="border-top:1px solid rgba(196,151,56,0.3);">
          <td style="color:#C49738;font-weight:600;font-family:'Cinzel',serif;">ZNITH.AI OS</td>
          <td style="color:#C49738;" colspan="2">Diagnóstico + Arquitetura + Implantação + Playbooks + Governança + IA aplicada com critério</td>
        </tr>
      </tbody>
    </table>
  </section>

  <!-- Positioning -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">7.6 Posicionamento Visual</h2>
    <div style="margin-bottom:16px;"></div>
    <p style="font-family:'Montserrat',sans-serif;font-size:15px;color:#BBBBBB;line-height:1.7;margin-bottom:20px;">
      Premium, tech, exclusivo, corporativo. Referências: Apple, Stripe, Linear, Vercel, Porsche, McKinsey. O produto deve parecer uma <strong style="color:#FFFFFF;">infraestrutura premium de crescimento</strong>, não uma solução tática de curto prazo.
    </p>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
      <div style="background:rgba(42,107,74,0.08);border:1px solid rgba(42,107,74,0.3);border-radius:8px;padding:16px;">
        <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#3A8A60;margin-bottom:8px;">Deve parecer</div>
        <ul class="prose-list">
          <li>Uma infraestrutura premium de crescimento</li>
          <li>Sistema robusto com fases claras</li>
          <li>Investimento estratégico de longo prazo</li>
        </ul>
      </div>
      <div style="background:rgba(122,42,42,0.08);border:1px solid rgba(122,42,42,0.3);border-radius:8px;padding:16px;">
        <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#A03A3A;margin-bottom:8px;">Não deve parecer</div>
        <ul class="prose-list" style="opacity:0.8;">
          <li>Software barato ou ferramenta simples</li>
          <li>Mentoria subjetiva sem estrutura</li>
          <li>Consultoria tradicional sem execução</li>
        </ul>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* =========================================
     COMPONENT: Produto Page VFX — Timeline + Reveal
     TRIGGER: scroll (IntersectionObserver)
     TIMING: 500ms ease-out (reveals), 800ms radar ping
     TIERS: all tiers (CSS-only effects)
     prefers-reduced-motion: instant visibility, no radar ping
     ========================================= */

  /* Phase node radar ping on reveal */
  .phase-node.revealed::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 2px solid rgba(196, 151, 56, 0.4);
    animation: radar-ping 800ms ease-out forwards;
    pointer-events: none;
  }

  @keyframes radar-ping {
    0% { transform: translate(-50%, -50%) scale(1); opacity: 0.6; }
    100% { transform: translate(-50%, -50%) scale(2); opacity: 0; }
  }

  /* ZNITH.AI OS row glow in comparison table */
  .znith-row {
    background: rgba(196, 151, 56, 0.06);
    box-shadow: 0 0 20px rgba(196, 151, 56, 0.08);
  }

  /* Scroll reveal system */
  [data-reveal] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 500ms ease-out, transform 500ms ease-out;
  }

  [data-reveal].revealed {
    opacity: 1;
    transform: translateY(0);
  }

  [data-reveal-stagger] {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 400ms ease-out, transform 400ms ease-out;
    transition-delay: calc(var(--stagger, 0) * 80ms);
  }

  [data-reveal].revealed [data-reveal-stagger] {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal],
    [data-reveal-stagger] {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .phase-node.revealed::after {
      display: none;
    }
  }
</style>

<script>
  // Scroll reveal via Intersection Observer
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('[data-reveal]').forEach(el => revealObserver.observe(el));

  // Phase node radar ping on scroll
  const phaseNodes = document.querySelectorAll('.phase-node');
  const nodeObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
        nodeObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.5 });

  phaseNodes.forEach(n => nodeObserver.observe(n));
</script>
