---
import Layout from '../layouts/Layout.astro';
const currentPath = '/personal';

const contentPillars = [
  {
    num: '01',
    title: 'Inteligência Artificial aplicada à expansão comercial',
    desc: 'IA não como curiosidade técnica, mas como alavanca de receita, produtividade, previsibilidade e escala. Como usar IA para estruturar atendimento, qualificação, follow-up, CRM, playbooks, automações e tomada de decisão.',
  },
  {
    num: '02',
    title: 'Estrutura comercial, vendas e operação previsível',
    desc: 'Território central. Funil, processo comercial, organização de atendimento, gestão de pipeline, cadência, follow-up, RevOps, CRM e arquitetura de crescimento.',
  },
  {
    num: '03',
    title: 'Liderança, cultura e maturidade empresarial',
    desc: 'Liderança real, não performática. Sustentar direção em meio ao caos, organizar pessoas, alinhar cultura, tomar decisões difíceis, criar ambientes onde resultado e verdade coexistam.',
  },
  {
    num: '04',
    title: 'Inteligência emocional aplicada a vendas e negócios',
    desc: 'Grande parte dos gargalos de uma empresa não são técnicos — são emocionais, relacionais e comportamentais. Mentalidade, sabotagens, comunicação, maturidade, coragem comercial.',
  },
  {
    num: '05',
    title: 'Fé, propósito e legado na construção de negócios',
    desc: 'Pilar fundacional, não decorativo. Construir empresa sem perder alma, crescer sem negociar essência, liderar com temor a Deus, usar a inteligência a serviço de algo maior do que lucro.',
  },
];

const channels = [
  { channel: 'LinkedIn', tone: 'Estratégico, profundo, confrontador com cuidado', content: 'Artigos longos, posts de posicionamento, cases' },
  { channel: 'Vídeo (YouTube/Instagram)', tone: 'Direto, didático, com presença forte', content: 'Aulas, análises, comentários de mercado' },
  { channel: 'Podcast', tone: 'Conversacional, profundo, estruturado', content: 'Entrevistas, reflexões, estratégia aplicada' },
  { channel: 'Palestras', tone: 'Autoridade máxima, provocativo, transformador', content: 'Conteúdo de alto impacto em eventos' },
  { channel: 'Twitter/X', tone: 'Direto, conciso, assertivo', content: 'Insights curtos, posicionamentos, reflexões' },
  { channel: 'Cursos', tone: 'Técnico-estratégico, pedagógico', content: 'Conteúdo estruturado com aplicação prática' },
];
---

<Layout title="Leilaine Campioto" currentPath={currentPath}>
  <div class="page-header">
    <span class="page-overline">Capítulo 6</span>
    <h1 class="page-title">Leilaine Campioto</h1>
    <p class="page-subtitle">Fundadora e CEO da ZNITH. Marca pessoal, arquétipos, pilares de conteúdo e direção visual.</p>
    <span class="gold-line"></span>
  </div>

  <!-- Profile -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">6.1 Perfil</h2>
    <div style="margin-bottom:24px;"></div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:32px;">
      <div class="card" data-reveal-stagger style="--stagger: 0">
        <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#C49738;margin-bottom:16px;">Dados Essenciais</div>
        <table style="width:100%;border-collapse:collapse;">
          {[
            { label: 'Nome', value: 'Leilaine Campioto Messias' },
            { label: 'Cargo', value: 'CEO / Fundadora — ZNITH' },
            { label: '3 Palavras', value: 'Estratégica · Profunda · Construtora' },
            { label: 'LinkedIn', value: 'linkedin.com/in/znith-ai/' },
            { label: 'Instagram', value: '@campioto.leilaine' },
          ].map(row => (
            <tr>
              <td style="font-family:'Montserrat',sans-serif;font-size:12px;font-weight:600;color:#7A7A7A;padding:6px 0;white-space:nowrap;padding-right:16px;">{row.label}</td>
              <td style="font-family:'Montserrat',sans-serif;font-size:13px;color:#BBBBBB;padding:6px 0;">{row.value}</td>
            </tr>
          ))}
        </table>
      </div>

      <div class="card" data-reveal-stagger style="--stagger: 1">
        <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#C49738;margin-bottom:16px;">Arquétipos</div>
        <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:20px;">
          {['Mentor', 'Visionário', 'Estrategista', 'Autoridade'].map(a => (
            <span style="font-family:'Cinzel',serif;font-size:14px;color:#FFFFFF;padding:8px 14px;background:#1A2D52;border:1px solid #253D66;border-radius:6px;">{a}</span>
          ))}
        </div>
        <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#7A7A7A;margin-bottom:8px;">Números de autoridade</div>
        <ul class="prose-list">
          <li>20+ anos em vendas e gestão comercial</li>
          <li>R$500M+ em participação em vendas (direta e indireta)</li>
          <li>Contribuição para crescimento de R$20M → R$80M/ano</li>
          <li>15+ anos liderando equipes comerciais</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- História -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">6.2 História e Narrativa</h2>
    <div style="margin-bottom:24px;"></div>

    <p style="font-family:'Montserrat',sans-serif;font-size:15px;color:#BBBBBB;line-height:1.7;margin-bottom:20px;">
      A trajetória de Leilaine não nasceu de uma linha reta. Nasceu de dor, reconstrução, fé e trabalho.
    </p>
    <p style="font-family:'Montserrat',sans-serif;font-size:15px;color:#BBBBBB;line-height:1.7;margin-bottom:20px;">
      Ao longo de mais de vinte anos, ela atuou diretamente com vendas, liderança comercial, treinamento de equipes e expansão de negócios. Viveu o comercial na prática, no campo, na pressão, na meta, no caos e também na reconstrução.
    </p>

    <div style="background:#132140;border:1px solid rgba(196,151,56,0.3);border-radius:10px;padding:24px;margin-bottom:24px;">
      <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#C49738;margin-bottom:12px;">O Momento de Virada</div>
      <p style="font-family:'Montserrat',sans-serif;font-size:15px;color:#BBBBBB;line-height:1.7;">
        Em 2018, Leilaine enfrentou um dos períodos mais duros da sua vida — uma quebra financeira profunda, com mais de um milhão em dívidas e dezenas de processos. Foi nesse lugar de dor que uma aliança foi firmada: se fosse levantada, ninguém passaria por sua vida sem ouvir de algo maior do que ela. A partir dali, a carreira deixou de ser sobre performance. Passou a ser sobre propósito.
      </p>
    </div>

    <blockquote class="brand-blockquote" style="margin-bottom:24px;">
      "Eu consigo olhar para uma empresa e não ver apenas um funil quebrado, um CRM mal usado ou um atendimento desorganizado. Eu enxergo a estrutura invisível por trás do problema: a mentalidade do líder, a maturidade da operação, os gargalos de comunicação..."
    </blockquote>

    <p style="font-family:'Montserrat',sans-serif;font-size:15px;color:#BBBBBB;line-height:1.7;">
      O diferencial de Leilaine não é falar de crescimento a partir de teoria isolada. É falar a partir de travessia, prática, reconstrução e operação real. O mercado normalmente separa as dimensões que ela une: vendas, alma, propósito, IA, liderança e legado.
    </p>
  </section>

  <!-- Content Pillars -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">6.3 Pilares de Conteúdo</h2>
    <div style="margin-bottom:24px;"></div>

    <div style="display:flex;flex-direction:column;gap:12px;">
      {contentPillars.map(p => (
        <div style="display:flex;gap:20px;padding:20px;background:#132140;border:1px solid #253D66;border-radius:10px;align-items:flex-start;">
          <div style="font-family:'Cinzel',serif;font-size:24px;font-weight:400;color:#253D66;min-width:36px;line-height:1;">{p.num}</div>
          <div>
            <h4 style="font-family:'Cinzel',serif;font-size:15px;font-weight:400;color:#FFFFFF;margin-bottom:8px;">{p.title}</h4>
            <p style="font-family:'Montserrat',sans-serif;font-size:13px;color:#BBBBBB;line-height:1.6;">{p.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Visual Direction -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">6.4 Direção Visual Pessoal</h2>
    <div style="margin-bottom:20px;"></div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:24px;">
      <div class="card" data-reveal-stagger style="--stagger: 0">
        <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#D4A84C;margin-bottom:12px;">Conceito</div>
        <p style="font-family:'Montserrat',sans-serif;font-size:14px;color:#BBBBBB;line-height:1.6;">Executiva contemporânea, feminina, sóbria e premium, com presença de quem pensa grande e não precisa performar excesso para ser notada.</p>
      </div>
      <div class="card" data-reveal-stagger style="--stagger: 1">
        <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#D4A84C;margin-bottom:12px;">Paleta pessoal</div>
        <div style="display:flex;gap:8px;margin-bottom:12px;">
          {['#000000','#333333','#FFFFFF','#F5F5F0','#0E1A32','#D4A84C'].map(c => (
            <div style={`width:32px;height:32px;border-radius:6px;background:${c};border:1px solid #253D66;`} title={c}></div>
          ))}
        </div>
        <p style="font-family:'Montserrat',sans-serif;font-size:12px;color:#7A7A7A;">Preto, grafite, branco, off-white, navy. Acentos metálicos sutis — dourado queimado, champagne, prata fria.</p>
      </div>
    </div>

    <div class="card">
      <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#D4A84C;margin-bottom:12px;">Referências de marca visual</div>
      <div style="display:flex;flex-wrap:wrap;gap:10px;">
        {['Apple — clareza e refinamento','Stripe — elegância estratégica','Porsche — sofisticação e força silenciosa','Linear/Vercel — estética tecnológica limpa'].map(ref => (
          <span style="font-family:'Montserrat',sans-serif;font-size:13px;color:#BBBBBB;padding:8px 14px;background:#1A2D52;border:1px solid #253D66;border-radius:6px;">{ref}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Channels -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">6.5 Canais e Presença</h2>
    <div style="margin-bottom:20px;"></div>
    <table class="brand-table">
      <thead>
        <tr>
          <th>Canal</th>
          <th>Tom Principal</th>
          <th>Tipo de Conteúdo</th>
        </tr>
      </thead>
      <tbody>
        {channels.map(c => (
          <tr>
            <td style="color:#FFFFFF;font-weight:500;">{c.channel}</td>
            <td>{c.tone}</td>
            <td style="color:#BBBBBB;">{c.content}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
</Layout>
