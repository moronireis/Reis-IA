---
import Layout from '../layouts/Layout.astro';
const currentPath = '/identidade';

const logoVariants = [
  {
    file: '/logos/ZINITH_oficial_png.png',
    name: 'Logo Principal — Vertical com Tagline',
    desc: 'Aplicação principal, primeira impressão, hero de website',
    bg: '#060E1F',
    label: 'Dark background',
  },
  {
    file: '/logos/ZINITH_oficial_png - sem frase.png',
    name: 'Logo Vertical — Sem Tagline',
    desc: 'Headers, aplicações recorrentes, segunda ocorrência em documento',
    bg: '#132140',
    label: 'Surface background',
  },
  {
    file: '/logos/ZINITH_horizontal_png.png',
    name: 'Logo Horizontal',
    desc: 'Email, documentos, slides de apresentação, banners horizontais',
    bg: '#060E1F',
    label: 'Dark background',
  },
  {
    file: '/logos/ZINITH-fundoescuro1.png',
    name: 'Variante Escura 1',
    desc: 'Layout horizontal alternativo com leão menor',
    bg: '#060E1F',
    label: 'Dark background',
  },
  {
    file: '/logos/ZINITH-fundoescuro2.png',
    name: 'Variante Escura 2',
    desc: 'Leão centralizado com tagline abaixo',
    bg: '#060E1F',
    label: 'Dark background',
  },
];

const symbolVariants = [
  {
    file: '/logos/Z-3.png',
    name: 'Z-3 — Dark Mode',
    desc: 'Versão preferida para digital dark mode. Favicon, avatar, ícone de app.',
    bg: '#060E1F',
  },
  {
    file: '/logos/Z-2.png',
    name: 'Z-2 — Contorno Dourado',
    desc: 'Fundo claro com contorno dourado. Selos, badges, contextos de alto contraste claro.',
    bg: '#FFFFFF',
  },
  {
    file: '/logos/Z.png',
    name: 'Z — Versão Clean',
    desc: 'Fundo branco, sem contorno. Fundos claros, watermarks em documentos claros.',
    bg: '#FFFFFF',
  },
];

const incorrectRules = [
  'Não distorcer ou esticar — manter sempre o aspect ratio',
  'Não usar cores fora da paleta — apenas navy, branco e dourado',
  'Não adicionar efeitos — sem sombra, brilho, gradiente, emboss ou extrusão 3D',
  'Não colocar sobre fundos sem contraste suficiente',
  'Não rotacionar — sempre a 0° de rotação',
  'Não separar o leão do wordmark como logo principal',
  'Não usar versões de baixa resolução — para A2+, usar arquivos vetoriais',
  'Não modificar a coroa — é parte da ilustração',
  'Não alterar a tipografia do wordmark — sempre Cinzel',
  'Não adicionar texto dentro da área de proteção',
];
---

<Layout title="Identidade Visual" currentPath={currentPath}>
  <div class="page-header">
    <span class="page-overline">Capítulo 3</span>
    <h1 class="page-title">Identidade Visual</h1>
    <p class="page-subtitle">Logo system, variantes, área de proteção e regras de uso.</p>
    <span class="gold-line"></span>
  </div>

  <!-- Logo Principal -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">3.1 Logo System</h2>
    <div style="margin-bottom:8px;"></div>
    <p style="font-family:'Montserrat',sans-serif;font-size:15px;color:#BBBBBB;line-height:1.7;margin-bottom:32px;">
      O logo ZNITH completo é composto por três elementos em composição stacked: o Símbolo (leão com coroa dourada), o Wordmark ("ZNITH" em Cinzel) e a Tagline ("DIREÇÃO. CONSCIÊNCIA. LEGADO." em Montserrat uppercase). O ponto após cada palavra da tagline é intencional — cria ritmo e finalidade. Nunca remover.
    </p>

    <h3 class="section-h3">Versões de Layout</h3>
    <div style="margin-bottom:20px;"></div>

    <div style="display:flex;flex-direction:column;gap:16px;margin-bottom:48px;">
      {logoVariants.map((logo, i) => (
        <div class="card logo-card" data-reveal-stagger style={`--stagger:${i};`}>
          <div style="display:grid;grid-template-columns:1fr 2fr;gap:24px;align-items:center;">
            <div class="logo-showcase" style={`background:${logo.bg};border-radius:8px;padding:24px;display:flex;align-items:center;justify-content:center;min-height:140px;border:1px solid #253D66;`}>
              <img src={logo.file} alt={logo.name} class="logo-img" style="max-width:100%;max-height:120px;object-fit:contain;" />
            </div>
            <div>
              <div style="font-family:'Cinzel',serif;font-size:16px;color:#FFFFFF;margin-bottom:6px;">{logo.name}</div>
              <div style="font-family:'Montserrat',sans-serif;font-size:13px;color:#BBBBBB;line-height:1.6;margin-bottom:12px;">{logo.desc}</div>
              <span class="badge badge-navy">{logo.label}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Símbolo Reduzido -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">Símbolo — Reduced Mark</h2>
    <div style="margin-bottom:8px;"></div>
    <p style="font-family:'Montserrat',sans-serif;font-size:15px;color:#BBBBBB;line-height:1.7;margin-bottom:24px;">
      O símbolo reduzido é a letra "Z" em tratamento serif com o rosto do leão integrado à forma da letra. Funciona como ícone da marca — usado onde o logo completo seria grande ou complexo demais para o contexto.
    </p>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:40px;">
      {symbolVariants.map((sym, i) => (
        <div class="card logo-card" data-reveal-stagger style={`text-align:center;--stagger:${i};`}>
          <div class="logo-showcase" style={`background:${sym.bg};border-radius:8px;padding:24px;margin-bottom:16px;display:flex;align-items:center;justify-content:center;min-height:100px;border:1px solid #253D66;`}>
            <img src={sym.file} alt={sym.name} class="logo-img" style="max-height:80px;max-width:80px;object-fit:contain;" />
          </div>
          <div style="font-family:'Cinzel',serif;font-size:14px;color:#FFFFFF;margin-bottom:8px;">{sym.name}</div>
          <div style="font-family:'Montserrat',sans-serif;font-size:12px;color:#7A7A7A;line-height:1.5;">{sym.desc}</div>
        </div>
      ))}
    </div>

    <h3 class="section-h3" style="margin-bottom:16px;">Tamanhos Mínimos para Legibilidade</h3>
    <table class="brand-table">
      <thead>
        <tr>
          <th>Elemento</th>
          <th>Contexto</th>
          <th>Tamanho Mínimo</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td style="color:#FFFFFF;">Logo Principal</td>
          <td>Digital</td>
          <td>160px de largura</td>
        </tr>
        <tr>
          <td style="color:#FFFFFF;">Logo Principal</td>
          <td>Impresso</td>
          <td>40mm de largura</td>
        </tr>
        <tr>
          <td style="color:#FFFFFF;">Wordmark isolado</td>
          <td>Digital</td>
          <td>80px de largura</td>
        </tr>
        <tr>
          <td style="color:#FFFFFF;">Wordmark isolado</td>
          <td>Impresso</td>
          <td>25mm de largura</td>
        </tr>
        <tr>
          <td style="color:#FFFFFF;">Símbolo Z</td>
          <td>Digital — favicon</td>
          <td>32 x 32px</td>
        </tr>
        <tr>
          <td style="color:#FFFFFF;">Símbolo Z</td>
          <td>Digital — interface</td>
          <td>48 x 48px</td>
        </tr>
        <tr>
          <td style="color:#FFFFFF;">Símbolo Z</td>
          <td>Impresso</td>
          <td>12mm x 12mm</td>
        </tr>
      </tbody>
    </table>
  </section>

  <!-- Área de Proteção -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">Área de Proteção (Clear Space)</h2>
    <div style="margin-bottom:16px;"></div>
    <p style="font-family:'Montserrat',sans-serif;font-size:15px;color:#BBBBBB;line-height:1.7;margin-bottom:24px;">
      A unidade de medida é <strong style="color:#FFFFFF;">a cap-height da letra "Z" no wordmark ZNITH</strong> em qualquer escala de reprodução (referida como "1x"). Nenhum elemento gráfico, texto, imagem ou borda pode entrar nessa zona. Mínimo de 1x em todos os quatro lados do bounding box do logo.
    </p>
    <div style="background:#132140;border:1px solid #253D66;border-radius:10px;padding:24px;font-family:'JetBrains Mono','Courier New',monospace;font-size:13px;color:#BBBBBB;line-height:1.8;">
      <div style="color:#C49738;margin-bottom:4px;">/* Logo Vertical (Stacked) */</div>
      <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;1x</div>
      <div>&nbsp;&nbsp;&nbsp;&nbsp;┌─────────────┐</div>
      <div>&nbsp;1x │&nbsp;&nbsp;[SYMBOL]&nbsp;&nbsp;&nbsp;│ 1x</div>
      <div>&nbsp;&nbsp;&nbsp;&nbsp;│&nbsp;&nbsp;&nbsp;ZNITH&nbsp;&nbsp;&nbsp;&nbsp;│</div>
      <div>&nbsp;&nbsp;&nbsp;&nbsp;│&nbsp;[tagline]&nbsp;&nbsp;│</div>
      <div>&nbsp;1x │&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;│</div>
      <div>&nbsp;&nbsp;&nbsp;&nbsp;└─────────────┘</div>
      <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;1x</div>
    </div>
  </section>

  <!-- Fundos Permitidos -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">Fundos Permitidos</h2>
    <div style="margin-bottom:20px;"></div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px;margin-bottom:32px;">
      {[
        { bg: '#060E1F', label: 'Navy Escuro — Preferido', hex: '#060E1F', ok: true },
        { bg: '#132140', label: 'Navy Médio (Surface)', hex: '#132140', ok: true },
        { bg: '#000000', label: 'Preto Sólido', hex: '#000000', ok: true },
        { bg: '#FFFFFF', label: 'Branco — Com cuidado', hex: '#FFFFFF', ok: true, light: true },
      ].map((f, i) => (
        <div data-reveal-stagger style={`background:${f.bg};border-radius:10px;padding:16px;border:1px solid ${f.light ? '#E0E0E0' : '#253D66'};--stagger:${i};`}>
          <div style={`font-family:'Montserrat',sans-serif;font-size:12px;font-weight:600;color:${f.light ? '#060E1F' : '#BBBBBB'};margin-bottom:4px;`}>{f.label}</div>
          <div style={`font-family:'JetBrains Mono','Courier New',monospace;font-size:11px;color:${f.light ? '#3A5585' : '#7A7A7A'};`}>{f.hex}</div>
          <div style="margin-top:8px;display:inline-flex;align-items:center;gap:4px;">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6L5 9L10 3" stroke={f.light ? '#2A6B4A' : '#3A8A60'} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span style={`font-family:'Montserrat',sans-serif;font-size:11px;color:${f.light ? '#2A6B4A' : '#3A8A60'};`}>Permitido</span>
          </div>
        </div>
      ))}
    </div>

    <div style="background:rgba(122,42,42,0.1);border:1px solid rgba(122,42,42,0.3);border-radius:10px;padding:16px;margin-bottom:8px;">
      <div style="font-family:'Montserrat',sans-serif;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:#A03A3A;margin-bottom:8px;">Fundos Proibidos</div>
      <ul class="prose-list" style="color:#BBBBBB;">
        <li>Gradientes como fundo direto — o logo precisa de campo de cor estável</li>
        <li>Fotografias sem overlay mínimo de 60% de opacidade navy</li>
        <li>Padrões gráficos (incluindo os próprios grafismos ZNITH)</li>
        <li>Fundos em tons médios — nem o logo claro nem o escuro leem com clareza</li>
      </ul>
    </div>
  </section>

  <!-- Uso Incorreto -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">Uso Incorreto — O Que Nunca Fazer</h2>
    <div style="margin-bottom:20px;"></div>
    <div style="display:flex;flex-direction:column;gap:8px;">
      {incorrectRules.map((rule, i) => (
        <div data-reveal-stagger style={`display:flex;align-items:flex-start;gap:16px;padding:14px 16px;background:#132140;border-radius:8px;border:1px solid #253D66;--stagger:${i};`}>
          <div style="font-family:'Cinzel',serif;font-size:14px;color:#A03A3A;min-width:24px;font-weight:600;">{String(i + 1).padStart(2, '0')}</div>
          <div style="font-family:'Montserrat',sans-serif;font-size:14px;color:#BBBBBB;line-height:1.5;">{rule}</div>
        </div>
      ))}
    </div>
  </section>
</Layout>

<style>
  /* =========================================
     COMPONENT: Identidade Page — Gallery VFX
     TRIGGER: scroll (IntersectionObserver) + hover
     TIMING: 500ms ease-out (reveals), 250ms (hover transitions)
     TIERS: all tiers (CSS-only effects)
     prefers-reduced-motion: instant visibility, hover glow still works
     ========================================= */

  /* Logo card inner shadow and hover glow */
  .logo-card {
    box-shadow: inset 0 1px 0 rgba(196, 151, 56, 0.06), 0 1px 3px rgba(0, 0, 0, 0.15);
  }

  .logo-img {
    transition: filter 250ms ease-out;
  }

  .logo-card:hover .logo-img {
    filter: drop-shadow(0 0 20px rgba(196, 151, 56, 0.10));
  }

  /* Subtle grid pattern on logo showcase areas */
  .logo-showcase {
    background-image:
      linear-gradient(rgba(37, 61, 102, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(37, 61, 102, 0.03) 1px, transparent 1px);
    background-size: 8px 8px;
  }

  /* Scroll reveal system */
  [data-reveal] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 500ms ease-out, transform 500ms ease-out;
  }

  [data-reveal].revealed {
    opacity: 1;
    transform: translateY(0);
  }

  [data-reveal-stagger] {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 400ms ease-out, transform 400ms ease-out;
    transition-delay: calc(var(--stagger, 0) * 60ms);
  }

  [data-reveal].revealed [data-reveal-stagger] {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal],
    [data-reveal-stagger] {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  // Scroll reveal via Intersection Observer
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('[data-reveal]').forEach(el => revealObserver.observe(el));
</script>
