---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  currentPath?: string;
}

const { title, description = 'ZNITH Brandbook & Design System — Versao 2.0', currentPath = '/' } = Astro.props;

const navGroups = [
  {
    label: 'MARCA',
    items: [
      { href: '/marca', label: 'A Marca' },
      { href: '/arquitetura', label: 'Arquitetura' },
    ],
  },
  {
    label: 'IDENTIDADE',
    items: [
      { href: '/identidade', label: 'Visual' },
      { href: '/cores', label: 'Cores' },
      { href: '/tipografia', label: 'Tipografia' },
      { href: '/grafismos', label: 'Grafismos' },
    ],
  },
  {
    label: 'SISTEMA',
    items: [
      { href: '/componentes', label: 'Componentes' },
    ],
  },
  {
    label: 'MESSAGING',
    items: [
      { href: '/voz', label: 'Tom de Voz' },
    ],
  },
  {
    label: 'CAMADAS',
    items: [
      { href: '/personal', label: 'Leilaine Campioto' },
      { href: '/produto', label: 'ZNITH.AI OS' },
      { href: '/movimento', label: 'Lideres Leoes' },
    ],
  },
  {
    label: 'APLICACAO',
    items: [
      { href: '/aplicacoes', label: 'Aplicacoes' },
    ],
  },
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — ZNITH Brandbook</title>
    <link rel="icon" type="image/png" href="/logos/Z-3.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <!-- Mobile header -->
    <header class="mobile-header" style="display: none;">
      <a href="/" style="display:flex;align-items:center;gap:12px;">
        <img src="/logos/Z-3.png" alt="ZNITH" style="height:36px;width:36px;object-fit:contain;" />
        <span style="font-family:'Cinzel',serif;font-size:20px;color:#FFFFFF;letter-spacing:0.08em;">ZNITH</span>
      </a>
      <button id="menuBtn" aria-label="Menu" style="background:none;border:1px solid var(--color-navy-600);border-radius:6px;padding:8px 10px;cursor:pointer;color:var(--color-neutral-300);">
        <svg width="18" height="14" viewBox="0 0 18 14" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="18" height="2" fill="currentColor"/>
          <rect y="6" width="18" height="2" fill="currentColor"/>
          <rect y="12" width="18" height="2" fill="currentColor"/>
        </svg>
      </button>
    </header>

    <!-- Sidebar overlay for mobile -->
    <div id="sidebarOverlay" style="display:none;position:fixed;inset:0;background:rgba(3,8,16,0.85);z-index:299;"></div>

    <!-- Sidebar -->
    <nav id="sidebar" style="
      position: fixed;
      left: 0;
      top: 0;
      bottom: 0;
      width: 300px;
      background: var(--color-navy-950);
      box-shadow: 1px 0 0 rgba(37, 61, 102, 0.3);
      overflow-y: auto;
      z-index: 300;
      display: flex;
      flex-direction: column;
    ">
      <!-- Scroll Progress Bar -->
      <div class="scroll-progress-bar">
        <div class="scroll-progress-fill" id="scrollProgressFill"></div>
      </div>

      <!-- Logo area -->
      <div style="padding:28px 24px 24px;position:relative;">
        <a href="/" style="display:flex;align-items:center;gap:14px;text-decoration:none;">
          <img src="/logos/Z-3.png" alt="ZNITH" style="height:40px;width:40px;object-fit:contain;" />
          <div>
            <div style="font-family:'Cinzel',serif;font-size:18px;color:#FFFFFF;letter-spacing:0.1em;line-height:1;">ZNITH</div>
            <div style="font-family:'Montserrat',sans-serif;font-size:10px;color:var(--color-gold-400);letter-spacing:0.15em;text-transform:uppercase;margin-top:4px;">Brandbook v2.0</div>
          </div>
        </a>
        <!-- Gradient border -->
        <div style="position:absolute;bottom:0;left:24px;right:24px;height:1px;background:linear-gradient(90deg, transparent, rgba(196, 151, 56, 0.12), transparent);"></div>
      </div>

      <!-- Navigation -->
      <div style="padding:20px 0;flex:1;">
        {navGroups.map((group) => (
          <div style="margin-bottom:10px;">
            <div style="
              padding: 8px 24px;
              font-family: 'Montserrat', sans-serif;
              font-size: 11px;
              font-weight: 600;
              text-transform: uppercase;
              letter-spacing: 0.14em;
              color: var(--color-navy-400);
              margin-top: 8px;
            ">{group.label}</div>
            {group.items.map((item) => {
              const isActive = currentPath === item.href || (currentPath !== '/' && item.href !== '/' && currentPath.startsWith(item.href));
              return (
                <a
                  href={item.href}
                  class:list={['nav-link', { active: isActive }]}
                >
                  {item.label}
                </a>
              );
            })}
          </div>
        ))}
      </div>

      <!-- Footer -->
      <div style="padding:20px 24px;position:relative;">
        <div style="position:absolute;top:0;left:24px;right:24px;height:1px;background:linear-gradient(90deg, transparent, rgba(196, 151, 56, 0.12), transparent);"></div>
        <div class="sidebar-tagline" style="font-family:'Cinzel',serif;font-size:10px;color:var(--color-navy-400);letter-spacing:0.14em;text-align:center;">
          DIRECAO. CONSCIENCIA. LEGADO.
        </div>
      </div>
    </nav>

    <!-- Main content -->
    <main style="
      margin-left: 300px;
      min-height: 100vh;
      background: var(--color-navy-900);
    ">
      <div style="
        max-width: 840px;
        padding: 0 56px 96px;
        margin: 0 auto;
      " class="main-content">
        <slot />
      </div>
    </main>

    <style>
      @media (max-width: 767px) {
        .mobile-header {
          display: flex !important;
          align-items: center;
          justify-content: space-between;
          padding: 16px 20px;
          background: var(--color-navy-950);
          border-bottom: 1px solid rgba(37, 61, 102, 0.3);
          position: sticky;
          top: 0;
          z-index: 200;
        }
        #sidebar {
          transform: translateX(-100%);
          transition: transform 0.3s ease;
        }
        #sidebar.open {
          transform: translateX(0);
        }
        main {
          margin-left: 0 !important;
        }
        .main-content {
          padding: 0 20px 64px !important;
        }
      }
    </style>

    <script>
      const menuBtn = document.getElementById('menuBtn');
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('sidebarOverlay');

      function openMenu() {
        sidebar?.classList.add('open');
        if (overlay) overlay.style.display = 'block';
      }

      function closeMenu() {
        sidebar?.classList.remove('open');
        if (overlay) overlay.style.display = 'none';
      }

      menuBtn?.addEventListener('click', openMenu);
      overlay?.addEventListener('click', closeMenu);

      // Close on nav link click (mobile)
      sidebar?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', closeMenu);
      });

      // Scroll Progress Bar
      const fill = document.getElementById('scrollProgressFill');
      if (fill) {
        const updateProgress = () => {
          const scrollTop = document.documentElement.scrollTop || document.body.scrollTop;
          const scrollHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
          const progress = scrollHeight > 0 ? (scrollTop / scrollHeight) * 100 : 0;
          fill.style.width = progress + '%';
        };

        let ticking = false;
        window.addEventListener('scroll', () => {
          if (!ticking) {
            requestAnimationFrame(() => {
              updateProgress();
              ticking = false;
            });
            ticking = true;
          }
        });
        updateProgress();
      }

      // Scroll Reveal Observer
      const revealElements = document.querySelectorAll('[data-reveal], [data-reveal-stagger]');
      if (revealElements.length > 0) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15 });

        revealElements.forEach(el => observer.observe(el));
      }

      // Gold line reveal
      const goldLines = document.querySelectorAll('.gold-line');
      if (goldLines.length > 0) {
        const lineObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              lineObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.5 });

        goldLines.forEach(el => lineObserver.observe(el));
      }
    </script>
  </body>
</html>
