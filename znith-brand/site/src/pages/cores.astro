---
import Layout from '../layouts/Layout.astro';
const currentPath = '/cores';

const navyScale = [
  { name: 'Navy 950 — Darkest', hex: '#050B17', usage: 'Modal scrim base, darkest surface' },
  { name: 'Navy 900 — Background', hex: '#091022', usage: 'Fundo de página, base root' },
  { name: 'Navy 800 — Deep Surface', hex: '#0D1828', usage: 'Superfície profunda' },
  { name: 'Navy 700 — Surface', hex: '#14203A', usage: 'Cards, painéis, navbars' },
  { name: 'Navy 600 — Elevated', hex: '#1C2A4A', usage: 'Dropdowns, popovers, cards elevados' },
  { name: 'Navy 500 — Border', hex: '#2A3A5A', usage: 'Bordas padrão, divisores' },
  { name: 'Navy 400', hex: '#3A5080', usage: 'Elementos de UI sutis' },
  { name: 'Navy 300', hex: '#5E74A0', usage: 'Texto secundário em superfícies médias' },
  { name: 'Navy 200', hex: '#8E9EBE', usage: 'Texto muted em fundos claros' },
  { name: 'Navy 100', hex: '#C5CEDE', usage: 'Bordas em superfícies claras' },
  { name: 'Navy 50', hex: '#E8ECF4', usage: 'Fundos claros, contextos invertidos' },
];

const goldScale = [
  { name: 'Gold Light', hex: '#F0CC5E', usage: 'Highlights, hover states, linhas decorativas' },
  { name: 'Gold 300', hex: '#E5B855', usage: 'Acento secundário, fills de ícone' },
  { name: 'Gold 400', hex: '#D9A548', usage: 'Suporte de dourado, gradient endpoint' },
  { name: 'Gold 500 — Primary', hex: '#D4A04A', usage: 'Acento principal — CTAs, headings, ícones-chave' },
  { name: 'Gold Deep', hex: '#A8792E', usage: 'Estados pressionados, sombras de dourado' },
];

const neutralScale = [
  { name: 'White', hex: '#FFFFFF', usage: 'Texto primário, contraste máximo' },
  { name: 'Neutral 200', hex: '#DDDDDD', usage: 'Texto secundário em dark' },
  { name: 'Neutral 300', hex: '#BBBBBB', usage: 'Texto de suporte, captions' },
  { name: 'Neutral 400', hex: '#999999', usage: 'Placeholder text' },
  { name: 'Neutral 500', hex: '#7A7A7A', usage: 'Texto desabilitado, metadata' },
];

const brandLayers = [
  {
    name: 'ZNITH Corp',
    desc: 'Consultoria principal. Autoridade e peso institucional.',
    colors: [
      { label: 'Primary', hex: '#D4A04A' },
      { label: 'Light', hex: '#F0CC5E' },
      { label: 'Deep', hex: '#A8792E' },
      { label: 'Surface Tint', hex: 'rgba(212,160,74,0.08)', display: '#D4A04A', opacity: '8%' },
    ],
  },
  {
    name: 'ZNITH.AI OS',
    desc: 'Produto flagship. Dourado + azul tech sinalizam inteligência.',
    colors: [
      { label: 'Primary', hex: '#D4A04A' },
      { label: 'Tech Accent', hex: '#2A5090' },
      { label: 'Tech Light', hex: '#4A78C8' },
      { label: 'Surface Tint', hex: 'rgba(42,80,144,0.08)', display: '#2A5090', opacity: '8%' },
    ],
  },
  {
    name: 'Leilaine (Personal)',
    desc: 'Marca pessoal. Dourado quente, mais pessoal e caloroso.',
    colors: [
      { label: 'Primary', hex: '#E8A847' },
      { label: 'Warm Gold', hex: '#F0C070' },
      { label: 'Navy Deep', hex: '#0D1828' },
      { label: 'Surface Tint', hex: 'rgba(232,168,71,0.06)', display: '#E8A847', opacity: '6%' },
    ],
  },
  {
    name: 'Líderes Leões',
    desc: 'Movimento. Dourado intenso — contexto único onde ouro é irrestrito.',
    colors: [
      { label: 'Primary', hex: '#F0CC5E' },
      { label: 'Intense', hex: '#D4A04A' },
      { label: 'Dark Base', hex: '#050B17' },
      { label: 'Lion Gold', hex: '#A8792E' },
    ],
  },
];

const surfaces = [
  { tier: '0 — Background', hex: '#091022', label: 'Page base, root background' },
  { tier: '1 — Surface', hex: '#14203A', label: 'Cards, panels, navbars' },
  { tier: '2 — Elevated', hex: '#1C2A4A', label: 'Dropdowns, popovers, raised cards' },
  { tier: '3 — Overlay', hex: 'rgba(20,32,58,0.92)', display: '#14203A', label: 'Modal backdrops, tooltips' },
  { tier: '4 — Border', hex: '#2A3A5A', label: 'Dividers, card borders, input borders' },
];
---

<Layout title="Paleta de Cores" currentPath={currentPath}>
  <div class="page-header">
    <span class="page-overline">Capítulo 3.2 — Tokens</span>
    <h1 class="page-title">Paleta de Cores</h1>
    <p class="page-subtitle">Escala navy, acento dourado, neutros, semânticas e sistema de superfícies.</p>
    <span class="gold-line"></span>
  </div>

  <p style="font-family:'Montserrat',sans-serif;font-size:14px;color:#7A7A7A;line-height:1.6;margin-bottom:48px;background:#14203A;border:1px solid #2A3A5A;border-radius:8px;padding:14px 18px;">
    Clique em qualquer swatch para copiar o hex para a área de transferência.
  </p>

  <!-- Navy Scale -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">Escala Navy — Core Background</h2>
    <div style="margin-bottom:8px;"></div>
    <p style="font-family:'Montserrat',sans-serif;font-size:14px;color:#BBBBBB;line-height:1.7;margin-bottom:24px;">
      O navy profundo é o ambiente nativo da ZNITH. Comunica autoridade, profundidade e peso institucional.
    </p>
    <div style="display:flex;flex-direction:column;gap:8px;">
      {navyScale.map((c, i) => (
        <div
          class="color-swatch"
          data-hex={c.hex}
          data-reveal-stagger
          style={`display:grid;grid-template-columns:64px 1fr auto;align-items:center;gap:16px;padding:12px 16px;background:#14203A;border:1px solid #2A3A5A;border-radius:8px;cursor:pointer;--stagger:${i};`}
          title={`Clique para copiar ${c.hex}`}
        >
          <div class="swatch-preview" style={`width:64px;height:40px;border-radius:6px;background:${c.hex};border:1px solid rgba(255,255,255,0.08);transition:transform 200ms ease-out;`}></div>
          <div>
            <div style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600;color:#FFFFFF;margin-bottom:2px;">{c.name}</div>
            <div style="font-family:'Montserrat',sans-serif;font-size:12px;color:#7A7A7A;">{c.usage}</div>
          </div>
          <div style="font-family:'JetBrains Mono','Courier New',monospace;font-size:13px;color:#D4A04A;letter-spacing:0.04em;">{c.hex}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Gold Scale -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">Acento Dourado</h2>
    <div style="margin-bottom:8px;"></div>
    <p style="font-family:'Montserrat',sans-serif;font-size:14px;color:#BBBBBB;line-height:1.7;margin-bottom:24px;">
      O dourado é a assinatura cromática da ZNITH. <strong style="color:#FFFFFF;">Máximo 15% de qualquer superfície.</strong> Nunca como fundo em blocos grandes.
    </p>
    <div style="display:flex;flex-direction:column;gap:8px;">
      {goldScale.map((c, i) => (
        <div
          class="color-swatch"
          data-hex={c.hex}
          data-reveal-stagger
          style={`display:grid;grid-template-columns:64px 1fr auto;align-items:center;gap:16px;padding:12px 16px;background:#14203A;border:1px solid #2A3A5A;border-radius:8px;cursor:pointer;--stagger:${i};`}
          title={`Clique para copiar ${c.hex}`}
        >
          <div class="swatch-preview" style={`width:64px;height:40px;border-radius:6px;background:${c.hex};transition:transform 200ms ease-out;`}></div>
          <div>
            <div style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600;color:#FFFFFF;margin-bottom:2px;">{c.name}</div>
            <div style="font-family:'Montserrat',sans-serif;font-size:12px;color:#7A7A7A;">{c.usage}</div>
          </div>
          <div style="font-family:'JetBrains Mono','Courier New',monospace;font-size:13px;color:#D4A04A;letter-spacing:0.04em;">{c.hex}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Neutral Scale -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">Escala Neutra — Texto e UI</h2>
    <div style="margin-bottom:24px;"></div>
    <div style="display:flex;flex-direction:column;gap:8px;">
      {neutralScale.map((c, i) => (
        <div
          class="color-swatch"
          data-hex={c.hex}
          data-reveal-stagger
          style={`display:grid;grid-template-columns:64px 1fr auto;align-items:center;gap:16px;padding:12px 16px;background:#14203A;border:1px solid #2A3A5A;border-radius:8px;cursor:pointer;--stagger:${i};`}
          title={`Clique para copiar ${c.hex}`}
        >
          <div class="swatch-preview" style={`width:64px;height:40px;border-radius:6px;background:${c.hex};border:1px solid rgba(42,58,90,0.8);transition:transform 200ms ease-out;`}></div>
          <div>
            <div style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600;color:#FFFFFF;margin-bottom:2px;">{c.name}</div>
            <div style="font-family:'Montserrat',sans-serif;font-size:12px;color:#7A7A7A;">{c.usage}</div>
          </div>
          <div style="font-family:'JetBrains Mono','Courier New',monospace;font-size:13px;color:#D4A04A;letter-spacing:0.04em;">{c.hex}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Surface System -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">Sistema de Superfícies</h2>
    <div style="margin-bottom:8px;"></div>
    <p style="font-family:'Montserrat',sans-serif;font-size:14px;color:#BBBBBB;line-height:1.7;margin-bottom:24px;">
      Cinco níveis de superfície criam percepção de profundidade em dark mode.
    </p>
    <div style="display:flex;flex-direction:column;gap:4px;max-width:500px;">
      {surfaces.map((s, i) => (
        <div style={`padding:${16 + i*8}px 20px;background:${s.display || s.hex};border-radius:${i === 0 ? '10px 10px' : (i === surfaces.length-1 ? '0 0' : '0 0')} 0 0;border:1px solid #2A3A5A;`}>
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <div>
              <div style="font-family:'Montserrat',sans-serif;font-size:12px;font-weight:600;color:#FFFFFF;margin-bottom:2px;">{s.tier}</div>
              <div style="font-family:'Montserrat',sans-serif;font-size:11px;color:#7A7A7A;">{s.label}</div>
            </div>
            <div style="font-family:'JetBrains Mono','Courier New',monospace;font-size:11px;color:#D4A04A;">{s.hex}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Brand Layers -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">Variações por Camada de Marca</h2>
    <div style="margin-bottom:8px;"></div>
    <p style="font-family:'Montserrat',sans-serif;font-size:14px;color:#BBBBBB;line-height:1.7;margin-bottom:24px;">
      Cada produto ou frente da ZNITH tem uma expressão de acento construída sobre a mesma fundação navy.
    </p>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:16px;">
      {brandLayers.map((layer, i) => (
        <div class="card" data-reveal-stagger style={`--stagger:${i};`}>
          <div style="font-family:'Cinzel',serif;font-size:16px;color:#FFFFFF;margin-bottom:4px;">{layer.name}</div>
          <div style="font-family:'Montserrat',sans-serif;font-size:12px;color:#7A7A7A;margin-bottom:16px;line-height:1.5;">{layer.desc}</div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;">
            {layer.colors.map(c => (
              <div style="text-align:center;">
                <div style={`width:48px;height:48px;border-radius:8px;background:${c.display || c.hex};border:1px solid #2A3A5A;margin:0 auto 4px;`}></div>
                <div style="font-family:'Montserrat',sans-serif;font-size:10px;color:#7A7A7A;margin-bottom:2px;">{c.label}</div>
                <div style="font-family:'JetBrains Mono','Courier New',monospace;font-size:10px;color:#D4A04A;">{c.opacity ? `${c.opacity}` : c.hex.slice(0, 7)}</div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Regras -->
  <section class="content-section" data-reveal>
    <h2 class="section-h2">Regras de Uso da Cor</h2>
    <div style="margin-bottom:20px;"></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
      <div style="background:rgba(42,107,74,0.08);border:1px solid rgba(42,107,74,0.3);border-radius:10px;padding:20px;">
        <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#3A8A60;margin-bottom:12px;">Fazer</div>
        <ul class="prose-list">
          <li>Usar navy escuro como fundo dominante</li>
          <li>Usar dourado para criar hierarquia e direcionar o olhar</li>
          <li>Manter max 15% de superfície em dourado</li>
          <li>Usar borda com acento dourado em hover states</li>
        </ul>
      </div>
      <div style="background:rgba(122,42,42,0.08);border:1px solid rgba(122,42,42,0.3);border-radius:10px;padding:20px;">
        <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#A03A3A;margin-bottom:12px;">Não fazer</div>
        <ul class="prose-list" style="color:#BBBBBB;">
          <li>Usar dourado como fundo em blocos grandes</li>
          <li>Adicionar cores fora da paleta (vermelho vivo, verde neon, roxo)</li>
          <li>Criar gradientes de dourado para dourado em textos</li>
          <li>Usar azul elétrico brilhante como acento principal</li>
        </ul>
      </div>
    </div>
  </section>
</Layout>

<div id="toast" style="
  position:fixed;bottom:24px;right:24px;
  background:#14203A;border:1px solid #D4A04A;
  border-radius:8px;padding:12px 20px;
  font-family:'Montserrat',sans-serif;font-size:13px;color:#D4A04A;
  opacity:0;transition:opacity 0.2s ease;pointer-events:none;z-index:1000;
">Hex copiado!</div>

<style>
  /* =========================================
     COMPONENT: Swatch Flash Feedback
     TRIGGER: click (copy-to-clipboard)
     TIMING: 300ms ease-out
     TIERS: all tiers (CSS-only, no perf cost)
     prefers-reduced-motion: flash still plays (instant visual feedback)
     ========================================= */

  .swatch-preview:hover {
    transform: scale(1.08);
  }

  .color-swatch {
    transition: transform 150ms ease-out, box-shadow 150ms ease-out;
  }

  .color-swatch:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
  }

  .swatch-flash {
    position: relative;
  }

  .swatch-flash::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.2);
    border-radius: inherit;
    animation: flash-fade 300ms ease-out forwards;
    pointer-events: none;
  }

  @keyframes flash-fade {
    to { opacity: 0; }
  }

  /* --- Scroll reveal for sections --- */
  [data-reveal] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 500ms ease-out, transform 500ms ease-out;
  }

  [data-reveal].revealed {
    opacity: 1;
    transform: translateY(0);
  }

  [data-reveal-stagger] {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 400ms ease-out, transform 400ms ease-out;
    transition-delay: calc(var(--stagger, 0) * 60ms);
  }

  [data-reveal].revealed [data-reveal-stagger] {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal],
    [data-reveal-stagger] {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  // Copy-to-clipboard with flash feedback
  const swatches = document.querySelectorAll('[data-hex]');
  const toast = document.getElementById('toast');
  let toastTimer: ReturnType<typeof setTimeout>;

  swatches.forEach(swatch => {
    swatch.addEventListener('click', () => {
      const hex = (swatch as HTMLElement).dataset.hex || '';
      navigator.clipboard.writeText(hex).then(() => {
        // Flash feedback
        swatch.classList.add('swatch-flash');
        setTimeout(() => swatch.classList.remove('swatch-flash'), 300);

        if (toast) {
          toast.textContent = `Copiado: ${hex}`;
          toast.style.opacity = '1';
          clearTimeout(toastTimer);
          toastTimer = setTimeout(() => {
            if (toast) toast.style.opacity = '0';
          }, 2000);
        }
      });
    });
  });

  // Scroll reveal via Intersection Observer
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('[data-reveal]').forEach(el => revealObserver.observe(el));
</script>
