---
import Layout from '../layouts/Layout.astro';
const currentPath = '/grafismos';

const grafismos = [
  {
    id: '1',
    file: '/logos/GRAFISMO1.png',
    name: 'GRAFISMO1 — Swoosh / Checkmark Accent',
    form: 'Forma curva abstrata ou angular em navy sólido.',
    character: 'Dinâmico, movimento para frente, decisivo.',
    uses: [
      'Acento decorativo em slides (cantos ou transições de seção)',
      'Motivo de transição em slides',
      'Elemento de textura de fundo em baixa opacidade',
      'Decoração de pull quote em documentos',
    ],
    restrictions: ['Não usar como identificador de marca standalone', 'Não usar em tamanhos onde se torna indistinto'],
    active: true,
  },
  {
    id: '2',
    file: '/logos/GRAFISMO2.png',
    name: 'GRAFISMO2 — Coroa',
    form: 'Coroa estilizada, flat/monocromática, navy — versão simplificada da coroa do leão.',
    character: 'Autoridade, conquista, posicionamento premium.',
    uses: [
      'Cabeçalhos de seção em propostas e decks',
      'Selos e badges de conquista',
      'Ornamentação de pull quotes',
      'Capas de materiais impressos',
      'Tratamentos de carimbo ou selo',
    ],
    restrictions: [
      'Não usar como elemento de logo primário — é grafismo de suporte',
      'Não aplicar gradientes ou efeitos',
    ],
    active: true,
  },
  {
    id: '3',
    file: '/logos/GRAFISMO3.png',
    name: 'GRAFISMO3 — Z com Rosto do Leão (escala gráfica)',
    form: 'A marca Z com rosto do leão em escala gráfica menor. Funciona como marca reduzida alternativa.',
    character: 'Recall de marca, reforço de identidade compacto.',
    uses: [
      'Alternativa ao símbolo Z em contextos gráficos específicos',
      'Elemento de padrão (quando repetido)',
      'Watermark em documentos',
      'Sticker / aplicação de selo',
    ],
    restrictions: [
      'Em tamanhos muito pequenos, garantir que o rosto do leão no Z leia com clareza',
      'Mínimo 48px digital / 15mm impresso',
    ],
    active: true,
  },
  {
    id: '4',
    file: '/logos/GRAFISMO4.png',
    name: 'GRAFISMO4 — Wave / S-Curve Pattern',
    form: 'Padrão repetido de ondas ou curva S, navy sobre fundo escuro — padrão têxtil/de marca.',
    character: 'Textura de luxo, ritmo, continuidade.',
    uses: [
      'Textura de fundo em slides dark',
      'Merchandise: capas de caderno, embalagens, sacolas, lenços',
      'Materiais de evento: toalhas, painéis de backdrop',
      'Interior de envelopes (papelaria premium)',
    ],
    restrictions: [
      'Não usar como fundo direto atrás do logo principal sem separação de contraste suficiente',
      'Opacidade preferida: 100% para merchandise, 20–40% para textura digital',
    ],
    active: true,
  },
  {
    id: '5',
    file: '/logos/GRAFISMO5.png',
    name: 'GRAFISMO5 — Diagonal Z Pattern',
    form: 'Padrão diagonal repetido da letra Z em navy — padrão têxtil/de marca tipográfico.',
    character: 'Saturação de marca, monograma de luxo, identidade de padrão.',
    uses: [
      'Fundos de embalagem',
      'Sacolas e caixas de presente, papel de embrulho',
      'Capas de pasta de apresentação',
      'Merchandise: bolsas, capas de celular, forro de roupas',
    ],
    restrictions: [
      'Mesma regra do GRAFISMO4 — não usar diretamente atrás do logo sem quebra de contraste clara',
      'Escala recomendada: os elementos Z devem ser legíveis como letras, não micro-textura',
    ],
    active: true,
  },
  {
    id: '6',
    file: '/logos/GRAFISMO6.png',
    name: 'GRAFISMO6 — Coroa 3D Dourada com Rubi',
    form: 'Coroa renderizada em 3D com pedra rubi.',
    character: 'Opulento, ornado, dimensional.',
    uses: [
      'Contextos de campanha específica (lançamento VIP, evento exclusivo)',
    ],
    restrictions: [
      'Avaliação obrigatória: este ativo não se alinha totalmente à estética clean e premium da marca',
      'O estilo 3D e o rubi introduzem qualidade barroca que contrasta com a ilustração flat do leão',
      'Nunca usar como elemento de marca recorrente sem aprovação de brief explícita',
      'Arquivar se não houver caso de uso de campanha específica',
    ],
    active: false,
    warning: true,
  },
];
---

<Layout title="Grafismos & Patterns" currentPath={currentPath}>
  <div class="page-header">
    <span class="page-overline">Capítulo 3.4</span>
    <h1 class="page-title">Grafismos & Patterns</h1>
    <p class="page-subtitle">Seis elementos gráficos que estendem a linguagem da marca além do logo.</p>
    <span class="gold-line"></span>
  </div>

  <p style="font-family:'Montserrat',sans-serif;font-size:15px;color:#BBBBBB;line-height:1.7;margin-bottom:48px;">
    Os grafismos são elementos de suporte visual — nunca substitutos ou extensões do logo. Eles aparecem em layouts, apresentações, merchandise e materiais impressos para ampliar e texturas a linguagem visual da marca.
  </p>

  {grafismos.map(g => (
    <section class="content-section" data-reveal>
      <div class="card" style={g.warning ? 'border-color:rgba(160,58,58,0.4);' : ''}>
        {g.warning && (
          <div style="background:rgba(122,42,42,0.15);border:1px solid rgba(122,42,42,0.3);border-radius:6px;padding:10px 14px;margin-bottom:20px;font-family:'Montserrat',sans-serif;font-size:12px;color:#A03A3A;">
            Avaliacao necessaria — uso condicional apenas. Ver restricoes abaixo.
          </div>
        )}

        <div style="display:grid;grid-template-columns:220px 1fr;gap:32px;align-items:start;">
          <div>
            <div style="background:#091022;border-radius:10px;padding:20px;border:1px solid #2A3A5A;margin-bottom:12px;display:flex;align-items:center;justify-content:center;min-height:180px;">
              <img src={g.file} alt={g.name} style="max-width:100%;max-height:160px;object-fit:contain;" />
            </div>
            <div style="font-family:'JetBrains Mono','Courier New',monospace;font-size:11px;color:#7A7A7A;text-align:center;">GRAFISMO{g.id}.png</div>
          </div>

          <div>
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">
              <h2 style="font-family:'Cinzel',serif;font-size:18px;font-weight:400;color:#FFFFFF;">{g.name}</h2>
              {!g.active && <span class="badge" style="background:rgba(122,42,42,0.2);border-color:rgba(122,42,42,0.4);color:#A03A3A;">Uso restrito</span>}
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
              <div>
                <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:#7A7A7A;margin-bottom:6px;">Forma</div>
                <p style="font-family:'Montserrat',sans-serif;font-size:13px;color:#BBBBBB;line-height:1.5;">{g.form}</p>
              </div>
              <div>
                <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:#7A7A7A;margin-bottom:6px;">Caráter</div>
                <p style="font-family:'Montserrat',sans-serif;font-size:13px;color:#BBBBBB;line-height:1.5;">{g.character}</p>
              </div>
            </div>

            <div style="margin-bottom:16px;">
              <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:#D4A04A;margin-bottom:8px;">Uso Recomendado</div>
              <ul class="prose-list">
                {g.uses.map(u => <li>{u}</li>)}
              </ul>
            </div>

            <div>
              <div style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:#7A7A7A;margin-bottom:8px;">Restricoes</div>
              <ul class="prose-list" style={g.warning ? 'color:#A03A3A;opacity:0.9;' : 'opacity:0.7;'}>
                {g.restrictions.map(r => <li>{r}</li>)}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}
</Layout>
