---
import Layout from '../layouts/Layout.astro';

const values = [
  {
    num: '01',
    title: 'Verdade antes de vaidade',
    body: 'A ZNITH nao foi construida para parecer inteligente; foi construida para resolver com profundidade. Sem maquiar problema, sem vender solucao rasa para dor profunda, sem usar tecnologia como enfeite.',
  },
  {
    num: '02',
    title: 'Estrutura acima de improviso',
    body: 'Crescimento sem governanca, sem processo, sem cadencia e sem leitura operacional so aumenta a bagunca. A cultura da ZNITH e de arquitetura, disciplina e previsibilidade.',
  },
  {
    num: '03',
    title: 'Responsabilidade real com resultado',
    body: 'Compromisso com implantacao, acompanhamento, documentacao e indicadores de sucesso concretos. Nao e consultoria de palco; e construcao com mao na operacao.',
  },
  {
    num: '04',
    title: 'Inteligencia com criterio',
    body: 'IA, automacao, playbook e dados sao ferramentas — nao objetivos. "IA sem criterio so acelera bagunca." Discernimento, desenho correto e maturidade antes da escala.',
  },
  {
    num: '05',
    title: 'Confidencialidade e legado',
    body: 'Sigilo formal, respeito a propriedade intelectual, documentacao organizada, continuidade de acesso. Uma empresa que nao opera no curto prazo da conveniencia.',
  },
];

const brandArchitecture = [
  { level: 'Master Brand', name: 'ZNITH', desc: 'Arquitetura de crescimento comercial com IA', color: '#EDBA63' },
  { level: 'Consulting', name: 'ZNITH Consulting', desc: 'Expansao comercial, RevOps, CRM, processos', color: '#D9A04A' },
  { level: 'Technology', name: 'ZNITH.AI', desc: 'Agente de IA, atendimento, qualificacao, automacao', color: '#C8883B' },
  { level: 'Platform', name: 'ZNITH.AI OS', desc: 'Sistema operacional comercial — arquitetura e escala', color: '#B87530' },
  { level: 'Movement', name: 'Lideres Leoes', desc: 'Desenvolvimento de lideranca — consciencia e governo', color: '#A85D18' },
];
---

<Layout title="A Marca - ZNITH Design System" activeRoute="/marca">
  <div style="max-width: 1120px; margin: 0 auto; padding: 64px 32px;">

    <!-- Header -->
    <div class="reveal" style="margin-bottom: 64px;">
      <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.2em; color: #EDBA63; margin: 0 0 16px;">Design System</p>
      <h1 style="font-family: 'Cinzel', serif; font-size: clamp(32px, 5vw, 56px); color: #ffffff; margin: 0 0 16px; letter-spacing: 0.06em;">A Marca</h1>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 16px; color: #8CA0B5; max-width: 560px; line-height: 1.7; margin: 0 0 24px;">Origem, proposito, valores e arquitetura do ecossistema ZNITH.</p>
      <div class="gold-line"></div>
    </div>

    <!-- Origin Story -->
    <section class="reveal" style="margin-bottom: 64px;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: start;">
        <div>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.2em; color: #EDBA63; margin: 0 0 16px;">Origem</p>
          <h2 style="font-family: 'Cinzel', serif; font-size: 32px; color: #ffffff; margin: 0 0 24px; letter-spacing: 0.04em; line-height: 1.2;">Nascida da dor, construida com direcao</h2>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 14px; color: #8CA0B5; margin: 0 0 16px; line-height: 1.8;">
            A ZNITH nao nasceu de um plano de negocio limpo. Nasceu de travessia. Leilaine Campioto, fundadora e CEO, passou por mais de 20 anos no comercial — vendas, lideranca, estruturacao de times, crescimento de operacoes. Viu empresas crescerem sem estrutura. Viu gente competente sem direcao.
          </p>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 14px; color: #8CA0B5; margin: 0 0 16px; line-height: 1.8;">
            Em 2018, enfrentou quebra financeira profunda — mais de um milhao em dividas, dezenas de processos. Foi nesse lugar que entendeu que crescer sem estrutura interna e construir em terreno instavel.
          </p>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 14px; color: #8CA0B5; margin: 0; line-height: 1.8;">
            A ZNITH nasceu como resposta madura: ajudar empresas a crescer com inteligencia artificial, sem perder a essencia humana, a clareza estrategica e o proposito.
          </p>
        </div>
        <div style="display: flex; flex-direction: column; gap: 16px;">
          <div style="background: rgba(237,186,99,0.05); border: 1px solid rgba(237,186,99,0.15); border-radius: 20px; padding: 32px;">
            <p style="font-family: 'Cinzel', serif; font-size: 40px; color: #EDBA63; margin: 0 0 4px; font-weight: 700;">+20</p>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #8CA0B5; margin: 0;">Anos de experiencia comercial</p>
          </div>
          <div style="background: rgba(237,186,99,0.05); border: 1px solid rgba(237,186,99,0.15); border-radius: 20px; padding: 32px;">
            <p style="font-family: 'Cinzel', serif; font-size: 40px; color: #EDBA63; margin: 0 0 4px; font-weight: 700;">R$500M+</p>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #8CA0B5; margin: 0;">Em vendas estruturadas ao longo da trajetoria</p>
          </div>
          <div style="background: rgba(237,186,99,0.05); border: 1px solid rgba(237,186,99,0.15); border-radius: 20px; padding: 32px;">
            <p style="font-family: 'Cinzel', serif; font-size: 40px; color: #EDBA63; margin: 0 0 4px; font-weight: 700;">US$1M+</p>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #8CA0B5; margin: 0;">Em vendas internacionais contribuidas</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Mission, Vision, Promise -->
    <section class="reveal" style="margin-bottom: 64px;">
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;">
        {[
          {
            label: 'Missao',
            text: 'Estruturar operacoes comerciais para que empresas cresçam com mais clareza, previsibilidade e inteligencia, usando IA como alavanca — nao como maquiagem.',
          },
          {
            label: 'Visao',
            text: 'Ser reconhecida como a parceira que transforma caos comercial em sistema de crescimento previsivel — com verdade, metodo e construcao real.',
          },
          {
            label: 'Promessa',
            text: 'Diagnosticamos com profundidade, estruturamos com inteligencia, implementamos com criterio e reposicionamos a operacao para crescer com maturidade.',
          },
        ].map(item => (
          <div style="background: #0D1724; border-radius: 20px; padding: 32px; border: 1px solid rgba(38,64,96,0.4);">
            <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: #EDBA63; margin: 0 0 12px;">{item.label}</p>
            <div style="width: 32px; height: 1px; background: linear-gradient(90deg, #EDBA63, transparent); margin-bottom: 16px;"></div>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 14px; color: #C0CDD8; margin: 0; line-height: 1.8;">{item.text}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Brand Values -->
    <section class="reveal" style="margin-bottom: 64px;">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Valores da Marca</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">5 principios que governam todas as decisoes da ZNITH</p>

      <div style="display: flex; flex-direction: column; gap: 0; border-radius: 20px; overflow: hidden; border: 1px solid rgba(38,64,96,0.4);">
        {values.map((v, i) => (
          <div style={`
            display: flex;
            gap: 32px;
            padding: 32px 40px;
            border-bottom: ${i < values.length - 1 ? '1px solid rgba(38,64,96,0.25)' : 'none'};
            background: ${i % 2 === 0 ? '#0D1724' : 'transparent'};
            align-items: start;
          `}>
            <span style="font-family: 'Cinzel', serif; font-size: 32px; color: rgba(237,186,99,0.15); font-weight: 700; flex-shrink: 0; line-height: 1;">{v.num}</span>
            <div>
              <h3 style="font-family: 'Cinzel', serif; font-size: 18px; color: #ffffff; margin: 0 0 8px; font-weight: 600; letter-spacing: 0.04em;">{v.title}</h3>
              <p style="font-family: 'Montserrat', sans-serif; font-size: 14px; color: #8CA0B5; margin: 0; line-height: 1.7;">{v.body}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Brand Architecture -->
    <section class="reveal" style="margin-bottom: 64px;">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Arquitetura de Marca</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">Ecossistema ZNITH — 5 frentes complementares</p>

      <div style="background: #0D1724; border-radius: 20px; padding: 40px; border: 1px solid rgba(38,64,96,0.4);">
        <div style="display: flex; flex-direction: column; gap: 0; position: relative;">
          <!-- Connecting line -->
          <div style="position: absolute; left: 23px; top: 40px; bottom: 40px; width: 1px; background: linear-gradient(180deg, rgba(237,186,99,0.3), rgba(237,186,99,0.05));"></div>

          {brandArchitecture.map((item, i) => (
            <div style={`
              display: flex;
              align-items: start;
              gap: 24px;
              padding: ${i === 0 ? '0 0 28px' : '28px 0'};
              ${i < brandArchitecture.length - 1 ? 'border-bottom: 1px solid rgba(38,64,96,0.2);' : ''}
              padding-left: ${i === 0 ? '0' : `${i * 16}px`};
            `}>
              <div style={`
                width: 48px;
                height: 48px;
                border-radius: 12px;
                background: ${item.color}15;
                border: 1px solid ${item.color}30;
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
                position: relative;
                z-index: 1;
              `}>
                <span style={`font-family: 'Cinzel', serif; font-size: 11px; font-weight: 700; color: ${item.color};`}>{i === 0 ? 'Z' : `0${i}`}</span>
              </div>
              <div>
                <p style={`font-family: 'Montserrat', sans-serif; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: ${item.color}; margin: 0 0 4px;`}>{item.level}</p>
                <h3 style="font-family: 'Cinzel', serif; font-size: 18px; color: #ffffff; margin: 0 0 4px; font-weight: 600;">{item.name}</h3>
                <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0;">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Personality -->
    <section class="reveal">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Personalidade da Marca</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">"Se a ZNITH fosse uma pessoa..."</p>

      <div style="background: rgba(237,186,99,0.04); border: 1px solid rgba(237,186,99,0.12); border-radius: 20px; padding: 48px;">
        <p style="font-family: 'Montserrat', sans-serif; font-size: 15px; color: #C0CDD8; margin: 0 0 32px; line-height: 1.9; max-width: 720px;">
          Seria estrategica, madura, direta e profundamente observadora. Nao seria a pessoa que chega na sala tentando impressionar com palavras bonitas. Seria a pessoa que escuta com atencao, enxerga rapido o que esta desalinhado, organiza o pensamento dos outros e traz uma leitura que ninguem conseguiu fazer sozinho.
        </p>
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; max-width: 560px;">
          {[
            { trait: 'Lucidez', desc: 'Para diagnosticar' },
            { trait: 'Disciplina', desc: 'Para estruturar' },
            { trait: 'Coragem', desc: 'Para confrontar' },
            { trait: 'Responsabilidade', desc: 'Para acompanhar ate a execucao' },
          ].map(t => (
            <div style="display: flex; align-items: center; gap: 12px;">
              <div style="width: 6px; height: 6px; background: #EDBA63; border-radius: 50%; flex-shrink: 0;"></div>
              <div>
                <span style="font-family: 'Cinzel', serif; font-size: 14px; color: #EDBA63; font-weight: 600;">{t.trait}</span>
                <span style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890;"> — {t.desc}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>

  <style>
    @media (max-width: 768px) {
      section > div[style*='grid-template-columns: 1fr 1fr'] {
        grid-template-columns: 1fr !important;
      }
      section > div[style*='grid-template-columns: repeat(3'] {
        grid-template-columns: 1fr !important;
      }
    }
  </style>
</Layout>
