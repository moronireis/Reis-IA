---
import Layout from '../layouts/Layout.astro';

const voiceProfiles = [
  {
    brand: 'ZNITH Corp',
    sub: 'Marca Empresarial Principal',
    accentColor: '#EDBA63',
    desc: 'Premium, consultivo, estrategico, preciso. Fala como quem entende negocio de verdade — nao como quem quer apenas parecer moderno.',
    vocab: ['Arquitetura de crescimento', 'Previsibilidade', 'Governanca', 'Estrutura', 'Diagnostico', 'Criterio'],
    prohibited: ['Revolucionario', 'Inovador', 'Solucao robusta', 'Modinha'],
    signatures: [
      '"Nao vende ferramenta. Vende direcao."',
      '"Estrutura que cresce com voce."',
      '"IA sem criterio so acelera bagunca."',
    ],
  },
  {
    brand: 'ZNITH.AI OS',
    sub: 'Sistema Operacional Comercial',
    accentColor: '#C8883B',
    desc: 'Tecnologico mas nao tecnico. Fala de IA em termos de resultado: previsibilidade, velocidade, maturidade operacional. Nunca de codigo ou API.',
    vocab: ['Inteligencia comercial', 'Automacao com criterio', 'Playbook', 'Pipeline', 'Rastreabilidade', 'Escala'],
    prohibited: ['APIs', 'Stack', 'Deploy', 'Disruptivo', 'Inovador'],
    signatures: [
      '"O sistema comercial que pensa com voce."',
      '"Mais velocidade, sem perder qualidade."',
      '"Da urgencia para a arquitetura."',
    ],
  },
  {
    brand: 'Leilaine Campioto',
    sub: 'Personal Brand — CEO e Fundadora',
    accentColor: '#D9A04A',
    desc: 'Direta, profunda, confrontadora na medida certa. Une firmeza com cuidado, profundidade com execucao, fe com inteligencia. Fala da travessia, nao do palco.',
    vocab: ['Travessia', 'Reconstrucao', 'Fe', 'Proposito', 'Verdade', 'Forja', 'Legado'],
    prohibited: ['Alta performance', 'Guru', 'Motivacional', 'Inspiracional vazio'],
    signatures: [
      '"Estratégica, profunda e construtora."',
      '"Nao começo pelo problema. Começo pelo diagnostico."',
      '"Fé com acao, nao com discurso."',
    ],
  },
  {
    brand: 'Lideres Leoes',
    sub: 'Movimento de Lideranca',
    accentColor: '#8B4A12',
    desc: 'Firme, corajoso, confrontador. Fala de lideranca como governo — nao como performance. Vocabulario de responsabilidade, carater e maturidade.',
    vocab: ['Governo', 'Chamado', 'Territorio', 'Postura', 'Fortalecimento', 'Alinhamento'],
    prohibited: ['Motivacional', 'Hype', 'Alta performance', 'Carisma sem carater'],
    signatures: [
      '"Coragem para governar. Consciencia para permanecer."',
      '"Leao nao performa presenca. Ele carrega presenca."',
      '"Lideranca e governo, nao aparencia."',
    ],
  },
];
---

<Layout title="Tom de Voz - ZNITH Design System" activeRoute="/voz">
  <div style="max-width: 1120px; margin: 0 auto; padding: 64px 32px;">

    <!-- Header -->
    <div class="reveal" style="margin-bottom: 64px;">
      <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.2em; color: #EDBA63; margin: 0 0 16px;">Design System</p>
      <h1 style="font-family: 'Cinzel', serif; font-size: clamp(32px, 5vw, 56px); color: #ffffff; margin: 0 0 16px; letter-spacing: 0.06em;">Tom de Voz</h1>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 16px; color: #8CA0B5; max-width: 560px; line-height: 1.7; margin: 0 0 24px;">4 perfis de comunicacao — cada um com vocabulario, restricoes e frases de assinatura proprios.</p>
      <div class="gold-line"></div>
    </div>

    <!-- Core Principle -->
    <section class="reveal" style="margin-bottom: 64px;">
      <div style="background: rgba(237,186,99,0.05); border: 1px solid rgba(237,186,99,0.15); border-radius: 20px; padding: 40px; position: relative; overflow: hidden;">
        <div style="position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, transparent, #EDBA63, transparent);"></div>
        <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.2em; color: #EDBA63; margin: 0 0 16px;">Principio Central</p>
        <blockquote style="font-family: 'Cinzel', serif; font-size: clamp(18px, 3vw, 28px); color: #ffffff; margin: 0; line-height: 1.5; font-weight: 400;">
          "Falar como quem ja resolveu o problema — nao como quem esta vendendo a solucao."
        </blockquote>
        <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 16px 0 0;">Aplicado em todos os 4 perfis de marca.</p>
      </div>
    </section>

    <!-- Voice Profiles -->
    {voiceProfiles.map((profile, idx) => (
      <section class="reveal" style="margin-bottom: 40px;">
        <div style={`
          background: #0D1724;
          border-radius: 20px;
          overflow: hidden;
          border: 1px solid rgba(38,64,96,0.4);
        `}>
          <!-- Header -->
          <div style={`
            padding: 32px 40px;
            border-bottom: 1px solid rgba(38,64,96,0.3);
            background: rgba(20, 41, 64, 0.3);
            position: relative;
          `}>
            <div style="position: absolute; top: 0; left: 0; width: 3px; height: 100%;"
              style={`background: ${profile.accentColor}; position: absolute; top: 0; left: 0; width: 3px; height: 100%;`}
            ></div>
            <div style={`position: absolute; top: 0; left: 0; width: 3px; height: 100%; background: ${profile.accentColor};`}></div>
            <div style="display: flex; align-items: start; justify-content: space-between; gap: 16px; flex-wrap: wrap;">
              <div>
                <p style={`font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: ${profile.accentColor}; margin: 0 0 6px;`}>{profile.sub}</p>
                <h2 style="font-family: 'Cinzel', serif; font-size: 26px; color: #ffffff; margin: 0; font-weight: 700; letter-spacing: 0.06em;">{profile.brand}</h2>
              </div>
              <span style={`
                font-family: 'Montserrat', sans-serif;
                font-size: 10px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                padding: 4px 10px;
                border-radius: 6px;
                background: ${profile.accentColor}18;
                border: 1px solid ${profile.accentColor}33;
                color: ${profile.accentColor};
                flex-shrink: 0;
              `}>Perfil {idx + 1}</span>
            </div>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 14px; color: #8CA0B5; margin: 16px 0 0; line-height: 1.7; max-width: 680px;">{profile.desc}</p>
          </div>

          <!-- Content Grid -->
          <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0;">

            <!-- Vocabulary -->
            <div style="padding: 32px; border-right: 1px solid rgba(38,64,96,0.3);">
              <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: #5E7890; margin: 0 0 20px;">Vocabulario Central</p>
              <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                {profile.vocab.map(word => (
                  <span style={`
                    font-family: 'Montserrat', sans-serif;
                    font-size: 12px;
                    font-weight: 500;
                    padding: 5px 12px;
                    border-radius: 8px;
                    background: ${profile.accentColor}12;
                    border: 1px solid ${profile.accentColor}25;
                    color: ${profile.accentColor};
                  `}>{word}</span>
                ))}
              </div>
            </div>

            <!-- Prohibited -->
            <div style="padding: 32px; border-right: 1px solid rgba(38,64,96,0.3);">
              <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: #5E7890; margin: 0 0 20px;">Nunca Use</p>
              <div style="display: flex; flex-direction: column; gap: 8px;">
                {profile.prohibited.map(word => (
                  <div style="display: flex; align-items: center; gap: 8px;">
                    <div style="width: 14px; height: 14px; border-radius: 50%; background: rgba(122,32,32,0.3); border: 1px solid rgba(248,113,113,0.3); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                      <div style="width: 6px; height: 1.5px; background: #f87171; border-radius: 1px;"></div>
                    </div>
                    <span style="font-family: 'Montserrat', sans-serif; font-size: 12px; color: #8CA0B5; text-decoration: line-through; text-decoration-color: rgba(248,113,113,0.4);">{word}</span>
                  </div>
                ))}
              </div>
            </div>

            <!-- Signature Phrases -->
            <div style="padding: 32px;">
              <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: #5E7890; margin: 0 0 20px;">Frases de Assinatura</p>
              <div style="display: flex; flex-direction: column; gap: 16px;">
                {profile.signatures.map(sig => (
                  <p style={`font-family: 'Cinzel', serif; font-size: 13px; color: #C0CDD8; margin: 0; line-height: 1.6; border-left: 2px solid ${profile.accentColor}33; padding-left: 12px;`}>{sig}</p>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>
    ))}

    <!-- Quick Reference -->
    <section class="reveal" style="margin-top: 64px;">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 32px; letter-spacing: 0.06em;">Antes / Depois</h2>
      <div style="display: flex; flex-direction: column; gap: 16px;">
        {[
          {
            before: '"Nossas solucoes inovadoras de IA permitem que empresas transformem seus processos e alcancem resultados extraordinarios."',
            after: '"A maioria das empresas que nos procura ja tentou IA antes. Gastaram. Nao funcionou. Comecamos pelo resultado financeiro, nao pela tecnologia."',
          },
          {
            before: '"Nossa abordagem revolucionaria potencializa o ROI das operacoes comerciais atraves de sinergias estrategicas."',
            after: '"Diagnosticamos a operacao, corrigimos o gargalo, estruturamos o processo. Sem formulas prontas. Sem automacao de bagunca."',
          },
        ].map(pair => (
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div style="background: rgba(122,32,32,0.08); border: 1px solid rgba(122,32,32,0.25); border-radius: 16px; padding: 24px;">
              <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: #f87171; margin: 0 0 12px;">Antes — IA</p>
              <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #8CA0B5; margin: 0; line-height: 1.7;">{pair.before}</p>
            </div>
            <div style="background: rgba(42,107,74,0.08); border: 1px solid rgba(42,107,74,0.25); border-radius: 16px; padding: 24px;">
              <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: #4ade80; margin: 0 0 12px;">Depois — ZNITH</p>
              <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #C0CDD8; margin: 0; line-height: 1.7;">{pair.after}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

  </div>

  <style>
    @media (max-width: 768px) {
      .voice-grid {
        grid-template-columns: 1fr !important;
      }
    }
  </style>
</Layout>
