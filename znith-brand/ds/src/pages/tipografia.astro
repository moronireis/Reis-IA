---
import Layout from '../layouts/Layout.astro';

const typeScale = [
  { name: 'Display XL', size: '96px', weight: '700', family: 'Cinzel', sample: 'ZNITH' },
  { name: 'Display L', size: '72px', weight: '700', family: 'Cinzel', sample: 'ZNITH' },
  { name: 'Display M', size: '56px', weight: '600', family: 'Cinzel', sample: 'Direcao' },
  { name: 'Display S', size: '40px', weight: '600', family: 'Cinzel', sample: 'Consciencia' },
  { name: 'Heading XL', size: '32px', weight: '600', family: 'Cinzel', sample: 'Legado Real' },
  { name: 'Heading L', size: '24px', weight: '600', family: 'Cinzel', sample: 'Valores da Marca' },
  { name: 'Heading M', size: '20px', weight: '600', family: 'Cinzel', sample: 'Componentes do Sistema' },
  { name: 'Heading S', size: '16px', weight: '600', family: 'Cinzel', sample: 'Tom de Comunicacao' },
  { name: 'Body XL', size: '18px', weight: '400', family: 'Montserrat', sample: 'Estruturar crescimento com inteligencia e direcao.' },
  { name: 'Body L', size: '16px', weight: '400', family: 'Montserrat', sample: 'A ZNITH nao vende modinha tecnologica: entregamos direcao, consciencia e estrutura.' },
  { name: 'Body M', size: '14px', weight: '400', family: 'Montserrat', sample: 'Para empresas que querem crescer com consistencia e legado real.' },
  { name: 'Body S', size: '13px', weight: '400', family: 'Montserrat', sample: 'Consultoria estrategica de expansao comercial com inteligencia artificial.' },
  { name: 'Label', size: '12px', weight: '600', family: 'Montserrat', sample: 'LABEL — UPPERCASE' },
  { name: 'Caption', size: '11px', weight: '500', family: 'Montserrat', sample: 'VERSAO 3.0 — ABRIL 2026' },
];

const cinzelWeights = [400, 600, 700];
const montserratWeights = [300, 400, 500, 600, 700, 800];
---

<Layout title="Tipografia - ZNITH Design System" activeRoute="/tipografia">
  <div style="max-width: 1120px; margin: 0 auto; padding: 64px 32px;">

    <!-- Header -->
    <div class="reveal" style="margin-bottom: 64px;">
      <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.2em; color: #EDBA63; margin: 0 0 16px;">Design System</p>
      <h1 style="font-family: 'Cinzel', serif; font-size: clamp(32px, 5vw, 56px); color: #ffffff; margin: 0 0 16px; letter-spacing: 0.06em;">Tipografia</h1>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 16px; color: #8CA0B5; max-width: 560px; line-height: 1.7; margin: 0 0 24px;">Dois typefaces em contraste deliberado: Cinzel para autoridade e presenca, Montserrat para clareza e leitura.</p>
      <div class="gold-line"></div>
    </div>

    <!-- Cinzel Specimens -->
    <section class="reveal" style="margin-bottom: 64px;">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Cinzel — Display & Headings</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">Serifada classica. Autoridade, legado, presenca. Pesos: 400, 600, 700.</p>

      <div style="display: flex; flex-direction: column; gap: 0; background: #0D1724; border-radius: 16px; overflow: hidden; border: 1px solid rgba(38,64,96,0.4);">
        {cinzelWeights.map((weight, i) => (
          <div style={`padding: 32px; border-bottom: ${i < cinzelWeights.length - 1 ? '1px solid rgba(38,64,96,0.3)' : 'none'};`}>
            <div style="display: flex; align-items: baseline; justify-content: space-between; gap: 16px; flex-wrap: wrap;">
              <p style={`font-family: 'Cinzel', serif; font-size: clamp(28px, 4vw, 48px); color: #ffffff; margin: 0; font-weight: ${weight}; letter-spacing: 0.08em;`}>
                {weight === 400 ? 'Direção' : weight === 600 ? 'Consciência' : 'Legado'}
              </p>
              <div style="text-align: right; flex-shrink: 0;">
                <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; color: #EDBA63; margin: 0 0 2px; text-transform: uppercase; letter-spacing: 0.1em;">Cinzel</p>
                <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; color: #5E7890; margin: 0;">{weight === 400 ? 'Regular' : weight === 600 ? 'SemiBold' : 'Bold'} {weight}</p>
              </div>
            </div>
            <p style="font-family: 'Cinzel', serif; font-size: 16px; color: #5E7890; margin: 12px 0 0; font-weight: 400; letter-spacing: 0.06em;">
              ABCDEFGHIJKLMNOPQRSTUVWXYZ 0123456789
            </p>
          </div>
        ))}
      </div>
    </section>

    <!-- Montserrat Specimens -->
    <section class="reveal" style="margin-bottom: 64px;">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Montserrat — Body & UI</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">Sans-serif geometrica. Leitura, labels, UI. Pesos: 300, 400, 500, 600, 700, 800.</p>

      <div style="display: flex; flex-direction: column; gap: 0; background: #0D1724; border-radius: 16px; overflow: hidden; border: 1px solid rgba(38,64,96,0.4);">
        {montserratWeights.map((weight, i) => (
          <div style={`padding: 24px 32px; border-bottom: ${i < montserratWeights.length - 1 ? '1px solid rgba(38,64,96,0.3)' : 'none'}; display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap;`}>
            <p style={`font-family: 'Montserrat', sans-serif; font-size: 20px; color: #ffffff; margin: 0; font-weight: ${weight};`}>
              Estrutura com inteligencia e direcao
            </p>
            <span style="font-family: 'Montserrat', sans-serif; font-size: 11px; color: #5E7890; flex-shrink: 0;">
              {weight === 300 ? 'Light' : weight === 400 ? 'Regular' : weight === 500 ? 'Medium' : weight === 600 ? 'SemiBold' : weight === 700 ? 'Bold' : 'ExtraBold'} {weight}
            </span>
          </div>
        ))}
      </div>
    </section>

    <!-- Type Scale Table -->
    <section class="reveal" style="margin-bottom: 64px;">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Escala Tipografica</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">14 passos — do caption ao display</p>

      <div style="background: #0D1724; border-radius: 16px; overflow: hidden; border: 1px solid rgba(38,64,96,0.4);">
        <div style="display: grid; grid-template-columns: 120px 1fr 80px; background: #142940; padding: 12px 24px; border-bottom: 1px solid rgba(38,64,96,0.3);">
          <span style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; color: #D9A04A; text-transform: uppercase; letter-spacing: 0.1em;">Nome</span>
          <span style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; color: #D9A04A; text-transform: uppercase; letter-spacing: 0.1em;">Amostra</span>
          <span style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; color: #D9A04A; text-transform: uppercase; letter-spacing: 0.1em;">Tamanho</span>
        </div>
        {typeScale.map((t, i) => (
          <div style={`
            display: grid;
            grid-template-columns: 120px 1fr 80px;
            align-items: center;
            padding: 16px 24px;
            border-bottom: ${i < typeScale.length - 1 ? '1px solid rgba(38,64,96,0.2)' : 'none'};
            background: ${i % 2 === 0 ? 'transparent' : 'rgba(20, 41, 64, 0.2)'};
          `}>
            <span style="font-family: 'Montserrat', sans-serif; font-size: 11px; color: #5E7890;">{t.name}</span>
            <span style={`font-family: '${t.family}', ${t.family === 'Cinzel' ? 'serif' : 'sans-serif'}; font-size: ${t.size}; font-weight: ${t.weight}; color: #ffffff; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;`}>
              {t.sample}
            </span>
            <span style="font-family: 'Montserrat', sans-serif; font-size: 11px; color: #EDBA63; font-variant-numeric: tabular-nums;">{t.size}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Pairing Examples -->
    <section class="reveal">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Combinacoes de Uso</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">Como Cinzel e Montserrat funcionam juntos</p>

      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px;">

        <div style="background: #0D1724; border-radius: 16px; padding: 32px; border: 1px solid rgba(38,64,96,0.4);">
          <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.2em; color: #EDBA63; margin: 0 0 12px;">Consultoria</p>
          <h3 style="font-family: 'Cinzel', serif; font-size: 28px; color: #ffffff; margin: 0 0 12px; font-weight: 700; line-height: 1.2;">Arquitetura de Crescimento</h3>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 14px; color: #8CA0B5; margin: 0; line-height: 1.7;">Estruturamos operacoes comerciais para que empresas cresçam com mais clareza, previsibilidade e inteligencia.</p>
        </div>

        <div style="background: #0D1724; border-radius: 16px; padding: 32px; border: 1px solid rgba(38,64,96,0.4);">
          <h3 style="font-family: 'Cinzel', serif; font-size: 40px; color: #EDBA63; margin: 0 0 8px; font-weight: 700;">R$ 80M</h3>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 600; color: #C0CDD8; margin: 0 0 4px; text-transform: uppercase; letter-spacing: 0.08em;">em vendas estruturadas</p>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 12px; color: #5E7890; margin: 0;">Operacoes que saem de 20M para 80M/ano</p>
        </div>

        <div style="background: #0D1724; border-radius: 16px; padding: 32px; border: 1px solid rgba(38,64,96,0.4);">
          <h3 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 16px; font-weight: 600; letter-spacing: 0.06em;">Valores da ZNITH</h3>
          {['Verdade antes de vaidade', 'Estrutura acima de improviso', 'Inteligencia com criterio'].map(v => (
            <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 10px;">
              <div style="width: 4px; height: 4px; background: #EDBA63; border-radius: 50%; flex-shrink: 0;"></div>
              <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #C0CDD8; margin: 0;">{v}</p>
            </div>
          ))}
        </div>

        <div style="background: rgba(237,186,99,0.06); border-radius: 16px; padding: 32px; border: 1px solid rgba(237,186,99,0.15);">
          <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #EDBA63; margin: 0 0 8px; text-transform: uppercase; letter-spacing: 0.12em; font-weight: 600;">Pull Quote</p>
          <blockquote style="font-family: 'Cinzel', serif; font-size: 20px; color: #ffffff; margin: 0; font-weight: 400; line-height: 1.5; font-style: normal;">
            "Nao vender ferramenta por vender, mas estruturar empresas com inteligencia, processo, verdade e proposito."
          </blockquote>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 12px; color: #5E7890; margin: 16px 0 0;">Leilaine Campioto, CEO ZNITH</p>
        </div>

        <div style="background: #0D1724; border-radius: 16px; padding: 32px; border: 1px solid rgba(38,64,96,0.4);">
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
            <div style="width: 40px; height: 40px; border-radius: 10px; background: linear-gradient(135deg, #EDBA63, #C8883B); display: flex; align-items: center; justify-content: center;">
              <span style="font-family: 'Cinzel', serif; font-size: 16px; color: #00101E; font-weight: 700;">Z</span>
            </div>
            <div>
              <p style="font-family: 'Cinzel', serif; font-size: 15px; color: #ffffff; margin: 0; font-weight: 600;">ZNITH.AI</p>
              <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; color: #5E7890; margin: 0;">Expansao Comercial com IA</p>
            </div>
          </div>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #8CA0B5; margin: 0; line-height: 1.6;">Interface de card com logo + hierarquia tipografica clara.</p>
        </div>

        <div style="background: #0D1724; border-radius: 16px; padding: 32px; border: 1px solid rgba(38,64,96,0.4);">
          <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.25em; color: #EDBA63; margin: 0 0 8px;">Design System</p>
          <div class="gold-line" style="margin: 0 0 16px;"></div>
          <p style="font-family: 'Cinzel', serif; font-size: 18px; color: #ffffff; margin: 0 0 8px; font-weight: 600;">Label + Divisor + Heading</p>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0; line-height: 1.6;">Combinacao padrao de introducao de secao.</p>
        </div>

      </div>
    </section>
  </div>
</Layout>
