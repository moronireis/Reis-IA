---
import Layout from '../layouts/Layout.astro';

const navyScale = [
  { name: 'Black', var: '--black', hex: '#000A14' },
  { name: 'Base 950', var: '--base-950', hex: '#00101E' },
  { name: 'Base 900', var: '--base-900', hex: '#00172B', primary: true },
  { name: 'Base 850', var: '--base-850', hex: '#001F38' },
  { name: 'Base 800', var: '--base-800', hex: '#0D1724' },
  { name: 'Base 750', var: '--base-750', hex: '#0F2236' },
  { name: 'Base 700', var: '--base-700', hex: '#142940' },
  { name: 'Base 600', var: '--base-600', hex: '#1C3550' },
  { name: 'Base 500', var: '--base-500', hex: '#264060' },
  { name: 'Base 400', var: '--base-400', hex: '#3A5575' },
  { name: 'Base 300', var: '--base-300', hex: '#5E7890' },
  { name: 'Base 200', var: '--base-200', hex: '#8CA0B5' },
  { name: 'Base 100', var: '--base-100', hex: '#C0CDD8' },
  { name: 'Base 50', var: '--base-50', hex: '#E8EEF3' },
];

const goldScale = [
  { name: 'Gold 50', var: '--gold-50', hex: '#FFF8ED' },
  { name: 'Gold 100', var: '--gold-100', hex: '#FDEFD0' },
  { name: 'Gold 200', var: '--gold-200', hex: '#EDBA63', primary: true },
  { name: 'Gold 300', var: '--gold-300', hex: '#D9A04A' },
  { name: 'Gold 400', var: '--gold-400', hex: '#C8883B' },
  { name: 'Gold 500', var: '--gold-500', hex: '#B87530' },
  { name: 'Gold 600', var: '--gold-600', hex: '#A85D18' },
  { name: 'Gold 700', var: '--gold-700', hex: '#8B4A12' },
  { name: 'Gold 800', var: '--gold-800', hex: '#6B380E' },
  { name: 'Gold 900', var: '--gold-900', hex: '#4A270A' },
];

const surfaceSystem = [
  { label: 'Page Background', hex: '#00172B', desc: 'Base 900 — superficie primaria' },
  { label: 'Card / Surface', hex: '#0D1724', desc: 'Base 800 — cards e paineis' },
  { label: 'Elevated', hex: '#142940', desc: 'Base 700 — modais e dropdowns' },
  { label: 'Border', hex: '#264060', desc: 'Base 500 — bordas e divisores' },
  { label: 'Primary Accent', hex: '#EDBA63', desc: 'Gold 200 — elemento principal' },
  { label: 'Accent Hover', hex: '#D9A04A', desc: 'Gold 300 — estado hover' },
];

const contrastPairs = [
  { bg: '#00172B', text: '#EDBA63', bgLabel: 'Base 900', textLabel: 'Gold 200', ratio: '6.2:1', pass: 'AA' },
  { bg: '#00172B', text: '#C0CDD8', bgLabel: 'Base 900', textLabel: 'Base 100', ratio: '8.4:1', pass: 'AAA' },
  { bg: '#0D1724', text: '#EDBA63', bgLabel: 'Base 800', textLabel: 'Gold 200', ratio: '5.9:1', pass: 'AA' },
  { bg: '#142940', text: '#EDBA63', bgLabel: 'Base 700', textLabel: 'Gold 200', ratio: '5.1:1', pass: 'AA' },
];
---

<Layout title="Cores - ZNITH Design System" activeRoute="/cores">
  <div style="max-width: 1120px; margin: 0 auto; padding: 64px 32px;">

    <!-- Page Header -->
    <div class="reveal" style="margin-bottom: 64px;">
      <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.2em; color: #EDBA63; margin: 0 0 16px;">Design System</p>
      <h1 style="font-family: 'Cinzel', serif; font-size: clamp(32px, 5vw, 56px); color: #ffffff; margin: 0 0 16px; letter-spacing: 0.06em;">Cores</h1>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 16px; color: #8CA0B5; max-width: 560px; line-height: 1.7; margin: 0 0 24px;">Paleta extraida diretamente dos assets de marca — azul marinho profundo e ouro da coroa.</p>
      <div class="gold-line"></div>
    </div>

    <!-- Navy Scale -->
    <section class="reveal" style="margin-bottom: 64px;">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Escala Azul Marinho</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">Base extraida de #00172B (Z-3.png background)</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 12px;">
        {navyScale.map(color => (
          <button
            class="swatch-btn"
            data-hex={color.hex}
            style={`
              background: none;
              border: none;
              cursor: pointer;
              text-align: left;
              padding: 0;
              transition: transform 0.2s;
            `}
            title="Clique para copiar"
          >
            <div style={`
              width: 100%;
              height: 80px;
              border-radius: 12px;
              background: ${color.hex};
              border: ${color.primary ? '2px solid #EDBA63' : '1px solid rgba(38,64,96,0.4)'};
              margin-bottom: 8px;
              transition: transform 0.2s;
              position: relative;
            `}>
              {color.primary && (
                <span style="position: absolute; top: 6px; right: 6px; background: #EDBA63; color: #00101E; font-family: 'Montserrat', sans-serif; font-size: 9px; font-weight: 700; padding: 2px 6px; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.05em;">Primary</span>
              )}
            </div>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 12px; font-weight: 600; color: #C0CDD8; margin: 0 0 2px;">{color.name}</p>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; color: #5E7890; margin: 0 0 2px; font-variant-numeric: tabular-nums;">{color.hex}</p>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 10px; color: #3A5575; margin: 0;">{color.var}</p>
          </button>
        ))}
      </div>
    </section>

    <!-- Gold Scale -->
    <section class="reveal" style="margin-bottom: 64px;">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Escala Ouro</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">Extraida da coroa do leao — brilhante, media e sombra</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 12px;">
        {goldScale.map(color => (
          <button
            class="swatch-btn"
            data-hex={color.hex}
            style="background: none; border: none; cursor: pointer; text-align: left; padding: 0;"
            title="Clique para copiar"
          >
            <div style={`
              width: 100%;
              height: 80px;
              border-radius: 12px;
              background: ${color.hex};
              border: ${color.primary ? '2px solid #EDBA63' : '1px solid rgba(38,64,96,0.2)'};
              margin-bottom: 8px;
              position: relative;
            `}>
              {color.primary && (
                <span style="position: absolute; top: 6px; right: 6px; background: #00101E; color: #EDBA63; font-family: 'Montserrat', sans-serif; font-size: 9px; font-weight: 700; padding: 2px 6px; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.05em;">Key</span>
              )}
            </div>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 12px; font-weight: 600; color: #C0CDD8; margin: 0 0 2px;">{color.name}</p>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; color: #5E7890; margin: 0; font-variant-numeric: tabular-nums;">{color.hex}</p>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 10px; color: #3A5575; margin: 0;">{color.var}</p>
          </button>
        ))}
      </div>
    </section>

    <!-- Surface System -->
    <section class="reveal" style="margin-bottom: 64px;">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Sistema de Superficies</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">Camadas de profundidade para criar hierarquia visual</p>
      <div style="display: flex; flex-direction: column; gap: 0; border-radius: 16px; overflow: hidden; border: 1px solid rgba(38,64,96,0.4);">
        {surfaceSystem.map((s, i) => (
          <div style={`
            display: flex;
            align-items: center;
            gap: 20px;
            padding: 20px 24px;
            background: ${s.hex};
            border-bottom: ${i < surfaceSystem.length - 1 ? '1px solid rgba(38,64,96,0.3)' : 'none'};
          `}>
            <div style={`
              width: 48px;
              height: 48px;
              border-radius: 10px;
              background: ${s.hex};
              border: 1px solid rgba(237,186,99,0.3);
              flex-shrink: 0;
            `}></div>
            <div>
              <p style="font-family: 'Cinzel', serif; font-size: 14px; color: #ffffff; margin: 0 0 4px; font-weight: 600;">{s.label}</p>
              <p style="font-family: 'Montserrat', sans-serif; font-size: 12px; color: #8CA0B5; margin: 0;">{s.desc} — <code style="font-family: 'Montserrat', sans-serif; color: #EDBA63;">{s.hex}</code></p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Contrast Checker -->
    <section class="reveal" style="margin-bottom: 64px;">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Checagem de Contraste</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">Pares de cor aprovados para acessibilidade WCAG 2.1</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px;">
        {contrastPairs.map(pair => (
          <div style={`
            background: ${pair.bg};
            border-radius: 16px;
            padding: 24px;
            border: 1px solid rgba(38,64,96,0.4);
          `}>
            <p style={`font-family: 'Cinzel', serif; font-size: 24px; color: ${pair.text}; margin: 0 0 12px; font-weight: 700;`}>ZNITH</p>
            <p style={`font-family: 'Montserrat', sans-serif; font-size: 13px; color: ${pair.text}; margin: 0 0 16px;`}>Direcao. Consciencia. Legado.</p>
            <div style="display: flex; align-items: center; justify-content: space-between; padding-top: 12px; border-top: 1px solid rgba(255,255,255,0.06);">
              <span style="font-family: 'Montserrat', sans-serif; font-size: 11px; color: #5E7890;">{pair.bgLabel} + {pair.textLabel}</span>
              <span style={`
                font-family: 'Montserrat', sans-serif;
                font-size: 11px;
                font-weight: 700;
                padding: 3px 8px;
                border-radius: 6px;
                background: ${pair.pass === 'AAA' ? 'rgba(42, 107, 74, 0.3)' : 'rgba(42, 74, 107, 0.3)'};
                color: ${pair.pass === 'AAA' ? '#4ade80' : '#60a5fa'};
              `}>{pair.ratio} {pair.pass}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Semantic Colors -->
    <section class="reveal">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Cores Semanticas</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">Uso muted — nunca vibrante, sempre integrado ao sistema</p>
      <div style="display: flex; gap: 16px; flex-wrap: wrap;">
        {[
          { label: 'Success', hex: '#2A6B4A', text: 'Confirmacoes e sucesso' },
          { label: 'Warning', hex: '#7A5800', text: 'Alertas e atencao' },
          { label: 'Error', hex: '#7A2020', text: 'Erros e falhas' },
        ].map(s => (
          <div style={`background: ${s.hex}22; border: 1px solid ${s.hex}66; border-radius: 12px; padding: 20px 24px; min-width: 180px;`}>
            <div style={`width: 32px; height: 32px; border-radius: 8px; background: ${s.hex}; margin-bottom: 12px;`}></div>
            <p style="font-family: 'Cinzel', serif; font-size: 14px; color: #ffffff; margin: 0 0 4px;">{s.label}</p>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; color: #8CA0B5; margin: 0;">{s.hex}</p>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; color: #5E7890; margin: 4px 0 0;">{s.text}</p>
          </div>
        ))}
      </div>
    </section>
  </div>

  <!-- Toast notification -->
  <div id="copy-toast" style="
    position: fixed;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: rgba(13, 23, 36, 0.95);
    border: 1px solid rgba(237, 186, 99, 0.3);
    border-radius: 10px;
    padding: 12px 24px;
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    color: #EDBA63;
    z-index: 2000;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  ">Copiado!</div>

  <script>
    const toast = document.getElementById('copy-toast');

    document.querySelectorAll('.swatch-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const hex = (btn as HTMLElement).dataset.hex;
        if (hex) {
          navigator.clipboard.writeText(hex).then(() => {
            if (toast) {
              toast.textContent = `${hex} copiado!`;
              toast.style.transform = 'translateX(-50%) translateY(0)';
              setTimeout(() => {
                if (toast) toast.style.transform = 'translateX(-50%) translateY(100px)';
              }, 2000);
            }
          });
        }
      });

      btn.addEventListener('mouseenter', () => {
        const inner = (btn as HTMLElement).querySelector('div');
        if (inner) inner.style.transform = 'scale(1.05)';
      });
      btn.addEventListener('mouseleave', () => {
        const inner = (btn as HTMLElement).querySelector('div');
        if (inner) inner.style.transform = '';
      });
    });
  </script>
</Layout>
