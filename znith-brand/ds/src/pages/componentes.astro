---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Componentes - ZNITH Design System" activeRoute="/componentes">
  <div style="max-width: 1120px; margin: 0 auto; padding: 64px 32px;">

    <!-- Header -->
    <div class="reveal" style="margin-bottom: 64px;">
      <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.2em; color: #EDBA63; margin: 0 0 16px;">Design System</p>
      <h1 style="font-family: 'Cinzel', serif; font-size: clamp(32px, 5vw, 56px); color: #ffffff; margin: 0 0 16px; letter-spacing: 0.06em;">Componentes</h1>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 16px; color: #8CA0B5; max-width: 560px; line-height: 1.7; margin: 0 0 24px;">Todos os componentes interativos do sistema — producao-ready, acessiveis e com estados completos.</p>
      <div class="gold-line"></div>
    </div>

    <!-- ====== BUTTONS ====== -->
    <section class="reveal" style="margin-bottom: 80px;">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Botoes</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">4 variantes, 3 tamanhos, estados: default, hover, focus, disabled</p>

      <div style="background: #0D1724; border-radius: 20px; padding: 40px; border: 1px solid rgba(38,64,96,0.4); display: flex; flex-direction: column; gap: 40px;">

        <!-- Primary Buttons -->
        <div>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: #EDBA63; margin: 0 0 16px;">Primary</p>
          <div style="display: flex; flex-wrap: wrap; gap: 12px; align-items: center;">
            <button class="btn-primary btn-sm">Pequeno</button>
            <button class="btn-primary btn-md">Medio</button>
            <button class="btn-primary btn-lg">Grande</button>
            <button class="btn-primary btn-md" disabled style="opacity: 0.4; cursor: not-allowed;">Desativado</button>
          </div>
        </div>

        <!-- Secondary Buttons -->
        <div>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: #EDBA63; margin: 0 0 16px;">Secondary</p>
          <div style="display: flex; flex-wrap: wrap; gap: 12px; align-items: center;">
            <button class="btn-secondary btn-sm">Pequeno</button>
            <button class="btn-secondary btn-md">Medio</button>
            <button class="btn-secondary btn-lg">Grande</button>
            <button class="btn-secondary btn-md" disabled style="opacity: 0.4; cursor: not-allowed;">Desativado</button>
          </div>
        </div>

        <!-- Ghost Buttons -->
        <div>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: #EDBA63; margin: 0 0 16px;">Ghost</p>
          <div style="display: flex; flex-wrap: wrap; gap: 12px; align-items: center;">
            <button class="btn-ghost btn-sm">Pequeno</button>
            <button class="btn-ghost btn-md">Medio</button>
            <button class="btn-ghost btn-lg">Grande</button>
            <button class="btn-ghost btn-md" disabled style="opacity: 0.4; cursor: not-allowed;">Desativado</button>
          </div>
        </div>

        <!-- Dark Buttons -->
        <div>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: #EDBA63; margin: 0 0 16px;">Dark</p>
          <div style="display: flex; flex-wrap: wrap; gap: 12px; align-items: center;">
            <button class="btn-dark btn-sm">Pequeno</button>
            <button class="btn-dark btn-md">Medio</button>
            <button class="btn-dark btn-lg">Grande</button>
            <button class="btn-dark btn-md" disabled style="opacity: 0.4; cursor: not-allowed;">Desativado</button>
          </div>
        </div>

        <!-- With Icons -->
        <div>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: #EDBA63; margin: 0 0 16px;">Com Icones</p>
          <div style="display: flex; flex-wrap: wrap; gap: 12px; align-items: center;">
            <button class="btn-primary btn-md" style="display: flex; align-items: center; gap: 8px;">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2v12M2 8h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              Novo Projeto
            </button>
            <button class="btn-secondary btn-md" style="display: flex; align-items: center; gap: 8px;">
              Saiba Mais
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- ====== CARDS ====== -->
    <section class="reveal" style="margin-bottom: 80px;">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Cards</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">5 variantes — Glass, Solid, Feature, Stat, Bordered</p>

      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">

        <!-- Glass Card -->
        <div>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: #5E7890; margin: 0 0 12px;">Glass Card</p>
          <div class="card-glass">
            <p style="font-family: 'Cinzel', serif; font-size: 18px; color: #ffffff; margin: 0 0 8px; font-weight: 600; letter-spacing: 0.04em;">Arquitetura Comercial</p>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #8CA0B5; margin: 0; line-height: 1.6;">Estruturamos operacoes para crescimento previsivel com IA, processo e governanca.</p>
          </div>
        </div>

        <!-- Solid Card -->
        <div>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: #5E7890; margin: 0 0 12px;">Solid Card</p>
          <div class="card-solid">
            <p style="font-family: 'Cinzel', serif; font-size: 18px; color: #ffffff; margin: 0 0 8px; font-weight: 600; letter-spacing: 0.04em;">Consultoria Estrategica</p>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #8CA0B5; margin: 0; line-height: 1.6;">Diagnostico profundo, leitura de gargalos e estruturacao de crescimento com inteligencia.</p>
          </div>
        </div>

        <!-- Feature Card -->
        <div>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: #5E7890; margin: 0 0 12px;">Feature Card</p>
          <div class="card-glass card-feature">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: linear-gradient(135deg, rgba(237,186,99,0.15), rgba(237,186,99,0.05)); border: 1px solid rgba(237,186,99,0.2); display: flex; align-items: center; justify-content: center; margin-bottom: 16px;">
              <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                <path d="M11 3v16M3 11h16" stroke="#EDBA63" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <p style="font-family: 'Cinzel', serif; font-size: 16px; color: #ffffff; margin: 0 0 8px; font-weight: 600;">Expansao Comercial</p>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #8CA0B5; margin: 0; line-height: 1.6;">Transformamos operacoes em sistemas de crescimento previsivel com uso real de IA.</p>
          </div>
        </div>

        <!-- Stat Card -->
        <div>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: #5E7890; margin: 0 0 12px;">Stat Card</p>
          <div class="card-solid">
            <p style="font-family: 'Cinzel', serif; font-size: 48px; color: #EDBA63; margin: 0 0 4px; font-weight: 700; line-height: 1;">R$80M</p>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 600; color: #C0CDD8; margin: 0 0 4px; text-transform: uppercase; letter-spacing: 0.08em;">Em vendas estruturadas</p>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 12px; color: #5E7890; margin: 0;">Operacao cresceu de 20M para 80M/ano</p>
          </div>
        </div>

        <!-- Bordered Card -->
        <div>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: #5E7890; margin: 0 0 12px;">Bordered Card</p>
          <div class="card-bordered">
            <p style="font-family: 'Cinzel', serif; font-size: 18px; color: #ffffff; margin: 0 0 8px; font-weight: 600; letter-spacing: 0.04em;">RCaaS</p>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #8CA0B5; margin: 0; line-height: 1.6;">Revenue Center as a Service — acompanhamento estrategico e operacional continuo da maquina comercial.</p>
          </div>
        </div>

        <!-- Gold Accent Card -->
        <div>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: #5E7890; margin: 0 0 12px;">Gold Accent</p>
          <div style="background: rgba(237,186,99,0.05); border: 1px solid rgba(237,186,99,0.2); border-radius: 20px; padding: 32px; transition: border-color 0.25s, box-shadow 0.25s;" class="card-gold">
            <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.2em; color: #EDBA63; margin: 0 0 12px;">Destaque</p>
            <p style="font-family: 'Cinzel', serif; font-size: 18px; color: #ffffff; margin: 0 0 8px; font-weight: 600;">ZNITH.AI OS</p>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #8CA0B5; margin: 0; line-height: 1.6;">Plataforma de estruturacao comercial — arquitetura de sistema, implantacao e escalabilidade.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ====== INPUTS ====== -->
    <section class="reveal" style="margin-bottom: 80px;">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Inputs</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">Campos de formulario — default, focus, erro, desativado</p>

      <div style="background: #0D1724; border-radius: 20px; padding: 40px; border: 1px solid rgba(38,64,96,0.4); display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 28px;">

        <!-- Default -->
        <div>
          <label class="input-label">Nome Completo</label>
          <input type="text" placeholder="Leilaine Campioto" class="input-field" />
        </div>

        <!-- With value -->
        <div>
          <label class="input-label">Email Corporativo</label>
          <input type="email" value="leilaine@znith.com.br" class="input-field" />
        </div>

        <!-- Error state -->
        <div>
          <label class="input-label">Telefone</label>
          <input type="tel" placeholder="+55 11 99999-9999" class="input-field input-error" />
          <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; color: #f87171; margin: 6px 0 0;">Formato invalido. Use: +55 11 99999-9999</p>
        </div>

        <!-- Disabled -->
        <div>
          <label class="input-label" style="opacity: 0.5;">Empresa (Somente leitura)</label>
          <input type="text" value="ZNITH Consulting" class="input-field" disabled style="opacity: 0.5; cursor: not-allowed;" />
        </div>

        <!-- Textarea -->
        <div style="grid-column: 1 / -1;">
          <label class="input-label">Mensagem</label>
          <textarea placeholder="Descreva o desafio comercial da sua operacao..." class="input-field" style="min-height: 100px; resize: vertical;"></textarea>
        </div>

        <!-- Select -->
        <div>
          <label class="input-label">Segmento</label>
          <select class="input-field" style="cursor: pointer;">
            <option value="">Selecione</option>
            <option>Consultoria</option>
            <option>Industria</option>
            <option>Tecnologia</option>
            <option>Agencia</option>
          </select>
        </div>

      </div>
    </section>

    <!-- ====== BADGES ====== -->
    <section class="reveal" style="margin-bottom: 80px;">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Badges</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">Rotulos, status e categorias</p>

      <div style="background: #0D1724; border-radius: 20px; padding: 40px; border: 1px solid rgba(38,64,96,0.4); display: flex; flex-wrap: wrap; gap: 12px; align-items: center;">
        <span class="badge badge-gold">Gold</span>
        <span class="badge badge-navy">Navy</span>
        <span class="badge badge-success">Ativo</span>
        <span class="badge badge-error">Inativo</span>
        <span class="badge badge-warning">Pendente</span>
        <span class="badge badge-gold">Premium</span>
        <span class="badge badge-navy">v3.0</span>
        <span class="badge badge-success">Aprovado</span>
        <span class="badge badge-gold">Consultoria</span>
        <span class="badge badge-navy">RCaaS</span>
        <span class="badge badge-gold">ZNITH.AI</span>
        <span class="badge badge-navy">Líderes Leões</span>
      </div>
    </section>

    <!-- ====== DIVIDERS ====== -->
    <section class="reveal" style="margin-bottom: 80px;">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Divisores</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">3 estilos — solid, gradient, gold</p>

      <div style="background: #0D1724; border-radius: 20px; padding: 40px; border: 1px solid rgba(38,64,96,0.4); display: flex; flex-direction: column; gap: 32px;">

        <div>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; color: #5E7890; margin: 0 0 16px; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600;">Solid</p>
          <div style="height: 1px; background: #1C3550;"></div>
        </div>

        <div>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; color: #5E7890; margin: 0 0 16px; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600;">Gradient</p>
          <div style="height: 1px; background: linear-gradient(90deg, transparent, #264060, transparent);"></div>
        </div>

        <div>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; color: #5E7890; margin: 0 0 16px; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600;">Gold</p>
          <div class="gold-line" style="width: 120px !important;"></div>
        </div>

        <div>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; color: #5E7890; margin: 0 0 16px; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600;">Gold Centered</p>
          <div style="height: 1px; background: linear-gradient(90deg, transparent, #A85D18, #EDBA63, #A85D18, transparent); max-width: 120px; margin: 0 auto;"></div>
        </div>

      </div>
    </section>

    <!-- ====== TABLES ====== -->
    <section class="reveal" style="margin-bottom: 80px;">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Tabelas</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">Header ouro, linhas alternadas, hover sutil</p>

      <div style="background: #0D1724; border-radius: 20px; overflow: hidden; border: 1px solid rgba(38,64,96,0.4);">
        <table style="width: 100%; border-collapse: collapse;">
          <thead>
            <tr style="background: #142940;">
              <th style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; color: #D9A04A; text-transform: uppercase; letter-spacing: 0.1em; padding: 14px 24px; text-align: left; border-bottom: 1px solid rgba(38,64,96,0.4);">Servico</th>
              <th style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; color: #D9A04A; text-transform: uppercase; letter-spacing: 0.1em; padding: 14px 24px; text-align: left; border-bottom: 1px solid rgba(38,64,96,0.4);">Faixa de Valor</th>
              <th style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; color: #D9A04A; text-transform: uppercase; letter-spacing: 0.1em; padding: 14px 24px; text-align: left; border-bottom: 1px solid rgba(38,64,96,0.4);">Modelo</th>
              <th style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; color: #D9A04A; text-transform: uppercase; letter-spacing: 0.1em; padding: 14px 24px; text-align: left; border-bottom: 1px solid rgba(38,64,96,0.4);">Status</th>
            </tr>
          </thead>
          <tbody>
            {[
              { name: 'Consultoria Estrategica', value: 'R$15K - R$250K+', model: 'Projeto', status: 'Ativo', statusType: 'success' },
              { name: 'RCaaS', value: 'R$5K - R$85K/mes', model: 'Recorrencia', status: 'Ativo', statusType: 'success' },
              { name: 'ZNITH.AI OS', value: 'Sob consulta', model: 'Implantacao', status: 'Lancamento', statusType: 'warning' },
              { name: 'Palestras / Workshops', value: 'Sob consulta', model: 'Evento', status: 'Disponivel', statusType: 'success' },
            ].map((row, i) => (
              <tr class="table-row" style={`background: ${i % 2 === 0 ? 'transparent' : 'rgba(20, 41, 64, 0.2)'};`}>
                <td style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #C0CDD8; padding: 14px 24px; border-bottom: 1px solid rgba(38,64,96,0.15);">{row.name}</td>
                <td style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #EDBA63; padding: 14px 24px; border-bottom: 1px solid rgba(38,64,96,0.15);">{row.value}</td>
                <td style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #8CA0B5; padding: 14px 24px; border-bottom: 1px solid rgba(38,64,96,0.15);">{row.model}</td>
                <td style="padding: 14px 24px; border-bottom: 1px solid rgba(38,64,96,0.15);">
                  <span class={`badge badge-${row.statusType}`}>{row.status}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- ====== NAV BAR MOCK ====== -->
    <section class="reveal" style="margin-bottom: 80px;">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Barra de Navegacao</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">Top bar fixa — 64px, glass morphism, blur</p>

      <div style="
        height: 64px;
        background: rgba(0, 16, 30, 0.85);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(38, 64, 96, 0.3);
        border-radius: 16px;
        display: flex;
        align-items: center;
        padding: 0 32px;
        overflow: hidden;
      ">
        <div style="display: flex; align-items: center; justify-content: space-between; width: 100%;">
          <div style="display: flex; align-items: center; gap: 10px;">
            <img src="/logos/Z.png" alt="ZNITH" style="height: 28px; width: auto;" />
            <span style="font-family: 'Cinzel', serif; font-size: 16px; color: #ffffff; letter-spacing: 0.12em; font-weight: 600;">ZNITH</span>
          </div>
          <div style="display: flex; gap: 4px;">
            {['Servicos', 'Cases', 'Sobre', 'Contato'].map((l, i) => (
              <span style={`
                font-family: 'Montserrat', sans-serif;
                font-size: 11px;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                padding: 6px 14px;
                border-radius: 6px;
                color: ${i === 0 ? '#EDBA63' : '#8CA0B5'};
                background: ${i === 0 ? 'rgba(237, 186, 99, 0.06)' : 'transparent'};
              `}>{l}</span>
            ))}
          </div>
          <span style="
            font-family: 'Montserrat', sans-serif;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: #00101E;
            background: linear-gradient(135deg, #EDBA63, #C8883B);
            padding: 3px 10px;
            border-radius: 6px;
          ">v3.0</span>
        </div>
      </div>
    </section>

    <!-- ====== FORM EXAMPLE ====== -->
    <section class="reveal">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Formulario Completo</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">Composicao real — label, input, selecao, textarea e CTA</p>

      <div class="card-glass" style="max-width: 560px;">
        <h3 style="font-family: 'Cinzel', serif; font-size: 20px; color: #ffffff; margin: 0 0 8px; font-weight: 600;">Solicitar Diagnostico</h3>
        <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 28px; line-height: 1.6;">Preencha para que possamos entender o cenario da sua operacao comercial.</p>
        <div style="display: flex; flex-direction: column; gap: 20px;">
          <div>
            <label class="input-label">Nome Completo</label>
            <input type="text" placeholder="Seu nome" class="input-field" />
          </div>
          <div>
            <label class="input-label">Email</label>
            <input type="email" placeholder="email@empresa.com.br" class="input-field" />
          </div>
          <div>
            <label class="input-label">Faturamento Anual Aproximado</label>
            <select class="input-field" style="cursor: pointer;">
              <option value="">Selecione</option>
              <option>Ate R$1M</option>
              <option>R$1M - R$5M</option>
              <option>R$5M - R$20M</option>
              <option>Acima de R$20M</option>
            </select>
