---
import Layout from '../layouts/Layout.astro';

const values = [
  { word: 'Coragem', desc: 'Para governar o que foi confiado' },
  { word: 'Consciencia', desc: 'Para nao se perder no processo' },
  { word: 'Governo', desc: 'Nao aparencia — responsabilidade real' },
  { word: 'Maturidade', desc: 'Interior antes do exterior' },
  { word: 'Legado', desc: 'Construcao que permanece' },
  { word: 'Fe', desc: 'Fundamento de tudo o mais' },
  { word: 'Verdade', desc: 'Acima de performance' },
];

const prohibitions = [
  'Lideranca construida em carisma sem carater',
  'Motivacionais que inflamam por um dia sem transformar a base',
  'Alta performance sem identidade, maturidade e responsabilidade',
  'Formulas prontas que ignoram processo e consciencia',
  'Crescimento sustentado em exaucao, improviso e ego',
  'Liderar para parecer forte — nao para governar com verdade',
];

const symbols = [
  { symbol: 'O Leao', meaning: 'Governo, coragem, vigilancia, presenca, autoridade, protecao e consciencia de territorio' },
  { symbol: 'A Coroa', meaning: 'Autoridade, responsabilidade e governo — nao status, mas peso de missao' },
  { symbol: 'O Olhar do Leao', meaning: 'Direcao, vigilancia, consciencia de tudo que cerca' },
  { symbol: 'O Dourado', meaning: 'Legado, honra e autoridade — construcao que vale e permanece' },
  { symbol: 'O Azul Profundo', meaning: 'Profundidade, firmeza e maturidade — nao superficialidade' },
];

const rituals = [
  'Encontro semanal',
  'Desafio mensal',
  'Celebracao de conquistas',
  'Onboarding estruturado',
  'Mentoria entre pares',
  'Ranking de avanco',
];
---

<Layout title="Lideres Leoes - ZNITH Design System" activeRoute="/movimento">

  <!-- Full-width Manifesto Hero -->
  <div style="
    position: relative;
    overflow: hidden;
    background: #00101E;
    border-bottom: 1px solid rgba(38,64,96,0.4);
    padding: 120px 32px;
    text-align: center;
  ">
    <!-- Grain texture overlay -->
    <div style="
      position: absolute;
      inset: 0;
      background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E&quot;);
      opacity: 0.04;
      pointer-events: none;
    "></div>

    <!-- Radial glow -->
    <div style="
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(168, 93, 24, 0.06) 0%, transparent 70%);
      pointer-events: none;
    "></div>

    <div style="position: relative; z-index: 1; max-width: 800px; margin: 0 auto;" class="reveal">
      <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.3em; color: #A85D18; margin: 0 0 24px;">Manifesto</p>

      <div style="display: flex; justify-content: center; margin-bottom: 32px;">
        <img src="/logos/ZINITH_oficial_png - sem frase.png" alt="ZNITH" style="height: 80px; width: auto; opacity: 0.9;" />
      </div>

      <h1 style="font-family: 'Cinzel', serif; font-size: clamp(28px, 5vw, 52px); color: #ffffff; margin: 0 0 24px; letter-spacing: 0.08em; line-height: 1.2;">Lideres Leoes</h1>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 14px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.2em; color: #A85D18; margin: 0 0 40px;">Coragem para governar. Consciencia para permanecer.</p>

      <!-- Gold line -->
      <div style="height: 1px; background: linear-gradient(90deg, transparent, #A85D18, #EDBA63, #A85D18, transparent); max-width: 160px; margin: 0 auto 40px;"></div>

      <p style="font-family: 'Montserrat', sans-serif; font-size: 16px; color: #8CA0B5; line-height: 1.9; max-width: 640px; margin: 0 auto 24px;">
        Acreditamos que lideranca nao e cargo, aparencia ou performance vazia. Lideranca e responsabilidade, direcao, coragem e consciencia diante daquilo que Deus confiou as nossas maos.
      </p>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 16px; color: #8CA0B5; line-height: 1.9; max-width: 640px; margin: 0 auto;">
        Defendemos que fe, estrategia, inteligencia, vendas, lideranca e tecnologia podem caminhar juntas, formando lideres que nao apenas crescem, mas sustentam crescimento com verdade, estrutura e proposito.
      </p>
    </div>
  </div>

  <div style="max-width: 1120px; margin: 0 auto; padding: 64px 32px;">

    <!-- Counter -->
    <section class="reveal" style="margin-bottom: 64px; text-align: center;">
      <div style="background: rgba(168,93,24,0.06); border: 1px solid rgba(168,93,24,0.2); border-radius: 20px; padding: 48px;">
        <p style="font-family: 'Cinzel', serif; font-size: 80px; color: #EDBA63; margin: 0; font-weight: 700; line-height: 1;" id="counter">0</p>
        <p style="font-family: 'Montserrat', sans-serif; font-size: 14px; font-weight: 600; color: #C0CDD8; margin: 8px 0 0; text-transform: uppercase; letter-spacing: 0.12em;">Lideres em Formacao</p>
        <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 8px 0 0;">A tribo esta crescendo. Meta: 100 lideres.</p>
      </div>
    </section>

    <!-- Origin of Frustration -->
    <section class="reveal" style="margin-bottom: 64px;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px;">
        <div>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.2em; color: #A85D18; margin: 0 0 16px;">Frustracao de Origem</p>
          <h2 style="font-family: 'Cinzel', serif; font-size: 28px; color: #ffffff; margin: 0 0 20px; letter-spacing: 0.04em; line-height: 1.3;">O que estava quebrado</h2>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 14px; color: #8CA0B5; margin: 0 0 16px; line-height: 1.8;">
            Lideres cansados, confusos e sobrecarregados, tentando sustentar empresas, equipes e responsabilidades sem direcao clara, sem estrutura emocional e sem fundamento suficiente para suportar o peso da propria missao.
          </p>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 14px; color: #8CA0B5; margin: 0; line-height: 1.8;">
            O mercado formando profissionais rapidos, mas nao lideres integros. Pessoas cheias de informacao, mas sem consciencia, governo e maturidade para conduzir o que receberam.
          </p>
        </div>
        <div>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.2em; color: #A85D18; margin: 0 0 16px;">Mundo Ideal</p>
          <h2 style="font-family: 'Cinzel', serif; font-size: 28px; color: #ffffff; margin: 0 0 20px; letter-spacing: 0.04em; line-height: 1.3;">Se o movimento vencesse</h2>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 14px; color: #8CA0B5; margin: 0 0 16px; line-height: 1.8;">
            Lideres mais fortes por dentro, mais claros em suas decisoes e mais integros na forma de conduzir pessoas, empresas e propositos. Menos improviso, menos lideranca baseada em ego.
          </p>
          <p style="font-family: 'Montserrat', sans-serif; font-size: 14px; color: #8CA0B5; margin: 0; line-height: 1.8;">
            Uma geracao que entende que nao basta chegar ao topo — e preciso chegar com consciencia, permanecer com carater e usar a influencia para construir algo que glorifique a Deus e gere legado real.
          </p>
        </div>
      </div>
    </section>

    <!-- Symbols -->
    <section class="reveal" style="margin-bottom: 64px;">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Simbolos do Movimento</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">Cada simbolo carrega significado — nao e decoracao</p>

      <div style="display: flex; flex-direction: column; gap: 0; background: #0D1724; border-radius: 20px; overflow: hidden; border: 1px solid rgba(38,64,96,0.4);">
        {symbols.map((s, i) => (
          <div style={`
            display: flex;
            align-items: start;
            gap: 20px;
            padding: 24px 32px;
            border-bottom: ${i < symbols.length - 1 ? '1px solid rgba(38,64,96,0.25)' : 'none'};
          `}>
            <div style="width: 4px; height: 4px; background: #A85D18; border-radius: 50%; flex-shrink: 0; margin-top: 6px;"></div>
            <div>
              <span style="font-family: 'Cinzel', serif; font-size: 15px; color: #EDBA63; font-weight: 600;">{s.symbol}</span>
              <span style="font-family: 'Montserrat', sans-serif; font-size: 14px; color: #5E7890;"> — </span>
              <span style="font-family: 'Montserrat', sans-serif; font-size: 14px; color: #8CA0B5;">{s.meaning}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Values + What We Oppose -->
    <section class="reveal" style="margin-bottom: 64px;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">

        <!-- Values -->
        <div>
          <h2 style="font-family: 'Cinzel', serif; font-size: 20px; color: #ffffff; margin: 0 0 24px; letter-spacing: 0.06em;">Valores Compartilhados</h2>
          <div style="display: flex; flex-direction: column; gap: 12px;">
            {values.map(v => (
              <div style="background: #0D1724; border-radius: 12px; padding: 16px 20px; border: 1px solid rgba(38,64,96,0.4); display: flex; align-items: center; gap: 16px;">
                <div style="width: 32px; height: 32px; border-radius: 8px; background: rgba(168,93,24,0.12); border: 1px solid rgba(168,93,24,0.25); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                  <div style="width: 6px; height: 6px; background: #A85D18; border-radius: 50%;"></div>
                </div>
                <div>
                  <p style="font-family: 'Cinzel', serif; font-size: 14px; color: #EDBA63; margin: 0; font-weight: 600;">{v.word}</p>
                  <p style="font-family: 'Montserrat', sans-serif; font-size: 12px; color: #5E7890; margin: 0;">{v.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- What We Oppose -->
        <div>
          <h2 style="font-family: 'Cinzel', serif; font-size: 20px; color: #ffffff; margin: 0 0 24px; letter-spacing: 0.06em;">O Que Combatemos</h2>
          <div style="display: flex; flex-direction: column; gap: 12px;">
            {prohibitions.map(p => (
              <div style="background: rgba(122,32,32,0.06); border: 1px solid rgba(122,32,32,0.2); border-radius: 12px; padding: 16px 20px; display: flex; align-items: start; gap: 12px;">
                <div style="width: 18px; height: 18px; border-radius: 50%; background: rgba(122,32,32,0.2); border: 1px solid rgba(248,113,113,0.25); display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px;">
                  <div style="width: 8px; height: 1.5px; background: #f87171; border-radius: 1px;"></div>
                </div>
                <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #8CA0B5; margin: 0; line-height: 1.5;">{p}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Tribe Profile -->
    <section class="reveal" style="margin-bottom: 64px;">
      <div style="background: rgba(237,186,99,0.04); border: 1px solid rgba(237,186,99,0.12); border-radius: 20px; padding: 48px;">
        <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.2em; color: #EDBA63; margin: 0 0 16px;">A Tribo</p>
        <h2 style="font-family: 'Cinzel', serif; font-size: 28px; color: #ffffff; margin: 0 0 24px; letter-spacing: 0.04em;">Quem e um Lider Leao</h2>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 32px;">
          <div>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 14px; color: #8CA0B5; margin: 0; line-height: 1.9;">
              Lideres, empresarios, gestores, fundadores, profissionais em posicao de influencia — que entendem que foram chamados para mais do que sobreviver, repetir rotina ou apenas performar resultados.
            </p>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 14px; color: #8CA0B5; margin: 16px 0 0; line-height: 1.9;">
              Nao e uma tribo de curiosos. E uma tribo de pessoas em fase de fortalecimento, alinhamento ou expansao.
            </p>
          </div>
          <div>
            <p style="font-family: 'Cinzel', serif; font-size: 16px; color: #EDBA63; margin: 0 0 16px; font-weight: 600; letter-spacing: 0.04em;">Quem nao entra:</p>
            {[
              'Quem quer motivacao rapida sem transformacao',
              'Quem foge de responsabilidade e romantiza vitimismo',
              'Ego inflado e lideranca performatica',
              'Quem busca validacao acima de verdade',
              'Crescimento sem disciplina e amadurecimento',
            ].map(item => (
              <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
                <div style="width: 4px; height: 4px; background: rgba(168,93,24,0.6); border-radius: 50%; flex-shrink: 0;"></div>
                <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0;">{item}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Rituals + Vocabulary -->
    <section class="reveal" style="margin-bottom: 64px;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
        <div>
          <h2 style="font-family: 'Cinzel', serif; font-size: 20px; color: #ffffff; margin: 0 0 24px; letter-spacing: 0.06em;">Rituais da Tribo</h2>
          <div style="display: flex; flex-direction: column; gap: 8px;">
            {rituals.map((r, i) => (
              <div style="display: flex; align-items: center; gap: 16px; padding: 14px 20px; background: #0D1724; border-radius: 10px; border: 1px solid rgba(38,64,96,0.4);">
                <span style="font-family: 'Cinzel', serif; font-size: 12px; color: rgba(168,93,24,0.6); font-weight: 600; flex-shrink: 0;">0{i + 1}</span>
                <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #C0CDD8; margin: 0;">{r}</p>
              </div>
            ))}
          </div>
        </div>
        <div>
          <h2 style="font-family: 'Cinzel', serif; font-size: 20px; color: #ffffff; margin: 0 0 24px; letter-spacing: 0.06em;">Vocabulario Interno</h2>
          <div style="display: flex; flex-wrap: wrap; gap: 8px;">
            {['Direcao', 'Consciencia', 'Legado', 'Governo', 'Chamado', 'Postura', 'Fortalecimento', 'Alinhamento', 'Territorio', 'Peso da lideranca', 'Verdade antes da performance', 'Coragem para governar', 'Nao e aparencia, e governo'].map(word => (
              <span style="
                font-family: 'Montserrat', sans-serif;
                font-size: 12px;
                font-weight: 500;
                padding: 5px 12px;
                border-radius: 8px;
                background: rgba(168, 93, 24, 0.1);
                border: 1px solid rgba(168, 93, 24, 0.2);
                color: #C8883B;
              ">{word}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Closing Manifesto -->
    <section class="reveal">
      <div style="text-align: center; padding: 64px 32px; background: #00101E; border-radius: 24px; border: 1px solid rgba(38,64,96,0.4); position: relative; overflow: hidden;">
        <div style="position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, #A85D18, transparent);"></div>
        <div style="position: absolute; bottom: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, #A85D18, transparent);"></div>

        <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.3em; color: #A85D18; margin: 0 0 24px;">Lema</p>
        <h2 style="font-family: 'Cinzel', serif; font-size: clamp(20px, 4vw, 40px); color: #ffffff; margin: 0 0 16px; letter-spacing: 0.1em; line-height: 1.3;">Coragem para governar.<br />Consciencia para permanecer.</h2>
        <div style="height: 1px; background: linear-gradient(90deg, transparent, #A85D18, #EDBA63, #A85D18, transparent); max-width: 120px; margin: 24px auto;"></div>
        <p style="font-family: 'Montserrat', sans-serif; font-size: 14px; color: #5E7890; margin: 0;">Lideres Leoes — Movimento de Lideranca com Proposito</p>
      </div>
    </section>

  </div>

  <script>
    // Counter animation
    const counter = document.getElementById('counter');
    const target = 100;
    let current = 0;

    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        observer.disconnect();
        const startTime = performance.now();
        const duration = 2000;

        function animate(currentTime: number) {
          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          current = Math.floor(eased * target);
          if (counter) counter.textContent = current.toString();
          if (progress < 1) requestAnimationFrame(animate);
        }

        requestAnimationFrame(animate);
      }
    }, { threshold: 0.3 });

    if (counter) observer.observe(counter);
  </script>

  <style>
    @media (max-width: 768px) {
      section > div[style*='grid-template-columns: 1fr 1fr'] {
        grid-template-columns: 1fr !important;
      }
    }
  </style>
</Layout>
