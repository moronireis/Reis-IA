---
import Layout from '../layouts/Layout.astro';

const mainLogos = [
  { file: 'ZINITH_oficial_png.png', label: 'Logo Oficial com Frase', desc: 'Versao completa — uso principal em materiais premium' },
  { file: 'ZINITH_oficial_png - sem frase.png', label: 'Logo Oficial sem Frase', desc: 'Versao limpa para icones, favicons e espaco reduzido' },
  { file: 'ZINITH_horizontal_png.png', label: 'Logo Horizontal', desc: 'Para cabecalhos, banners e assinaturas de email' },
  { file: 'ZINITH-fundoescuro1.png', label: 'Logo Fundo Escuro 1', desc: 'Variante otimizada para backgrounds escuros' },
  { file: 'ZINITH-fundoescuro2.png', label: 'Logo Fundo Escuro 2', desc: 'Segunda variante para backgrounds escuros' },
  { file: 'Z.png', label: 'Simbolo Z', desc: 'Marca isolada — favicon, avatar, selo' },
  { file: 'Z-2.png', label: 'Simbolo Z Variante 2', desc: 'Variante do simbolo central' },
  { file: 'Z-3.png', label: 'Simbolo Z Variante 3', desc: 'Terceira variante — fundo escuro nativo' },
];

const grafismos = [
  { file: 'GRAFISMO1.png', label: 'Grafismo 1' },
  { file: 'GRAFISMO2.png', label: 'Grafismo 2' },
  { file: 'GRAFISMO3.png', label: 'Grafismo 3' },
  { file: 'GRAFISMO4.png', label: 'Grafismo 4' },
  { file: 'GRAFISMO5.png', label: 'Grafismo 5' },
  { file: 'GRAFISMO6.png', label: 'Grafismo 6' },
];
---

<Layout title="Logos - ZNITH Design System" activeRoute="/logos">
  <div style="max-width: 1120px; margin: 0 auto; padding: 64px 32px;">

    <!-- Header -->
    <div class="reveal" style="margin-bottom: 64px;">
      <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.2em; color: #EDBA63; margin: 0 0 16px;">Design System</p>
      <h1 style="font-family: 'Cinzel', serif; font-size: clamp(32px, 5vw, 56px); color: #ffffff; margin: 0 0 16px; letter-spacing: 0.06em;">Logos</h1>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 16px; color: #8CA0B5; max-width: 560px; line-height: 1.7; margin: 0 0 24px;">Todas as variantes do sistema de identidade visual ZNITH — logos, simbolos e grafismos.</p>
      <div class="gold-line"></div>
    </div>

    <!-- Main Logo Gallery -->
    <section class="reveal" style="margin-bottom: 64px;">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Logos Principais</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">8 variantes oficiais — use sempre o arquivo original PNG</p>

      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px;">
        {mainLogos.map(logo => (
          <div style="background: #0D1724; border-radius: 16px; overflow: hidden; border: 1px solid rgba(38,64,96,0.4);">
            <!-- Dark background preview -->
            <div id={`dark-${logo.file.replace(/[^a-z0-9]/gi, '-')}`} style="
              padding: 48px 32px;
              display: flex;
              align-items: center;
              justify-content: center;
              min-height: 160px;
              background: #00172B;
              border-bottom: 1px solid rgba(38,64,96,0.3);
            ">
              <img
                src={`/logos/${logo.file}`}
                alt={logo.label}
                style="max-width: 200px; max-height: 100px; object-fit: contain;"
              />
            </div>
            <!-- Info -->
            <div style="padding: 20px 24px;">
              <div style="display: flex; align-items: start; justify-content: space-between; gap: 12px;">
                <div>
                  <p style="font-family: 'Cinzel', serif; font-size: 14px; color: #ffffff; margin: 0 0 4px; font-weight: 600;">{logo.label}</p>
                  <p style="font-family: 'Montserrat', sans-serif; font-size: 12px; color: #5E7890; margin: 0;">{logo.desc}</p>
                </div>
                <a href={`/logos/${logo.file}`} download style="
                  flex-shrink: 0;
                  background: rgba(237,186,99,0.1);
                  border: 1px solid rgba(237,186,99,0.2);
                  border-radius: 8px;
                  padding: 6px 12px;
                  font-family: 'Montserrat', sans-serif;
                  font-size: 11px;
                  font-weight: 600;
                  color: #EDBA63;
                  text-decoration: none;
                  text-transform: uppercase;
                  letter-spacing: 0.08em;
                  transition: background 0.2s;
                ">PNG</a>
              </div>
              <p style="font-family: 'Montserrat', sans-serif; font-size: 10px; color: #3A5575; margin: 8px 0 0; font-variant-numeric: tabular-nums;">{logo.file}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Clear Space Guide -->
    <section class="reveal" style="margin-bottom: 64px;">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Area de Protecao</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">Espaco minimo ao redor do logo — unidade baseada na altura do simbolo Z</p>

      <div style="background: #0D1724; border-radius: 16px; padding: 48px; border: 1px solid rgba(38,64,96,0.4); display: flex; align-items: center; justify-content: center;">
        <div style="position: relative; display: inline-block;">
          <!-- Clear space indicator -->
          <div style="
            position: absolute;
            inset: -24px;
            border: 1px dashed rgba(237,186,99,0.3);
            border-radius: 4px;
          ">
            <!-- Corner labels -->
            <span style="position: absolute; top: -16px; left: 50%; transform: translateX(-50%); font-family: 'Montserrat', sans-serif; font-size: 10px; color: #EDBA63; white-space: nowrap;">1x</span>
            <span style="position: absolute; bottom: -16px; left: 50%; transform: translateX(-50%); font-family: 'Montserrat', sans-serif; font-size: 10px; color: #EDBA63; white-space: nowrap;">1x</span>
            <span style="position: absolute; left: -16px; top: 50%; transform: translateY(-50%); font-family: 'Montserrat', sans-serif; font-size: 10px; color: #EDBA63;">1x</span>
            <span style="position: absolute; right: -16px; top: 50%; transform: translateY(-50%); font-family: 'Montserrat', sans-serif; font-size: 10px; color: #EDBA63;">1x</span>
          </div>
          <img src="/logos/Z.png" alt="ZNITH Symbol" style="height: 80px; width: auto; display: block;" />
        </div>
      </div>
    </section>

    <!-- Minimum Size -->
    <section class="reveal" style="margin-bottom: 64px;">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Tamanho Minimo</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">Abaixo desses valores, legibilidade e qualidade ficam comprometidas</p>

      <div style="display: flex; align-items: flex-end; gap: 32px; flex-wrap: wrap; background: #0D1724; border-radius: 16px; padding: 40px; border: 1px solid rgba(38,64,96,0.4);">
        {[
          { size: '16px', label: 'Favicon / Avatar', pixelSize: 16 },
          { size: '32px', label: 'App Icon', pixelSize: 32 },
          { size: '48px', label: 'Cabecalho Mobile', pixelSize: 48 },
          { size: '80px', label: 'Cabecalho Desktop', pixelSize: 80 },
          { size: '120px', label: 'Uso Premium', pixelSize: 120 },
        ].map(s => (
          <div style="display: flex; flex-direction: column; align-items: center; gap: 8px;">
            <img src="/logos/Z.png" alt="ZNITH" style={`height: ${s.pixelSize}px; width: auto;`} />
            <p style="font-family: 'Montserrat', sans-serif; font-size: 11px; color: #EDBA63; margin: 0;">{s.size}</p>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 10px; color: #5E7890; margin: 0; text-align: center;">{s.label}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Grafismos -->
    <section class="reveal" style="margin-bottom: 64px;">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 8px; letter-spacing: 0.06em;">Grafismos</h2>
      <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #5E7890; margin: 0 0 32px;">6 elementos graficos de suporte — backgrounds, texturas e composicoes visuais</p>

      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px;">
        {grafismos.map(g => (
          <div style="background: #0D1724; border-radius: 16px; overflow: hidden; border: 1px solid rgba(38,64,96,0.4);">
            <div style="
              height: 200px;
              display: flex;
              align-items: center;
              justify-content: center;
              overflow: hidden;
              background: #00172B;
            ">
              <img
                src={`/logos/${g.file}`}
                alt={g.label}
                style="width: 100%; height: 100%; object-fit: cover;"
              />
            </div>
            <div style="padding: 16px 20px; display: flex; align-items: center; justify-content: space-between;">
              <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; color: #C0CDD8; margin: 0; font-weight: 500;">{g.label}</p>
              <a href={`/logos/${g.file}`} download style="
                background: rgba(237,186,99,0.1);
                border: 1px solid rgba(237,186,99,0.2);
                border-radius: 6px;
                padding: 4px 10px;
                font-family: 'Montserrat', sans-serif;
                font-size: 10px;
                font-weight: 600;
                color: #EDBA63;
                text-decoration: none;
                text-transform: uppercase;
                letter-spacing: 0.08em;
              ">PNG</a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Usage Rules -->
    <section class="reveal">
      <h2 style="font-family: 'Cinzel', serif; font-size: 22px; color: #ffffff; margin: 0 0 32px; letter-spacing: 0.06em;">Regras de Uso</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px;">
        <div style="background: rgba(42, 107, 74, 0.08); border: 1px solid rgba(42, 107, 74, 0.25); border-radius: 16px; padding: 24px;">
          <p style="font-family: 'Cinzel', serif; font-size: 14px; color: #4ade80; margin: 0 0 12px; font-weight: 600;">Permitido</p>
          {['Logo em fundos escuros (#00172B)', 'Escala proporcional uniforme', 'Versao horizontal em cabecalhos', 'Simbolo Z em espacos reduzidos'].map(r => (
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
              <div style="width: 4px; height: 4px; background: #4ade80; border-radius: 50%; flex-shrink: 0;"></div>
              <p style="font-family: 'Montserrat', sans-serif; font-size: 12px; color: #8CA0B5; margin: 0;">{r}</p>
            </div>
          ))}
        </div>
        <div style="background: rgba(122, 32, 32, 0.08); border: 1px solid rgba(122, 32, 32, 0.25); border-radius: 16px; padding: 24px;">
          <p style="font-family: 'Cinzel', serif; font-size: 14px; color: #f87171; margin: 0 0 12px; font-weight: 600;">Proibido</p>
          {['Distorcer ou inclinar o logo', 'Aplicar sobre fundos claros', 'Recolorir ou alterar o ouro', 'Adicionar efeitos, sombras ou filtros', 'Usar abaixo do tamanho minimo'].map(r => (
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
              <div style="width: 4px; height: 4px; background: #f87171; border-radius: 50%; flex-shrink: 0;"></div>
              <p style="font-family: 'Montserrat', sans-serif; font-size: 12px; color: #8CA0B5; margin: 0;">{r}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>
</Layout>
