---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ZNITH Design System" activeRoute="/">

  <!-- Full-screen Hero -->
  <section style="
    min-height: calc(100vh - 64px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 32px 48px;
    position: relative;
    overflow: hidden;
  ">
    <!-- Animated radial background -->
    <div style="
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(20, 41, 64, 0.7) 0%, #00172B 70%);
      pointer-events: none;
    "></div>

    <!-- Pulsing glow behind logo -->
    <div style="
      position: absolute;
      width: 300px;
      height: 300px;
      background: radial-gradient(ellipse, rgba(237, 186, 99, 0.08) 0%, transparent 70%);
      border-radius: 50%;
      animation: pulse 4s ease-in-out infinite;
      pointer-events: none;
    "></div>

    <!-- Content -->
    <div style="position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; gap: 24px; text-align: center;" class="reveal">

      <!-- Logo -->
      <img
        src="/logos/ZINITH_oficial_png.png"
        alt="ZNITH Official Logo"
        style="width: 200px; height: auto;"
      />

      <!-- Label -->
      <p style="
        font-family: 'Montserrat', sans-serif;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.25em;
        color: #EDBA63;
        margin: 0;
      ">Design System</p>

      <!-- Brand Name -->
      <h1 style="
        font-family: 'Cinzel', serif;
        font-size: clamp(48px, 8vw, 80px);
        font-weight: 700;
        color: #ffffff;
        margin: 0;
        letter-spacing: 0.12em;
        line-height: 1;
      ">ZNITH</h1>

      <!-- Tagline -->
      <p style="
        font-family: 'Montserrat', sans-serif;
        font-size: 14px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.25em;
        color: #EDBA63;
        margin: 0;
      ">Direcao. Consciencia. Legado.</p>

      <!-- Version -->
      <p style="
        font-family: 'Montserrat', sans-serif;
        font-size: 12px;
        color: #5E7890;
        margin: 0;
        letter-spacing: 0.05em;
      ">Versao 3.0 - Abril 2026</p>

      <!-- Gold divider line -->
      <div class="gold-line" style="margin: 8px auto;"></div>
    </div>

    <!-- Navigation Cards -->
    <div class="reveal" style="
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      max-width: 960px;
      width: 100%;
      margin-top: 48px;
    " id="nav-cards">

      <a href="/cores" class="nav-card">
        <h3 class="nav-card-title">Cores</h3>
        <p class="nav-card-desc">Paleta completa - azul marinho + ouro</p>
      </a>
      <a href="/tipografia" class="nav-card">
        <h3 class="nav-card-title">Tipografia</h3>
        <p class="nav-card-desc">Cinzel + Montserrat, escala e pesos</p>
      </a>
      <a href="/logos" class="nav-card">
        <h3 class="nav-card-title">Logos</h3>
        <p class="nav-card-desc">Variantes, grafismos e guia de uso</p>
      </a>
      <a href="/componentes" class="nav-card">
        <h3 class="nav-card-title">Componentes</h3>
        <p class="nav-card-desc">Botoes, cards, inputs e tabelas</p>
      </a>
      <a href="/voz" class="nav-card">
        <h3 class="nav-card-title">Tom de Voz</h3>
        <p class="nav-card-desc">4 perfis de comunicacao da marca</p>
      </a>
      <a href="/marca" class="nav-card">
        <h3 class="nav-card-title">A Marca</h3>
        <p class="nav-card-desc">Origem, valores e posicionamento</p>
      </a>
      <a href="/movimento" class="nav-card">
        <h3 class="nav-card-title">Lideres Leoes</h3>
        <p class="nav-card-desc">Manifesto, tribo e simbolos</p>
      </a>
      <a href="/" class="nav-card">
        <h3 class="nav-card-title">v3.0</h3>
        <p class="nav-card-desc">Ultima atualizacao: Abril 2026</p>
      </a>
    </div>

    <!-- Scroll indicator -->
    <div style="position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%); animation: bounce 2s ease-in-out infinite;">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M10 4v12M4 10l6 6 6-6" stroke="#5E7890" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </section>

  <style>
    @keyframes pulse {
      0%, 100% { opacity: 0.5; transform: scale(1); }
      50% { opacity: 1; transform: scale(1.1); }
    }
    @keyframes bounce {
      0%, 100% { transform: translateX(-50%) translateY(0); }
      50% { transform: translateX(-50%) translateY(6px); }
    }
    .nav-card {
      background: rgba(13, 23, 36, 0.6);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(38, 64, 96, 0.5);
      border-radius: 20px;
      padding: 28px;
      text-decoration: none;
      display: flex;
      flex-direction: column;
      gap: 8px;
      transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
    }
    .nav-card:hover {
      border-color: rgba(237, 186, 99, 0.3);
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(237, 186, 99, 0.08);
    }
    .nav-card-title {
      font-family: 'Cinzel', serif;
      font-size: 15px;
      color: #ffffff;
      margin: 0;
      font-weight: 600;
      letter-spacing: 0.06em;
    }
    .nav-card-desc {
      font-family: 'Montserrat', sans-serif;
      font-size: 12px;
      color: #5E7890;
      margin: 0;
      line-height: 1.5;
    }
    @media (max-width: 768px) {
      #nav-cards {
        grid-template-columns: repeat(2, 1fr) !important;
      }
    }
    @media (max-width: 480px) {
      #nav-cards {
        grid-template-columns: 1fr !important;
      }
    }
  </style>
</Layout>
