<footer class="bg-neutral-950 border-t border-neutral-800" aria-label="Site footer">
  <div class="mx-auto max-w-[1200px] px-5 md:px-8 lg:px-0 pt-16 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 md:gap-12">
      <!-- Brand column -->
      <div>
        <a href="/" class="text-white font-bold text-xl tracking-tight" aria-label="Reis IA - Home">REIS IA</a>
        <p class="text-neutral-500 text-sm mt-3 leading-relaxed">The AI Revenue Ecosystem</p>
      </div>

      <!-- Ecosystem links -->
      <div>
        <p class="text-neutral-400 text-[13px] uppercase tracking-widest font-medium mb-4">Ecosystem</p>
        <ul class="space-y-3">
          <li><a href="/builder" class="text-neutral-500 text-sm hover:text-white transition-colors">Builder</a></li>
          <li><a href="/systems" class="text-neutral-500 text-sm hover:text-white transition-colors">Systems</a></li>
          <li><a href="#" class="text-neutral-500 text-sm hover:text-white transition-colors">Partners</a></li>
          <li><a href="#" class="text-neutral-500 text-sm hover:text-white transition-colors">Network</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <p class="text-neutral-400 text-[13px] uppercase tracking-widest font-medium mb-4">Resources</p>
        <ul class="space-y-3">
          <li><a href="#" class="text-neutral-500 text-sm hover:text-white transition-colors">About</a></li>
          <li><a href="#" class="text-neutral-500 text-sm hover:text-white transition-colors">Case Studies</a></li>
          <li><a href="#" class="text-neutral-500 text-sm hover:text-white transition-colors">Blog</a></li>
          <li><a href="#" class="text-neutral-500 text-sm hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <p class="text-neutral-400 text-[13px] uppercase tracking-widest font-medium mb-4">Connect</p>
        <ul class="space-y-3">
          <li><a href="#" class="text-neutral-500 text-sm hover:text-white transition-colors" aria-label="LinkedIn">LinkedIn</a></li>
          <li><a href="#" class="text-neutral-500 text-sm hover:text-white transition-colors" aria-label="YouTube">YouTube</a></li>
          <li><a href="#" class="text-neutral-500 text-sm hover:text-white transition-colors" aria-label="Instagram">Instagram</a></li>
          <li><a href="#" class="text-neutral-500 text-sm hover:text-white transition-colors" aria-label="Twitter/X">Twitter/X</a></li>
        </ul>
      </div>
