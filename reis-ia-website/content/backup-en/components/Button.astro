---
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost' | 'hero';
  href?: string;
  class?: string;
  type?: 'button' | 'submit';
}

const { variant = 'primary', href, class: className = '', type = 'button' } = Astro.props;

const variantClasses = {
  primary: 'bg-accent text-black font-semibold tracking-wide px-8 py-4 rounded-md hover:bg-accent-hover hover:-translate-y-px active:bg-accent-muted transition-all duration-200 min-w-[200px] text-center inline-flex items-center justify-center text-base',
  secondary: 'bg-transparent text-white border border-neutral-700 px-8 py-4 rounded-md hover:border-neutral-500 hover:bg-white/[0.03] transition-all duration-200 inline-flex items-center justify-center text-base font-semibold',
  ghost: 'bg-transparent text-neutral-400 py-2 px-0 hover:text-white hover:underline transition-colors inline-flex items-center text-sm font-medium',
  hero: 'bg-accent text-black text-lg font-semibold tracking-wide px-10 py-5 rounded-lg hover:bg-accent-hover hover:-translate-y-px active:bg-accent-muted transition-all duration-200 inline-flex items-center justify-center text-center',
};
---

{href ? (
  <a href={href} class={`${variantClasses[variant]} ${className} focus:outline-none focus:ring-2 focus:ring-accent/20`}>
    <slot />
  </a>
) : (
  <button type={type} class={`${variantClasses[variant]} ${className} focus:outline-none focus:ring-2 focus:ring-accent/20`}>
    <slot />
  </button>
)}
