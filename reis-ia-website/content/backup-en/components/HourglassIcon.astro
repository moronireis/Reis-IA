---
interface Props {
  class?: string;
  size?: number;
  ariaHidden?: boolean;
}

const { class: className = '', size = 24, ariaHidden = true } = Astro.props;
---

<svg
  viewBox="0 0 24 36"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="square"
  width={size}
  height={size * 1.5}
  class={className}
  aria-hidden={ariaHidden ? "true" : undefined}
  role={ariaHidden ? "presentation" : undefined}
>
  <!-- Top cap -->
  <line x1="2" y1="1" x2="22" y2="1" />
  <line x1="2" y1="1" x2="2" y2="4" />
  <line x1="22" y1="1" x2="22" y2="4" />
  <!-- Top triangle (pointing down) -->
  <line x1="3" y1="4" x2="12" y2="16" />
  <line x1="21" y1="4" x2="12" y2="16" />
  <!-- Neck connection -->
  <line x1="12" y1="16" x2="12" y2="20" />
  <!-- Bottom triangle (pointing up) -->
  <line x1="12" y1="20" x2="3" y2="32" />
  <line x1="12" y1="20" x2="21" y2="32" />
  <!-- Sand lines (subtle, inside bottom triangle) -->
  <line x1="8" y1="29" x2="16" y2="29" opacity="0.4" />
  <line x1="9.5" y1="31" x2="14.5" y2="31" opacity="0.25" />
  <!-- Bottom cap -->
  <line x1="2" y1="32" x2="22" y2="32" />
  <line x1="2" y1="32" x2="2" y2="35" />
  <line x1="22" y1="32" x2="22" y2="35" />
</svg>
