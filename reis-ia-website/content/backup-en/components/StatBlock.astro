---
interface Props {
  value: string;
  label: string;
  context?: string;
  muted?: boolean;
}

const { value, label, context, muted = false } = Astro.props;
---

<div class="text-center">
  <p class={`text-5xl md:text-[56px] font-bold leading-none ${muted ? 'text-neutral-500' : 'text-white'}`}>
    {value}
  </p>
  <p class="text-sm uppercase tracking-widest text-neutral-500 mt-2">{label}</p>
  {context && <p class="text-sm text-neutral-400 mt-1">{context}</p>}
</div>
