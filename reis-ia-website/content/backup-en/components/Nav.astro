---
interface Props {
  activePage?: 'home' | 'builder' | 'systems' | 'partners' | 'network' | 'about';
}

const { activePage = 'home' } = Astro.props;

const navLinks = [
  { label: 'Builder', href: '/builder', key: 'builder' },
  { label: 'Systems', href: '/systems', key: 'systems' },
  { label: 'Partners', href: '#', key: 'partners' },
  { label: 'Network', href: '#', key: 'network' },
  { label: 'About', href: '#', key: 'about' },
];
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 bg-black/80 backdrop-blur-md border-b border-neutral-800 h-[72px]"
  aria-label="Main navigation"
>
  <div class="mx-auto max-w-[1200px] px-5 md:px-8 lg:px-0 h-full flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="text-white font-bold text-xl tracking-tight hover:text-neutral-200 transition-colors" aria-label="Reis IA - Home">
      REIS IA
    </a>

    <!-- Desktop nav links -->
    <div class="hidden lg:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`text-sm font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-accent/20 rounded-sm ${
            activePage === link.key
              ? 'text-white border-b-2 border-accent pb-0.5'
              : 'text-neutral-400 hover:text-white'
          }`}
          aria-current={activePage === link.key ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- CTA + Mobile menu toggle -->
    <div class="flex items-center gap-4">
      <a
        href="#booking"
        class="hidden lg:inline-flex items-center justify-center bg-accent text-black text-sm font-semibold tracking-wide px-5 py-2.5 rounded-md hover:bg-accent-hover transition-all duration-200"
      >
        Book a Call
      </a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-toggle"
        class="lg:hidden text-white focus:outline-none focus:ring-2 focus:ring-accent/20 rounded-sm p-1"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile menu overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-50 bg-black/95 backdrop-blur-lg flex flex-col items-center justify-center hidden lg:hidden"
  aria-hidden="true"
>
  <button
    id="mobile-menu-close"
    class="absolute top-6 right-5 text-white focus:outline-none focus:ring-2 focus:ring-accent/20 rounded-sm p-1"
    aria-label="Close navigation menu"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18" />
      <line x1="6" y1="6" x2="18" y2="18" />
    </svg>
  </button>

  <div class="flex flex-col items-center gap-6">
    <a href="/" class="text-white font-bold text-2xl tracking-tight">REIS IA</a>
    <div class="w-8 h-px bg-neutral-800"></div>
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="text-white text-2xl font-semibold hover:text-accent transition-colors"
      >
        {link.label}
      </a>
    ))}
    <div class="w-8 h-px bg-neutral-800"></div>
    <a
      href="#booking"
      class="inline-flex items-center justify-center bg-accent text-black text-lg font-semibold px-10 py-4 rounded-lg hover:bg-accent-hover transition-all duration-200 w-full max-w-xs text-center"
    >
      Book a Call
    </a>
  </div>
</div>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const closeBtn = document.getElementById('mobile-menu-close');
  const menu = document.getElementById('mobile-menu');

  function openMenu() {
    menu?.classList.remove('hidden');
    menu?.setAttribute('aria-hidden', 'false');
    toggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    menu?.setAttribute('aria-hidden', 'true');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);

  // Close on link click
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>
