---
interface Props {
  class?: string;
  size?: number;
  ariaHidden?: boolean;
}

const { class: className = '', size = 40, ariaHidden = true } = Astro.props;
---

<svg
  viewBox="0 0 40 72"
  fill="currentColor"
  width={size}
  height={size * 1.8}
  class={className}
  aria-hidden={ariaHidden ? "true" : undefined}
  role={ariaHidden ? "presentation" : undefined}
>
  <!-- Base -->
  <rect x="8" y="62" width="24" height="8" rx="2" />
  <!-- Pedestal -->
  <path d="M10 62 L14 50 L26 50 L30 62 Z" />
  <!-- Neck / body -->
  <rect x="15" y="32" width="10" height="20" />
  <!-- Head - simplified horse profile -->
  <path d="M15 32 L15 20 Q16 14 22 12 L28 10 L26 18 L24 20 L25 26 L22 32 Z" />
  <!-- Ear -->
  <path d="M20 12 L23 6 L26 10 Z" />
  <!-- Muzzle -->
  <path d="M24 20 L30 22 L30 26 L24 26 Z" />
</svg>
