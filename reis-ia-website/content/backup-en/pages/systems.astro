---
import MainLayout from '../layouts/MainLayout.astro';
import Badge from '../components/Badge.astro';
import Button from '../components/Button.astro';
import SectionLabel from '../components/SectionLabel.astro';
import StatBlock from '../components/StatBlock.astro';
import TestimonialBlock from '../components/TestimonialBlock.astro';
import HourglassIcon from '../components/HourglassIcon.astro';
import ChessKnightIcon from '../components/ChessKnightIcon.astro';
import FaqAccordion from '../components/FaqAccordion.tsx';

const faqItems = [
  {
    question: "What if we tried AI before and it didn't work?",
    answer: "That's actually the most common thing we hear. The reason almost every AI failure we've seen comes down to one thing: the project started with the technology instead of the business outcome. Our process starts with the AI Revenue Audit — which maps where AI creates measurable revenue impact before we build anything. That's the difference.",
  },
  {
    question: "Will this integrate with our existing systems?",
    answer: "Integration is the first thing we map in the AI Revenue Audit. We work with WhatsApp Business API, HubSpot, Salesforce, Pipedrive, custom CRMs, ERPs, and most systems with an API. Before any implementation starts, you'll have a clear picture of every integration point and any constraints.",
  },
  {
    question: "How long before we see results?",
    answer: "This is the right question — and most AI vendors dodge it. Here's the honest answer. The Starter Package is scoped for a 2–4 week build. You'll see the system live within a month and have real usage data within 30 days of launch. Full implementations take 4–8 weeks to build and integrate. Optimized results — the kind where you can draw a clear line from the system to a business outcome — are typically visible within 60 days of launch. But here's the time framing that actually matters. The companies waiting for a 'better time to start' are not saving time. They're spending it — on the same manual processes, the same unqualified leads, the same support bottlenecks. Every week without the right system running is a week of that cost accumulating. The AI Revenue Audit is a 60-minute investment. It tells you exactly what to build, what it costs, and when you'd see a return. Even if you decide not to move forward with us, you'll know more about your AI opportunity than 90% of the companies in your market. That 60 minutes is the fastest thing on your calendar.",
  },
  {
    question: "What happens to our data? Is it secure?",
    answer: "Your data stays on your systems or approved cloud infrastructure — never on Reis IA's servers. We follow data minimization principles: the AI accesses only what it needs to function. For regulated industries (LGPD, GDPR, HIPAA), we design implementations that meet your compliance requirements. This is addressed explicitly in the AI Revenue Audit.",
  },
  {
    question: "What if something breaks after handoff?",
    answer: "You receive full documentation, credentials, and access to everything we build — you own it completely. The Starter Package includes 30 days of post-handoff support. Full implementations include 60 days of priority support and a 60-day performance guarantee. We also offer monthly retainers for ongoing management.",
  },
  {
    question: "Do we need clean data to start?",
    answer: "Not necessarily. Most companies start with imperfect data, and the audit process identifies what data requirements exist for each specific implementation. Many AI implementations don't require large datasets — they require clear business logic, which we help you define.",
  },
  {
    question: "Can we scale after the initial implementation?",
    answer: "Yes — and this is by design. Every Reis IA Systems implementation is built for scalability from the start. We document everything so future additions are straightforward, and the Full Implementation tier is specifically designed for multi-system deployments that grow with your business.",
  },
];
---

<MainLayout
  title="Systems — Done-For-You AI Implementation That Generates Revenue"
  description="Reis IA Systems builds AI agents and automations that connect directly to revenue-generating processes — starting with where the money is, not with what's technically interesting."
  activePage="systems"
>

  <!-- SECTION 1: HERO -->
  <section class="relative bg-black pt-32 pb-24 md:pt-20 md:pb-16 overflow-hidden">
    <!-- Radial glow -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
      style="background: radial-gradient(ellipse at 30% 50%, rgba(201, 168, 76, 0.03) 0%, transparent 70%);">
    </div>

    <!-- Hourglass decorative (desktop) -->
    <div class="absolute right-[8%] top-[40%] hidden lg:block pointer-events-none text-accent opacity-90" aria-hidden="true">
      <HourglassIcon size={80} />
    </div>

    <div class="mx-auto max-w-[1200px] px-5 md:px-8 lg:px-0 relative z-10">
      <p class="text-[13px] font-semibold tracking-widest uppercase text-neutral-500 mb-4">
        For Growth-Stage Companies Ready to Move from "We Should Implement AI" to "Our AI Is Generating Results"
      </p>

      <h1 class="text-[40px] md:text-[56px] lg:text-7xl font-bold leading-none tracking-tighter text-white max-w-[900px]">
        Your AI project didn't fail because the technology doesn't work.<br />
        It failed because nobody asked the right question first.
      </h1>

      <p class="text-lg md:text-xl font-normal leading-relaxed text-neutral-400 mt-6 max-w-[640px]">
        Reis IA Systems builds AI agents and automations that connect directly to revenue-generating processes — starting with where the money is, not with what's technically interesting.
      </p>

      <div class="mt-10">
        <Button variant="hero" href="#audit">Book a Free AI Revenue Assessment &#8594;</Button>
        <p class="text-[13px] text-neutral-500 mt-3">30 minutes. We identify where AI generates the highest-leverage revenue impact in your business — before you spend a dollar.</p>
      </div>
    </div>
  </section>

  <!-- SECTION 2: PROBLEM -->
  <section class="bg-neutral-950 py-24 md:py-16">
    <div class="mx-auto max-w-[1200px] px-5 md:px-8 lg:px-0">
      <div class="max-w-[720px]">
        <h2 class="text-[28px] md:text-[36px] lg:text-[42px] font-semibold text-white leading-tight" style="letter-spacing: -0.01em;">
          You've Seen What AI Can Do. You've Also Seen What Happens When It Doesn't Work.
        </h2>

        <div class="mt-8 space-y-5 text-[17px] text-neutral-300 leading-relaxed">
          <p>The headlines are clear.</p>
          <p>Companies that implement AI correctly are reducing support costs by 30–40%. They're qualifying more leads without hiring more salespeople. They're scaling operations without scaling headcount.</p>
          <p>And then there's the other story — the one that doesn't make the case studies.</p>
          <p>The chatbot that got built, launched, and forgotten within six months. The AI initiative that started with a vendor demo and ended with a project in limbo. The automation that worked in testing and broke in production.</p>
        </div>

        <!-- Stat callout -->
        <div class="text-center py-8 my-6">
          <p class="text-[48px] font-bold text-accent leading-none">42%</p>
          <p class="text-[17px] text-neutral-300 mt-2">of companies abandoned AI projects in 2025.</p>
        </div>

        <div class="space-y-5 text-[17px] text-neutral-300 leading-relaxed">
          <p>Not because AI doesn't work. Because the approach was wrong.</p>
          <p>Most AI projects start with a technology decision — "let's build a chatbot," "let's automate this workflow," "let's implement an AI agent." Then they get built. And then the business waits for results that don't materialize, because nobody mapped where the results were supposed to come from.</p>
        </div>

        <p class="text-xl font-semibold text-white mt-6">That's the Prototype Graveyard. And it's where most AI investment ends up.</p>

        <!-- Symptoms -->
        <div class="mt-8 bg-neutral-900 border border-neutral-800 rounded-lg p-8">
          <h3 class="text-xl font-semibold text-white mb-4">The symptoms look like this:</h3>
          <ul class="space-y-3">
            {[
              'You had an AI project scoped, built, and launched — and nobody\'s measuring what it actually does for the business',
              'Your team is still doing the same manual work they were doing before "AI was implemented"',
              'You got a demo that looked impressive and a deliverable that doesn\'t match',
              'You tried no-code tools or freelancers and hit the ceiling of what they can actually build',
              'You\'ve been told your data isn\'t clean enough, your systems are too complex, or your use case is too custom — and you\'re stuck',
            ].map(item => (
              <li class="flex items-start gap-3 text-[15px] text-neutral-400">
                <span class="text-neutral-600 mt-0.5" aria-hidden="true">—</span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <p class="text-[17px] text-neutral-400 leading-relaxed mt-4 italic">
          Or you haven't started at all, because every vendor pitch you've seen led with technology capabilities you couldn't evaluate, not business outcomes you could measure.
        </p>
      </div>
    </div>
  </section>

  <!-- SECTION 3: AGITATION -->
  <section class="bg-black py-24 md:py-16">
    <div class="mx-auto max-w-[1200px] px-5 md:px-8 lg:px-0">
      <div class="max-w-[720px]">
        <h2 class="text-[28px] md:text-[36px] lg:text-[42px] font-semibold text-white leading-tight" style="letter-spacing: -0.01em;">
          The Cost of Getting This Wrong
        </h2>

        <p class="text-[17px] text-neutral-300 leading-relaxed mt-6">Every month without the right AI implementation is a month where:</p>

        <ul class="mt-4 space-y-4">
          {[
            'Your sales team is manually qualifying leads that an AI could score in seconds',
            'Your support team is answering the same questions hundreds of times — questions that have the same 12 correct answers every time',
            'Your operations are dependent on human bandwidth that doesn\'t scale',
            'Your competitors — the ones who got implementation right — are handling the same volume with fewer people and responding faster',
          ].map(item => (
            <li class="flex items-start gap-3 text-[17px] text-neutral-300">
              <span class="text-accent mt-1" aria-hidden="true">—</span>
              {item}
            </li>
          ))}
        </ul>

        <p class="text-[17px] text-neutral-300 leading-relaxed mt-8">This isn't theoretical.</p>

        <!-- Klarna example -->
        <div class="mt-6 bg-neutral-900 border border-neutral-800 rounded-lg p-8">
          <p class="text-[17px] text-neutral-300 leading-relaxed">
            Klarna's AI handles 2.3 million customer service conversations. Not because Klarna is a uniquely technical company. Because they asked the right question before building: <strong class="text-white">"Where does this save money and improve the customer experience?"</strong>
          </p>
          <p class="text-[17px] text-neutral-300 leading-relaxed mt-4">
            That question is the entire difference between a functioning AI system and a prototype that collects dust.
          </p>
        </div>

        <div class="mt-8 space-y-3">
          <p class="text-xl font-semibold text-white">The gap isn't between companies that have AI and companies that don't.</p>
          <p class="text-xl font-semibold text-white">The gap is between companies that implemented it right and companies that didn't.</p>
        </div>

        <!-- Hourglass variation closer (ADDED 2026-03-11) -->
        <div class="mt-8 space-y-4 text-[17px] text-neutral-300 leading-relaxed">
          <p>And that gap is not static.</p>
          <p>It widens every month.</p>
          <p>The company that implemented a lead qualification agent six months ago has six months of data, six months of optimization, and a sales team that has learned to work at a new pace. The company still evaluating is starting from zero — while that competitor is already at version three.</p>
          <p>AI doesn't just save time. It compounds time into competitive distance.</p>
          <p class="flex items-start gap-3">
            <HourglassIcon size={24} class="text-accent flex-shrink-0 mt-0.5" />
            <strong class="text-xl font-semibold text-white">Every week without the right system is a week that doesn't come back.</strong>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 4: SOLUTION -->
  <section class="relative bg-neutral-950 py-24 md:py-16">
    <!-- Chess grid texture -->
    <div class="chess-grid absolute inset-0 pointer-events-none opacity-100" aria-hidden="true"></div>

    <div class="mx-auto max-w-[1200px] px-5 md:px-8 lg:px-0 relative z-10">
      <div class="flex items-center gap-3 mb-2">
        <ChessKnightIcon size={32} class="text-accent" />
        <SectionLabel>The Approach</SectionLabel>
      </div>

      <h2 class="text-[28px] md:text-[36px] lg:text-[42px] font-semibold text-white leading-tight mt-2" style="letter-spacing: -0.01em;">
        We Build AI Systems Using the Revenue-First Framework.
      </h2>

      <!-- Chess variation opening (ADDED 2026-03-11) -->
      <div class="mt-8 space-y-5 text-[17px] text-neutral-300 leading-relaxed max-w-[720px]">
        <p>The Revenue-First Framework is not a checklist. It's a strategic architecture.</p>
        <p>A skilled chess player doesn't move pieces randomly and hope for a win. Every piece has a role. Every move builds toward a position. The player who wins is the one who sees three moves ahead before touching the board.</p>
        <p>That's exactly how we approach AI implementation.</p>
        <p>We map your business — your revenue processes, your operational bottlenecks, your highest-leverage opportunities — before writing a line of code. Then we build systems with precise intent, connected to outcomes you define before the project starts.</p>
        <p class="text-xl font-semibold text-white">We don't just build AI. We architect revenue.</p>
        <p>Every engagement begins with the AI Revenue Audit — a structured diagnostic that maps your business against three questions:</p>
      </div>

      <!-- Framework questions -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-10 max-w-none">
        {[
          { num: '01', question: 'Where does AI create the highest-leverage revenue impact in your specific operations?' },
          { num: '02', question: "What's the expected ROI of each implementation, and what does it take to measure it?" },
          { num: '03', question: 'What gets built first to generate the fastest return?' },
        ].map(({ num, question }) => (
          <div class="bg-neutral-900 border border-neutral-800 rounded-lg p-6">
            <p class="text-[32px] font-bold text-accent leading-none mb-4">{num}</p>
            <p class="text-[17px] font-semibold text-white leading-snug">{question}</p>
          </div>
        ))}
      </div>

      <div class="mt-8 space-y-4 text-[17px] text-neutral-300 leading-relaxed max-w-[720px]">
        <p>We don't write a line of code until that map exists.</p>
        <p>This is the Revenue-First AI Framework. It's what separates implementations that generate measurable results from implementations that become expensive technical projects with nothing to show for them.</p>
      </div>
    </div>
  </section>

  <!-- SECTION 5: SERVICE OFFERINGS -->
  <section class="bg-black py-24 md:py-16">
    <div class="mx-auto max-w-[1200px] px-5 md:px-8 lg:px-0">
      <div class="text-center mb-12">
        <SectionLabel>What We Build</SectionLabel>
        <h2 class="text-[28px] md:text-[36px] lg:text-[42px] font-semibold text-white mt-4" style="letter-spacing: -0.01em;">
          AI Systems That Connect to Revenue
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-[1000px] mx-auto">
        {[
          {
            title: 'AI Sales Agent',
            body: 'Qualifies inbound leads across WhatsApp, website, and email. Asks the right discovery questions, scores each lead against your criteria, routes the qualified ones to your sales team — automatically. Your team spends time on prospects who are ready to buy.',
            timeFrame: 'Every hour your sales team spends on unqualified leads is an hour not spent closing. The AI Sales Agent gives your highest-value people their time back.',
            metric: 'Typical results: [METRIC]% increase in qualified leads reaching sales, [METRIC] hours saved per week on lead processing',
          },
          {
            title: 'AI Customer Support System',
            body: 'Handles the 60–80% of support queries that have defined answers — across WhatsApp, your website, and email. Resolves issues without human involvement. Escalates edge cases with full context so your team doesn\'t start from zero. Feeds every interaction into your CRM.',
            timeFrame: 'Your support team is answering the same 12 questions, hundreds of times, every week. The AI Customer Support System handles the repeatable 60–80% automatically, so your team\'s hours go toward conversations that actually build client relationships.',
            metric: 'Typical results: [METRIC]% of tickets resolved without human handling, [METRIC] in support cost reduction',
          },
          {
            title: 'Lead Qualification Agent',
            body: 'For businesses with high inbound volume and a need to separate buyers from browsers before the sales conversation happens. Asks structured questions, identifies intent signals, and filters your pipeline to the leads worth pursuing.',
            timeFrame: 'The hours your team loses deciding whether a lead is worth pursuing compound into weeks over the course of a year. The Lead Qualification Agent makes that decision in seconds — consistently, at scale.',
            metric: 'Typical results: [METRIC]',
          },
          {
            title: 'Operational Automation Suite',
            body: 'CRM workflows that update themselves. Reports that generate without anyone running them. Data that moves between systems without human copy-paste. Internal processes that currently depend on the right person doing the right thing at the right time — automated.',
            timeFrame: 'Every manual process in your operations is a recurring tax on your team\'s time. The Operational Automation Suite eliminates that tax — those hours get redirected to the work only humans can do.',
            metric: 'Typical results: [METRIC]',
          },
          {
            title: 'Internal Knowledge Base AI',
            body: 'An AI assistant trained on your documentation, processes, and institutional knowledge. New hires find answers in seconds. Your team stops Slacking each other the same questions. Your knowledge stays with the company when employees leave.',
            timeFrame: 'How much time does your team spend looking for information that already exists inside your company? The Knowledge Base AI answers that question in seconds — every time, for every team member.',
            metric: 'Typical results: [METRIC]',
          },
          {
            title: 'Custom AI Integrations',
            body: 'WhatsApp Business API, HubSpot, Salesforce, Pipedrive, custom CRMs, internal databases, ERPs, and proprietary systems. We\'ve built integrations across the stack — if it has an API, we can connect it.',
            timeFrame: 'Every integration gap is manual work in disguise. We close those gaps so your data moves — and your team doesn\'t have to.',
            metric: 'Typical results: [METRIC]',
          },
        ].map(({ title, body, timeFrame, metric }) => (
          <div class="bg-neutral-900 border border-neutral-800 rounded-lg p-8 hover:border-neutral-700 hover:bg-neutral-850 transition-colors duration-200 flex flex-col">
            <HourglassIcon size={32} class="text-accent mb-4" />
            <h3 class="text-xl font-semibold text-white mb-3">{title}</h3>
            <p class="text-[15px] text-neutral-400 leading-relaxed mb-4 flex-1">{body}</p>
            <p class="text-[14px] text-neutral-500 leading-relaxed mb-3 italic">{timeFrame}</p>
            <p class="text-[13px] font-medium text-accent-muted italic placeholder-content px-2 py-1 rounded">{metric}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 6: PROCESS -->
  <section class="bg-neutral-950 py-24 md:py-16">
    <div class="mx-auto max-w-[1200px] px-5 md:px-8 lg:px-0">
      <SectionLabel>How It Works</SectionLabel>
      <h2 class="text-[28px] md:text-[36px] lg:text-[42px] font-semibold text-white mt-4 mb-12" style="letter-spacing: -0.01em;">
        How a Reis IA Systems Project Works
      </h2>

      <div class="space-y-12">
        {[
          {
            num: '01',
            title: 'AI Revenue Audit',
            week: 'WEEK 1',
            showHourglass: true,
            body: 'Before a single system is built, we do something most AI vendors skip entirely: we figure out where the money is. A 60–90 minute session. We map your business, your operations, and your revenue processes against the Revenue-First framework. Not to impress you with technical possibilities — to identify exactly where AI generates the fastest, highest-leverage return. You receive a written report with top 3–5 AI revenue opportunities, priority ranking by effort vs. impact, budget and timeline estimates, and integration requirements. Why does this matter? Because the most expensive thing in any AI project is not the technology. It\'s the time lost building the wrong thing. The Audit eliminates that before you spend a dollar.',
            bullets: [],
          },
          {
            num: '02',
            title: 'Implementation Plan',
            week: 'WEEKS 1–2',
            showHourglass: false,
            body: 'Based on the audit, we define the scope, timeline, KPIs, and integration requirements for the implementation. No ambiguity. No "we\'ll figure it out as we go." Every implementation starts with a clear definition of what success looks like.',
            bullets: [],
          },
          {
            num: '03',
            title: 'Build',
            week: 'WEEKS 2–6',
            showHourglass: false,
            body: 'We build the agreed systems. You receive progress updates throughout. No black box — you see what\'s being built and why.',
            bullets: [],
          },
          {
            num: '04',
            title: 'Integration and Testing',
            week: 'WEEKS 4–7',
            showHourglass: false,
            body: 'We integrate with your existing systems — CRM, WhatsApp, website, APIs — and run structured testing before launch. Your team is involved in testing so they understand what\'s been built.',
            bullets: [],
          },
          {
            num: '05',
            title: 'Launch and Optimization',
            week: 'WEEKS 6–8+',
            showHourglass: false,
            body: 'Systems launch into production. We monitor for the first 4 weeks and optimize based on real usage data. We don\'t disappear at launch.',
            bullets: [],
          },
          {
            num: '06',
            title: 'Team Training and Handoff',
            week: 'POST-LAUNCH',
            showHourglass: false,
            body: 'Your team is trained on how the systems work, how to maintain them, and when to escalate issues. You receive full documentation. You own everything — code, documentation, access credentials, all of it.',
            bullets: [],
          },
          {
            num: '07',
            title: '60-Day Performance Window',
            week: '60 DAYS POST-HANDOFF',
            showHourglass: false,
            body: 'After handoff, we monitor KPIs for 60 days. If agreed targets aren\'t trending in the right direction, we continue optimizing at no additional cost.',
            bullets: [],
          },
        ].map((step) => (
          <div class="grid grid-cols-1 lg:grid-cols-[80px_1fr] gap-6">
            <div class="flex items-start gap-3">
              <span class="text-[48px] font-bold text-accent leading-none">{step.num}</span>
              {step.showHourglass && (
                <HourglassIcon size={24} class="text-accent mt-3" />
              )}
            </div>
            <div class="lg:border-l lg:border-neutral-800 lg:pl-8">
              <div class="flex flex-wrap items-center gap-3 mb-2">
                <h3 class="text-2xl font-semibold text-white">{step.title}</h3>
                <span class="text-xs uppercase tracking-widest bg-neutral-800 text-neutral-400 px-2 py-0.5 rounded">{step.week}</span>
              </div>
              <p class="text-base text-neutral-400 leading-relaxed max-w-[600px]">{step.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 7: RESULTS / PROOF -->
  <section class="bg-black py-24 md:py-16">
    <div class="mx-auto max-w-[1200px] px-5 md:px-8 lg:px-0">
      <div class="text-center mb-12">
        <SectionLabel>Results</SectionLabel>
        <h2 class="text-[28px] md:text-[36px] lg:text-[42px] font-semibold text-white mt-4" style="letter-spacing: -0.01em;">
          What Happens When AI Is Implemented Right
        </h2>
      </div>

      <!-- Case studies -->
      <div class="space-y-8">
        <!-- Case Study 1: Lead Qualification -->
        <div class="bg-neutral-900 border border-neutral-800 rounded-lg overflow-hidden placeholder-content">
          <div class="placeholder-content p-3 border-b border-neutral-800">
            <span class="text-xs uppercase tracking-widest text-neutral-600">Placeholder — Case Study: Lead Qualification</span>
          </div>
          <div class="grid grid-cols-1 lg:grid-cols-12">
            <div class="lg:col-span-5 p-8 lg:p-12">
              <p class="text-[48px] font-bold text-accent leading-none">[METRIC]%</p>
              <p class="text-[13px] uppercase tracking-widest text-neutral-500 mt-2">improvement in sales-ready leads</p>
              <p class="text-[48px] font-bold text-white leading-none mt-6">[METRIC]</p>
              <p class="text-[13px] uppercase tracking-widest text-neutral-500 mt-2">hours/week returned to sales</p>
              <p class="text-[48px] font-bold text-white leading-none mt-6">[METRIC]%</p>
              <p class="text-[13px] uppercase tracking-widest text-neutral-500 mt-2">improvement in close rate</p>
            </div>
            <div class="lg:col-span-7 p-8 lg:p-12 lg:border-l lg:border-neutral-800">
              <p class="text-[13px] uppercase tracking-widest text-neutral-500">[B2B Company Placeholder] — Professional Services</p>
              <h3 class="text-xl font-semibold text-white mt-3">The situation:</h3>
              <p class="text-base text-neutral-300 leading-relaxed mt-2">Sales team spending 70% of their time on leads that weren't ready to buy. Pipeline was full but conversion rate was low.</p>
              <h3 class="text-xl font-semibold text-white mt-4">What we built:</h3>
              <p class="text-base text-neutral-300 leading-relaxed mt-2">AI lead qualification agent integrated with their CRM and WhatsApp. Handles inbound inquiries, asks structured discovery questions, scores and routes qualified leads.</p>
              <h3 class="text-xl font-semibold text-white mt-4">Result:</h3>
              <ul class="mt-2 space-y-1 text-base text-neutral-300">
                <li>— [METRIC]% improvement in sales-ready leads reaching the team</li>
                <li>— [METRIC] hours per week returned to the sales team</li>
                <li>— [METRIC]% improvement in close rate within 60 days</li>
              </ul>
              <div class="mt-6">
                <TestimonialBlock
                  quote="[TESTIMONIAL — placeholder quote text]"
                  name="[Contact Name]"
                  role="[Company] — [Title]"
                  isPlaceholder={true}
                />
              </div>
            </div>
          </div>
        </div>

        <!-- Case Study 2: Customer Support -->
        <div class="bg-neutral-900 border border-neutral-800 rounded-lg overflow-hidden placeholder-content">
          <div class="placeholder-content p-3 border-b border-neutral-800">
            <span class="text-xs uppercase tracking-widest text-neutral-600">Placeholder — Case Study: Customer Support</span>
          </div>
          <div class="grid grid-cols-1 lg:grid-cols-12">
            <div class="lg:col-span-7 p-8 lg:p-12">
