---
/**
 * StatBlock -- Stat value + label + blue divider, data-counter for animation.
 */
interface Props {
  value: string;
  label: string;
  context?: string;
  color?: 'blue' | 'white';
  class?: string;
}

const {
  value,
  label,
  context,
  color = 'blue',
  class: className = '',
} = Astro.props;

const valueColor = color === 'blue' ? 'text-[var(--accent-blue)]' : 'text-[var(--text-primary)]';

// Parse numeric value for counter animation
const match = value.match(/^([^0-9]*)(\d+)(.*)$/);
const numericPrefix = match ? match[1] : '';
const numericTarget = match ? parseInt(match[2], 10) : null;
const numericSuffix = match ? match[3] : '';
const canAnimate = numericTarget !== null;
---

<div class:list={['text-center md:text-left', className]}>
  <!-- Blue accent divider -->
  <div
    class="w-10 h-px mb-4 mx-auto md:mx-0"
    style="background: linear-gradient(to right, var(--accent-blue), transparent);"
    aria-hidden="true"
  ></div>

  <p
    class:list={['font-bold tabular-nums leading-none', valueColor]}
    style="font-size: clamp(2.5rem, 1.5rem + 3.5vw, 3.5rem);"
    data-counter={canAnimate ? '' : undefined}
    data-target={canAnimate ? numericTarget : undefined}
    data-suffix={canAnimate ? numericSuffix : undefined}
    data-prefix={canAnimate ? numericPrefix : undefined}
    aria-label={`${value} - ${label}`}
  >
    {value}
  </p>

  <p class="text-[var(--text-label)] uppercase tracking-[0.05em] font-semibold text-[var(--text-tertiary)] mt-3 max-w-[200px] mx-auto md:mx-0 leading-snug">
    {label}
  </p>

  {context && (
    <p class="text-[var(--text-body-sm)] text-[var(--text-secondary)] mt-1 leading-relaxed">
      {context}
    </p>
  )}
</div>
