---
/**
 * MockupTransformation — Split before/after card showing professional transformation.
 * Left: grey "Profissional com dúvidas" with low progress bars.
 * Right: blue "Operador de IA" with animated progress bars.
 * Stripe/Linear style product mockup.
 */
---

<div class="mockup-card p-6 rounded-[var(--radius-xl)] flex flex-col gap-5">
  <!-- Header -->
  <span style="font-size: var(--text-label); font-weight: 600; letter-spacing: 0.03em; color: var(--text-secondary); text-transform: uppercase;">
    Transformação Z7
  </span>

  <!-- Split cards -->
  <div class="grid grid-cols-2 gap-4">
    <!-- Before -->
    <div class="p-4 rounded-lg" style="background: var(--surface-3); border: 1px solid var(--border-subtle);">
      <p style="font-size: var(--text-micro); color: var(--text-quaternary); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">Quem Entra</p>
      <div class="flex flex-col gap-3">
        <div>
          <div class="flex items-center justify-between mb-1">
            <span style="font-size: 10px; color: var(--text-quaternary);">Oferta</span>
            <span style="font-size: 10px; color: var(--text-quaternary); font-variant-numeric: tabular-nums;">15%</span>
          </div>
          <div class="h-1 rounded-full" style="background: var(--surface-2);">
            <div class="mockup-progress-bar h-full rounded-full" style="--progress-width: 15%; background: var(--text-quaternary); opacity: 0.5;"></div>
          </div>
        </div>
        <div>
          <div class="flex items-center justify-between mb-1">
            <span style="font-size: 10px; color: var(--text-quaternary);">Aquisição</span>
            <span style="font-size: 10px; color: var(--text-quaternary); font-variant-numeric: tabular-nums;">10%</span>
          </div>
          <div class="h-1 rounded-full" style="background: var(--surface-2);">
            <div class="mockup-progress-bar h-full rounded-full" style="--progress-width: 10%; background: var(--text-quaternary); opacity: 0.5;"></div>
          </div>
        </div>
        <div>
          <div class="flex items-center justify-between mb-1">
            <span style="font-size: 10px; color: var(--text-quaternary);">Entrega</span>
            <span style="font-size: 10px; color: var(--text-quaternary); font-variant-numeric: tabular-nums;">5%</span>
          </div>
          <div class="h-1 rounded-full" style="background: var(--surface-2);">
            <div class="mockup-progress-bar h-full rounded-full" style="--progress-width: 5%; background: var(--text-quaternary); opacity: 0.5;"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- After -->
    <div class="p-4 rounded-lg" style="background: rgba(74,144,255,0.08); border: 1px solid rgba(74,144,255,0.2);">
      <p style="font-size: var(--text-micro); color: var(--accent-blue); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px; font-weight: 600;">Quem Sai</p>
      <div class="flex flex-col gap-3">
        <div>
          <div class="flex items-center justify-between mb-1">
            <span style="font-size: 10px; color: var(--accent-blue);">Oferta</span>
            <span style="font-size: 10px; color: var(--accent-blue); font-variant-numeric: tabular-nums;">100%</span>
          </div>
          <div class="h-1 rounded-full" style="background: rgba(74,144,255,0.15);">
            <div class="mockup-progress-bar h-full rounded-full" style="--progress-width: 100%; background: var(--accent-blue);"></div>
          </div>
        </div>
        <div>
          <div class="flex items-center justify-between mb-1">
            <span style="font-size: 10px; color: var(--accent-blue);">Aquisição</span>
            <span style="font-size: 10px; color: var(--accent-blue); font-variant-numeric: tabular-nums;">100%</span>
          </div>
          <div class="h-1 rounded-full" style="background: rgba(74,144,255,0.15);">
            <div class="mockup-progress-bar h-full rounded-full" style="--progress-width: 100%; background: var(--accent-blue);"></div>
          </div>
        </div>
        <div>
          <div class="flex items-center justify-between mb-1">
            <span style="font-size: 10px; color: var(--accent-blue);">Entrega</span>
            <span style="font-size: 10px; color: var(--accent-blue); font-variant-numeric: tabular-nums;">100%</span>
          </div>
          <div class="h-1 rounded-full" style="background: rgba(74,144,255,0.15);">
            <div class="mockup-progress-bar h-full rounded-full" style="--progress-width: 100%; background: var(--accent-blue);"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom label -->
  <p style="font-size: var(--text-micro); color: var(--text-quaternary); text-align: center;">
    <span style="color: var(--accent-blue); font-weight: 600;">7 dias</span> — de dúvida a operador completo
  </p>
</div>
