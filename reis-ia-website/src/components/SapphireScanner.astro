---
/**
 * SapphireScanner -- Wrapper with rotating blue conic-gradient border.
 * Max 1-2 per page.
 */
interface Props {
  class?: string;
  tag?: string;
}

const { class: className = '', tag = 'div' } = Astro.props;
const Tag = tag as any;
---

<Tag class:list={['sapphire-scanner', className]}>
  <slot />
</Tag>
