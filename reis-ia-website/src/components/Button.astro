---
/**
 * Button -- Design system button.
 * Variants: primary (blue bg, white text), secondary (border), ghost (text+arrow), hero (larger primary).
 * Props: variant, href, size, type, class.
 */
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost' | 'hero';
  href?: string;
  class?: string;
  type?: 'button' | 'submit';
  size?: 'md' | 'lg' | 'hero';
}

const {
  variant = 'primary',
  href,
  class: className = '',
  type = 'button',
  size,
} = Astro.props;

// Resolve effective size
const effectiveSize = size ?? (variant === 'hero' ? 'hero' : 'md');

const sizeClass = `btn-${effectiveSize}`;

const variantClass = variant === 'hero' ? 'btn-primary' : `btn-${variant}`;

const classes = `btn ${variantClass} ${sizeClass} ${className}`.trim();
---

{href ? (
  <a href={href} class={classes}>
    <slot />
    {variant === 'ghost' && <span class="arrow-icon" aria-hidden="true">&rarr;</span>}
  </a>
) : (
  <button type={type} class={classes}>
    <slot />
    {variant === 'ghost' && <span class="arrow-icon" aria-hidden="true">&rarr;</span>}
  </button>
)}
