---
/**
 * MockupBeforeAfter — Split card showing Before (47h/semana, grey) vs
 * After (8h/semana, blue accent) with animated compression bar.
 * Stripe/Linear style product mockup.
 */
---

<div class="mockup-card p-6 rounded-[var(--radius-xl)] flex flex-col gap-5">
  <!-- Header -->
  <span style="font-size: var(--text-label); font-weight: 600; letter-spacing: 0.03em; color: var(--text-secondary); text-transform: uppercase;">
    Antes &amp; Depois
  </span>

  <!-- Split comparison -->
  <div class="grid grid-cols-2 gap-4">
    <!-- Before -->
    <div
      class="p-4 rounded-lg text-center"
      style="background: var(--surface-3); border: 1px solid var(--border-subtle);"
    >
      <p style="font-size: var(--text-micro); color: var(--text-quaternary); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Antes</p>
      <p class="font-bold tabular-nums" style="font-size: clamp(1.5rem, 1rem + 1.5vw, 2rem); color: var(--text-tertiary);">47h</p>
      <p style="font-size: var(--text-micro); color: var(--text-quaternary);">/semana</p>
    </div>

    <!-- After -->
    <div
      class="p-4 rounded-lg text-center"
      style="background: rgba(74,144,255,0.08); border: 1px solid rgba(74,144,255,0.2);"
    >
      <p style="font-size: var(--text-micro); color: var(--accent-blue); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px; font-weight: 600;">Depois</p>
      <p class="font-bold tabular-nums" style="font-size: clamp(1.5rem, 1rem + 1.5vw, 2rem); color: var(--accent-blue);">8h</p>
      <p style="font-size: var(--text-micro); color: var(--accent-blue); opacity: 0.7;">/semana</p>
    </div>
  </div>

  <!-- Compression bar -->
  <div>
    <div class="flex items-center justify-between mb-2">
      <span style="font-size: var(--text-micro); color: var(--text-quaternary);">Compressão de tempo</span>
      <span style="font-size: var(--text-micro); color: var(--accent-blue); font-weight: 600;">83%</span>
    </div>
    <div class="h-1.5 rounded-full" style="background: var(--surface-3);">
      <div class="compress-bar h-full rounded-full" style="background: var(--accent-blue); width: 100%;"></div>
    </div>
  </div>

  <!-- Bottom stat -->
  <p style="font-size: var(--text-micro); color: var(--text-quaternary); text-align: center;">
    <span style="color: var(--accent-blue); font-weight: 600;">+39h</span> devolvidas por semana para estrategia e receita
  </p>
</div>
