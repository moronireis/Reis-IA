---
/**
 * MockupFunnel — 4 horizontal bars shrinking from Visitantes to Clientes.
 * Width animates on scroll via .mockup-funnel-bar + IntersectionObserver.
 * Stripe/Linear style product mockup.
 */
---

<div class="mockup-card p-6 rounded-[var(--radius-xl)] flex flex-col gap-4">
  <!-- Header -->
  <span style="font-size: var(--text-label); font-weight: 600; letter-spacing: 0.03em; color: var(--text-secondary); text-transform: uppercase;">
    Funil de Conversão
  </span>

  <!-- Funnel bars -->
  <div class="flex flex-col gap-3 mt-1">
    <!-- Visitantes -->
    <div>
      <div class="flex items-center justify-between mb-1">
        <span style="font-size: var(--text-micro); color: var(--text-tertiary);">Visitantes</span>
        <span style="font-size: var(--text-micro); color: var(--text-quaternary); font-variant-numeric: tabular-nums;">12.400</span>
      </div>
      <div class="h-2 rounded-full" style="background: var(--surface-3);">
        <div class="mockup-funnel-bar h-full rounded-full" style="--funnel-width: 100%; background: var(--accent-blue);"></div>
      </div>
    </div>

    <!-- Leads -->
    <div>
      <div class="flex items-center justify-between mb-1">
        <span style="font-size: var(--text-micro); color: var(--text-tertiary);">Leads</span>
        <span style="font-size: var(--text-micro); color: var(--text-quaternary); font-variant-numeric: tabular-nums;">3.720</span>
      </div>
      <div class="h-2 rounded-full" style="background: var(--surface-3);">
        <div class="mockup-funnel-bar h-full rounded-full" style="--funnel-width: 30%; background: var(--accent-blue); opacity: 0.85;"></div>
      </div>
    </div>

    <!-- Qualificados -->
    <div>
      <div class="flex items-center justify-between mb-1">
        <span style="font-size: var(--text-micro); color: var(--text-tertiary);">Qualificados</span>
        <span style="font-size: var(--text-micro); color: var(--text-quaternary); font-variant-numeric: tabular-nums;">1.116</span>
      </div>
      <div class="h-2 rounded-full" style="background: var(--surface-3);">
        <div class="mockup-funnel-bar h-full rounded-full" style="--funnel-width: 9%; background: var(--accent-blue); opacity: 0.7;"></div>
      </div>
    </div>

    <!-- Clientes -->
    <div>
      <div class="flex items-center justify-between mb-1">
        <span style="font-size: var(--text-micro); color: var(--text-tertiary);">Clientes</span>
        <span style="font-size: var(--text-micro); color: var(--text-quaternary); font-variant-numeric: tabular-nums;">446</span>
      </div>
      <div class="h-2 rounded-full" style="background: var(--surface-3);">
        <div class="mockup-funnel-bar h-full rounded-full" style="--funnel-width: 3.6%; background: var(--accent-blue); opacity: 0.55;"></div>
      </div>
    </div>
  </div>
</div>
