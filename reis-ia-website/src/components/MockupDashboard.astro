---
/**
 * MockupDashboard — Glassmorphism card with 3 animated metric counters,
 * mini CSS bar chart, and a pulsing "live" indicator.
 * Stripe/Linear style product mockup.
 */
---

<div class="mockup-card p-6 rounded-[var(--radius-xl)] flex flex-col gap-5">
  <!-- Header row: title + live indicator -->
  <div class="flex items-center justify-between">
    <span style="font-size: var(--text-label); font-weight: 600; letter-spacing: 0.03em; color: var(--text-secondary); text-transform: uppercase;">
      Dashboard IA
    </span>
    <span class="flex items-center gap-1.5">
      <span class="mockup-live-dot"></span>
      <span style="font-size: var(--text-micro); color: var(--text-quaternary);">Live</span>
    </span>
  </div>

  <!-- 3 metric counters -->
  <div class="grid grid-cols-3 gap-4">
    <div>
      <p
        class="font-bold tabular-nums text-[var(--accent-blue)]"
        style="font-size: clamp(1.25rem, 1rem + 1vw, 1.75rem);"
        data-counter data-target="847" data-suffix="h"
      >0h</p>
      <p style="font-size: var(--text-micro); color: var(--text-quaternary); margin-top: 2px;">Horas recuperadas</p>
    </div>
    <div>
      <p
        class="font-bold tabular-nums text-[var(--text-primary)]"
        style="font-size: clamp(1.25rem, 1rem + 1vw, 1.75rem);"
        data-counter data-target="312" data-prefix="R$" data-suffix="K"
      >R$0K</p>
      <p style="font-size: var(--text-micro); color: var(--text-quaternary); margin-top: 2px;">Receita atribuída</p>
    </div>
    <div>
      <p
        class="font-bold tabular-nums text-[var(--accent-blue)]"
        style="font-size: clamp(1.25rem, 1rem + 1vw, 1.75rem);"
        data-counter data-target="70" data-suffix="x"
      >0x</p>
      <p style="font-size: var(--text-micro); color: var(--text-quaternary); margin-top: 2px;">Mais rápido</p>
    </div>
  </div>

  <!-- Mini bar chart (CSS only) -->
  <div class="flex items-end gap-1.5 h-12 mt-1">
    <div class="mockup-bar flex-1 rounded-t-sm" style="--bar-height: 45%;"></div>
    <div class="mockup-bar flex-1 rounded-t-sm" style="--bar-height: 65%;"></div>
    <div class="mockup-bar flex-1 rounded-t-sm" style="--bar-height: 40%;"></div>
    <div class="mockup-bar flex-1 rounded-t-sm" style="--bar-height: 80%;"></div>
    <div class="mockup-bar flex-1 rounded-t-sm" style="--bar-height: 55%;"></div>
    <div class="mockup-bar flex-1 rounded-t-sm" style="--bar-height: 90%;"></div>
    <div class="mockup-bar flex-1 rounded-t-sm" style="--bar-height: 70%;"></div>
    <div class="mockup-bar flex-1 rounded-t-sm" style="--bar-height: 100%;"></div>
  </div>
</div>
