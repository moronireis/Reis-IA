---
interface Props {
  class?: string;
  size?: number;
  ariaHidden?: boolean;
}

const { class: className = '', size = 24, ariaHidden = true } = Astro.props;
---

<svg
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  width={size}
  height={size}
  class={className}
  aria-hidden={ariaHidden ? "true" : undefined}
  role={ariaHidden ? "presentation" : undefined}
>
  <!-- Base platform -->
  <path d="M6 20h12" />
  <!-- Pedestal -->
  <path d="M8 20v-2h8v2" />
  <!-- Knight body/neck -->
  <path d="M10 18V14" />
  <!-- Knight head shape — simplified profile -->
  <path d="M10 14c0 0-2-1-2-4 0-2 1-4 3-5l2-1 1 2-1 1 1 3-1 2-3 2z" />
  <!-- Ear detail -->
  <path d="M12 5l1-2" />
  <!-- Muzzle/nose -->
  <path d="M11 10c1 0 2 .5 2 1.5" />
</svg>
