---
/**
 * MockupDiagnostico — Mini mockup showing a simplified "time report":
 * 3 horizontal bars with time-waste percentages and a "30 min" timer badge.
 * Compact single card for agendar hero.
 * Stripe/Linear style product mockup.
 */
---

<div class="mockup-card p-5 rounded-[var(--radius-xl)] flex flex-col gap-4" style="max-width: 420px; margin: 0 auto;">
  <!-- Header row -->
  <div class="flex items-center justify-between">
    <span style="font-size: var(--text-label); font-weight: 600; letter-spacing: 0.03em; color: var(--text-secondary); text-transform: uppercase;">
      Diagnóstico de Tempo
    </span>
    <span
      class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full"
      style="background: rgba(74,144,255,0.1); border: 1px solid rgba(74,144,255,0.2); font-size: 10px; font-weight: 600; color: var(--accent-blue);"
    >
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
      </svg>
      30 min
    </span>
  </div>

  <!-- 3 department bars -->
  <div class="flex flex-col gap-3">
    <div>
      <div class="flex items-center justify-between mb-1">
        <span style="font-size: var(--text-micro); color: var(--text-tertiary);">Vendas — follow-up manual</span>
        <span style="font-size: var(--text-micro); color: var(--accent-blue); font-weight: 600; font-variant-numeric: tabular-nums;">62%</span>
      </div>
      <div class="h-1.5 rounded-full" style="background: var(--surface-3);">
        <div class="mockup-funnel-bar h-full rounded-full" style="--funnel-width: 62%; background: var(--accent-blue);"></div>
      </div>
    </div>
    <div>
      <div class="flex items-center justify-between mb-1">
        <span style="font-size: var(--text-micro); color: var(--text-tertiary);">Suporte — respostas repetitivas</span>
        <span style="font-size: var(--text-micro); color: var(--accent-blue); font-weight: 600; font-variant-numeric: tabular-nums;">48%</span>
      </div>
      <div class="h-1.5 rounded-full" style="background: var(--surface-3);">
        <div class="mockup-funnel-bar h-full rounded-full" style="--funnel-width: 48%; background: var(--accent-blue); opacity: 0.8;"></div>
      </div>
    </div>
    <div>
      <div class="flex items-center justify-between mb-1">
        <span style="font-size: var(--text-micro); color: var(--text-tertiary);">Ops — relatórios manuais</span>
        <span style="font-size: var(--text-micro); color: var(--accent-blue); font-weight: 600; font-variant-numeric: tabular-nums;">71%</span>
      </div>
      <div class="h-1.5 rounded-full" style="background: var(--surface-3);">
        <div class="mockup-funnel-bar h-full rounded-full" style="--funnel-width: 71%; background: var(--accent-blue); opacity: 0.65;"></div>
      </div>
    </div>
  </div>

  <!-- Bottom stat -->
  <p style="font-size: var(--text-micro); color: var(--text-quaternary); text-align: center;">
    Tempo recuperável identificado: <span style="color: var(--accent-blue); font-weight: 600;">207h/mês</span>
  </p>
</div>
