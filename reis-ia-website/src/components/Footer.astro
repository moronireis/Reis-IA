---
/**
 * Footer -- Surface-1 background, blue gradient divider at top, 4-column layout.
 * H1-B hourglass + "Reis IA" wordmark (font-weight 300) + "O Tempo e Rei".
 */
import HourglassIcon from './HourglassIcon.astro';

const columns = [
  {
    title: 'Ecossistema',
    links: [
      { label: 'Time Builders', href: '/builder' },
      { label: 'Systems', href: '/systems' },
    ],
  },
  {
    title: 'Recursos',
    links: [
      { label: 'Blog', href: '#' },
      { label: 'Sobre', href: '#' },
    ],
  },
  {
    title: 'Contato',
    links: [
      { label: 'LinkedIn', href: 'https://linkedin.com/in/moronireis' },
      { label: 'Instagram', href: 'https://instagram.com/reis.ia' },
    ],
  },
];
---

<footer
  style="background: var(--surface-1);"
  aria-label="Rodape do site"
>
  <!-- Blue gradient divider at top -->
  <div class="gradient-divider-blue"></div>

  <div class="container-standard" style="padding-top: var(--space-3xl); padding-bottom: var(--space-2xl);">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-3 group mb-3" aria-label="Reis IA">
          <HourglassIcon
            size={24}
            class="text-[var(--accent-blue)] transition-colors duration-300 group-hover:text-[var(--accent-blue-hover)]"
          />
          <span class="font-light text-[var(--text-primary)] tracking-tight text-sm">
            REIS IA
          </span>
        </a>
        <p class="text-[var(--text-caption)] text-[var(--text-tertiary)] mt-2 italic">
          O Tempo é Rei
        </p>
      </div>

      <!-- Link columns -->
      {columns.map(col => (
        <div>
          <h4
            class="text-[var(--text-label)] uppercase tracking-[0.05em] font-semibold text-[var(--text-tertiary)] mb-4"
          >
            {col.title}
          </h4>
          <ul class="space-y-3">
            {col.links.map(link => (
              <li>
                <a
                  href={link.href}
                  class="text-[var(--text-body-sm)] text-[var(--text-tertiary)] hover:text-[var(--text-primary)] transition-colors"
                  style="transition-duration: var(--duration-fast);"
                  {...(link.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="gradient-divider" style="margin-top: var(--space-xl);"></div>
    <div class="flex flex-col md:flex-row justify-between items-center gap-4" style="margin-top: var(--space-lg);">
      <span class="text-[var(--text-caption)] text-[var(--text-quaternary)]">
        &copy; {new Date().getFullYear()} Reis IA. Todos os direitos reservados.
      </span>
      <div class="flex items-center gap-4">
        <a
          href="https://linkedin.com/in/moronireis"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[var(--text-quaternary)] hover:text-[var(--text-secondary)] transition-colors"
          style="transition-duration: var(--duration-fast);"
          aria-label="LinkedIn"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a
          href="https://instagram.com/reis.ia"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[var(--text-quaternary)] hover:text-[var(--text-secondary)] transition-colors"
          style="transition-duration: var(--duration-fast);"
          aria-label="Instagram"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
