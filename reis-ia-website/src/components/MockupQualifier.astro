---
/**
 * MockupQualifier — Two side-by-side compact cards: "Match" (blue/check)
 * and "No Match" (grey/X). Visual header for qualifier section.
 * Stripe/Linear style product mockup.
 */
---

<div class="grid grid-cols-2 gap-4" style="max-width: 600px; margin: 0 auto;">
  <!-- Match card -->
  <div class="mockup-card p-5 rounded-[var(--radius-xl)] flex flex-col gap-3">
    <div class="flex items-center gap-2">
      <div
        class="w-8 h-8 rounded-full flex items-center justify-center"
        style="background: rgba(74,144,255,0.12); border: 1px solid rgba(74,144,255,0.25);"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent-blue);" aria-hidden="true">
          <path d="m9 12 2 2 4-4"/>
        </svg>
      </div>
      <span style="font-size: var(--text-label); font-weight: 600; color: var(--accent-blue); text-transform: uppercase; letter-spacing: 0.03em;">
        Match
      </span>
    </div>
    <div class="flex flex-col gap-2">
      <div class="flex items-center gap-2">
        <span style="color: var(--accent-blue); font-size: 10px;" aria-hidden="true">&#10003;</span>
        <span style="font-size: var(--text-micro); color: var(--text-secondary);">Experiência em negócios</span>
      </div>
      <div class="flex items-center gap-2">
        <span style="color: var(--accent-blue); font-size: 10px;" aria-hidden="true">&#10003;</span>
        <span style="font-size: var(--text-micro); color: var(--text-secondary);">Urgência de agir</span>
      </div>
      <div class="flex items-center gap-2">
        <span style="color: var(--accent-blue); font-size: 10px;" aria-hidden="true">&#10003;</span>
        <span style="font-size: var(--text-micro); color: var(--text-secondary);">Foco em resultado</span>
      </div>
    </div>
  </div>

  <!-- No Match card -->
  <div class="mockup-card p-5 rounded-[var(--radius-xl)] flex flex-col gap-3" style="opacity: 0.6;">
    <div class="flex items-center gap-2">
      <div
        class="w-8 h-8 rounded-full flex items-center justify-center"
        style="background: var(--surface-3); border: 1px solid var(--border-subtle);"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-quaternary);" aria-hidden="true">
          <path d="m15 9-6 6"/><path d="m9 9 6 6"/>
        </svg>
      </div>
      <span style="font-size: var(--text-label); font-weight: 600; color: var(--text-quaternary); text-transform: uppercase; letter-spacing: 0.03em;">
        No Match
      </span>
    </div>
    <div class="flex flex-col gap-2">
      <div class="flex items-center gap-2">
        <span style="color: var(--text-quaternary); font-size: 10px;" aria-hidden="true">&#10007;</span>
        <span style="font-size: var(--text-micro); color: var(--text-quaternary);">IA como hobby</span>
      </div>
      <div class="flex items-center gap-2">
        <span style="color: var(--text-quaternary); font-size: 10px;" aria-hidden="true">&#10007;</span>
        <span style="font-size: var(--text-micro); color: var(--text-quaternary);">Sem urgência</span>
      </div>
      <div class="flex items-center gap-2">
        <span style="color: var(--text-quaternary); font-size: 10px;" aria-hidden="true">&#10007;</span>
        <span style="font-size: var(--text-micro); color: var(--text-quaternary);">Busca opção barata</span>
      </div>
    </div>
  </div>
</div>
