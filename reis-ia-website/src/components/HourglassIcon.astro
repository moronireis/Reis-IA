---
interface Props {
  class?: string;
  size?: number;
  ariaHidden?: boolean;
}

const { class: className = '', size = 24, ariaHidden = true } = Astro.props;
---

<svg
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  width={size}
  height={size}
  class={className}
  aria-hidden={ariaHidden ? "true" : undefined}
  role={ariaHidden ? "presentation" : undefined}
>
  <!-- Top bar -->
  <path d="M5 2h14" />
  <!-- Top triangle narrowing to center -->
  <path d="M5 2l5 8h4l5-8" />
  <!-- Center neck -->
  <path d="M10 10s-.5 1 0 2" />
  <path d="M14 10s.5 1 0 2" />
  <!-- Bottom triangle widening from center -->
  <path d="M10 12l-5 8h14l-5-8" />
  <!-- Bottom bar -->
  <path d="M5 22h14" />
  <!-- Sand fill line (subtle) -->
  <path d="M8.5 18h7" stroke-opacity="0.4" />
</svg>
