---
/**
 * HourglassIcon -- H1-B Variation A brand mark.
 * 5-line geometric hourglass, viewBox 64x64.
 * Geometry: M14,8 L50,8 / M50,8 L14,56 / M14,8 L25,25 / M39,39 L50,56 / M14,56 L50,56
 */
interface Props {
  class?: string;
  size?: number;
  strokeWidth?: number;
  ariaHidden?: boolean;
}

const {
  class: className = '',
  size = 24,
  strokeWidth = 5,
  ariaHidden = true,
} = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 64 64"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  width={size}
  height={size}
  class={className}
  aria-hidden={ariaHidden ? "true" : undefined}
  role={ariaHidden ? "presentation" : undefined}
>
  <!-- Top bar -->
  <line x1="14" y1="8" x2="50" y2="8" />
  <!-- Top-right to bottom-left diagonal -->
  <line x1="50" y1="8" x2="14" y2="56" />
  <!-- Top-left to center-left -->
  <line x1="14" y1="8" x2="25" y2="25" />
  <!-- Center-right to bottom-right -->
  <line x1="39" y1="39" x2="50" y2="56" />
  <!-- Bottom bar -->
  <line x1="14" y1="56" x2="50" y2="56" />
</svg>
