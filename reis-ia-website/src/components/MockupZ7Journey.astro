---
/**
 * MockupZ7Journey — Mini horizontal journey: 3 inline states
 * "Candidatura → Z7 Days → Operador IA" with icons and dash connectors.
 * Compact, inline-friendly. For aplicar hero.
 * Stripe/Linear style product mockup.
 */
---

<div class="mockup-card p-5 rounded-[var(--radius-xl)] flex flex-col gap-4" style="max-width: 480px; margin: 0 auto;">
  <!-- Header -->
  <span style="font-size: var(--text-label); font-weight: 600; letter-spacing: 0.03em; color: var(--text-secondary); text-transform: uppercase;">
    Sua Jornada
  </span>

  <!-- 3 stages inline -->
  <div class="flex items-center gap-0">
    <!-- Stage 1: Candidatura -->
    <div class="flex flex-col items-center gap-2 flex-shrink-0">
      <div
        class="w-10 h-10 rounded-lg flex items-center justify-center"
        style="background: var(--surface-3); border: 1px solid var(--border-subtle);"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-tertiary);" aria-hidden="true">
          <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
          <polyline points="14 2 14 8 20 8"/>
        </svg>
      </div>
      <span style="font-size: 10px; color: var(--text-quaternary); white-space: nowrap;">Candidatura</span>
    </div>

    <!-- Connector -->
    <div class="flex-1 h-px relative mx-2" style="min-width: 20px;">
      <div class="mockup-dash-line"></div>
    </div>

    <!-- Stage 2: Z7 Days (featured) -->
    <div class="flex flex-col items-center gap-2 flex-shrink-0">
      <div class="relative">
        <div
          class="w-11 h-11 rounded-xl flex items-center justify-center mockup-node-pulse"
          style="background: linear-gradient(135deg, rgba(74,144,255,0.15), rgba(74,144,255,0.05)); border: 1px solid rgba(74,144,255,0.3);"
        >
          <span style="font-size: 14px; font-weight: 700; color: var(--accent-blue);">Z7</span>
        </div>
        <!-- 7 dias badge -->
        <span
          class="absolute -top-1.5 -right-2 px-1.5 py-0.5 rounded-full"
          style="font-size: 8px; font-weight: 700; background: var(--accent-blue); color: white; white-space: nowrap;"
        >7d</span>
      </div>
      <span style="font-size: 10px; color: var(--accent-blue); font-weight: 600; white-space: nowrap;">Z7 Days</span>
    </div>

    <!-- Connector -->
    <div class="flex-1 h-px relative mx-2" style="min-width: 20px;">
      <div class="mockup-dash-line"></div>
    </div>

    <!-- Stage 3: Operador IA -->
    <div class="flex flex-col items-center gap-2 flex-shrink-0">
      <div
        class="w-10 h-10 rounded-lg flex items-center justify-center"
        style="background: rgba(74,144,255,0.08); border: 1px solid rgba(74,144,255,0.2);"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent-blue);" aria-hidden="true">
          <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
        </svg>
      </div>
      <span style="font-size: 10px; color: var(--accent-blue); white-space: nowrap;">Operador IA</span>
    </div>
  </div>

  <!-- Bottom stat -->
  <p style="font-size: var(--text-micro); color: var(--text-quaternary); text-align: center;">
    Máx. <span style="color: var(--accent-blue); font-weight: 600;">12 participantes</span> por turma — construção junto
  </p>
</div>
