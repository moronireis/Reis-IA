---
/**
 * MockupPipeline — 6 connected horizontal nodes showing the Systems process.
 * First node active (blue), rest pending (grey). Animated dash connectors.
 * Stripe/Linear style product mockup.
 */
---

<div class="mockup-card p-6 rounded-[var(--radius-xl)] flex flex-col gap-5">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <span style="font-size: var(--text-label); font-weight: 600; letter-spacing: 0.03em; color: var(--text-secondary); text-transform: uppercase;">
      Pipeline de Implementação
    </span>
    <span style="font-size: var(--text-micro); color: var(--text-quaternary);">4-12 semanas</span>
  </div>

  <!-- Pipeline nodes -->
  <div class="flex items-center gap-0 mt-2 overflow-x-auto pb-2">
    {[
      { name: 'Diagnóstico', active: true },
      { name: 'Arquitetura', active: false },
      { name: 'Construção', active: false },
      { name: 'Calibração', active: false },
      { name: 'Lançamento', active: false },
      { name: 'Vigília', active: false },
    ].map((step, i) => (
      <div class="flex items-center flex-1 min-w-0">
        <div class="flex flex-col items-center gap-1.5 flex-shrink-0">
          <div
            class:list={[
              "w-8 h-8 sm:w-9 sm:h-9 rounded-lg flex items-center justify-center",
              step.active ? "mockup-node-pulse" : ""
            ]}
            style={step.active
              ? "background: linear-gradient(135deg, rgba(74,144,255,0.15), rgba(74,144,255,0.05)); border: 1px solid rgba(74,144,255,0.3);"
              : "background: var(--surface-3); border: 1px solid var(--border-subtle);"
            }
          >
            {step.active ? (
              <div class="w-2 h-2 rounded-full" style="background: var(--accent-blue);"></div>
            ) : (
              <div class="w-1.5 h-1.5 rounded-full" style="background: var(--text-quaternary); opacity: 0.5;"></div>
            )}
          </div>
          <span style={`font-size: 9px; white-space: nowrap; ${step.active ? 'color: var(--accent-blue); font-weight: 600;' : 'color: var(--text-quaternary);'}`}>
            {step.name}
          </span>
        </div>
        {i < 5 && (
          <div class="flex-1 h-px relative mx-1" style="min-width: 6px;">
            <div class="mockup-dash-line"></div>
          </div>
        )}
      </div>
    ))}
  </div>

  <!-- Status line -->
  <div class="flex items-center gap-2 mt-1">
    <div class="w-1.5 h-1.5 rounded-full" style="background: #34d399;"></div>
    <span style="font-size: var(--text-micro); color: var(--text-quaternary);">Fase 1 ativa — diagnóstico de tempo em andamento</span>
  </div>
</div>
