---
/**
 * MockupROI — Card with 3 KPI mini-gauges: Receita Atribuída (counter),
 * Tempo Devolvido (counter), Escala (multiplier). Glassmorphism card.
 * Stripe/Linear style product mockup.
 */
---

<div class="mockup-card p-6 rounded-[var(--radius-xl)] flex flex-col gap-5">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <span style="font-size: var(--text-label); font-weight: 600; letter-spacing: 0.03em; color: var(--text-secondary); text-transform: uppercase;">
      ROI Dashboard
    </span>
    <span class="flex items-center gap-1.5">
      <span class="mockup-live-dot"></span>
      <span style="font-size: var(--text-micro); color: var(--text-quaternary);">Live</span>
    </span>
  </div>

  <!-- 3 KPIs -->
  <div class="grid grid-cols-3 gap-4">
    <!-- Receita Atribuída -->
    <div class="text-center p-3 rounded-lg" style="background: var(--surface-3);">
      <p
        class="font-bold tabular-nums text-[var(--accent-blue)]"
        style="font-size: clamp(1.1rem, 0.9rem + 0.8vw, 1.5rem);"
        data-counter data-target="2300" data-prefix="R$" data-suffix="K"
      >R$0K</p>
      <p style="font-size: 10px; color: var(--text-quaternary); margin-top: 4px; line-height: 1.3;">Receita<br/>Atribuída</p>
    </div>

    <!-- Tempo Devolvido -->
    <div class="text-center p-3 rounded-lg" style="background: var(--surface-3);">
      <p
        class="font-bold tabular-nums text-[var(--text-primary)]"
        style="font-size: clamp(1.1rem, 0.9rem + 0.8vw, 1.5rem);"
        data-counter data-target="847" data-suffix="h"
      >0h</p>
      <p style="font-size: 10px; color: var(--text-quaternary); margin-top: 4px; line-height: 1.3;">Tempo<br/>Devolvido</p>
    </div>

    <!-- Escala -->
    <div class="text-center p-3 rounded-lg" style="background: var(--surface-3);">
      <p
        class="font-bold tabular-nums text-[var(--accent-blue)]"
        style="font-size: clamp(1.1rem, 0.9rem + 0.8vw, 1.5rem);"
        data-counter data-target="3" data-suffix="x"
      >0x</p>
      <p style="font-size: 10px; color: var(--text-quaternary); margin-top: 4px; line-height: 1.3;">Escala<br/>sem Headcount</p>
    </div>
  </div>

  <!-- Mini bar chart -->
  <div class="flex items-end gap-1.5 h-10">
    <div class="mockup-bar flex-1 rounded-t-sm" style="--bar-height: 35%;"></div>
    <div class="mockup-bar flex-1 rounded-t-sm" style="--bar-height: 50%;"></div>
    <div class="mockup-bar flex-1 rounded-t-sm" style="--bar-height: 45%;"></div>
    <div class="mockup-bar flex-1 rounded-t-sm" style="--bar-height: 70%;"></div>
    <div class="mockup-bar flex-1 rounded-t-sm" style="--bar-height: 60%;"></div>
    <div class="mockup-bar flex-1 rounded-t-sm" style="--bar-height: 85%;"></div>
    <div class="mockup-bar flex-1 rounded-t-sm" style="--bar-height: 100%;"></div>
  </div>
</div>
