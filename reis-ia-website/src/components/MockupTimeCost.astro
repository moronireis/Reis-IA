---
/**
 * MockupTimeCost — "Calculadora de tempo perdido" card with 3 department lines
 * and animated total counter. Glassmorphism card.
 * Stripe/Linear style product mockup.
 */
---

<div class="mockup-card p-6 rounded-[var(--radius-xl)] flex flex-col gap-5">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <span style="font-size: var(--text-label); font-weight: 600; letter-spacing: 0.03em; color: var(--text-secondary); text-transform: uppercase;">
      Calculadora de Tempo
    </span>
    <span style="font-size: var(--text-micro); color: var(--text-quaternary);">por mês</span>
  </div>

  <!-- Department rows -->
  <div class="flex flex-col gap-3">
    <!-- Vendas -->
    <div class="flex items-center justify-between p-3 rounded-lg" style="background: var(--surface-3);">
      <div class="flex items-center gap-3">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-tertiary);" aria-hidden="true">
          <path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/>
        </svg>
        <span style="font-size: var(--text-body-sm); color: var(--text-secondary);">Vendas</span>
      </div>
      <span class="font-bold tabular-nums" style="font-size: var(--text-body); color: var(--text-primary);">
        <span data-counter data-target="60" data-suffix="h">0h</span>
      </span>
    </div>

    <!-- Suporte -->
    <div class="flex items-center justify-between p-3 rounded-lg" style="background: var(--surface-3);">
      <div class="flex items-center gap-3">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-tertiary);" aria-hidden="true">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
        <span style="font-size: var(--text-body-sm); color: var(--text-secondary);">Suporte</span>
      </div>
      <span class="font-bold tabular-nums" style="font-size: var(--text-body); color: var(--text-primary);">
        <span data-counter data-target="47" data-suffix="h">0h</span>
      </span>
    </div>

    <!-- Operações -->
    <div class="flex items-center justify-between p-3 rounded-lg" style="background: var(--surface-3);">
      <div class="flex items-center gap-3">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-tertiary);" aria-hidden="true">
          <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 8 19.08a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 3.68 14.7a1.65 1.65 0 0 0-1.51-1H2a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 3.68 8.68a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H8a1.65 1.65 0 0 0 1-1.51V2a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V8a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
        </svg>
        <span style="font-size: var(--text-body-sm); color: var(--text-secondary);">Operações</span>
      </div>
      <span class="font-bold tabular-nums" style="font-size: var(--text-body); color: var(--text-primary);">
        <span data-counter data-target="100" data-suffix="h">0h</span>
      </span>
    </div>
  </div>

  <!-- Divider -->
  <div class="gradient-divider"></div>

  <!-- Total -->
  <div class="flex items-center justify-between">
    <span style="font-size: var(--text-body); font-weight: 600; color: var(--text-primary);">Total desperdiçado</span>
    <span class="font-bold tabular-nums text-[var(--accent-blue)]" style="font-size: clamp(1.25rem, 1rem + 1vw, 1.75rem);">
      <span data-counter data-target="207" data-suffix="h/mês">0h/mês</span>
    </span>
  </div>
</div>
