---
/**
 * MockupWorkflow — 3 connected nodes (Input -> AI Agent -> Output) with
 * animated dashed connector line and glowing AI node.
 * Stripe/Linear style product mockup.
 */
---

<div class="mockup-card p-6 rounded-[var(--radius-xl)] flex flex-col gap-5">
  <!-- Header -->
  <span style="font-size: var(--text-label); font-weight: 600; letter-spacing: 0.03em; color: var(--text-secondary); text-transform: uppercase;">
    Workflow Automatizado
  </span>

  <!-- Node chain -->
  <div class="flex items-center gap-0 mt-2">
    <!-- Node 1: Input -->
    <div class="flex flex-col items-center gap-2 flex-shrink-0">
      <div
        class="w-11 h-11 rounded-lg flex items-center justify-center"
        style="background: var(--surface-3); border: 1px solid var(--border-subtle);"
      >
        <!-- Inbox icon -->
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--text-tertiary)]">
          <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" />
        </svg>
      </div>
      <span style="font-size: 10px; color: var(--text-quaternary);">Input</span>
    </div>

    <!-- Connector 1 -->
    <div class="flex-1 h-px relative mx-1" style="min-width: 20px;">
      <div class="mockup-dash-line"></div>
    </div>

    <!-- Node 2: AI Agent (glowing) -->
    <div class="flex flex-col items-center gap-2 flex-shrink-0">
      <div class="relative">
        <div
          class="w-12 h-12 rounded-xl flex items-center justify-center mockup-node-pulse"
          style="background: linear-gradient(135deg, rgba(74,144,255,0.15), rgba(74,144,255,0.05)); border: 1px solid rgba(74,144,255,0.3);"
        >
          <!-- Bot/AI icon -->
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--accent-blue)]">
            <rect x="3" y="11" width="18" height="10" rx="2" /><circle cx="12" cy="5" r="2" /><line x1="12" y1="7" x2="12" y2="11" /><circle cx="8" cy="16" r="1" fill="currentColor" /><circle cx="16" cy="16" r="1" fill="currentColor" />
          </svg>
        </div>
      </div>
      <span style="font-size: 10px; color: var(--accent-blue); font-weight: 600;">AI Agent</span>
    </div>

    <!-- Connector 2 -->
    <div class="flex-1 h-px relative mx-1" style="min-width: 20px;">
      <div class="mockup-dash-line"></div>
    </div>

    <!-- Node 3: Output -->
    <div class="flex flex-col items-center gap-2 flex-shrink-0">
      <div
        class="w-11 h-11 rounded-lg flex items-center justify-center"
        style="background: var(--surface-3); border: 1px solid var(--border-subtle);"
      >
        <!-- Zap/lightning icon -->
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--text-tertiary)]">
          <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
        </svg>
      </div>
      <span style="font-size: 10px; color: var(--text-quaternary);">Output</span>
    </div>
  </div>

  <!-- Status line -->
  <div class="flex items-center gap-2 mt-1">
    <div class="w-1.5 h-1.5 rounded-full" style="background: #34d399;"></div>
    <span style="font-size: var(--text-micro); color: var(--text-quaternary);">3 workflows ativos — processando 24/7</span>
  </div>
</div>
