     ============================================================ -->
<style>
  /* ---- BUILDER AURORA (more intense than master) ---- */
  .builder-aurora-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 20% 40%, rgba(45, 122, 255, 0.12) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 80% 20%, rgba(0, 180, 255, 0.08) 0%, transparent 60%),
      radial-gradient(ellipse 50% 60% at 50% 80%, rgba(45, 122, 255, 0.06) 0%, transparent 60%);
    animation: aurora-shift 20s ease-in-out infinite alternate;
    pointer-events: none;
  }

  /* ---- BUILDER BADGE ---- */
  .builder-badge {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 6px 16px;
    border-radius: var(--radius-md);
    background: rgba(45, 122, 255, 0.12);
    border: 1px solid rgba(45, 122, 255, 0.25);
    color: var(--builder-electric);
  }

  /* ---- BUILDER SECTION LABEL ---- */
  .builder-label {
    color: var(--builder-electric) !important;
  }

  /* ---- BUILDER ELECTRIC TEXT ---- */
  .builder-electric-text {
    color: var(--builder-electric);
  }

  /* ---- BUILDER Z7 GLOW ---- */
  .builder-z7-glow {
    filter: drop-shadow(0 0 12px rgba(45, 122, 255, 0.4));
  }

  /* ---- BUILDER CTA PRIMARY ---- */
  .builder-cta-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-family: inherit;
    font-weight: 600;
    border-radius: var(--radius-lg);
    cursor: pointer;
    text-decoration: none;
    border: none;
    outline: none;
    white-space: nowrap;
    background: var(--builder-electric);
    color: white;
    transition: all var(--duration-fast) var(--ease-base);
  }
  .builder-cta-primary:hover {
    background: var(--builder-electric-hover);
    color: white;
    box-shadow: 0 0 30px rgba(45, 122, 255, 0.25);
    transform: translateY(-1px);
  }
  .builder-cta-primary:active {
    background: var(--builder-electric-active);
    transform: translateY(0) scale(0.98);
    box-shadow: none;
  }
  .builder-cta-primary:focus-visible {
    outline: 2px solid rgba(45, 122, 255, 0.5);
    outline-offset: 2px;
  }

  /* ---- VILLAIN CARDS ---- */
  .villain-card {
    background: var(--surface-2);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-xl);
    transition: border-color var(--duration-normal) var(--ease-base),
                background-color var(--duration-normal) var(--ease-base);
    overflow: hidden;
  }
  .villain-card:hover {
    border-color: var(--border-visible);
    background: var(--surface-3);
  }
  .villain-card-inner {
    padding: 28px;
  }
  .villain-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-quaternary);
    margin-bottom: 16px;
  }
  .villain-time-stolen {
    font-size: var(--text-caption);
    color: var(--text-quaternary);
    font-style: italic;
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--border-subtle);
  }

  /* ---- Z7 MEANING BOX ---- */
  .builder-z7-meaning {
    padding: 24px;
    border-radius: var(--radius-lg);
    background: rgba(45, 122, 255, 0.04);
    border: 1px solid rgba(45, 122, 255, 0.12);
  }

  /* ---- BUILDER CHECKLIST ---- */
  .builder-checklist {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .builder-checklist li {
    position: relative;
    padding-left: 28px;
    margin-bottom: 12px;
    font-size: var(--text-body);
    line-height: 1.65;
    color: var(--text-secondary);
  }
  .builder-checklist li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 8px;
