---
/**
 * Builder — Comunidade para aprender a construir e vender projetos de agentes de IA
 * v5.0 — Streamlined to 8 sections: Hero, Ecossistema, Jornada, Para Quem, Objeções,
 *         Investimento, FAQ, CTA Final
 *
 * Colors: Builder Electric #2D7AFF + Cyan #00B4FF for content.
 * Nav/footer remain master #4A90FF.
 * Hero background: HeroGrid + radial glow (matches home page pattern).
 */
import MainLayout from '../layouts/MainLayout.astro';
import Badge from '../components/Badge.astro';
import Button from '../components/Button.astro';
import SectionLabel from '../components/SectionLabel.astro';
import FaqAccordion from '../components/FaqAccordion.tsx';
import HeroGrid from '../components/backgrounds/HeroGrid.tsx';

const objectionFaqItems = [
  {
    question: 'Não tenho tempo pra mais um programa agora.',
    answer: 'Essa é exatamente a razão pra estar aqui. Você está sangrando tempo em processos manuais, tentativas sem direção e pesquisa que não leva a receita. A mentoria Builders existe pra devolver tempo, não pra roubar mais. Construção focada, com acompanhamento real — sem enrolação.',
  },
  {
    question: 'Já tentei outros cursos de IA e não funcionou.',
    answer: 'Cursos ensinam teoria. O programa Builders é mentoria onde implementamos junto. Você não recebe uma planilha e um "boa sorte." Moroni e a equipe constroem ao seu lado. Oferta, precificação, sistema de aquisição, primeiro projeto entregue. A diferença é que nós não viramos as costas.',
  },
  {
    question: 'Não sou técnico. Não sei programar.',
    answer: 'Perfeito. Builders não são engenheiros. Somos profissionais de negócio que entendem onde IA gera receita. Você traz experiência em vendas, ofertas e relacionamento. Nós damos os frameworks de implementação. Quem sabe vender é quem deveria estar liderando IA.',
  },
  {
    question: 'O mercado de IA muda toda semana. E se ficar obsoleto?',
    answer: 'Ferramentas mudam. A habilidade de encontrar oportunidade de receita, construir oferta e vender não muda. O programa Builders ensina o framework — não a ferramenta do momento. Você sai com capacidade de adaptação, não com dependência de uma plataforma.',
  },
];

const faqItems = [
  ...objectionFaqItems,
  {
    question: 'O que é Builders?',
    answer: 'Builders é uma comunidade e programa de mentoria para aprender a construir e vender projetos de agentes de IA. Não somos alunos passivos. Somos construtores ativos — e medimos tudo pela única métrica que importa: projetos entregues e receita gerada com IA.',
  },
  {
    question: 'Preciso de experiência técnica?',
    answer: 'Não. Builders são profissionais de negócio — donos de agência, gestores de tráfego, especialistas em automação, estrategistas de marketing. Você traz a experiência em vendas e estratégia. Nós damos os frameworks de implementação de IA.',
  },
  {
    question: 'Como funciona o processo seletivo?',
    answer: 'Cada candidatura é analisada pessoalmente. Buscamos profissionais com experiência em serviços, fome de agir e disposição de construir.',
  },
  {
    question: 'Funciona pra quem já trabalha com IA?',
    answer: 'Sim. Se você já mexe com IA mas não estruturou oferta, precificação ou sistema de aquisição de clientes, o programa Builders comprime meses de tentativa e erro. Se você já vende IA, os frameworks de entrega e escala aceleram tudo.',
  },
  {
    question: 'E se eu for iniciante?',
    answer: 'Iniciantes são bem-vindos. A jornada Builders começa do diagnóstico e te acompanha passo a passo. Se for muito no início, direcionamos para a formação adequada antes da mentoria.',
  },
];
---

<MainLayout
  title="Builders — Aprenda a Lucrar com IA | Construa e Venda Agentes de IA"
  description="Builders é o programa de mentoria para aprender a construir e vender projetos de agentes de IA. Sem precisar programar. Com Moroni Reis ao seu lado. Aplique agora."
  activePage="builder"
>

  <!-- ============================================================
       SECTION 1: HERO — Surface-0, HeroGrid background
       ============================================================ -->
  <section
    class="relative overflow-hidden flex items-center justify-center"
    style="background: var(--surface-0); min-height: 100vh; padding: var(--space-2xl) 0;"
    aria-labelledby="hero-heading"
  >
    <!-- Background: HeroGrid + subtle blue radial glow -->
    <HeroGrid client:load />
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(45,122,255,0.07) 0%, transparent 70%);"
    ></div>
    <!-- Top accent line -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 pointer-events-none" aria-hidden="true" style="width:400px;height:1px;background:linear-gradient(90deg,transparent,rgba(45,122,255,0.2) 50%,transparent);"></div>

    <div class="container-standard relative z-10">
      <div class="flex flex-col items-center text-center" style="max-width: 860px; margin: 0 auto;">

        <!-- Badge -->
        <div class="hero-animate hero-animate-1">
          <Badge variant="accent">Builders</Badge>
        </div>

        <!-- Headline -->
        <h1
          id="hero-heading"
          class="hero-animate hero-animate-2 mt-8 text-balance"
          style="font-size: clamp(2.5rem, 1.4rem + 5vw, 4.5rem); font-weight: 600; line-height: 1.08; letter-spacing: -0.025em;"
        >
          Enquanto Outros Esperam, <span class="builder-electric-text">Nós Construímos.</span>
        </h1>

        <!-- Subheadline -->
        <p
          class="hero-animate hero-animate-3 mt-6 text-balance mx-auto"
          style="font-size: clamp(1.05rem, 0.7rem + 1.1vw, 1.3rem); line-height: 1.60; color: var(--text-secondary); max-width: 620px;"
        >
          Comunidade para profissionais que querem aprender a lucrar com IA — criando e vendendo projetos de agentes de inteligência artificial.
        </p>

        <!-- CTA -->
        <div class="hero-animate hero-animate-4 mt-10 flex flex-col items-center gap-3">
          <a href="#cta-builders" class="builder-cta-primary btn-hero btn-press">
            Começar a lucrar com IA
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
          </a>
        </div>

        <!-- Scroll indicator -->
        <div class="hero-animate hero-animate-5 mt-16 flex justify-center" aria-hidden="true">
          <div class="w-px h-12" style="background: linear-gradient(to bottom, rgba(45,122,255,0.3), transparent);"></div>
        </div>

      </div>
    </div>
  </section>


  <!-- ============================================================
       SECTION 2: O ECOSSISTEMA — Surface-1, 3 Hub mockups alternating
       ============================================================ -->
  <section
    class="relative"
    style="background: var(--surface-1); padding: var(--space-4xl) 0;"
    aria-labelledby="ecossistema-heading"
  >
    <div class="container-narrow relative z-10">

      <div class="animate-on-scroll mb-14">
        <SectionLabel class="mb-4 builder-label">O ecossistema</SectionLabel>
        <h2 id="ecossistema-heading" class="mb-5">
          Tudo que você precisa para <span class="builder-electric-text">lucrar com IA.</span>
        </h2>
        <p style="font-size: var(--text-body-lg); color: var(--text-secondary); max-width: var(--container-text);">
          Mentoria, formações completas e uma comunidade ativa. Tudo dentro do REIS [IA] Hub.
        </p>
      </div>

      <!-- Mockup A: Mentorias (text left, mockup right) -->
      <div class="animate-on-scroll">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
          <div>
            <h3 class="text-[var(--text-h4)] font-semibold mb-3 builder-electric-text">Mentorias ao vivo</h3>
            <p class="text-[var(--text-body)] leading-relaxed" style="color: var(--text-secondary);">Sessões individuais e em grupo de mentoria. Agende direto pelo Hub, acompanhe seu progresso e receba feedback em tempo real sobre sua oferta, aquisição e entrega.</p>
          </div>
          <div>
            <div class="rounded-xl overflow-hidden" style="background:var(--surface-1);border:1px solid var(--border-default);box-shadow:0 20px 50px rgba(0,0,0,0.4)">
              <div class="flex items-center gap-2 px-4 py-2.5" style="background:var(--surface-0);border-bottom:1px solid var(--border-default)">
                <div class="w-2 h-2 rounded-full" style="background:#FF5F57"></div>
                <div class="w-2 h-2 rounded-full" style="background:#FEBC2E"></div>
                <div class="w-2 h-2 rounded-full" style="background:#28C840"></div>
                <span class="ml-2 text-[9px] font-medium" style="color:var(--text-tertiary)">REIS [IA] Hub — Mentorias</span>
              </div>
              <div style="padding:14px">
                <p class="text-[10px] font-semibold mb-2" style="color:var(--text-primary)">Próxima sessão</p>
                <div class="p-3 rounded-lg mb-3" style="background:var(--surface-0);border:1px solid var(--border-default)">
                  <div class="flex items-center justify-between">
                    <div>
                      <p class="text-[11px] font-semibold" style="color:var(--text-primary)">Sessão individual</p>
                      <p class="text-[9px] mt-0.5" style="color:var(--text-tertiary)">Seg, 31 Mar — 14:00</p>
                    </div>
                    <span class="text-[8px] px-2 py-0.5 rounded" style="background:rgba(34,197,94,0.1);color:#22C55E">Confirmada</span>
                  </div>
                </div>
                <p class="text-[10px] font-semibold mb-2 mt-3" style="color:var(--text-primary)">Seu progresso</p>
                <div class="space-y-1.5">
                  <div class="flex items-center gap-2"><div class="w-full h-1 rounded-full" style="background:var(--surface-0)"><div class="h-full rounded-full" style="width:100%;background:#22C55E"></div></div><span class="text-[8px] whitespace-nowrap" style="color:var(--text-tertiary)">Oferta</span></div>
                  <div class="flex items-center gap-2"><div class="w-full h-1 rounded-full" style="background:var(--surface-0)"><div class="h-full rounded-full" style="width:65%;background:var(--builder-electric, #2D7AFF)"></div></div><span class="text-[8px] whitespace-nowrap" style="color:var(--text-tertiary)">Aquisição</span></div>
                  <div class="flex items-center gap-2"><div class="w-full h-1 rounded-full" style="background:var(--surface-0)"><div class="h-full rounded-full" style="width:30%;background:var(--builder-electric, #2D7AFF)"></div></div><span class="text-[8px] whitespace-nowrap" style="color:var(--text-tertiary)">Projeto</span></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Mockup B: Formações (mockup left, text right) -->
      <div class="animate-on-scroll mt-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
          <div class="order-2 lg:order-1">
            <div class="rounded-xl overflow-hidden" style="background:var(--surface-1);border:1px solid var(--border-default);box-shadow:0 20px 50px rgba(0,0,0,0.4)">
              <div class="flex items-center gap-2 px-4 py-2.5" style="background:var(--surface-0);border-bottom:1px solid var(--border-default)">
                <div class="w-2 h-2 rounded-full" style="background:#FF5F57"></div>
                <div class="w-2 h-2 rounded-full" style="background:#FEBC2E"></div>
                <div class="w-2 h-2 rounded-full" style="background:#28C840"></div>
                <span class="ml-2 text-[9px] font-medium" style="color:var(--text-tertiary)">REIS [IA] Hub — Formações</span>
              </div>
              <div style="padding:14px">
                <div class="space-y-2">
                  <div class="flex items-center gap-3 p-2.5 rounded-lg" style="background:var(--surface-0);border:1px solid var(--border-default)">
                    <div class="w-8 h-8 rounded-md flex items-center justify-center text-[12px] font-bold" style="background:rgba(45,122,255,0.08);color:var(--builder-electric, #2D7AFF)">01</div>
                    <div class="flex-1"><p class="text-[10px] font-semibold" style="color:var(--text-primary)">Fundamentos de IA</p><p class="text-[8px]" style="color:var(--text-tertiary)">12 aulas · 4h</p></div>
                    <span class="text-[8px] px-1.5 py-0.5 rounded" style="background:rgba(34,197,94,0.1);color:#22C55E">Concluído</span>
                  </div>
                  <div class="flex items-center gap-3 p-2.5 rounded-lg" style="background:var(--surface-0);border:1px solid rgba(45,122,255,0.1)">
                    <div class="w-8 h-8 rounded-md flex items-center justify-center text-[12px] font-bold" style="background:rgba(45,122,255,0.08);color:var(--builder-electric, #2D7AFF)">02</div>
                    <div class="flex-1"><p class="text-[10px] font-semibold" style="color:var(--text-primary)">Vendas e Prospecção</p><p class="text-[8px]" style="color:var(--text-tertiary)">15 aulas · 5h</p></div>
                    <span class="text-[8px] px-1.5 py-0.5 rounded" style="background:rgba(45,122,255,0.1);color:var(--builder-electric, #2D7AFF)">Em progresso</span>
                  </div>
                  <div class="flex items-center gap-3 p-2.5 rounded-lg" style="background:var(--surface-0);border:1px solid var(--border-default)">
                    <div class="w-8 h-8 rounded-md flex items-center justify-center text-[12px] font-bold" style="background:rgba(45,122,255,0.08);color:var(--builder-electric, #2D7AFF)">03</div>
                    <div class="flex-1"><p class="text-[10px] font-semibold" style="color:var(--text-primary)">Agentes e Automações</p><p class="text-[8px]" style="color:var(--text-tertiary)">18 aulas · 6h</p></div>
                    <span class="text-[8px] px-1.5 py-0.5 rounded" style="background:rgba(255,255,255,0.05);color:var(--text-tertiary)">Em breve</span>
                  </div>
                  <div class="flex items-center gap-3 p-2.5 rounded-lg" style="background:var(--surface-0);border:1px solid var(--border-default)">
                    <div class="w-8 h-8 rounded-md flex items-center justify-center text-[12px] font-bold" style="background:rgba(255,255,255,0.03);color:var(--text-tertiary)">04</div>
                    <div class="flex-1"><p class="text-[10px] font-semibold" style="color:var(--text-tertiary)">Especialista em IA</p><p class="text-[8px]" style="color:rgba(255,255,255,0.2)">24 aulas · 8h</p></div>
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="order-1 lg:order-2">
            <h3 class="text-[var(--text-h4)] font-semibold mb-3 builder-electric-text">Formações completas</h3>
            <p class="text-[var(--text-body)] leading-relaxed" style="color: var(--text-secondary);">Do básico ao especialista, com certificação. Conteúdo prático que você aplica no dia seguinte. Aulas gravadas + materiais de apoio + exercícios práticos — tudo dentro do Hub.</p>
          </div>
        </div>
      </div>

      <!-- Mockup C: Comunidade (text left, mockup right) -->
      <div class="animate-on-scroll mt-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
          <div>
            <h3 class="text-[var(--text-h4)] font-semibold mb-3 builder-electric-text">Comunidade ativa</h3>
            <p class="text-[var(--text-body)] leading-relaxed" style="color: var(--text-secondary);">Troque experiências com outros Builders em tempo real. Feed de atualizações, espaços temáticos, eventos ao vivo e acesso direto a quem já está vendendo e entregando IA.</p>
          </div>
          <div>
            <div class="rounded-xl overflow-hidden" style="background:var(--surface-1);border:1px solid var(--border-default);box-shadow:0 20px 50px rgba(0,0,0,0.4)">
              <div class="flex items-center gap-2 px-4 py-2.5" style="background:var(--surface-0);border-bottom:1px solid var(--border-default)">
                <div class="w-2 h-2 rounded-full" style="background:#FF5F57"></div>
                <div class="w-2 h-2 rounded-full" style="background:#FEBC2E"></div>
                <div class="w-2 h-2 rounded-full" style="background:#28C840"></div>
                <span class="ml-2 text-[9px] font-medium" style="color:var(--text-tertiary)">REIS [IA] Hub — Comunidade</span>
              </div>
              <div class="flex gap-0 px-3 pt-2" style="border-bottom:1px solid var(--border-default)">
                <span class="text-[9px] font-medium px-2 pb-2" style="color:var(--builder-electric, #2D7AFF);border-bottom:2px solid var(--builder-electric, #2D7AFF)">Feed</span>
                <span class="text-[9px] font-medium px-2 pb-2" style="color:var(--text-tertiary)">Espaços</span>
                <span class="text-[9px] font-medium px-2 pb-2" style="color:var(--text-tertiary)">Eventos</span>
              </div>
              <div style="padding:10px 14px">
                <div class="p-2.5 rounded-lg mb-2" style="background:var(--surface-0);border:1px solid var(--border-default)">
                  <div class="flex items-center gap-2 mb-1.5">
                    <div class="w-5 h-5 rounded-full flex items-center justify-center text-[7px] font-bold" style="background:rgba(45,122,255,0.1);color:var(--builder-electric, #2D7AFF)">RL</div>
                    <span class="text-[9px] font-semibold" style="color:var(--text-primary)">Rafael Lima</span>
                    <span class="text-[8px]" style="color:var(--text-tertiary)">· 2h</span>
                  </div>
                  <p class="text-[9px] leading-relaxed" style="color:var(--text-secondary)">Fechei meu primeiro projeto. R$8.500 por um chatbot de qualificação. O framework funciona.</p>
                </div>
                <div class="p-2.5 rounded-lg" style="background:var(--surface-0);border:1px solid var(--border-default)">
                  <div class="flex items-center gap-2 mb-1.5">
                    <div class="w-5 h-5 rounded-full flex items-center justify-center text-[7px] font-bold" style="background:rgba(34,197,94,0.1);color:#22C55E">MR</div>
                    <span class="text-[9px] font-semibold" style="color:var(--text-primary)">Moroni Reis</span>
                    <span class="text-[7px] px-1 py-0.5 rounded" style="background:rgba(45,122,255,0.1);color:var(--builder-electric, #2D7AFF)">Admin</span>
                  </div>
                  <p class="text-[9px] leading-relaxed" style="color:var(--text-secondary)">Novo framework de precificação disponível. Margem média de 65%.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>


  <!-- ============================================================
       SECTION 3: A JORNADA — Surface-0, 6 stage cards
       ============================================================ -->
  <section
    class="relative"
    style="background: var(--surface-0); padding: var(--space-4xl) 0;"
    aria-labelledby="jornada-heading"
  >
    <div class="container-standard relative z-10">

      <div class="text-center mb-16 animate-on-scroll">
        <SectionLabel class="mb-4 builder-label">A jornada</SectionLabel>
        <h2 id="jornada-heading">
          Do zero ao primeiro projeto <span class="builder-electric-text">vendido e entregue.</span>
        </h2>
        <p class="mt-4" style="font-size: var(--text-body-lg); color: var(--text-secondary); max-width: 640px; margin: 0 auto;">
          A jornada dentro da comunidade Builders é prática. Cada etapa constrói sobre a anterior — você avança no seu ritmo, com acompanhamento real.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5 grid-stagger" style="max-width: 1000px; margin: 0 auto;">

        <div class="stage-card">
          <span class="stage-day">Etapa 1</span>
          <h4 class="stage-name">Diagnóstico</h4>
          <p class="stage-desc">Mapeamento do seu perfil, experiência e mercado. Identificamos onde estão as melhores oportunidades de IA pra você.</p>
        </div>

        <div class="stage-card">
          <span class="stage-day">Etapa 2</span>
          <h4 class="stage-name">Oferta</h4>
          <p class="stage-desc">Construção da sua oferta de serviço de IA — posicionamento, escopo, precificação. Algo que você pode apresentar a clientes reais.</p>
        </div>

        <div class="stage-card">
          <span class="stage-day">Etapa 3</span>
          <h4 class="stage-name">Aquisição</h4>
          <p class="stage-desc">Sistema de captação de clientes: prospecção, abordagem, proposta. Não teoria — um processo que você opera toda semana.</p>
        </div>

        <div class="stage-card">
          <span class="stage-day">Etapa 4</span>
          <h4 class="stage-name">Implementação</h4>
          <p class="stage-desc">Frameworks de entrega de projetos de agentes de IA. Como construir, treinar e entregar um agente pro seu cliente.</p>
        </div>

        <div class="stage-card">
          <span class="stage-day">Etapa 5</span>
          <h4 class="stage-name">Primeiro Projeto</h4>
          <p class="stage-desc">Seu primeiro projeto real, acompanhado pela equipe. Do briefing à entrega — com suporte completo.</p>
        </div>

        <div class="stage-card stage-card-featured md:col-span-2 lg:col-span-1">
          <span class="stage-day stage-day-featured">Contínuo</span>
          <h4 class="stage-name">Escala</h4>
          <p class="stage-desc">Otimização, novos clientes, novos projetos. A comunidade continua — troca de experiências, casos e aprendizados. <strong class="text-[var(--text-primary)]">Você não para no primeiro projeto.</strong></p>
        </div>

      </div>

      <div class="text-center mt-12 animate-on-scroll" style="max-width: 700px; margin-left: auto; margin-right: auto;">
        <p style="font-size: var(--text-body); line-height: 1.70; color: var(--text-secondary);">
          O primeiro projeto vendido muda tudo. A partir dele, você tem prova, confiança e um sistema que se repete. <strong class="builder-electric-text">Quem aplica rápido, fatura rápido.</strong>
        </p>
      </div>

    </div>
  </section>


  <!-- ============================================================
       CTA INTERMEDIÁRIO — Card de aplicação antes do FAQ
       ============================================================ -->
  <section
    id="cta-builders"
    class="relative overflow-hidden"
    style="background: var(--surface-0); padding: var(--space-3xl) 0;"
  >
    <div class="container-standard relative z-10">
      <div class="animate-on-scroll rounded-2xl overflow-hidden" style="background: var(--surface-1); border: 1px solid rgba(45,122,255,0.12); max-width: 900px; margin: 0 auto;">
        <div class="grid grid-cols-1 lg:grid-cols-5">
          <!-- Left: Copy -->
          <div class="lg:col-span-3 p-8 lg:p-10">
            <p class="text-[11px] font-semibold uppercase tracking-wider mb-4 builder-electric-text">Aplique agora</p>
            <h2 style="font-size: var(--text-h3); font-weight: 600; line-height: 1.12; letter-spacing: -0.02em;">
              O mercado de IA não vai te esperar.
            </h2>
            <p class="mt-4" style="font-size: var(--text-body); line-height: 1.60; color: var(--text-secondary);">
              Profissionais estão fechando projetos de R$5k a R$20k toda semana com IA. A diferença entre eles e você é uma decisão.
            </p>
            <div class="mt-6">
              <a href="/aplicar" class="builder-cta-primary btn-lg btn-press inline-flex">
                Aplicar para Builders
