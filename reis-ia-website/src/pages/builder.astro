---
import MainLayout from '../layouts/MainLayout.astro';
import Badge from '../components/Badge.astro';
import Button from '../components/Button.astro';
import SectionLabel from '../components/SectionLabel.astro';
import HourglassIcon from '../components/HourglassIcon.astro';
import ChessKnightIcon from '../components/ChessKnightIcon.astro';
import IconCheckCircle from '../components/icons/IconCheckCircle.astro';
import IconStar from '../components/icons/IconStar.astro';
import IconShield from '../components/icons/IconShield.astro';
import IconPuzzle from '../components/icons/IconPuzzle.astro';
import IconTarget from '../components/icons/IconTarget.astro';
import IconUsers from '../components/icons/IconUsers.astro';
import IconLayers from '../components/icons/IconLayers.astro';
import IconRocket from '../components/icons/IconRocket.astro';
import IconGraduationCap from '../components/icons/IconGraduationCap.astro';
import IconCalendar from '../components/icons/IconCalendar.astro';
import IconMessageCircle from '../components/icons/IconMessageCircle.astro';
import IconAward from '../components/icons/IconAward.astro';
import IconTrendingUp from '../components/icons/IconTrendingUp.astro';
import LogoMarquee from '../components/LogoMarquee.astro';
import HighlightBanner from '../components/HighlightBanner.astro';
---

<MainLayout
  title="Builder — Adicione Receita de AI à Sua Agência em 12 Semanas"
  description="O programa Reis IA Builder te dá uma oferta vendável de AI, um sistema de aquisição de clientes e seu primeiro projeto entregue — em 12 semanas. Sem precisar virar engenheiro."
  activePage="builder"
>

  <!-- SECTION 1: HERO — floating card style matching Home -->
  <section class="hero-card-outer" style="background-color: #080808; padding: 48px 8px 0;">
    <div
      class="hero-card relative overflow-hidden"
      style="padding: 80px 0 72px; min-height: 560px;"
    >
      <!-- Radial hero glow (gold signature) -->
      <div
        class="absolute inset-0 pointer-events-none"
        aria-hidden="true"
        style="background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(201, 168, 76, 0.10) 0%, transparent 70%);"
      ></div>
      <!-- Secondary subtle orb — left side depth -->
      <div
        class="gradient-orb gradient-orb-blue"
        aria-hidden="true"
        style="width: 500px; height: 350px; top: 40%; left: -8%; opacity: 0.5;"
      ></div>

      <div class="mx-auto max-w-[1200px] px-5 md:px-8 lg:px-12 relative z-10">
        <!-- Chess pre-headline with knight icon — functional, not decorative -->
        <div class="hero-animate hero-animate-1 flex items-center gap-2 mb-4">
          <ChessKnightIcon size={16} class="text-accent" />
          <p class="text-[13px] font-semibold tracking-widest uppercase text-accent">
            Para Donos de Agência Prontos para Parar de Reagir ao AI — e Começar a Liderar
          </p>
        </div>

        <h1
          class="hero-animate hero-animate-2 max-w-[900px]"
          style="font-size: clamp(36px, 7vw, 80px); font-weight: 800; line-height: 0.97; letter-spacing: -0.04em; color: #ffffff;"
        >
          AI sem estratégia é chute.<br />
          Em 12 semanas, você poderia estar jogando um jogo completamente diferente.
        </h1>

        <p
          class="hero-animate hero-animate-3 mt-6 max-w-[640px]"
          style="font-size: clamp(16px, 1.8vw, 18px); font-weight: 400; line-height: 1.7; color: rgba(255,255,255,0.55);"
        >
          O programa Reis IA Builder te dá uma oferta vendável de AI, um sistema de aquisição de clientes e seu primeiro projeto entregue — em 12 semanas. Com suporte direto de quem construiu isso do zero.
        </p>

        <div class="hero-animate hero-animate-4 flex flex-col sm:flex-row items-stretch sm:items-start gap-4 mt-10">
          <Button variant="hero" href="/aplicar" class="w-full sm:w-auto text-center">Quero me candidatar à próxima turma &#8594;</Button>
        </div>
        <p class="hero-animate hero-animate-5 text-xs mt-3" style="color: rgba(255,255,255,0.3);">Vagas limitadas. Candidaturas abertas.</p>
      </div>
    </div>
  </section>

  <!-- LOGO MARQUEE — after hero -->
  <div style="background-color: #080808;">
    <div class="mx-auto max-w-[1200px]">
      <LogoMarquee />
    </div>
  </div>

  <!-- Gold section divider -->
  <div class="divider-gold mx-auto max-w-[1200px] px-5 md:px-8 lg:px-0"></div>

  <!-- Sticky CTA bar (desktop only, shown after scroll) -->
  <div
    id="sticky-cta"
    class="hidden lg:flex fixed bottom-0 left-0 right-0 z-40 h-[72px] items-center translate-y-full transition-transform duration-300"
    style="background: rgba(17,17,19,0.92); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-top: 1px solid rgba(255,255,255,0.07);"
    aria-hidden="true"
  >
    <div class="mx-auto max-w-[1200px] px-8 w-full flex items-center justify-between">
      <p class="text-sm" style="color: rgba(255,255,255,0.45);">Vagas limitadas &nbsp;|&nbsp; Máximo de 12 participantes por turma</p>
      <a
        href="/aplicar"
        class="text-black text-sm font-semibold px-6 py-3 rounded-md transition-all duration-200"
        style="background-color: #C9A84C;"
        onmouseover="this.style.backgroundColor='#D4B85E'; this.style.boxShadow='0 8px 20px rgba(201,168,76,0.3)';"
        onmouseout="this.style.backgroundColor='#C9A84C'; this.style.boxShadow='none';"
      >
        Candidatar-se agora &#8594;
      </a>
    </div>
  </div>

  <script>
    const stickyCta = document.getElementById('sticky-cta');
    const heroSection = document.querySelector('section');

    if (stickyCta) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) {
              stickyCta.classList.remove('translate-y-full');
              stickyCta.setAttribute('aria-hidden', 'false');
            } else {
              stickyCta.classList.add('translate-y-full');
              stickyCta.setAttribute('aria-hidden', 'true');
            }
          });
        },
        { threshold: 0.1 }
      );
      if (heroSection) observer.observe(heroSection);
    }
  </script>

  <!-- SECTION 2: PROBLEM / AGITATION -->
  <section style="background-color: #111113; padding: 96px 0;" class="md:py-28 lg:py-32">
    <div class="mx-auto max-w-[1200px] px-5 md:px-8 lg:px-0">
      <div class="max-w-[720px]">
        <h2
          class="reveal leading-tight"
          style="font-size: clamp(28px, 4vw, 48px); font-weight: 600; letter-spacing: -0.02em; color: #ffffff;"
        >
          Seus Concorrentes Já Estão Vendendo AI. O Que Isso Significa para Você.
        </h2>

        <div class="mt-8 space-y-5 text-base md:text-[17px] leading-relaxed reveal" style="color: rgba(255,255,255,0.65);">
          <p>Você já viu isso acontecer.</p>
          <p>Uma agência que você conhece — talvez menor do que a sua — se reposicionou em torno de serviços de AI. Os preços subiram. Os clientes ficaram. Eles estão ganhando trabalhos que antes iam para você só pela reputação.</p>
          <p>Enquanto isso, você está observando.</p>
          <p>Não porque não entende a oportunidade. Você entende. AI é a maior virada no mercado de agências desde as redes sociais — e você sabe exatamente para onde isso vai.</p>
          <p>O problema não é a tecnologia.</p>
          <p><strong style="color: #ffffff; font-weight: 600;">O problema é que você não tem uma oferta empacotada, um processo de entrega claro nem uma conversa de vendas que fecha — e construir tudo isso do zero é um projeto de tempo integral enquanto você já toca uma agência de tempo integral.</strong></p>
          <p>Provavelmente você já tentou alguma versão disso:</p>
        </div>

        <ul class="mt-6 space-y-3 reveal">
          {[
            'Assistiu dezenas de horas de tutoriais de AI e ainda não sabe o que vender',
            'Experimentou ChatGPT, Make.com ou n8n e chegou no limite de tentar descobrir sozinho',
            'Vendeu uma capacidade de "fazemos AI" para um cliente — e depois teve que se virar para entregar',
            'Precificou um projeto de AI no achômetro, deixou dinheiro na mesa e não sabia como estruturar o próximo',
            'Perdeu um cliente — ou quase perdeu — para uma agência que se moveu mais rápido',
          ].map(item => (
            <li class="flex items-start gap-3 text-[15px]" style="color: rgba(255,255,255,0.55);">
              <span style="color: rgba(255,255,255,0.3); margin-top: 2px;" aria-hidden="true">—</span>
              {item}
            </li>
          ))}
        </ul>

        <div class="mt-8 space-y-4 text-base md:text-[17px] leading-relaxed reveal" style="color: rgba(255,255,255,0.65);">
          <p>Isso não é falta de conhecimento. É falta de estrutura.</p>
          <p>Você não precisa de mais tutoriais. Você precisa de um framework, uma metodologia e alguém que já abriu esse caminho — para parar de experimentar e começar a faturar.</p>
        </div>

        <!-- Market data callout box -->
        <div
          class="mt-8 rounded-2xl p-6 sm:p-8 reveal"
          style="background-color: #1c1c1e; border: 1px solid rgba(255,255,255,0.06);"
        >
          <p class="text-base md:text-[17px] leading-relaxed" style="color: rgba(255,255,255,0.65);">
            Os 60–70% de baixo das agências digitais vão entrar em uma corrida para o fundo em 2–3 anos. Não porque são ruins no que fazem. Porque não se diferenciaram.
          </p>
          <p class="text-lg sm:text-xl font-semibold mt-4" style="color: #ffffff;">Projetos de AI vendem por $5.000–$20.000.</p>
          <p class="text-base md:text-[17px] mt-2 leading-relaxed" style="color: rgba(255,255,255,0.65);">
            As agências que os vendem estão adicionando novos fluxos de receita por cima dos retainers existentes — não substituindo um pelo outro. A janela está aberta agora. Mas não vai ficar aberta para sempre.
          </p>
        </div>

        <!-- Hourglass inline functional closer -->
        <div class="mt-8 space-y-3 reveal">
          <p class="flex items-start gap-3 text-base md:text-[17px] leading-relaxed" style="color: rgba(255,255,255,0.65);">
            <HourglassIcon size={20} class="text-accent flex-shrink-0 mt-1" />
            <span>Esse é o custo que não aparece em nenhuma nota fiscal. A cada mês que você espera, um concorrente fecha um cliente de AI que você poderia ter fechado. A cada mês, a curva de aprendizado fica mais comprimida — mas a janela de oportunidade também. A cada mês, as agências que se moveram antes acumulam mais casos de sucesso, sobem preços e fidelizam clientes em retainer.</span>
          </p>
          <p class="text-base md:text-[17px] leading-relaxed pl-8" style="color: rgba(255,255,255,0.65);">O tempo não passa simplesmente. Ele se acumula — a favor deles.</p>
          <p class="text-lg sm:text-xl font-semibold pl-8" style="color: #ffffff;">O verdadeiro custo de esperar não é dinheiro. É o tempo que não volta.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 3: SOLUTION REVEAL -->
  <section style="background-color: #080808; padding: 96px 0;" class="md:py-28 lg:py-32">
    <div class="mx-auto max-w-[1200px] px-5 md:px-8 lg:px-0">
      <div class="max-w-[720px]">
        <div class="reveal">
          <SectionLabel>A Solução</SectionLabel>
        </div>
        <h2
          class="reveal mt-5 leading-tight"
          style="font-size: clamp(28px, 4vw, 48px); font-weight: 600; letter-spacing: -0.02em; color: #ffffff;"
        >
          É para Isso que o Programa Reis IA Builder Foi Criado.
        </h2>

        <div class="mt-8 space-y-5 text-base md:text-[17px] leading-relaxed reveal" style="color: rgba(255,255,255,0.65);">
          <p>Pense assim.</p>
          <p>Um curso te dá as peças. O Builder te ensina a jogar a partida.</p>
          <p>A cada semana, você não está só aprendendo AI — você está se posicionando. Estruturando sua oferta. Mapeando seu mercado. Construindo o sistema de vendas. Entregando o primeiro projeto. Cada etapa é intencional. Cada módulo te aproxima de uma posição de receita que seus concorrentes ainda não ocuparam.</p>
          <p class="text-lg sm:text-xl font-semibold" style="color: #ffffff;">Não construímos AI. Posicionamos as peças certas antes de mover.</p>
          <p>É isso que separa as agências que fecham clientes de AI das agências que só "fazem AI."</p>
        </div>
      </div>

      <!-- Comparison table -->
      <div class="mt-10 max-w-[800px] reveal">
        <div
          class="rounded-2xl overflow-hidden"
          style="background-color: #111113; border: 1px solid rgba(255,255,255,0.06);"
        >
          <div class="grid grid-cols-2" style="background-color: #1c1c1e;">
            <div class="px-4 sm:px-5 py-4 text-[13px] uppercase tracking-widest" style="color: rgba(255,255,255,0.4); letter-spacing: 0.08em;">Curso</div>
            <div class="px-4 sm:px-5 py-4 text-[13px] uppercase tracking-widest text-accent" style="letter-spacing: 0.08em;">Builder</div>
          </div>
          {[
            ['Informação', 'Aplicação'],
            ['Assistir passivamente', 'Sessões semanais de trabalho real'],
            ['Templates genéricos', 'Sua oferta específica, precificada, empacotada e pronta para vender'],
            ['Implementação solitária', 'Suporte direto nos seus primeiros 1–2 projetos com clientes'],
            ['Você corre atrás de clientes sozinho', 'Sistema de aquisição de clientes construído durante o programa'],
            ['Certificado na parede, sem receita', 'Receita antes de o programa terminar'],
          ].map(([course, builder]) => (
            <div class="grid grid-cols-2" style="border-top: 1px solid rgba(255,255,255,0.06);">
              <div class="px-4 sm:px-5 py-4 text-sm md:text-[15px]" style="color: rgba(255,255,255,0.35);">{course}</div>
              <div class="px-4 sm:px-5 py-4 text-sm md:text-[15px]" style="color: rgba(255,255,255,0.85);">{builder}</div>
            </div>
          ))}
        </div>
      </div>

      <p class="mt-8 text-base md:text-[17px] leading-relaxed max-w-[720px] reveal" style="color: rgba(255,255,255,0.65);">
        O Builder foi feito para quem é sério em adicionar AI como um fluxo de receita real — não para quem quer algo bonito para colocar no LinkedIn.
      </p>

      <!-- Inline CTA after comparison -->
      <div class="mt-10 reveal text-center sm:text-left">
        <Button variant="primary" href="/aplicar" class="w-full sm:w-auto text-center">Quero me candidatar à próxima turma &#8594;</Button>
      </div>
    </div>
  </section>

  <!-- SECTION 4: PROGRAM DETAIL -->
  <section style="background-color: #111113; padding: 96px 0;" class="md:py-28 lg:py-32">
    <div class="mx-auto max-w-[1200px] px-5 md:px-8 lg:px-0">
      <div class="reveal">
        <SectionLabel>O Programa</SectionLabel>
        <h2
          class="mt-5 leading-tight"
          style="font-size: clamp(28px, 4vw, 48px); font-weight: 600; letter-spacing: -0.02em; color: #ffffff;"
        >
          12 Semanas. Quatro Módulos. Um Objetivo — Receita.
        </h2>
      </div>

      <p class="text-base md:text-lg lg:text-xl mt-4 max-w-[720px] leading-relaxed reveal" style="color: rgba(255,255,255,0.55);">
        Pense nas 12 semanas como uma partida jogada em quatro lances. A maioria das agências perde no AI não por falta de habilidade — mas por mover peças sem ter uma posição. O Builder inverte isso. Cada módulo é um lance deliberado. Cada um constrói sua posição antes de avançar para o próximo.
      </p>

      <!-- Module cards — premium journey map -->
      <div class="mt-14 space-y-6 reveal-stagger">

        <!-- Module 01 -->
        <div class="reveal card-interactive group overflow-hidden" style="border-radius: 16px;">
          <!-- Card visual header -->
          <div
            class="flex items-end gap-4 p-6 pb-5"
            style="background: linear-gradient(135deg, rgba(201,168,76,0.12) 0%, rgba(201,168,76,0.03) 100%); border-bottom: 1px solid rgba(255,255,255,0.06);"
          >
            <span class="text-[56px] font-light text-accent leading-none" style="font-weight: 200;">01</span>
            <div>
              <div class="flex flex-wrap items-center gap-3 mb-1">
                <h3 class="text-xl sm:text-2xl font-semibold" style="color: #ffffff;">Arquitetura da Oferta de AI</h3>
                <ChessKnightIcon size={20} class="text-accent icon-hover" />
              </div>
              <span class="text-xs uppercase tracking-widest px-2 py-0.5 rounded" style="background-color: rgba(255,255,255,0.06); color: rgba(255,255,255,0.4); letter-spacing: 0.08em;">SEMANAS 1–2</span>
            </div>
          </div>
          <div class="p-6 sm:p-8">
            <p class="text-sm font-medium italic mb-4 text-accent-muted">O lance de abertura. Você não pode vencer um jogo que não configurou.</p>
            <p class="text-sm md:text-base leading-relaxed mb-5" style="color: rgba(255,255,255,0.55);">Antes de vender AI, você precisa saber exatamente o que está vendendo. A maioria das agências comete o erro de dizer "fazemos AI" — e isso não é uma oferta. É uma categoria.</p>
            <ul class="space-y-2">
              {['Mapeie seu mercado e identifique as oportunidades de AI de maior valor para seus clientes', 'Estruture sua oferta de AI — entregáveis, posicionamento, precificação e apresentação', 'Crie sua documentação de oferta: template de proposta, calculadora de precificação, framework de escopo', 'Saia com um serviço de AI específico e empacotado que sua agência pode vender esta semana'].map(bullet => (
                <li class="flex items-start gap-2 text-sm md:text-[15px]" style="color: rgba(255,255,255,0.55);">
                  <IconCheckCircle size={16} class="text-accent flex-shrink-0 mt-0.5" />
                  {bullet}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Module 02 -->
        <div class="reveal card-interactive group overflow-hidden" style="border-radius: 16px;">
          <div
            class="flex items-end gap-4 p-6 pb-5"
            style="background: linear-gradient(135deg, rgba(201,168,76,0.09) 0%, rgba(201,168,76,0.02) 100%); border-bottom: 1px solid rgba(255,255,255,0.06);"
          >
            <span class="text-[56px] font-light text-accent leading-none" style="font-weight: 200;">02</span>
            <div>
              <div class="flex flex-wrap items-center gap-3 mb-1">
                <h3 class="text-xl sm:text-2xl font-semibold" style="color: #ffffff;">Aquisição de Clientes</h3>
                <IconTrendingUp size={20} class="text-accent icon-hover" />
              </div>
              <span class="text-xs uppercase tracking-widest px-2 py-0.5 rounded" style="background-color: rgba(255,255,255,0.06); color: rgba(255,255,255,0.4); letter-spacing: 0.08em;">SEMANAS 3–4</span>
            </div>
          </div>
          <div class="p-6 sm:p-8">
            <p class="text-sm font-medium italic mb-4 text-accent-muted">Posicione antes de avançar. Uma oferta sem prospects é só um documento.</p>
            <p class="text-sm md:text-base leading-relaxed mb-5" style="color: rgba(255,255,255,0.55);">Uma oferta sem um sistema de vendas não vale nada.</p>
            <ul class="space-y-2">
              {['Construa seu sistema de prospecção e outreach — LinkedIn, e-mail, caminhos de indicação', 'Desenvolva conteúdo que atrai compradores de AI até você — sem precisar correr atrás', 'Domine a conversa de vendas de AI: como posicionar o valor, lidar com objeções e fechar pelo resultado', 'Conduza suas primeiras conversas de vendas com prospects reais — com coaching sobre o que ajustar'].map(bullet => (
                <li class="flex items-start gap-2 text-sm md:text-[15px]" style="color: rgba(255,255,255,0.55);">
                  <IconCheckCircle size={16} class="text-accent flex-shrink-0 mt-0.5" />
                  {bullet}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Module 03 -->
        <div class="reveal card-interactive group overflow-hidden" style="border-radius: 16px;">
          <div
            class="flex items-end gap-4 p-6 pb-5"
            style="background: linear-gradient(135deg, rgba(201,168,76,0.09) 0%, rgba(201,168,76,0.02) 100%); border-bottom: 1px solid rgba(255,255,255,0.06);"
          >
            <span class="text-[56px] font-light text-accent leading-none" style="font-weight: 200;">03</span>
            <div>
              <div class="flex flex-wrap items-center gap-3 mb-1">
                <h3 class="text-xl sm:text-2xl font-semibold" style="color: #ffffff;">Framework de Implementação</h3>
                <IconLayers size={20} class="text-accent icon-hover" />
              </div>
              <span class="text-xs uppercase tracking-widest px-2 py-0.5 rounded" style="background-color: rgba(255,255,255,0.06); color: rgba(255,255,255,0.4); letter-spacing: 0.08em;">SEMANAS 5–8</span>
            </div>
          </div>
          <div class="p-6 sm:p-8">
            <p class="text-sm font-medium italic mb-4 text-accent-muted">Execute com precisão. Você vendeu — agora é hora de entregar direito.</p>
            <p class="text-sm md:text-base leading-relaxed mb-5" style="color: rgba(255,255,255,0.55);">Você vendeu. Agora entrega — e entrega bem.</p>
            <ul class="space-y-2">
              {['Aprenda a metodologia Revenue-First de implementação — construa a coisa certa, não qualquer coisa', 'Configure sua infraestrutura de entrega: ferramentas, processos, templates e checklists de qualidade', 'Entregue seu primeiro projeto de AI com cliente — com a Reis IA como backup técnico e estratégico', 'Documente a entrega para que cada projeto futuro seja repetível e escalável'].map(bullet => (
                <li class="flex items-start gap-2 text-sm md:text-[15px]" style="color: rgba(255,255,255,0.55);">
                  <IconCheckCircle size={16} class="text-accent flex-shrink-0 mt-0.5" />
                  {bullet}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Module 04 -->
        <div class="reveal card-interactive group overflow-hidden" style="border-radius: 16px;">
          <div
            class="flex items-end gap-4 p-6 pb-5"
            style="background: linear-gradient(135deg, rgba(201,168,76,0.12) 0%, rgba(201,168,76,0.03) 100%); border-bottom: 1px solid rgba(255,255,255,0.06);"
          >
            <span class="text-[56px] font-light text-accent leading-none" style="font-weight: 200;">04</span>
            <div>
              <div class="flex flex-wrap items-center gap-3 mb-1">
                <h3 class="text-xl sm:text-2xl font-semibold" style="color: #ffffff;">Escalar e Sistematizar</h3>
                <IconRocket size={20} class="text-accent icon-hover" />
              </div>
              <span class="text-xs uppercase tracking-widest px-2 py-0.5 rounded" style="background-color: rgba(255,255,255,0.06); color: rgba(255,255,255,0.4); letter-spacing: 0.08em;">SEMANAS 9–12</span>
            </div>
          </div>
          <div class="p-6 sm:p-8">
            <p class="text-sm font-medium italic mb-4 text-accent-muted">Endgame. Transforme uma vitória em um sistema que continua vencendo.</p>
            <p class="text-sm md:text-base leading-relaxed mb-5" style="color: rgba(255,255,255,0.55);">Transforme um cliente em um pipeline. Transforme uma entrega em um processo.</p>
            <ul class="space-y-2">
