<style>
  /* Dashboard mockup helpers */
  .sys-mockup { background: var(--surface-0); border: 1px solid var(--border-default); border-radius: 12px; overflow: hidden; box-shadow: 0 24px 64px rgba(0,0,0,0.4); }
  .sys-chrome { display: flex; align-items: center; gap: 8px; padding: 10px 16px; background: rgba(10,10,15,0.8); border-bottom: 1px solid var(--border-default); }
  .stat-card { background: var(--surface-1); border: 1px solid var(--border-default); border-radius: 8px; padding: 12px; }
  .stat-label { font-size: 9px; font-weight: 500; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 6px; }
  .stat-value { font-size: 18px; font-weight: 700; color: var(--text-primary); margin: 0; line-height: 1; }
  .stat-sub { font-size: 9px; color: var(--text-tertiary); margin: 4px 0 0; font-weight: 500; }
  .agent-row { background: var(--surface-1); border: 1px solid var(--border-default); border-radius: 6px; padding: 8px 12px; margin-bottom: 6px; }
  .agent-dot { width: 6px; height: 6px; border-radius: 50%; background: #22C55E; flex-shrink: 0; }

  /* Typing animation */
  @keyframes sysTyping { 0%,100%{opacity:.3} 50%{opacity:1} }
  @keyframes floatChat { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }

  /* Typewriter effect */
  .sys-typewriter {
    display: inline-block;
    overflow: hidden;
    white-space: nowrap;
    border-right: 2px solid var(--accent-blue);
    animation: sysTypewrite 3s steps(60) 1s forwards, sysBlink 0.7s step-end infinite;
    width: 0;
  }
  @keyframes sysTypewrite { 0% { width: 0; } 100% { width: 100%; } }
  @keyframes sysBlink { 50% { border-color: transparent; } }

  /* Systems badge */
  .systems-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-blue);
    background: rgba(74, 144, 255, 0.08);
    border: 1px solid rgba(74, 144, 255, 0.2);
    border-radius: 20px;
    padding: 5px 14px;
  }

  /* Scroll indicator */
  .scroll-indicator {
    width: 24px;
    height: 38px;
    border: 1.5px solid rgba(255, 255, 255, 0.15);
    border-radius: 12px;
    margin: 0 auto;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 6px;
  }

  .scroll-dot {
    width: 4px;
    height: 8px;
    background: rgba(255, 255, 255, 0.3);
    border-radius: 2px;
    animation: scroll-bounce 2s ease-in-out infinite;
  }

  @keyframes scroll-bounce {
    0%, 100% { transform: translateY(0); opacity: 0.3; }
    50% { transform: translateY(6px); opacity: 0.7; }
  }

  /* Animate-on-scroll */
  .animate-on-scroll {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .animate-on-scroll.in-view {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // Intersection Observer for scroll animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
        }
      });
    },
    { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
  );

  document.querySelectorAll('.animate-on-scroll').forEach((el) => {
    observer.observe(el);
  });
</script>
