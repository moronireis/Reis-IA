---
/**
 * Systems — Reis IA Done-For-You Implementation Page
 * v4.0 — Rebuilt to 7 sections, aligned with home page visual pattern
 *
 * ICP: CEO/COO/VP, R$5M-R$100M, delegation mindset
 * All CTAs → /agendar | Blue #4A90FF EXTREME moderation | NO gold | NO chess
 * Visual: Predominantly black/white. Sophistication through ABSENCE of color.
 * Max 1-2 blue elements per viewport.
 */
import MainLayout from '../layouts/MainLayout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import Button from '../components/Button.astro';
import FaqAccordion from '../components/FaqAccordion.tsx';
import HeroGrid from '../components/backgrounds/HeroGrid.tsx';
import IconBot from '../components/icons/IconBot.astro';
import IconHeadphones from '../components/icons/IconHeadphones.astro';
import IconWorkflow from '../components/icons/IconWorkflow.astro';
import IconPlug from '../components/icons/IconPlug.astro';
import IconDatabase from '../components/icons/IconDatabase.astro';
import IconCpu from '../components/icons/IconCpu.astro';

const faqItems = [
  {
    question: 'Quanto custa implementar IA com a Reis IA Systems?',
    answer: 'Depende do escopo. Cada projeto começa com o IA Revenue Audit — uma sessão de diagnóstico onde mapeamos as oportunidades e estimamos investimento e retorno. Não trabalhamos com pacotes genéricos. O investimento é proporcional ao resultado projetado.',
  },
  {
    question: 'Quanto tempo leva pra ver resultado?',
    answer: 'Do diagnóstico ao sistema em produção: 4-12 semanas, dependendo da complexidade. As primeiras horas recuperadas aparecem a partir da semana 1 após o lançamento. Monitoramos KPIs por 60 dias pós-lançamento.',
  },
  {
    question: 'Preciso entender de IA pra contratar?',
    answer: 'Não. Esse é o ponto. Você precisa entender do seu negócio — seus processos, suas regras, seus gargalos. A tecnologia é responsabilidade nossa. Você participa das decisões de negócio, não das decisões técnicas.',
  },
  {
    question: 'E se o sistema não funcionar como prometido?',
    answer: 'Garantia de performance de 60 dias. Se as metas acordadas no Audit não estiverem caminhando na direção certa, continuamos otimizando sem custo adicional. Se o componente específico não performar, reembolso parcial daquele componente.',
  },
  {
    question: 'Vocês substituem minha equipe?',
    answer: 'Não. IA complementa seu time. Automatizamos as tarefas repetitivas que consomem tempo — qualificação de leads, respostas de suporte, atualização de CRM, geração de relatórios. Seu time passa a fazer o trabalho que só humano faz: estratégia, relacionamento, decisões complexas.',
  },
  {
    question: 'Qual a diferença entre a Reis IA e outros fornecedores de IA?',
    answer: 'A maioria começa pela tecnologia — "vamos construir um chatbot". Nós começamos pelo resultado — "onde IA gera o maior retorno de receita no seu negócio?" Essa inversão é o Revenue-First Framework. A consequência: sistemas que se justificam pelo resultado, não pela novidade.',
  },
  {
    question: 'Minha empresa fatura menos de R$5M. Faz sentido?',
    answer: 'Depende. Se você tem um gargalo operacional concreto que está custando tempo e receita, o Audit pode revelar oportunidades relevantes. Se está explorando IA sem um problema específico, ainda não é o momento ideal pra esse investimento.',
  },
  {
    question: 'Sou dono de tudo que é construído?',
    answer: 'Sim. Código, credenciais, documentação, dados — tudo é seu. Sem lock-in. Se amanhã quiser trocar de fornecedor, você leva tudo.',
  },
];

const services = [
  {
    icon: 'bot',
    title: 'Sistemas de Receita IA',
    hours: '60+ horas/mês',
    revenue: '+R$40k/mês em pipeline',
    subtitle: 'recuperadas do time de vendas',
    description: 'Qualificação de leads, follow-up e agendamento — automatizados. Seu time fecha em vez de perseguir. Cada hora recuperada volta pra fechar negócios que estavam travados na fila.',
  },
  {
    icon: 'headphones',
    title: 'Agente de Suporte IA',
    hours: '47 horas/mês',
    revenue: '',
    subtitle: 'recuperadas do time de atendimento',
    description: 'Resolve 70%+ dos tickets sem contato humano. As mesmas 50 perguntas que consomem o dia da sua equipe — respondidas em segundos, 24 horas por dia.',
  },
  {
    icon: 'workflow',
    title: 'Sistemas de Operações',
    hours: '100+ horas/mês',
    revenue: '',
    subtitle: 'recuperadas da operação',
    description: 'Relatórios, roteamento, processamento — comprimidos de horas pra segundos. O relatório de 2 horas que seu gerente monta na mão todo dia? Chega automaticamente às 6h.',
  },
  {
    icon: 'plug',
    title: 'CRM e Integrações',
    hours: '30+ horas/mês',
    revenue: '+R$15k/mês em retenção',
    subtitle: 'eliminadas em transferência manual',
    description: 'WhatsApp, CRM, ERP, APIs — tudo conversando com tudo. Monitoramento de conversas e ações dos agentes em tempo real. Fim da transferência manual de dados.',
  },
  {
    icon: 'database',
    title: 'Base de Conhecimento',
    hours: '15 horas/mês',
    revenue: '',
    subtitle: 'de buscas internas eliminadas',
    description: 'Novos colaboradores encontram respostas em segundos. O conhecimento institucional para de depender de uma pessoa que pode sair amanhã.',
  },
  {
    icon: 'cpu',
    title: 'Sistemas de Inteligência e Dados',
    hours: '50+ horas/mês',
    revenue: '+R$25k/mês em decisões',
    subtitle: 'recuperadas de análise manual',
    description: 'Dados processados, relatórios gerados, insights entregues — sem que ninguém gaste uma hora compilando planilhas.',
  },
];

const iconMap: Record<string, any> = {
  bot: IconBot,
  headphones: IconHeadphones,
  workflow: IconWorkflow,
  plug: IconPlug,
  database: IconDatabase,
  cpu: IconCpu,
};

const processSteps = [
  {
    phase: '1',
    name: 'Diagnóstico',
    timeline: 'Mapeamento',
    description: 'Identificamos onde seu negócio perde tempo e dinheiro. Cada gargalo vira uma oportunidade de IA.',
  },
  {
    phase: '2',
    name: 'Estratégia',
    timeline: 'Planejamento',
    description: 'Desenhamos o sistema com projeção de resultado por componente. Você sabe exatamente o que vai ganhar.',
  },
  {
    phase: '3',
    name: 'Construção',
    timeline: 'Implementação',
    description: 'Os agentes são construídos, treinados com seus dados e testados em cenários reais.',
  },
  {
    phase: '4',
    name: 'Precisão',
    timeline: 'Ajuste fino',
    description: 'Calibragem com dados e situações do dia a dia. O sistema aprende a operar como sua equipe.',
  },
  {
    phase: '5',
    name: 'Ativação',
    timeline: 'Go-live',
    description: 'Sistema em produção. A recuperação de tempo e receita começa imediatamente.',
  },
  {
    phase: '6',
    name: 'Escala',
    timeline: 'Monitoramento',
    description: 'Acompanhamento contínuo, otimização de performance e expansão para novos processos.',
  },
];
---

<MainLayout
  title="Systems — Implementação de IA"
  description="A Reis IA Systems implementa IA do início ao fim — medida pelo único número que importa: horas recuperadas que viram faturamento. Para empresários e C-Level."
  activePage="systems"
>

  <!-- ============================================================
       S1. HERO — HeroGrid background
       ============================================================ -->
  <section
    class="relative overflow-hidden flex items-center justify-center"
    style="background: var(--surface-0); min-height: 100vh; padding: var(--space-2xl) 0;"
    aria-labelledby="systems-hero-heading"
  >
    <div class="absolute inset-0 z-0" aria-hidden="true">
      <HeroGrid client:load />
      <div style="position:absolute;inset:0;background:radial-gradient(ellipse 60% 50% at 50% 40%,rgba(74,144,255,0.06) 0%,transparent 65%);pointer-events:none"></div>
    </div>

    <div class="container-standard relative z-10 text-center">
      <div class="animate-on-scroll">
        <span class="systems-badge">Systems</span>
      </div>

      <h1
        id="systems-hero-heading"
        class="animate-on-scroll mt-6"
        style="font-size: clamp(2.2rem, 5vw, 3.5rem); font-weight: 700; line-height: 1.08; letter-spacing: -0.03em; color: var(--text-primary); max-width: 800px; margin-left: auto; margin-right: auto;"
      >
        Implementação de IA que aparece no <span style="color: var(--accent-blue);">faturamento.</span>
      </h1>

      <p
        class="animate-on-scroll mt-6"
        style="font-size: var(--text-body-lg); line-height: 1.65; color: var(--text-secondary); max-width: 560px; margin-left: auto; margin-right: auto;"
      >
        Agentes de IA, automações e integrações para empresas que querem reduzir custos e aumentar receita. Medido em horas recuperadas por semana e lucro adicionado.
      </p>

      <div class="mt-10 animate-on-scroll">
        <Button variant="primary" href="#cta-systems">
          Recuperar tempo e receita &rarr;
        </Button>
      </div>

      <!-- Scroll indicator -->
      <div class="mt-16 animate-on-scroll" aria-hidden="true">
        <div class="scroll-indicator">
          <div class="scroll-dot"></div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================================
       S2. SERVIÇOS — surface-1
       ============================================================ -->
  <section
    class="relative overflow-hidden"
    style="background: var(--surface-1); padding: var(--space-3xl) 0;"
    aria-labelledby="services-heading"
  >
    <div class="container-standard">
      <div class="animate-on-scroll">
        <SectionLabel>Soluções</SectionLabel>
      </div>

      <h2
        id="services-heading"
        class="animate-on-scroll mt-5"
        style="font-size: var(--text-h2); font-weight: 600; line-height: 1.10; letter-spacing: -0.02em; color: var(--text-primary); max-width: 480px;"
      >
        O que implementamos.
      </h2>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 animate-on-scroll">
        {services.map((service) => {
          const Icon = iconMap[service.icon];
          return (
            <div
              style="background: var(--surface-0); border: 1px solid var(--border-default); border-radius: 12px; padding: 24px; display: flex; flex-direction: column; gap: 16px;"
            >
              <div style="width: 40px; height: 40px; border-radius: 8px; background: rgba(74,144,255,0.08); border: 1px solid rgba(74,144,255,0.12); display: flex; align-items: center; justify-content: center;">
                <Icon size={20} color="var(--accent-blue)" />
              </div>
              <div>
                <p style="font-size: var(--text-body-sm); font-weight: 600; color: var(--text-primary); margin: 0 0 4px;">{service.title}</p>
                <p style="font-size: var(--text-caption); font-weight: 600; color: var(--accent-blue); margin: 0;">{service.hours}</p>
                {service.revenue && <p style="font-size: var(--text-caption); font-weight: 600; color: #22C55E; margin: 2px 0 0;">{service.revenue}</p>}
                <p style="font-size: var(--text-caption); color: var(--text-tertiary); margin: 0;">{service.subtitle}</p>
              </div>
              <p style="font-size: var(--text-caption); line-height: 1.65; color: var(--text-secondary); margin: 0; flex: 1;">{service.description}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>


  <!-- ============================================================
       S3. PROCESSO — surface-0
       ============================================================ -->
  <section
    class="relative overflow-hidden"
    style="background: var(--surface-0); padding: var(--space-3xl) 0;"
    aria-labelledby="processo-heading"
  >
    <div class="container-standard">
      <div class="animate-on-scroll">
        <SectionLabel>Processo</SectionLabel>
      </div>

      <h2
        id="processo-heading"
        class="animate-on-scroll mt-5"
        style="font-size: var(--text-h2); font-weight: 600; line-height: 1.10; letter-spacing: -0.02em; color: var(--text-primary);"
      >
        Do diagnóstico ao resultado.
      </h2>

      <p
        class="animate-on-scroll mt-4"
        style="font-size: var(--text-body-lg); color: var(--text-secondary);"
      >
        Enquanto seu concorrente ainda está pesquisando, você já vai estar operando.
      </p>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 animate-on-scroll">
        {processSteps.map((step) => (
          <div style="background: var(--surface-1); border: 1px solid var(--border-default); border-radius: 12px; padding: 24px;">
            <div class="flex items-start gap-4 mb-4">
              <div style="width: 32px; height: 32px; border-radius: 50%; background: rgba(74,144,255,0.1); border: 1px solid rgba(74,144,255,0.2); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                <span style="font-size: 11px; font-weight: 700; color: var(--accent-blue);">{step.phase}</span>
              </div>
              <div>
                <p style="font-size: var(--text-body-sm); font-weight: 600; color: var(--text-primary); margin: 0 0 4px;">{step.name}</p>
                <span style="font-size: 10px; font-weight: 500; color: var(--text-tertiary); background: var(--surface-2); border: 1px solid var(--border-subtle); border-radius: 4px; padding: 2px 8px;">{step.timeline}</span>
              </div>
            </div>
            <p style="font-size: var(--text-caption); line-height: 1.65; color: var(--text-secondary); margin: 0;">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ============================================================
       S4. COMO FUNCIONA — surface-1 — Dashboard mockup
       ============================================================ -->
  <section
    class="relative overflow-hidden"
    style="background: var(--surface-1); padding: var(--space-3xl) 0;"
    aria-labelledby="como-funciona-heading"
  >
    <div class="container-standard">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        <!-- Left: Text -->
        <div>
          <div class="animate-on-scroll">
            <SectionLabel>Na prática</SectionLabel>
          </div>

          <h2
            id="como-funciona-heading"
            class="animate-on-scroll mt-5"
            style="font-size: var(--text-h2); font-weight: 600; line-height: 1.10; letter-spacing: -0.02em; color: var(--text-primary);"
          >
            Como seus resultados aparecem.
          </h2>

          <p class="animate-on-scroll mt-5" style="font-size: var(--text-body-lg); line-height: 1.65; color: var(--text-secondary);">
            Cada implementação é monitorada em tempo real. Horas recuperadas, agentes ativos e ROI — visíveis no painel desde o primeiro dia em produção.
          </p>

          <ul class="mt-8 space-y-3 animate-on-scroll" style="list-style: none; padding: 0; margin: 0;">
            {[
              'Dashboard de horas recuperadas por agente',
              'Alertas automáticos de performance',
              'Relatórios semanais com ROI acumulado',
              'Otimizações e atualizações constantes',
            ].map((item) => (
              <li class="flex items-start gap-3">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" style="color: var(--accent-blue); margin-top: 3px; flex-shrink: 0;">
                  <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
                  <polyline points="5,8 7,10 11,6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span style="font-size: var(--text-body-sm); color: var(--text-secondary); line-height: 1.5;">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Right: REIS [IA] Hub Systems Dashboard mockup -->
        <div class="animate-on-scroll" style="position:relative">
          <div aria-hidden="true" style="position:absolute;inset:-20px;background:radial-gradient(ellipse 60% 50% at 50% 50%,rgba(74,144,255,0.04) 0%,transparent 60%);pointer-events:none"></div>
          <div class="sys-mockup" style="position:relative;z-index:1">
            <!-- Window chrome -->
            <div class="sys-chrome">
              <div class="w-2.5 h-2.5 rounded-full" style="background:#FF5F57"></div>
              <div class="w-2.5 h-2.5 rounded-full" style="background:#FEBC2E"></div>
              <div class="w-2.5 h-2.5 rounded-full" style="background:#28C840"></div>
              <span class="ml-3 text-[10px] font-medium" style="color:var(--text-tertiary)">REIS [IA] Hub — Systems Monitor</span>
            </div>
            <!-- Stats -->
            <div style="padding:20px">
              <div class="grid grid-cols-4 gap-3 mb-4">
                <div class="stat-card"><p class="stat-label">Horas recuperadas</p><p class="stat-value">+127h</p><p class="stat-sub" style="color:#22C55E">↑ 23%</p></div>
                <div class="stat-card"><p class="stat-label">Receita gerada</p><p class="stat-value" style="color:#22C55E">+R$82k</p><p class="stat-sub">este mês</p></div>
                <div class="stat-card"><p class="stat-label">Agentes ativos</p><p class="stat-value">8</p><p class="stat-sub">online</p></div>
                <div class="stat-card" style="border-color:rgba(74,144,255,0.15)"><p class="stat-label">ROI</p><p class="stat-value" style="color:var(--accent-blue)">4.2x</p><p class="stat-sub">acumulado</p></div>
              </div>
              <!-- Chart -->
              <div class="stat-card mb-3">
                <div class="flex items-center justify-between mb-2">
                  <p class="stat-label" style="margin:0">Performance — últimas 8 semanas</p>
                  <div class="flex items-center gap-3">
                    <span class="flex items-center gap-1" style="font-size:8px;font-weight:500"><span style="display:inline-block;width:8px;height:2px;border-radius:1px;background:var(--accent-blue)"></span><span style="color:var(--text-tertiary)">Horas</span></span>
                    <span class="flex items-center gap-1" style="font-size:8px;font-weight:500"><span style="display:inline-block;width:8px;height:2px;border-radius:1px;background:#22C55E"></span><span style="color:var(--text-tertiary)">Receita</span></span>
                  </div>
                </div>
                <svg viewBox="0 0 240 56" width="100%" height="56" aria-hidden="true" preserveAspectRatio="none">
                  <defs>
                    <linearGradient id="sys-fill" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0%" stop-color="rgba(74,144,255,0.2)"/><stop offset="100%" stop-color="rgba(74,144,255,0)"/>
                    </linearGradient>
                    <linearGradient id="sys-fill-rev" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0%" stop-color="rgba(34,197,94,0.15)"/><stop offset="100%" stop-color="rgba(34,197,94,0)"/>
                    </linearGradient>
                  </defs>
                  <!-- Horas (azul) -->
                  <path d="M0,50 L30,44 L60,40 L90,34 L120,26 L150,18 L180,12 L210,8 L240,4 L240,56 L0,56 Z" fill="url(#sys-fill)"/>
                  <polyline points="0,50 30,44 60,40 90,34 120,26 150,18 180,12 210,8 240,4" fill="none" stroke="var(--accent-blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="240" cy="4" r="3" fill="var(--accent-blue)"/>
                  <!-- Receita (verde) -->
                  <path d="M0,52 L30,48 L60,46 L90,40 L120,34 L150,28 L180,20 L210,14 L240,10 L240,56 L0,56 Z" fill="url(#sys-fill-rev)"/>
                  <polyline points="0,52 30,48 60,46 90,40 120,34 150,28 180,20 210,14 240,10" fill="none" stroke="#22C55E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="4 3"/>
                  <circle cx="240" cy="10" r="2.5" fill="#22C55E"/>
                </svg>
              </div>
              <!-- Agents -->
              {[['Sistemas de Receita','+60h/mês'],['Agente de Suporte','+47h/mês'],['Sistemas de Operações','+100h/mês']].map(([n,v]) => (
                <div class="flex items-center justify-between agent-row">
                  <div class="flex items-center gap-2"><div class="agent-dot"></div><span style="font-size:10px;font-weight:500;color:var(--text-primary)">{n}</span></div>
                  <span style="font-size:10px;font-weight:600;color:var(--accent-blue)">{v}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ============================================================
       S5. AGENTE EM AÇÃO — surface-1 — Mockup de conversa
       ============================================================ -->
  <section
    class="relative overflow-hidden"
    style="background: var(--surface-1); padding: var(--space-3xl) 0;"
  >
    <div class="container-standard">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Left: Text -->
        <div>
          <div class="animate-on-scroll">
            <SectionLabel>Em ação</SectionLabel>
          </div>
          <h2 class="animate-on-scroll mt-5" style="font-size:var(--text-h2);font-weight:600;line-height:1.10;letter-spacing:-0.02em;color:var(--text-primary);">
            Seu agente trabalhando. Agora.
          </h2>
          <p class="animate-on-scroll mt-5" style="font-size:var(--text-body-lg);line-height:1.65;color:var(--text-secondary);">
            Enquanto sua equipe foca no que importa, os agentes IA fazem o atendimento, agendamentos, vendas, acompanhamento e suporte de forma humanizada — feitos sob medida com as informações do seu negócio.
          </p>
          <div class="mt-8 animate-on-scroll">
            <Button variant="primary" href="/agendar">
              Agendar diagnóstico &rarr;
            </Button>
          </div>
        </div>

        <!-- Right: Painel + mini chat flutuante -->
        <div class="animate-on-scroll" style="position:relative">
          <!-- Mini chat flutuante por cima do painel -->
          <div class="hidden lg:block" style="position:absolute;top:-30px;right:-20px;z-index:3;width:280px;animation:floatChat 6s ease-in-out infinite">
            <div class="rounded-xl overflow-hidden" style="background:var(--surface-1);border:1px solid rgba(74,144,255,0.15);box-shadow:0 20px 50px rgba(0,0,0,0.6)">
              <div class="flex items-center gap-2 px-3 py-2" style="background:var(--surface-0);border-bottom:1px solid var(--border-default)">
                <div class="w-2 h-2 rounded-full" style="background:#22C55E"></div>
                <span class="text-[8px] font-medium" style="color:var(--text-tertiary)">WhatsApp · Ao vivo</span>
                <span class="ml-auto text-[7px]" style="color:var(--text-tertiary)">Agora</span>
              </div>
              <div style="padding:10px 12px;display:flex;flex-direction:column;gap:8px">
                <!-- User -->
                <div style="display:flex;justify-content:flex-end">
                  <div style="background:rgba(74,144,255,0.12);border:1px solid rgba(74,144,255,0.15);border-radius:8px;border-top-right-radius:2px;padding:7px 10px;font-size:10px;color:var(--text-primary);line-height:1.4;max-width:190px">Oi! Vocês atendem empresas de logística?</div>
                </div>
                <!-- Agent -->
                <div style="display:flex;gap:5px">
