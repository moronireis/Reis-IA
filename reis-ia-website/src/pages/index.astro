---
/**
 * Homepage — Reis IA Brand Positioning & Routing
 * v3.0 copy from FINAL-homepage-copy.md [REALIGNED — Brand Ecosystem — 2026-03-18]
 * 7 sections: Hero, Manifesto, Mockups, Pilares, Estatisticas, Fundador, Newsletter, CTA Rodape
 * Philosophy: "O Tempo é Rei" + Z7 + Ecossistema 2 pilares
 */
import MainLayout from '../layouts/MainLayout.astro';
import Badge from '../components/Badge.astro';
import Button from '../components/Button.astro';
import StatBlock from '../components/StatBlock.astro';
import SectionLabel from '../components/SectionLabel.astro';
import HourglassIcon from '../components/HourglassIcon.astro';
import HourglassWatermark from '../components/HourglassWatermark.astro';
import SapphireScanner from '../components/SapphireScanner.astro';
import AmbientPool from '../components/AmbientPool.astro';
import Z7Icon from '../components/Z7Icon.astro';
import MockupDashboard from '../components/MockupDashboard.astro';
import MockupFunnel from '../components/MockupFunnel.astro';
import MockupWorkflow from '../components/MockupWorkflow.astro';
import MockupBeforeAfter from '../components/MockupBeforeAfter.astro';
---

<MainLayout
  title="Reis IA — O Tempo é Rei. IA que devolve tempo e gera receita."
  description="A Reis IA devolve o recurso mais valioso da sua empresa: tempo. Implementação de IA, programas Z7 e parcerias — tudo começa pelo tempo."
  activePage="home"
>

  <!-- ============================================================
       SECTION 1: HERO — Surface-0, immersive, full-viewport impact
       ============================================================ -->
  <section
    class="relative overflow-hidden flex items-center justify-center"
    style="background: var(--surface-0); min-height: 100vh; padding: var(--space-2xl) 0;"
    aria-labelledby="hero-heading"
  >
    <!-- Aurora background — intensified for hero impact -->
    <div class="aurora-bg" aria-hidden="true" style="opacity: 1.4;"></div>

    <!-- Ambient blue glow behind center content -->
    <div
      class="absolute pointer-events-none"
      aria-hidden="true"
      style="top: 50%; left: 50%; transform: translate(-50%, -50%); width: 800px; height: 800px; background: radial-gradient(circle, rgba(74,144,255,0.08) 0%, rgba(74,144,255,0.03) 30%, transparent 70%); filter: blur(40px);"
    ></div>

    <!-- Z7 watermarks — subtle corners -->
    <div class="absolute top-10 right-10 pointer-events-none opacity-[0.03]" aria-hidden="true">
      <Z7Icon size={64} variant="stroke" />
    </div>
    <div class="absolute bottom-10 left-10 pointer-events-none opacity-[0.02]" aria-hidden="true">
      <Z7Icon size={48} variant="stroke" />
    </div>

    <!-- Content -->
    <div class="container-standard relative z-10">
      <div class="max-w-[960px] mx-auto text-center">

        <!-- H1-B Hourglass — hero-size, animated glow -->
        <div class="hero-animate hero-animate-1 flex justify-center mb-10">
          <div class="relative">
            <HourglassIcon
              size={80}
              strokeWidth={3}
              class="text-[var(--accent-blue)] hourglass-hover-glow relative z-10"
            />
            <!-- Glow ring behind hourglass -->
            <div
              class="absolute inset-[-20px] rounded-full pointer-events-none"
              aria-hidden="true"
              style="background: radial-gradient(circle, rgba(74,144,255,0.12) 0%, transparent 70%); animation: watermark-breathe 6s ease-in-out infinite;"
            ></div>
          </div>
        </div>

        <!-- Main headline — massive, kinetic -->
        <h1
          id="hero-heading"
          class="hero-animate hero-animate-2 text-balance kinetic-text"
          style="font-size: clamp(3.5rem, 2rem + 6vw, 7rem); font-weight: 700; line-height: 0.95; letter-spacing: -0.04em; color: var(--text-primary);"
        >
          <span>O</span>
          <span>Tempo</span>
          <span style="opacity: 0.5;">é</span>
          <span class="hero-rei-highlight">Rei.</span>
        </h1>

        <!-- Second line — dramatic pause -->
        <p
          class="hero-animate hero-animate-3 mt-6 text-balance mx-auto"
          style="font-size: clamp(1.25rem, 0.8rem + 1.5vw, 2rem); font-weight: 400; line-height: 1.25; letter-spacing: -0.015em; color: var(--text-secondary); max-width: 720px;"
        >
          E a maioria das empresas está desperdiçando o dele.
        </p>

        <!-- Subheadline — concise, impactful -->
        <p
          class="hero-animate hero-animate-4 mt-8 mx-auto text-pretty"
          style="font-size: var(--text-body-lg); line-height: 1.65; color: var(--text-tertiary); max-width: 600px;"
        >
          A <span style="font-weight: 300; color: var(--text-secondary);">Reis IA</span> devolve o recurso mais valioso da sua empresa — o tempo — e transforma cada hora recuperada em receita.
        </p>

        <!-- Dual CTA — prominent -->
        <div class="hero-animate hero-animate-5 flex flex-col sm:flex-row items-center justify-center gap-4 mt-12">
          <Button variant="hero" href="/agendar">
            Agendar uma conversa &rarr;
          </Button>
          <Button variant="secondary" href="/aplicar">
            Quero vender IA &rarr;
          </Button>
        </div>

        <!-- Microcopy -->
        <p
          class="hero-animate hero-animate-5 mt-5"
          style="font-size: var(--text-micro); color: var(--text-quaternary);"
        >
          30 minutos. Zero compromisso. Clareza sobre onde seu tempo está sendo perdido.
        </p>

        <!-- Scroll indicator -->
        <div class="hero-animate hero-animate-5 mt-16 flex justify-center" aria-hidden="true">
          <div class="w-px h-12" style="background: linear-gradient(to bottom, var(--accent-blue), transparent); animation: heroFadeIn 2s ease-in-out infinite alternate;"></div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================================
       SECTION 2: MANIFESTO — Surface-1, text reveal, Z7 philosophy
       ============================================================ -->
  <section
    class="relative overflow-hidden light-pool-blue-bl"
    style="background: var(--surface-1); padding: var(--space-3xl) 0;"
    aria-labelledby="manifesto-heading"
  >
    <AmbientPool position="bottom-right" color="blue" size={500} opacity={0.04} />

    <div class="container-standard relative z-10">
      <div class="max-w-[var(--container-narrow)]">

        <SectionLabel number="01" class="animate-on-scroll">O Que Acreditamos</SectionLabel>

        <!-- Headline with text reveal -->
        <h2
          id="manifesto-heading"
          class="text-reveal mt-6"
          style="font-size: var(--text-h2); font-weight: 600; line-height: 1.10; letter-spacing: -0.02em; color: var(--text-primary);"
        >
          Tiramos a venda. A que impede as pessoas de verem o que IA realmente faz.
        </h2>

        <!-- Body — v3.0 manifesto -->
        <div
          class="mt-8 space-y-5 animate-on-scroll"
          style="font-size: var(--text-body-lg); line-height: 1.60; color: var(--text-secondary); max-width: var(--container-text);"
        >
          <p>O mercado de IA está cheio de vozes falsas. Promessas de prompts milagrosos. Templates que resolvem tudo. Cursos de meses que não produzem uma única venda. Mentores que viram as costas depois do pagamento.</p>

          <p>O resultado? Profissionais confusos. Empresários frustrados. E um cemitério crescente de projetos que funcionam na demo e morrem na operação.</p>

          <p>A verdade é simples: IA não é mágica. IA é uma ferramenta de tempo. Ela comprime semanas em horas. Elimina tarefas que roubam o dia dos seus colaboradores. Devolve o único recurso que nenhuma tecnologia fabrica e nenhum dinheiro recompra.</p>

          <!-- Hierarchy as manifesto statement -->
          <p
            style="font-size: var(--text-h3); font-weight: 700; line-height: 1.15; letter-spacing: -0.015em; color: var(--accent-blue);"
          >
            Tempo &rarr; Eficiência &rarr; Receita.
          </p>

          <p>É essa a hierarquia. Recupere o tempo. Crie a eficiência. A receita é inevitável.</p>

          <p>No xadrez, ninguém joga uma peça aleatória e torce pelo xeque-mate. Cada movimento segue uma estratégia que existia antes do jogo começar. É assim que a gente trabalha. Antes de qualquer sistema ser construído, perguntamos: <strong style="color: var(--text-primary);">onde o tempo está sendo perdido?</strong> Só então construímos. Com precisão. Com a filosofia Z7 — que comprime 7 meses em 7 dias e 7 anos em 7 horas.</p>

          <p>Nós falamos. Nós criamos. E tudo que construímos começa e termina com uma verdade:</p>
        </div>

        <!-- Bold closing: O Tempo é Rei -->
        <div class="mt-10 animate-on-scroll">
          <p
            style="font-size: var(--text-h2); font-weight: 700; line-height: 1.10; letter-spacing: -0.02em; color: var(--text-primary);"
          >
            O Tempo é Rei.
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================================
       SECTION 3: MOCKUPS — Surface-0, 2x2 animated product mockups (Stripe/Linear style)
       ============================================================ -->
  <section
    class="relative overflow-hidden"
    style="background: var(--surface-0); padding: var(--space-3xl) 0;"
    aria-labelledby="mockups-heading"
  >
    <div class="container-standard relative z-10">
      <!-- Section header -->
      <div class="text-center mb-16 animate-on-scroll">
        <SectionLabel number="02">O Que Construimos</SectionLabel>
        <h2
          id="mockups-heading"
          class="mt-5 text-balance mx-auto"
          style="font-size: var(--text-h2); font-weight: 600; line-height: 1.10; letter-spacing: -0.02em; color: var(--text-primary); max-width: var(--container-headline);"
        >
          IA que aparece no faturamento. Nao no PowerPoint.
        </h2>
        <p
          class="mt-4 mx-auto"
          style="font-size: var(--text-body-lg); line-height: 1.60; color: var(--text-secondary); max-width: var(--container-text);"
        >
          Dashboards que medem tempo recuperado. Funis que convertem sozinhos. Workflows que rodam 24/7. E o antes e depois que justifica cada centavo investido.
        </p>
      </div>

      <!-- 2x2 mockup grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 max-w-[880px] mx-auto grid-stagger">
        <MockupDashboard />
        <MockupFunnel />
        <MockupWorkflow />
        <MockupBeforeAfter />
      </div>
    </div>
  </section>


  <!-- ============================================================
       SECTION 4: PILARES — Surface-1, 2 ecosystem cards, Sapphire Scanner on Builder
       ============================================================ -->
  <section
    id="pilares"
    class="relative overflow-hidden"
    style="background: var(--surface-1); padding: var(--space-3xl) 0;"
    aria-labelledby="pilares-heading"
  >
    <div class="container-standard relative z-10">
      <!-- Section header -->
      <div class="text-center mb-16 animate-on-scroll">
        <SectionLabel number="03">O Ecossistema</SectionLabel>
        <h2
          id="pilares-heading"
          class="mt-5 text-balance mx-auto"
          style="font-size: var(--text-h2); font-weight: 600; line-height: 1.10; letter-spacing: -0.02em; color: var(--text-primary); max-width: var(--container-headline);"
        >
          Dois pilares. Um objetivo: devolver o seu tempo.
        </h2>
      </div>

      <!-- 2-column card grid with stagger -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 max-w-[880px] mx-auto grid-stagger card-grid-hover">

        <!-- CARD 1: Time Builders — Sapphire Scanner (featured, builder-electric accent) -->
        <SapphireScanner class="card-item p-7 flex flex-col">
          <div class="flex items-center gap-3 mb-6">
            <Badge variant="accent">Movimento</Badge>
          </div>
          <h3
            style="font-size: var(--text-h4); font-weight: 600; line-height: 1.20; letter-spacing: -0.01em; color: var(--text-primary);"
            class="mb-3"
          >
            Venda IA. Domine o Tempo. Faça Parte da Tribo.
          </h3>
          <p style="font-size: var(--text-body-sm); line-height: 1.55; color: var(--text-secondary);" class="mb-4 flex-1">
            Time Builders é um movimento de profissionais que se recusam a desperdiçar tempo. Se você vem do marketing digital, de agência, de automação ou estratégia — e quer construir e vender IA como serviço — esse é o seu lugar.
          </p>
          <p style="font-size: var(--text-body-sm); line-height: 1.55; color: var(--text-secondary);" class="mb-5">
            Não somos mentores que viram as costas. Construímos junto. Z7 Days comprime 7 meses em 7 dias. Você sai com oferta, sistema de aquisição e primeiro projeto — não com teoria.
          </p>
          <p style="font-size: var(--text-caption); color: var(--text-tertiary);" class="mb-4">
            <strong>Para quem é:</strong> Donos de agência. Profissionais do digital. Quem quer IA como fonte de receita — não como hobby intelectual.
          </p>
          <p style="font-size: var(--text-micro); color: var(--text-quaternary);" class="mb-5 italic">
            Enquanto outros esperam, nós construímos. 7 horas te separam de 7 anos de vantagem.
          </p>
          <div class="mt-auto">
            <Button variant="ghost" href="/aplicar">Aplicar para Time Builders</Button>
          </div>
        </SapphireScanner>

        <!-- CARD 2: Systems -->
        <div class="card-item card-interactive p-7 flex flex-col">
          <div class="flex items-center gap-3 mb-6">
            <Badge variant="accent">Implementação</Badge>
          </div>
          <h3
            style="font-size: var(--text-h4); font-weight: 600; line-height: 1.20; letter-spacing: -0.01em; color: var(--text-primary);"
            class="mb-3"
          >
            Se Não Traz Resultado, Não Serve.
          </h3>
          <p style="font-size: var(--text-body-sm); line-height: 1.55; color: var(--text-secondary);" class="mb-4 flex-1">
            Implementação de IA pra empresas que precisam de resultado, não de projeto de tecnologia. A gente constrói os sistemas, integra tudo e garante que os números apareçam — medidos em horas recuperadas e receita gerada.
          </p>
          <p style="font-size: var(--text-body-sm); line-height: 1.55; color: var(--text-secondary);" class="mb-5">
            Esqueça telas de código. Falemos de números: quantas horas seu time perde por semana em tarefas que uma máquina resolveria em segundos?
          </p>
          <p style="font-size: var(--text-caption); color: var(--text-tertiary);" class="mb-4">
            <strong>Para quem é:</strong> CEOs. COOs. Empresários que querem IA que apareça no faturamento — não no PowerPoint.
          </p>
          <p style="font-size: var(--text-micro); color: var(--text-quaternary);" class="mb-5 italic">
            Seus colaboradores podem ser até 70x mais rápidos. Cada semana sem o sistema certo é tempo que não volta.
          </p>
          <div class="mt-auto">
            <Button variant="ghost" href="/agendar">Agendar uma conversa</Button>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ============================================================
       SECTION 5: ESTATISTICAS — Surface-0, counter animation, temporal language, hourglass watermark
       ============================================================ -->
  <section
    class="relative overflow-hidden light-pool-tr"
    style="background: var(--surface-0); padding: var(--space-3xl) 0;"
    aria-labelledby="stats-heading"
  >
    <HourglassWatermark position="top-right" size={160} opacity={0.03} />

    <div class="container-standard relative z-10">
      <!-- Section header -->
      <div class="text-center mb-16 animate-on-scroll">
        <SectionLabel number="04">Resultados</SectionLabel>
        <h2
          id="stats-heading"
          class="mt-5 text-balance mx-auto"
          style="font-size: var(--text-h2); font-weight: 600; line-height: 1.10; letter-spacing: -0.02em; color: var(--text-primary); max-width: var(--container-headline);"
        >
          O tempo conta a verdade que o faturamento esconde.
        </h2>
        <p
          class="mt-4 mx-auto"
          style="font-size: var(--text-body-lg); line-height: 1.60; color: var(--text-secondary); max-width: var(--container-text);"
        >
          Quando a pergunta certa é "quanto tempo recuperamos?", os números mudam.
        </p>
      </div>

      <!-- Stats grid — Z7 temporal language -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 sm:gap-12 grid-stagger">

        <!-- Stat 1: Compressão Z7 -->
        <div>
          <div class="text-center md:text-left">
            <div
              class="w-10 h-px mb-4 mx-auto md:mx-0"
              style="background: linear-gradient(to right, var(--accent-blue), transparent);"
              aria-hidden="true"
            ></div>
            <p
              class="font-bold tabular-nums leading-none text-[var(--accent-blue)]"
              style="font-size: clamp(2.5rem, 1.5rem + 3.5vw, 3.5rem);"
              aria-label="7:7 — 7 horas com IA equivalem a 7 anos de aprendizado convencional"
            >
              7:7
            </p>
            <p class="text-[var(--text-label)] uppercase tracking-[0.05em] font-semibold text-[var(--text-tertiary)] mt-3 max-w-[200px] mx-auto md:mx-0 leading-snug">
              7 horas com IA equivalem a 7 anos de aprendizado convencional
            </p>
            <p class="text-[var(--text-body-sm)] text-[var(--text-secondary)] mt-1 leading-relaxed">
              A compressão Z7 é real. Quem dedica 7 horas focadas com IA acelera ao equivalente de 7 anos. Isso não é marketing. É matemática de tempo.
            </p>
          </div>
        </div>

        <!-- Stat 2: Velocidade -->
        <div>
          <StatBlock
            value="70x"
            label="mais rápidos — é o potencial de um colaborador com IA bem implementada"
            context="Não é redução de custo. É multiplicação de capacidade. Seu time fazendo em minutos o que levava horas. As horas recuperadas voltam pra onde geram receita."
            color="blue"
          />
        </div>

        <!-- Stat 3: Custo da inação -->
        <div>
          <StatBlock
            value="7 anos"
            label="de distância entre quem implementou IA e quem ainda está decidindo"
            context="Empresas com IA estão 7 anos à frente. Cada mês de &laquo;vamos ver&raquo; é um mês que seu concorrente usou pra abrir distância. A janela não espera."
            color="white"
          />
        </div>

        <!-- Stat 4: Tempo recuperado -->
        <div>
          <StatBlock
            value="+15h"
            label="por semana é o que um empresário médio recupera com IA bem implementada"
            context="15 horas por semana. 60 horas por mês. 720 horas por ano. É quase meio ano de dias úteis. Onde você investiria esse tempo?"
            color="blue"
          />
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================================
       SECTION 6: FUNDADOR — Surface-1, 7+5 weighted grid, Moroni as Governante/Herói/Rebelde
       ============================================================ -->
  <section
    class="relative overflow-hidden"
    style="background: var(--surface-1); padding: var(--space-3xl) 0;"
    aria-labelledby="founder-heading"
  >
    <AmbientPool position="bottom-left" color="blue" size={400} opacity={0.03} />
    <HourglassWatermark position="bottom-right" size={200} opacity={0.04} />

    <div class="container-standard relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">

        <!-- Photo column (5 cols) — Sapphire Scanner rotating border -->
        <div class="lg:col-span-5 animate-scale-reveal">
          <SapphireScanner class="w-full">
            <div
              class="w-full min-h-[260px] sm:min-h-[320px] lg:min-h-[480px] rounded-[11px] flex items-center justify-center p-8 placeholder-content"
              style="background: var(--surface-1); border: none;"
              aria-label="Foto do fundador Moroni Reis — a ser adicionada"
            >
              <p style="font-size: var(--text-body-sm); color: var(--text-quaternary); text-align: center;">
                [PLACEHOLDER: Foto profissional de Moroni Reis]
              </p>
            </div>
          </SapphireScanner>
        </div>

        <!-- Text column (7 cols) -->
        <div class="lg:col-span-7">
          <div class="animate-on-scroll">
            <SectionLabel number="05">Quem é Moroni Reis</SectionLabel>
          </div>

          <h2
            id="founder-heading"
            class="animate-on-scroll mt-5"
            style="font-size: var(--text-h3); font-weight: 600; line-height: 1.15; letter-spacing: -0.015em; color: var(--text-primary);"
          >
            Eu não vendo IA. Eu devolvo tempo.
          </h2>

          <div
            class="mt-6 space-y-5 animate-on-scroll"
            style="font-size: var(--text-body); line-height: 1.65; color: var(--text-secondary); max-width: var(--container-text);"
          >
            <p>Meu nome é Moroni Reis. Mais de uma década em marketing digital — funis, lançamentos, sistemas de aquisição pra empresas no Brasil e fora.</p>

            <p>Quando a IA se tornou acessível, fiz a única pergunta que um estrategista faz: onde isso gera dinheiro?</p>

            <p>O que encontrei foi perturbador. Não porque a tecnologia não funcionasse. Mas porque o mercado inteiro começava pelo lado errado. Empresas jogavam dinheiro em projetos sem perguntar quanto tempo desperdiçavam. Agências montavam demos impressionantes que morriam em produção. Mentores vendiam esperança e viravam as costas.</p>

            <p>Eu vi o padrão. Chamei de <strong style="color: var(--text-primary);">Cemitério de Protótipos</strong>. E decidi que ninguém mais precisava perder tempo ali.</p>

            <p>O problema nunca foi IA. O problema sempre foi tempo. Tempo desperdiçado em processos manuais. Tempo queimado com abordagens erradas. Tempo que, uma vez perdido, não volta. Jamais.</p>

            <!-- Philosophy crystallization with hourglass -->
            <p class="flex items-start gap-3">
              <HourglassIcon size={22} class="text-[var(--accent-blue)] flex-shrink-0 mt-0.5" />
              <span>Aí a filosofia cristalizou: <strong style="color: var(--accent-blue); font-weight: 700;">O Tempo é Rei.</strong></span>
            </p>

            <p>Não é slogan. É modelo operacional. Recupere o tempo com IA. Crie eficiência. A receita vem. Sempre vem.</p>

            <p>A <span style="font-weight: 300;">Reis IA</span> existe pra devolver tempo. Os programas Z7 existem pra comprimir o que levaria meses em dias. Systems existe pra fazer empresas recuperarem horas toda semana. E eu existo nessa história pra tirar o véu — o véu da descrença que impede as pessoas de verem que o mundo já mudou.</p>

            <p>Não com hype. Com números. Com resultado.</p>
          </div>

          <!-- Dual CTA -->
          <div class="flex flex-col sm:flex-row gap-4 mt-10 animate-on-scroll">
            <Button variant="primary" href="/agendar">
              Começar com uma conversa &rarr;
            </Button>
            <Button variant="ghost" href="/aplicar">
              Aplicar para Time Builders
            </Button>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================================
       SECTION 6: NEWSLETTER — Surface-0, email capture, centered narrow
       ============================================================ -->
  <section
    id="newsletter"
    class="relative overflow-hidden light-pool-blue-center"
    style="background: var(--surface-0); padding: var(--space-3xl) 0;"
    aria-labelledby="newsletter-heading"
  >
    <div class="container-narrow relative z-10">
      <div class="text-center animate-on-scroll">
        <SectionLabel number="06">Newsletter</SectionLabel>
        <h2
          id="newsletter-heading"
          class="mt-5 text-balance mx-auto"
          style="font-size: var(--text-h3); font-weight: 600; line-height: 1.15; letter-spacing: -0.015em; color: var(--text-primary);"
        >
          Frameworks que nossos clientes pagam pra ter. Na sua caixa de entrada.
        </h2>
        <p
          class="mt-4 mx-auto text-pretty"
          style="font-size: var(--text-body); line-height: 1.65; color: var(--text-secondary); max-width: var(--container-text);"
        >
          Estudos de caso reais. Estratégias que estamos usando esta semana. E os erros que vemos empresas cometendo com IA — pra você não desperdiçar tempo com eles. Sem enrolação.
        </p>
      </div>

      <!-- Email form -->
      <form
        class="mt-10 max-w-[480px] mx-auto animate-on-scroll"
        action="https://formspree.io/f/PLACEHOLDER_FORM_ID"
        method="POST"
        aria-label="Formulário de inscrição na newsletter"
      >
        <input type="hidden" name="_source" value="newsletter-home" />
        <div class="flex flex-col sm:flex-row gap-3">
          <input
            type="email"
            name="email"
            placeholder="Seu melhor email"
            class="input flex-1"
            required
            aria-label="Seu endereço de email"
          />
          <button
            type="submit"
            class="inline-flex items-center justify-center text-white font-semibold px-6 py-3 rounded-[var(--radius)] btn-press whitespace-nowrap focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--focus-ring)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--surface-0)]"
            style="background: var(--accent-blue); transition: background-color var(--duration-fast) var(--ease-base), transform 150ms var(--ease-base);"
          >
            Quero receber
          </button>
        </div>
        <p class="mt-4 text-center" style="font-size: var(--text-micro); color: var(--text-quaternary);">
          Sem spam. Cancele quando quiser. Suas informações ficam com a gente.
        </p>
      </form>
    </div>
  </section>


  <!-- ============================================================
       SECTION 7: CTA RODAPE — Surface-0, blue ambient glow, H1-B hourglass, "O Tempo é Rei"
       ============================================================ -->
  <section
    class="relative overflow-hidden"
    style="background: var(--surface-0); padding: var(--space-3xl) 0 var(--space-2xl);"
    aria-labelledby="footer-cta-heading"
  >
    <!-- Blue ambient glow centered -->
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse 70% 50% at 50% 50%, rgba(74, 144, 255, 0.06) 0%, transparent 65%);"
    ></div>

    <div class="container-standard relative z-10 text-center">
      <!-- H1-B Hourglass icon above headline -->
      <div class="flex justify-center mb-6 animate-on-scroll">
        <HourglassIcon size={48} class="text-[var(--accent-blue)] hourglass-hover-glow" ariaHidden={true} />
      </div>

      <h2
        id="footer-cta-heading"
        class="animate-on-scroll text-balance mx-auto"
        style="font-size: var(--text-h2); font-weight: 700; line-height: 1.10; letter-spacing: -0.02em; color: var(--text-primary); max-width: var(--container-headline);"
      >
        O Tempo é Rei.<br />
        E cada dia sem agir é um dia entregue ao concorrente.
      </h2>

      <p
        class="animate-on-scroll mt-6 mx-auto text-pretty"
        style="font-size: var(--text-body); line-height: 1.65; color: var(--text-secondary); max-width: 640px;"
      >
        Enquanto você decide, seu concorrente está implementando. Cada sistema de IA que ele coloca no ar recupera tempo pra equipe dele. Cada hora recuperada vira receita. E a distância entre quem agiu e quem ficou parado? Só aumenta. Nunca diminui.
      </p>

      <div class="animate-on-scroll mt-10">
        <Button variant="hero" href="/agendar">
          Agendar uma conversa &rarr;
        </Button>
      </div>

      <p
        class="animate-on-scroll mt-4 mx-auto"
        style="font-size: var(--text-micro); color: var(--text-quaternary); max-width: 500px;"
      >
        30 minutos. Um mapa de onde seu tempo está sendo desperdiçado — e como recuperá-lo.
      </p>
    </div>
  </section>

</MainLayout>

