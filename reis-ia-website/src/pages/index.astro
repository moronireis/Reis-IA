---
/**
 * Homepage — REIS [IA] — Ecossistema de IA para Negócios
 * v7.0 [VISUAL REWRITE — interactive hero grid, Hub mockups, inline stats — 2026-03-25]
 * Sections: Hero, Soluções, Mentorias, Formações, Comunidade, Resultados, Fundador, CTA
 * Copy: unchanged from v5.0
 */
import MainLayout from '../layouts/MainLayout.astro';
import Badge from '../components/Badge.astro';
import Button from '../components/Button.astro';
import SectionLabel from '../components/SectionLabel.astro';
import SapphireScanner from '../components/SapphireScanner.astro';
import HeroGrid from '../components/backgrounds/HeroGrid.tsx';
---

<MainLayout
  title="REIS [IA] — IA que aumenta receita e reduz custos para o seu negócio."
  description="Implementação de IA, mentoria, formações e comunidade para empresários que querem resultados reais: mais receita, menos custos, menos tempo perdido."
  activePage="home"
>

  <!-- ============================================================
       HERO — Centered message + premium background
       ============================================================ -->
  <section
    class="relative overflow-hidden flex items-center justify-center"
    style="background: var(--surface-0); min-height: 100vh; padding: var(--space-2xl) 0;"
    aria-labelledby="hero-heading"
  >
    <!-- Background: Interactive repel grid -->
    <HeroGrid client:load />
    <!-- Top accent line -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 pointer-events-none" aria-hidden="true" style="width:400px;height:1px;background:linear-gradient(90deg,transparent,rgba(74,144,255,0.15) 50%,transparent);"></div>

    <!-- Content: centered -->
    <div class="container-standard relative z-10">
      <div class="max-w-[800px] mx-auto text-center">

        <h1
          id="hero-heading"
          class="hero-animate hero-animate-2 text-balance"
          style="font-size: clamp(2.8rem, 1.6rem + 5vw, 5rem); font-weight: 600; line-height: 1.10; letter-spacing: -0.02em; color: var(--text-primary);"
        >
          Tempo é o ativo mais <span style="color: var(--accent-blue);">importante.</span>
        </h1>

        <p
          class="hero-animate hero-animate-3 mt-6 text-balance mx-auto"
          style="font-size: clamp(1.05rem, 0.7rem + 1.1vw, 1.35rem); font-weight: 400; line-height: 1.55; color: var(--text-secondary); max-width: 600px;"
        >
          Implementação de IA, mentorias, formações e comunidade para empresários que querem resultados em receita e eficiência.
        </p>

        <!-- CTA -->
        <div class="hero-animate hero-animate-4 flex items-center justify-center mt-10">
          <Button variant="hero" href="#cta-final">
            Quero resultados com IA &rarr;
          </Button>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================================
       SOLUÇÕES — Systems (protagonista)
       ============================================================ -->
  <section
    class="relative overflow-hidden"
    style="background: var(--surface-1); padding: var(--space-3xl) 0;"
    aria-labelledby="solucoes-heading"
  >
    <div class="container-standard relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        <!-- Left: Text -->
        <div>
          <div class="animate-on-scroll">
            <SectionLabel>Soluções</SectionLabel>
          </div>

          <h2
            id="solucoes-heading"
            class="animate-on-scroll mt-5"
            style="font-size: var(--text-h2); font-weight: 600; line-height: 1.10; letter-spacing: -0.02em; color: var(--text-primary);"
          >
            Soluções
          </h2>

          <p
            class="mt-5 animate-on-scroll"
            style="font-size: var(--text-body-lg); line-height: 1.60; color: var(--text-secondary);"
          >
            Implementação completa de IA na sua empresa. Agentes de atendimento, vendas, automações operacionais e integrações — tudo funcionando e gerando resultado.
          </p>

          <!-- What we build -->
          <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-3 animate-on-scroll">
            <div class="flex items-start gap-3 p-3 rounded-lg" style="background: rgba(74,144,255,0.04); border: 1px solid rgba(74,144,255,0.08);">
              <span style="color: var(--accent-blue); font-size: 18px; line-height: 1;">&#9679;</span>
              <div>
                <p class="font-semibold text-[var(--text-primary)] text-sm">Agentes de suporte</p>
                <p class="text-xs" style="color: var(--text-tertiary);">Atendimento 24/7 que resolve, não enrola</p>
              </div>
            </div>
            <div class="flex items-start gap-3 p-3 rounded-lg" style="background: rgba(74,144,255,0.04); border: 1px solid rgba(74,144,255,0.08);">
              <span style="color: var(--accent-blue); font-size: 18px; line-height: 1;">&#9679;</span>
              <div>
                <p class="font-semibold text-[var(--text-primary)] text-sm">Agentes de vendas</p>
                <p class="text-xs" style="color: var(--text-tertiary);">Qualificação e follow-up automáticos</p>
              </div>
            </div>
            <div class="flex items-start gap-3 p-3 rounded-lg" style="background: rgba(74,144,255,0.04); border: 1px solid rgba(74,144,255,0.08);">
              <span style="color: var(--accent-blue); font-size: 18px; line-height: 1;">&#9679;</span>
              <div>
                <p class="font-semibold text-[var(--text-primary)] text-sm">Automações operacionais</p>
                <p class="text-xs" style="color: var(--text-tertiary);">Processos manuais eliminados</p>
              </div>
            </div>
            <div class="flex items-start gap-3 p-3 rounded-lg" style="background: rgba(74,144,255,0.04); border: 1px solid rgba(74,144,255,0.08);">
              <span style="color: var(--accent-blue); font-size: 18px; line-height: 1;">&#9679;</span>
              <div>
                <p class="font-semibold text-[var(--text-primary)] text-sm">Integrações com IA</p>
                <p class="text-xs" style="color: var(--text-tertiary);">WhatsApp, CRMs, APIs, sistemas internos</p>
              </div>
            </div>
          </div>

          <div class="mt-8 animate-on-scroll">
            <Button variant="primary" href="/systems">
              Conhecer soluções &rarr;
            </Button>
          </div>
        </div>

        <!-- Right: Isometric stack — Systems services -->
        <div class="animate-on-scroll">
          <div style="perspective: 800px; display: flex; justify-content: center; align-items: flex-start; padding-top: 40px;">
            <div style="position: relative; transform-style: preserve-3d; transform: rotateX(6deg) rotateY(-10deg); width: 320px; height: 380px;">

              <!-- Back card: Automações -->
              <div style="position: absolute; top: 0; left: 15px; width: 290px; transform: translateZ(-30px); opacity: 0.5; background: var(--surface-0); border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; padding: 20px; box-shadow: 0 20px 50px rgba(0,0,0,0.3);">
                <p style="font-size: 10px; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;">Automações</p>
                <p style="font-size: 15px; font-weight: 600; margin-top: 6px; color: var(--text-primary);">Processos inteligentes</p>
                <p style="font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 4px;">Operação no automático</p>
              </div>

              <!-- Middle card: Integrações -->
              <div style="position: absolute; top: 30px; left: 8px; width: 290px; transform: translateZ(-15px); opacity: 0.7; background: var(--surface-0); border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; padding: 20px; box-shadow: 0 20px 50px rgba(0,0,0,0.4);">
                <p style="font-size: 10px; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;">Integrações</p>
                <p style="font-size: 15px; font-weight: 600; margin-top: 6px; color: var(--text-primary);">Tudo conectado</p>
                <p style="font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 4px;">WhatsApp, CRMs, APIs</p>
              </div>

              <!-- Front card: Agentes de IA (featured) -->
              <div style="position: absolute; top: 60px; left: 0; width: 290px; transform: translateZ(0); background: var(--surface-1); border: 1px solid rgba(74,144,255,0.15); border-radius: 12px; padding: 24px; box-shadow: 0 24px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(74,144,255,0.08);">
                <p style="font-size: 10px; color: var(--accent-blue); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;">Agentes de IA</p>
                <p style="font-size: 17px; font-weight: 600; margin-top: 8px; color: var(--text-primary);">Vendas + Suporte + Operações</p>
                <p style="font-size: 12px; color: rgba(255,255,255,0.5); margin-top: 6px; line-height: 1.5;">Agentes que qualificam leads, respondem clientes e automatizam tarefas — 24/7.</p>
                <div style="display: flex; gap: 16px; margin-top: 16px; padding-top: 16px; border-top: 1px solid rgba(255,255,255,0.06);">
                  <div>
                    <span style="font-size: 22px; font-weight: 700; color: var(--accent-blue);">+15h</span>
                    <span style="font-size: 10px; color: rgba(255,255,255,0.35); display: block; margin-top: 2px;">por semana</span>
                  </div>
                  <div>
                    <span style="font-size: 22px; font-weight: 700; color: var(--text-primary);">70x</span>
                    <span style="font-size: 10px; color: rgba(255,255,255,0.35); display: block; margin-top: 2px;">mais rápido</span>
                  </div>
                  <div>
                    <span style="font-size: 22px; font-weight: 700; color: #22C55E;">+R$80k</span>
                    <span style="font-size: 10px; color: rgba(255,255,255,0.35); display: block; margin-top: 2px;">receita/mês</span>
                  </div>
                </div>
              </div>

            </div>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ============================================================
       MENTORIAS — Builders (segundo plano)
       ============================================================ -->
  <section
    class="relative overflow-hidden"
    style="background: var(--surface-0); padding: var(--space-3xl) 0;"
    aria-labelledby="mentorias-heading"
  >
    <div class="container-standard relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        <!-- Left: Visual — REIS [IA] Hub mentoria mockup -->
        <div class="animate-on-scroll order-2 lg:order-1">
          <div style="position:relative">
            <div aria-hidden="true" style="position:absolute;inset:-20px;background:radial-gradient(ellipse 60% 50% at 50% 50%,rgba(74,144,255,0.04) 0%,transparent 60%);pointer-events:none"></div>
            <div class="rounded-xl overflow-hidden" style="position:relative;background:var(--surface-1);border:1px solid var(--border-default);box-shadow:0 24px 64px rgba(0,0,0,0.4)">
              <!-- Window chrome -->
              <div class="flex items-center gap-2 px-4 py-3" style="background:var(--surface-0);border-bottom:1px solid var(--border-default)">
                <div class="w-2.5 h-2.5 rounded-full" style="background:#FF5F57"></div>
                <div class="w-2.5 h-2.5 rounded-full" style="background:#FEBC2E"></div>
                <div class="w-2.5 h-2.5 rounded-full" style="background:#28C840"></div>
                <span class="ml-3 text-[10px] font-medium" style="color:var(--text-tertiary)">REIS [IA] Hub — Mentorias</span>
              </div>
              <!-- Sidebar + content -->
              <div class="flex" style="min-height:320px">
                <!-- Sidebar -->
                <div class="hidden sm:block" style="width:160px;background:var(--surface-0);border-right:1px solid var(--border-default);padding:16px 12px">
                  <div class="flex items-center gap-2 p-2 rounded-md mb-1" style="background:rgba(74,144,255,0.08)">
                    <div class="w-1.5 h-1.5 rounded-full" style="background:var(--accent-blue)"></div>
                    <span class="text-[10px] font-medium" style="color:var(--accent-blue)">Mentorias</span>
                  </div>
                  <div class="flex items-center gap-2 p-2 rounded-md mb-1">
                    <div class="w-1.5 h-1.5 rounded-full" style="background:rgba(255,255,255,0.15)"></div>
                    <span class="text-[10px]" style="color:var(--text-tertiary)">Formações</span>
                  </div>
                  <div class="flex items-center gap-2 p-2 rounded-md mb-1">
                    <div class="w-1.5 h-1.5 rounded-full" style="background:rgba(255,255,255,0.15)"></div>
                    <span class="text-[10px]" style="color:var(--text-tertiary)">Comunidade</span>
                  </div>
                  <div class="flex items-center gap-2 p-2 rounded-md">
                    <div class="w-1.5 h-1.5 rounded-full" style="background:rgba(255,255,255,0.15)"></div>
                    <span class="text-[10px]" style="color:var(--text-tertiary)">Progresso</span>
                  </div>
                </div>
                <!-- Main content -->
                <div style="flex:1;padding:16px">
                  <p class="text-[11px] font-semibold mb-3" style="color:var(--text-primary)">Próxima mentoria</p>
                  <div class="p-3 rounded-lg mb-3" style="background:var(--surface-0);border:1px solid var(--border-default)">
                    <div class="flex items-center justify-between">
                      <div>
                        <p class="text-[12px] font-semibold" style="color:var(--text-primary)">Sessão individual</p>
                        <p class="text-[10px] mt-1" style="color:var(--text-tertiary)">Seg, 28 Mar — 14:00</p>
                      </div>
                      <span class="text-[9px] px-2 py-0.5 rounded" style="background:rgba(34,197,94,0.1);color:#22C55E">Confirmada</span>
                    </div>
                  </div>
                  <p class="text-[11px] font-semibold mb-3 mt-4" style="color:var(--text-primary)">Seu progresso</p>
                  <div class="space-y-2">
                    <div class="flex items-center gap-2">
                      <div class="w-full h-1.5 rounded-full" style="background:var(--surface-0)"><div class="h-full rounded-full" style="width:100%;background:#22C55E"></div></div>
                      <span class="text-[9px] whitespace-nowrap" style="color:var(--text-tertiary)">Oferta</span>
                    </div>
                    <div class="flex items-center gap-2">
                      <div class="w-full h-1.5 rounded-full" style="background:var(--surface-0)"><div class="h-full rounded-full" style="width:65%;background:var(--accent-blue)"></div></div>
                      <span class="text-[9px] whitespace-nowrap" style="color:var(--text-tertiary)">Aquisição</span>
                    </div>
                    <div class="flex items-center gap-2">
                      <div class="w-full h-1.5 rounded-full" style="background:var(--surface-0)"><div class="h-full rounded-full" style="width:30%;background:var(--accent-blue)"></div></div>
                      <span class="text-[9px] whitespace-nowrap" style="color:var(--text-tertiary)">Projeto</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Text -->
        <div class="order-1 lg:order-2">
          <div class="animate-on-scroll">
            <SectionLabel>Mentorias</SectionLabel>
          </div>

          <h2
            id="mentorias-heading"
            class="animate-on-scroll mt-5"
            style="font-size: var(--text-h2); font-weight: 600; line-height: 1.10; letter-spacing: -0.02em; color: var(--text-primary);"
          >
            Mentorias
          </h2>

          <p
            class="mt-5 animate-on-scroll"
            style="font-size: var(--text-body-lg); line-height: 1.60; color: var(--text-secondary);"
          >
            Mentoria individual e em grupo com quem já implementou IA em dezenas de empresas. Aprenda a criar, vender e entregar projetos de agentes de IA. Acelere seus resultados com quem já passou pelo caminho.
          </p>

          <div class="mt-8 animate-on-scroll">
            <Button variant="primary" href="/builder">
              Conhecer o Builders &rarr;
            </Button>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ============================================================
       FORMAÇÕES
       ============================================================ -->
  <section
    class="relative overflow-hidden"
    style="background: var(--surface-1); padding: var(--space-3xl) 0;"
    aria-labelledby="formacoes-heading"
  >
    <div class="container-standard relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        <!-- Left: Text -->
        <div>
          <div class="animate-on-scroll">
            <SectionLabel>Formações</SectionLabel>
          </div>

          <h2
            id="formacoes-heading"
            class="animate-on-scroll mt-5"
            style="font-size: var(--text-h2); font-weight: 600; line-height: 1.10; letter-spacing: -0.02em; color: var(--text-primary);"
          >
            Formações
          </h2>

          <p
            class="mt-5 animate-on-scroll"
            style="font-size: var(--text-body-lg); line-height: 1.60; color: var(--text-secondary);"
          >
            Formações completas desenvolvidas para profissionais que querem dominar Inteligência Artificial aplicada aos negócios. Do básico ao especialista, com certificação.
          </p>

          <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-3 animate-on-scroll">
            <div class="p-4 rounded-lg text-center" style="background: var(--surface-0); border: 1px solid var(--border-default);">
              <p class="text-sm font-semibold text-[var(--text-primary)]">Fundamentos</p>
              <p class="text-xs mt-1" style="color: var(--text-tertiary);">IA aplicada do zero</p>
            </div>
            <div class="p-4 rounded-lg text-center" style="background: var(--surface-0); border: 1px solid var(--border-default);">
              <p class="text-sm font-semibold text-[var(--text-primary)]">Avançado</p>
              <p class="text-xs mt-1" style="color: var(--text-tertiary);">Agentes e automações</p>
            </div>
            <div class="p-4 rounded-lg text-center" style="background: var(--surface-0); border: 1px solid var(--border-default);">
              <p class="text-sm font-semibold text-[var(--text-primary)]">Especialista</p>
              <p class="text-xs mt-1" style="color: var(--text-tertiary);">Estratégia + implementação</p>
            </div>
          </div>

          <div class="mt-8 animate-on-scroll">
            <Button variant="primary" href="/agendar">
              Conhecer formações &rarr;
            </Button>
          </div>
        </div>

        <!-- Right: REIS [IA] Hub — Área de Membros mockup -->
        <div class="animate-on-scroll">
          <div class="rounded-xl overflow-hidden" style="background:var(--surface-0);border:1px solid var(--border-default);box-shadow:0 24px 64px rgba(0,0,0,0.4)">
            <div class="flex items-center gap-2 px-4 py-3" style="background:rgba(10,10,15,0.8);border-bottom:1px solid var(--border-default)">
              <div class="w-2.5 h-2.5 rounded-full" style="background:#FF5F57"></div>
              <div class="w-2.5 h-2.5 rounded-full" style="background:#FEBC2E"></div>
              <div class="w-2.5 h-2.5 rounded-full" style="background:#28C840"></div>
              <span class="ml-3 text-[10px] font-medium" style="color:var(--text-tertiary)">REIS [IA] Hub — Área de Membros</span>
            </div>
            <div style="padding:16px">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-8 h-8 rounded-full flex items-center justify-center text-[11px] font-bold" style="background:rgba(74,144,255,0.1);color:var(--accent-blue)">MR</div>
                <div><p class="text-[11px] font-semibold" style="color:var(--text-primary)">Bem-vindo, Moroni</p><p class="text-[9px]" style="color:var(--text-tertiary)">Nível: Especialista</p></div>
              </div>
              <p class="text-[10px] font-semibold mb-2" style="color:var(--text-tertiary);text-transform:uppercase;letter-spacing:0.05em">Suas formações</p>
              <div class="space-y-2">
                <div class="flex items-center gap-3 p-3 rounded-lg" style="background:var(--surface-1);border:1px solid var(--border-default)">
                  <div class="w-10 h-10 rounded-lg flex items-center justify-center text-[14px] font-bold" style="background:rgba(74,144,255,0.08);color:var(--accent-blue)">01</div>
                  <div class="flex-1"><p class="text-[11px] font-semibold" style="color:var(--text-primary)">Fundamentos de IA</p><p class="text-[9px]" style="color:var(--text-tertiary)">12 aulas · 4h</p></div>
                  <span class="text-[9px] px-2 py-0.5 rounded" style="background:rgba(34,197,94,0.1);color:#22C55E">Concluído</span>
                </div>
                <div class="flex items-center gap-3 p-3 rounded-lg" style="background:var(--surface-1);border:1px solid rgba(74,144,255,0.1)">
                  <div class="w-10 h-10 rounded-lg flex items-center justify-center text-[14px] font-bold" style="background:rgba(74,144,255,0.08);color:var(--accent-blue)">02</div>
                  <div class="flex-1"><p class="text-[11px] font-semibold" style="color:var(--text-primary)">Vendas e Prospecção</p><p class="text-[9px]" style="color:var(--text-tertiary)">15 aulas · 5h</p></div>
                  <span class="text-[9px] px-2 py-0.5 rounded" style="background:rgba(74,144,255,0.1);color:var(--accent-blue)">Em progresso</span>
                </div>
                <div class="flex items-center gap-3 p-3 rounded-lg" style="background:var(--surface-1);border:1px solid var(--border-default)">
                  <div class="w-10 h-10 rounded-lg flex items-center justify-center text-[14px] font-bold" style="background:rgba(74,144,255,0.08);color:var(--accent-blue)">03</div>
                  <div class="flex-1"><p class="text-[11px] font-semibold" style="color:var(--text-primary)">Agentes e Automações</p><p class="text-[9px]" style="color:var(--text-tertiary)">18 aulas · 6h</p></div>
                  <span class="text-[9px] px-2 py-0.5 rounded" style="background:rgba(255,255,255,0.05);color:var(--text-tertiary)">Em breve</span>
                </div>
                <div class="flex items-center gap-3 p-3 rounded-lg" style="background:var(--surface-1);border:1px solid var(--border-default)">
                  <div class="w-10 h-10 rounded-lg flex items-center justify-center text-[14px] font-bold" style="background:rgba(255,255,255,0.03);color:var(--text-tertiary)">04</div>
                  <div class="flex-1"><p class="text-[11px] font-semibold" style="color:var(--text-tertiary)">Especialista em IA</p><p class="text-[9px]" style="color:rgba(255,255,255,0.25)">24 aulas · 8h</p></div>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="2" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ============================================================
       COMUNIDADE
       ============================================================ -->
  <section
    class="relative overflow-hidden"
    style="background: var(--surface-0); padding: var(--space-3xl) 0;"
    aria-labelledby="comunidade-heading"
  >
    <!-- Subtle dot grid — fades from center -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
