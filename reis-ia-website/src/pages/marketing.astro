---
/**
 * Marketing — Reis IA Marketing com IA
 * v2.0 [VISUAL UPGRADE — 2026-03-26]
 * HeroGrid background, inline stats, CTA card, dashboard mockup, no AmbientPool/HourglassWatermark
 *
 * ICP: Entrepreneurs, business owners wanting structured marketing + AI demand generation
 * All CTAs → /agendar | Blue #4A90FF accent | NO gold | NO chess | NO pricing tables
 * Visual: Dark mode, premium minimal, Inter font, blue accent
 */
import MainLayout from '../layouts/MainLayout.astro';
import Badge from '../components/Badge.astro';
import Button from '../components/Button.astro';
import SectionLabel from '../components/SectionLabel.astro';
import HeroGrid from '../components/backgrounds/HeroGrid.tsx';
import FaqAccordion from '../components/FaqAccordion.tsx';
import IconTarget from '../components/icons/IconTarget.astro';
import IconTrendingUp from '../components/icons/IconTrendingUp.astro';
import IconZap from '../components/icons/IconZap.astro';
import IconBarChart from '../components/icons/IconBarChart.astro';
import IconCheckCircle from '../components/icons/IconCheckCircle.astro';
import IconWorkflow from '../components/icons/IconWorkflow.astro';
import IconFilter from '../components/icons/IconFilter.astro';
import IconBrain from '../components/icons/IconBrain.astro';
import IconClock from '../components/icons/IconClock.astro';
import IconUsers from '../components/icons/IconUsers.astro';
import IconRocket from '../components/icons/IconRocket.astro';
import IconMail from '../components/icons/IconMail.astro';

const faqItems = [
  {
    question: 'O que é exatamente o que a Reis IA faz em marketing?',
    answer: 'Estruturamos seu processo completo de marketing e vendas com IA — desde a geração de leads até o fechamento. Isso inclui construção de funis, automação de follow-up, produção de conteúdo estratégico e análise de dados. Não vendemos ferramenta. Implementamos o sistema que gera demanda previsível.',
  },
  {
    question: 'Meu negócio ainda não tem processo de marketing. Consigo começar do zero?',
    answer: 'Sim. Na prática, começar do zero é mais fácil. Não tem estrutura antiga pra desconstruir. Começamos pelo diagnóstico — mapeamos seu ICP, seu funil ideal e os canais certos. Depois construímos. Muitos dos nossos clientes saíram de zero leads qualificados para pipeline previsível em 60-90 dias.',
  },
  {
    question: 'Quanto tempo leva pra ver resultado?',
    answer: 'Depende do ponto de partida. Os primeiros leads qualificados aparecem dentro das primeiras semanas de funil ativo. Pipeline previsível — onde você sabe quantos leads vai ter no mês — costuma se consolidar em 60 a 90 dias. Monitoramos KPIs desde o dia 1.',
  },
  {
    question: 'Preciso de um time de marketing pra isso funcionar?',
    answer: 'Não necessariamente. A IA assume as tarefas operacionais — produção de conteúdo em escala, qualificação de leads, sequências de email, análise de dados. Um time pequeno (ou até você mesmo) consegue operar o sistema. O objetivo é que o marketing funcione com menos gente, não mais.',
  },
  {
    question: 'Qual a diferença entre contratar uma agência e trabalhar com a Reis IA?',
    answer: 'Agência terceiriza execução. Nós estruturamos o sistema que gera resultado — e esse sistema fica com você. Não existe dependência de fornecedor. No final, você tem um processo de marketing que roda com IA, de forma autônoma, com você no controle. Olha que diferença: ao invés de pagar mensalmente por execução, você paga uma vez pela estrutura.',
  },
  {
    question: 'Vocês trabalham com qual canal? Instagram, Google, LinkedIn?',
    answer: 'Começa pelo diagnóstico — identificamos onde seu ICP está e qual canal tem o melhor custo por aquisição pra ele. Não existe canal certo no abstrato. Existe canal certo pra cada negócio e público. Depois que está mapeado, construímos a estratégia e automação pra esses canais específicos.',
  },
];

const services = [
  {
    icon: 'filter',
    title: 'Funil de Aquisição IA',
    label: 'Geração e Qualificação de Leads',
    description: 'Atraia leads certos, qualifique automaticamente e entregue pro seu time de vendas só quem tem perfil. Sem desperdiçar hora de vendedor em lead que não vai fechar.',
  },
  {
    icon: 'brain',
    title: 'Conteúdo Estratégico',
    label: 'Atração e Conversão',
    description: 'Conteúdo que não é só postagem — é isca para o ICP certo. IA produz em escala, você aprova a estratégia. Seu canal vira fonte de leads, não de curtidas.',
  },
  {
    icon: 'workflow',
    title: 'Automação de Vendas',
    label: 'Follow-up, Nurturing, Pipeline',
    description: 'Sequências de email, follow-up automático, nutrição de leads frios — tudo rodando sem intervenção manual. Seu pipeline não para quando seu time descansa.',
  },
  {
    icon: 'barchart',
    title: 'Inteligência de Dados',
    label: 'Analytics, Atribuição e Otimização',
    description: 'Sabe exatamente de onde vem cada lead e qual canal tá gerando receita de verdade. IA processa os dados e entrega os insights que mudam suas decisões de alocação.',
  },
];

const iconMap: Record<string, any> = {
  filter: IconFilter,
  brain: IconBrain,
  workflow: IconWorkflow,
  barchart: IconBarChart,
};

const processSteps = [
  {
    phase: '01',
    name: 'Diagnóstico',
    description: 'Mapeamos seu ICP, canais atuais, métricas de funil e onde o marketing está perdendo receita. Um mapa claro antes de qualquer ação.',
  },
  {
    phase: '02',
    name: 'Estratégia',
    description: 'Definimos canais prioritários, oferta de entrada, estrutura de funil e automações. Cada decisão conectada a um resultado mensurável.',
  },
  {
    phase: '03',
    name: 'Implementação',
    description: 'Construímos o sistema — funil, automações, conteúdo, integrações. IA operando cada etapa do processo de aquisição.',
  },
  {
    phase: '04',
    name: 'Otimização',
    description: 'Pipeline ativo. Monitoramos performance, ajustamos com dados reais e escalamos o que funciona. Marketing que melhora sozinho.',
  },
];

const painPoints = [
  {
    icon: 'clock',
    title: 'Tempo desperdiçado sem retorno',
    description: 'Horas em conteúdo que não gera lead. Semanas em campanha que não converte. Meses sem saber de onde vem o cliente.',
  },
  {
    icon: 'target',
    title: 'Leads que não têm perfil',
    description: 'Volume sem qualidade. Time de vendas gasta energia em contatos que nunca iam fechar — e os bons ficam sem atenção.',
  },
  {
    icon: 'zap',
    title: 'Marketing no achismo',
    description: 'Sem dados de atribuição, você não sabe o que funciona. Você continua apostando em canais errados por falta de evidência.',
  },
  {
    icon: 'trending',
    title: 'Crescimento que não escala',
    description: 'Cada novo lead depende de ação manual. Quando o time cresce, o caos cresce junto. Sem sistema, não tem escala.',
  },
];

const painIconMap: Record<string, any> = {
  clock: IconClock,
  target: IconTarget,
  zap: IconZap,
  trending: IconTrendingUp,
};
---

<MainLayout
  title="Marketing IA — Gere Demanda e Feche Mais Vendas | Reis IA"
  description="Estruture seus processos de marketing e vendas com IA. Gere demanda previsível, automatize seu funil e transforme leads em receita — sem depender de achismo."
  activePage="marketing"
>

  <!-- ============================================================
       S1. HERO — Full viewport, HeroGrid background
       ============================================================ -->
  <section
    class="relative overflow-hidden flex items-center justify-center"
    style="background: var(--surface-0); min-height: 100vh; padding: var(--space-2xl) 0;"
    aria-labelledby="marketing-hero-heading"
  >
    <!-- Background: Interactive repel grid -->
    <HeroGrid client:load />

    <!-- Top accent line -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 pointer-events-none" aria-hidden="true" style="width:400px;height:1px;background:linear-gradient(90deg,transparent,rgba(74,144,255,0.15) 50%,transparent);"></div>

    <!-- Radial glow behind content -->
    <div
      class="absolute pointer-events-none"
      aria-hidden="true"
      style="top: 45%; left: 50%; transform: translate(-50%, -50%); width: 800px; height: 800px; background: radial-gradient(circle, rgba(74,144,255,0.06) 0%, rgba(74,144,255,0.02) 40%, transparent 65%); filter: blur(40px);"
    ></div>

    <!-- Hero content -->
    <div class="container-standard relative z-10">
      <div class="max-w-[900px] mx-auto text-center">

        <!-- Badge -->
        <div class="hero-animate hero-animate-1 flex justify-center mb-6">
          <Badge>Marketing IA</Badge>
        </div>

        <!-- H1 -->
        <h1
          id="marketing-hero-heading"
          class="hero-animate hero-animate-2"
          style="font-size: clamp(2.8rem, 1.5rem + 5vw, 5.5rem); font-weight: 700; line-height: 1.0; letter-spacing: -0.03em; color: var(--text-primary);"
        >
          Marketing que Gera Demanda.
          <br />
          <span style="color: var(--accent-blue);">IA que Fecha Vendas.</span>
        </h1>

        <!-- Subtitle -->
        <p
          class="hero-animate hero-animate-3 mt-6"
          style="font-size: var(--text-body-lg); line-height: 1.65; color: var(--text-secondary); max-width: 680px; margin-left: auto; margin-right: auto; letter-spacing: 0.01em;"
        >
          Estruture seus processos de marketing e vendas com IA. Gere demanda previsível, automatize seu funil e transforme leads em receita — sem depender de achismo.
        </p>

        <!-- CTA -->
        <div
          class="hero-animate hero-animate-4 mt-10"
          style="display: flex; align-items: center; justify-content: center;"
        >
          <Button variant="hero" href="#cta-marketing">
            Gerar demanda previsível &rarr;
          </Button>
          </a>
        </div>

      </div>
    </div>
  </section>


  <!-- ============================================================
       S2. PROBLEMA — Surface-1
       Pain amplification. 4 cards with icons.
       ============================================================ -->
  <section
    class="relative overflow-hidden"
    style="background: var(--surface-1); padding: var(--space-3xl) 0;"
    aria-labelledby="marketing-problem-heading"
  >
    <div class="container-standard relative z-10">
      <SectionLabel>O Problema</SectionLabel>

      <h2
        id="marketing-problem-heading"
        class="mt-6 text-reveal"
        style="font-weight: 600; letter-spacing: -0.015em; max-width: 720px;"
      >
        Seu marketing funciona no manual. E no achismo.
      </h2>

      <p class="mt-6 animate-on-scroll" style="font-size: var(--text-body-lg); line-height: 1.70; color: var(--text-secondary); max-width: var(--container-text); letter-spacing: 0.01em;">
        A maioria dos negócios investe tempo e dinheiro em marketing sem ter um processo estruturado. Resultado: gasto sem retorno mensurável, leads que não convertem e um time de vendas que não sabe de onde vem o próximo cliente.
      </p>

      <p class="mt-4 animate-on-scroll" style="line-height: 1.70; color: var(--text-secondary); max-width: var(--container-text); letter-spacing: 0.01em;">
        Na prática: você sabe que precisa de marketing, mas não sabe o que tá funcionando. Cada mês é um experimento novo, sem base de dados pra decidir com clareza.
      </p>

      <!-- Pain point cards -->
      <div
        class="mt-12 grid-stagger"
        style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1px; background: var(--border-default); border: 1px solid var(--border-default); border-radius: var(--radius-xl); overflow: hidden;"
      >
        {painPoints.map((point) => {
          const PainIcon = painIconMap[point.icon];
          return (
            <div class="card-item" style="background: var(--surface-1); padding: 28px 24px;">
              <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 14px;">
                <div
                  style="width: 36px; height: 36px; border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; background: var(--surface-3); border: 1px solid var(--border-subtle); flex-shrink: 0;"
                >
                  <PainIcon size={16} class="icon-muted" />
                </div>
                <h3 style="font-size: var(--text-h5); font-weight: 600; color: var(--text-primary); margin: 0;">{point.title}</h3>
              </div>
              <p style="font-size: var(--text-body-sm); line-height: 1.65; color: var(--text-secondary); margin: 0;">{point.description}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>


  <!-- ============================================================
       S3. SOLUÇÃO — Surface-0
       4 service cards + REIS [IA] Hub Marketing dashboard mockup
       ============================================================ -->
  <section
    class="relative overflow-hidden"
    style="background: var(--surface-0); padding: var(--space-3xl) 0;"
    aria-labelledby="marketing-solution-heading"
  >
    <div class="container-standard relative z-10">
      <SectionLabel>A Solução</SectionLabel>

      <!-- Two-column: text + dashboard mockup -->
      <div class="mt-6 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">

        <!-- Left: copy -->
        <div>
          <h2
            id="marketing-solution-heading"
            class="animate-on-scroll"
            style="font-weight: 600; letter-spacing: -0.015em;"
          >
            Marketing estruturado. Vendas automatizadas. Receita previsível.
          </h2>

          <p class="mt-6 animate-on-scroll" style="font-size: var(--text-body-lg); line-height: 1.70; color: var(--text-secondary); letter-spacing: 0.01em;">
            Não é mais um conjunto de táticas desconexas. É um sistema onde cada peça se conecta à próxima — da atração ao fechamento — com IA operando as partes que não precisam de você.
          </p>
        </div>

        <!-- Right: REIS [IA] Hub Marketing dashboard mockup -->
        <div class="animate-on-scroll">
          <div class="mkt-mockup-window" aria-label="REIS [IA] Hub — Marketing dashboard preview">
            <!-- Window chrome -->
            <div class="mkt-mockup-chrome">
              <div class="mkt-mockup-dots" aria-hidden="true">
                <span></span><span></span><span></span>
              </div>
              <span class="mkt-mockup-title">REIS [IA] Hub — Marketing</span>
            </div>
            <!-- Funnel visualization -->
            <div class="mkt-mockup-body">
              <p class="mkt-mockup-label">Funil de Aquisição — últimos 30 dias</p>
              <div class="mkt-funnel">
                <div class="mkt-funnel-row">
                  <span class="mkt-funnel-stage">Visitantes</span>
                  <div class="mkt-funnel-bar-wrap">
                    <div class="mkt-funnel-bar" style="width: 100%; background: rgba(74,144,255,0.18); border-color: rgba(74,144,255,0.3);">
                      <span class="mkt-funnel-value">12.400</span>
                    </div>
                  </div>
                </div>
                <div class="mkt-funnel-row">
                  <span class="mkt-funnel-stage">Leads</span>
                  <div class="mkt-funnel-bar-wrap">
                    <div class="mkt-funnel-bar" style="width: 68%; background: rgba(74,144,255,0.22); border-color: rgba(74,144,255,0.35);">
                      <span class="mkt-funnel-value">2.800</span>
                    </div>
                  </div>
                </div>
                <div class="mkt-funnel-row">
                  <span class="mkt-funnel-stage">Qualificados</span>
                  <div class="mkt-funnel-bar-wrap">
                    <div class="mkt-funnel-bar" style="width: 44%; background: rgba(74,144,255,0.28); border-color: rgba(74,144,255,0.4);">
                      <span class="mkt-funnel-value">890</span>
                    </div>
                  </div>
                </div>
                <div class="mkt-funnel-row">
                  <span class="mkt-funnel-stage">Clientes</span>
                  <div class="mkt-funnel-bar-wrap">
                    <div class="mkt-funnel-bar" style="width: 22%; background: rgba(52,211,153,0.18); border-color: rgba(52,211,153,0.35);">
                      <span class="mkt-funnel-value" style="color: #34d399;">124</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>

      <!-- Service cards grid -->
      <div
        class="mt-14 grid-stagger"
        style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1px; background: var(--border-default); border: 1px solid var(--border-default); border-radius: var(--radius-xl); overflow: hidden;"
      >
        {services.map((service) => {
          const ServiceIcon = iconMap[service.icon];
          return (
            <div class="card-interactive" style="background: var(--surface-0); padding: 32px 28px; cursor: default;">
              <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
                <div
                  style="width: 40px; height: 40px; border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, rgba(74,144,255,0.12), rgba(74,144,255,0.04)); border: 1px solid rgba(74,144,255,0.2); flex-shrink: 0;"
                >
                  <ServiceIcon size={18} class="text-[var(--accent-blue)]" />
                </div>
              </div>
              <p style="font-size: var(--text-label); font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; color: var(--accent-blue); margin: 0 0 8px;">{service.label}</p>
              <h3 style="font-size: var(--text-h4); font-weight: 600; color: var(--text-primary); margin: 0 0 12px; letter-spacing: -0.01em;">{service.title}</h3>
              <p style="font-size: var(--text-body-sm); line-height: 1.65; color: var(--text-secondary); margin: 0;">{service.description}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>


  <!-- ============================================================
       S4. PROCESSO — Surface-1, id="processo"
       4-step process with numbered steps.
       ============================================================ -->
  <section
    id="processo"
    class="relative overflow-hidden"
    style="background: var(--surface-1); padding: var(--space-3xl) 0;"
    aria-labelledby="marketing-process-heading"
  >
    <div class="container-standard relative z-10">
      <SectionLabel>Como Funciona</SectionLabel>

      <h2
        id="marketing-process-heading"
        class="mt-6 animate-on-scroll"
        style="font-weight: 600; letter-spacing: -0.015em; max-width: 700px;"
      >
        Do caos ao sistema. Em quatro etapas.
      </h2>

      <p class="mt-6 animate-on-scroll" style="font-size: var(--text-body-lg); line-height: 1.70; color: var(--text-secondary); max-width: var(--container-text); letter-spacing: 0.01em;">
        Cada etapa existe por um motivo. Não pulamos nenhuma. Diagnóstico sem estratégia é desperdício. Estratégia sem implementação é plano de gaveta. Implementação sem otimização é custo fixo.
      </p>

      <!-- Process steps — vertical timeline feel -->
      <div class="mt-14 grid-stagger" style="display: flex; flex-direction: column; gap: 1px; background: var(--border-default); border: 1px solid var(--border-default); border-radius: var(--radius-xl); overflow: hidden;">
        {processSteps.map((step, i) => (
          <div
            class="card-item"
            style="background: var(--surface-1); padding: 32px 36px; display: grid; grid-template-columns: auto 1fr; gap: 32px; align-items: start;"
          >
            <!-- Step number -->
            <div style="display: flex; flex-direction: column; align-items: center; gap: 0;">
              <span
                style={`font-size: 2.5rem; font-weight: 700; line-height: 1; letter-spacing: -0.03em; font-variant-numeric: tabular-nums; ${i === 0 ? 'color: var(--accent-blue);' : 'color: var(--text-quaternary);'}`}
              >
                {step.phase}
              </span>
            </div>
            <!-- Step content -->
            <div>
              <h3 style="font-size: var(--text-h4); font-weight: 600; color: var(--text-primary); margin: 0 0 10px; letter-spacing: -0.01em;">
                {step.name}
              </h3>
              <p style="font-size: var(--text-body-sm); line-height: 1.65; color: var(--text-secondary); margin: 0;">
                {step.description}
              </p>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div class="mt-10 animate-on-scroll" style="display: flex; flex-wrap: wrap; align-items: center; gap: 16px;">
        <Button variant="primary" href="/agendar" size="lg">Agendar uma conversa</Button>
      </div>
    </div>
  </section>


  <!-- ============================================================
       S5. RESULTADOS / STATS — Surface-0
       Inline horizontal stats (same pattern as home)
       ============================================================ -->
  <section
    class="relative overflow-hidden"
    style="background: var(--surface-0); padding: var(--space-3xl) 0;"
    aria-labelledby="marketing-stats-heading"
  >
    <div class="container-standard relative z-10">
      <SectionLabel>Resultados</SectionLabel>

      <h2
        id="marketing-stats-heading"
        class="mt-6 animate-on-scroll"
        style="font-weight: 600; letter-spacing: -0.015em; max-width: 680px;"
      >
        Números de quem estruturou o processo.
      </h2>

      <p class="mt-6 animate-on-scroll" style="font-size: var(--text-body-lg); line-height: 1.70; color: var(--text-secondary); max-width: var(--container-text); letter-spacing: 0.01em;">
        Não são estimativas de mercado. São resultados de quem saiu do marketing no achismo e passou a operar com sistema e IA.
      </p>

      <!-- Inline horizontal stats -->
      <div class="mt-14 animate-on-scroll">
        <div class="flex flex-wrap justify-center gap-12 sm:gap-16 lg:gap-24">
          <div class="text-center">
            <p class="font-bold tabular-nums" style="font-size:clamp(2.5rem,1.5rem+3vw,4rem);color:var(--accent-blue);letter-spacing:-0.02em;line-height:1">+340%</p>
            <p class="text-sm mt-2" style="color:var(--text-tertiary)">aumento médio em leads</p>
          </div>
          <div class="text-center">
            <p class="font-bold tabular-nums" style="font-size:clamp(2.5rem,1.5rem+3vw,4rem);color:var(--text-primary);letter-spacing:-0.02em;line-height:1">-40%</p>
            <p class="text-sm mt-2" style="color:var(--text-tertiary)">custo por aquisição de cliente</p>
          </div>
          <div class="text-center">
            <p class="font-bold tabular-nums" style="font-size:clamp(2.5rem,1.5rem+3vw,4rem);color:var(--text-primary);letter-spacing:-0.02em;line-height:1">+60%</p>
            <p class="text-sm mt-2" style="color:var(--text-tertiary)">taxa de conversão do funil</p>
          </div>
          <div class="text-center">
            <p class="font-bold tabular-nums" style="font-size:clamp(2.5rem,1.5rem+3vw,4rem);color:var(--text-primary);letter-spacing:-0.02em;line-height:1">15h</p>
            <p class="text-sm mt-2" style="color:var(--text-tertiary)">economizadas por semana</p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================================
       S6.5. CTA CARD — Surface-0
       Before FAQ: blue-border card with checkmarks
       ============================================================ -->
  <section
    id="cta-marketing"
    class="relative overflow-hidden"
    style="background: var(--surface-0); padding: var(--space-3xl) 0;"
  >
    <div class="container-standard relative z-10">
      <div class="animate-on-scroll rounded-2xl overflow-hidden" style="background: var(--surface-1); border: 1px solid rgba(74,144,255,0.15); max-width: 900px; margin: 0 auto;">
        <div class="grid grid-cols-1 lg:grid-cols-5">
          <!-- Left: copy -->
          <div class="lg:col-span-3 p-8 lg:p-10">
            <p style="font-size: 11px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--accent-blue); margin: 0 0 16px;">Comece agora</p>
            <h2 style="font-size: var(--text-h3); font-weight: 600; line-height: 1.12; letter-spacing: -0.02em; margin: 0 0 16px;">
              Seu marketing pode gerar 3x mais demanda.
            </h2>
            <p style="font-size: var(--text-body); line-height: 1.60; color: var(--text-secondary); margin: 0 0 24px;">
              Em 30 minutos mapeamos onde seu funil está perdendo receita — e o que fazer pra mudar isso.
            </p>
            <Button variant="primary" href="/agendar">
              Conhecer agora &rarr;
            </Button>
          </div>
          <!-- Right: checkmarks -->
          <div class="lg:col-span-2 p-8 lg:p-10 flex flex-col justify-center gap-5" style="background: rgba(74,144,255,0.03); border-left: 1px solid rgba(74,144,255,0.08);">
            <div class="flex items-start gap-3">
              <svg class="flex-shrink-0 mt-0.5" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4A90FF" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              <p style="font-size: 13px; color: var(--text-secondary); margin: 0;">Funil completo de aquisição</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="flex-shrink-0 mt-0.5" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4A90FF" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              <p style="font-size: 13px; color: var(--text-secondary); margin: 0;">IA que qualifica automaticamente</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="flex-shrink-0 mt-0.5" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4A90FF" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              <p style="font-size: 13px; color: var(--text-secondary); margin: 0;">Conteúdo em escala com IA</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="flex-shrink-0 mt-0.5" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4A90FF" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              <p style="font-size: 13px; color: var(--text-secondary); margin: 0;">Dashboard em tempo real</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================================
       S6. PARA QUEM É — Surface-1
       Two columns: "Para quem é" / "Para quem NÃO é"
       ============================================================ -->
  <section
    class="relative overflow-hidden"
    style="background: var(--surface-1); padding: var(--space-3xl) 0;"
    aria-labelledby="marketing-forwhom-heading"
  >
    <div class="container-standard relative z-10">
      <SectionLabel>Qualificação</SectionLabel>

      <h2
        id="marketing-forwhom-heading"
        class="mt-6 animate-on-scroll"
        style="font-weight: 600; letter-spacing: -0.015em; max-width: 640px;"
      >
        Para quem é — e para quem não é.
      </h2>

      <p class="mt-6 animate-on-scroll" style="font-size: var(--text-body-lg); line-height: 1.70; color: var(--text-secondary); max-width: var(--container-text); letter-spacing: 0.01em;">
        Não trabalhamos com todo mundo. Se você não se encaixa no perfil abaixo, esse não é o momento certo. Sem problema — e sem perda de tempo pra você.
      </p>

      <div
        class="mt-12 grid-stagger mkt-qual-grid"
        style="display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--border-default); border: 1px solid var(--border-default); border-radius: var(--radius-xl); overflow: hidden;"
      >
        <!-- Para quem É -->
        <div class="card-item" style="background: var(--surface-1); padding: 36px 32px;">
          <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 24px;">
            <div style="width: 8px; height: 8px; border-radius: 50%; background: #34d399; flex-shrink: 0;"></div>
            <h3 style="font-size: var(--text-h5); font-weight: 600; color: var(--text-primary); margin: 0;">Para quem é</h3>
          </div>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 14px;">
            {[
              'Empreendedor ou dono de negócio que quer gerar demanda de forma previsível',
              'Empresa que tem produto ou serviço validado e quer crescer com estrutura',
              'Negócio que investe em marketing mas não sabe o que tá funcionando de verdade',
              'Fundador que quer parar de depender de indicação e criar um funil que gera lead',
              'Time de marketing que precisa de processos e IA pra operar em escala',
            ].map((item) => (
              <li style="display: flex; align-items: flex-start; gap: 10px;">
                <IconCheckCircle size={16} class="text-[#34d399] flex-shrink-0 mt-0.5" />
                <span style="font-size: var(--text-body-sm); line-height: 1.60; color: var(--text-secondary);">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Para quem NÃO é -->
        <div class="card-item" style="background: var(--surface-1); padding: 36px 32px;">
          <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 24px;">
            <div style="width: 8px; height: 8px; border-radius: 50%; background: rgba(255,100,100,0.7); flex-shrink: 0;"></div>
            <h3 style="font-size: var(--text-h5); font-weight: 600; color: var(--text-primary); margin: 0;">Para quem não é</h3>
          </div>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 14px;">
            {[
              'Quem ainda não tem produto ou serviço funcionando pra vender',
              'Quem busca fórmula mágica que gera resultado sem processo',
              'Quem quer delegar tudo e não participar das decisões de estratégia',
              'Quem não tem budget pra colocar marketing em funcionamento',
              'Quem já tentou estruturar e não quer mudar a forma como faz as coisas',
            ].map((item) => (
              <li style="display: flex; align-items: flex-start; gap: 10px;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(255,100,100,0.7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="flex-shrink-0 mt-0.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                <span style="font-size: var(--text-body-sm); line-height: 1.60; color: var(--text-secondary);">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================================
       S7. FAQ — Surface-1
       FaqAccordion React island
       ============================================================ -->
  <section
    class="relative overflow-hidden"
    style="background: var(--surface-1); padding: var(--space-3xl) 0;"
    aria-labelledby="marketing-faq-heading"
  >
    <div class="container-text relative z-10">
      <SectionLabel>Perguntas Frequentes</SectionLabel>

      <h2
        id="marketing-faq-heading"
        class="mt-6 animate-on-scroll"
        style="font-weight: 600; letter-spacing: -0.015em; max-width: 640px;"
      >
        Dúvidas que aparecem antes de começar.
      </h2>

      <div class="mt-12 animate-on-scroll">
        <FaqAccordion items={faqItems} client:visible />
      </div>
    </div>
  </section>


  <!-- ============================================================
       S8. CTA FINAL — Surface-0
       Subtle radial glow, strong close.
       ============================================================ -->
  <section
    class="relative overflow-hidden"
    style="background: var(--surface-0); padding: var(--space-4xl) 0;"
    aria-labelledby="marketing-cta-heading"
  >
    <!-- Radial glow centered -->
    <div
      class="absolute pointer-events-none"
      aria-hidden="true"
      style="top: 50%; left: 50%; transform: translate(-50%, -50%); width: 700px; height: 700px; background: radial-gradient(circle, rgba(74,144,255,0.07) 0%, rgba(74,144,255,0.03) 40%, transparent 65%); filter: blur(60px);"
    ></div>

    <div class="container-text relative z-10 text-center">

      <h2
        id="marketing-cta-heading"
        class="animate-on-scroll"
        style="font-weight: 600; letter-spacing: -0.02em; max-width: 700px; margin: 0 auto;"
      >
        Seu marketing pode gerar demanda previsível. Vamos construir isso.
      </h2>

      <p
        class="mt-6 animate-on-scroll"
        style="font-size: var(--text-body-lg); line-height: 1.65; color: var(--text-secondary); max-width: 560px; margin: 0 auto; letter-spacing: 0.01em;"
      >
        30 minutos. Sem pitch de ferramenta. Você sai com um mapa claro de onde seu marketing está deixando receita na mesa — e o que fazer pra mudar isso.
      </p>

      <div class="mt-10 animate-on-scroll" style="display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 16px;">
        <Button variant="hero" href="/agendar">
          Agendar uma conversa
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
        </Button>
      </div>

    </div>
  </section>

</MainLayout>

