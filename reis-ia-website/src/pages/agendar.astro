---
/**
 * /agendar — Conversational Lead Qualification + Booking
 * Standalone page — no main nav, no footer. Just logo + progress + chat.
 */
export const prerender = false;

const source = Astro.url.searchParams.get('source') ?? 'typebot-agendar';
const isBuilders = source === 'builders';
const defaultIntro = isBuilders
  ? 'Opa! Que bom que se interessou pelo Builders. Vou te fazer algumas perguntas rápidas pra entender seu momento e como podemos te ajudar a lucrar com IA. Qual é o seu nome?'
  : undefined;
const apiSource = isBuilders ? 'typebot-aplicar' : 'typebot-agendar';

import LeadTypebot from '../components/LeadTypebot';
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{isBuilders ? "Aplicar para Builders | REIS [IA]" : "Agendar | REIS [IA]"}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body {
      height: 100%;
      background: #050508;
      color: #fff;
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    :root {
      --surface-0: #050508;
      --surface-1: #0a0a0f;
      --surface-2: #0e0e15;
      --accent-blue: #4A90FF;
      --text-primary: #FFFFFF;
      --text-secondary: rgba(255,255,255,0.6);
      --text-tertiary: rgba(255,255,255,0.35);
      --border-default: rgba(255,255,255,0.06);
    }
    .page {
      display: flex;
      flex-direction: column;
      height: 100vh;
      overflow: hidden;
    }
    .topbar {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 24px;
      border-bottom: 1px solid var(--border-default);
      background: var(--surface-0);
    }
    .logo {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      color: var(--text-primary);
    }
    .logo-text {
      font-size: 14px;
      font-weight: 300;
      letter-spacing: -0.02em;
      color: var(--text-primary);
    }
    .context-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
    }
    .chat-area {
      flex: 1;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      padding: 0 24px 24px;
    }
    .chat-inner {
      flex: 1;
      max-width: 600px;
      width: 100%;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      position: relative;
    }
    :global(.typebot-input::placeholder) {
      color: rgba(255,255,255,0.25);
    }
  </style>
</head>
<body>
  <div class="page">
    <!-- Top bar: logo + hourglass + context -->
    <div class="topbar">
      <a href="/" class="logo" aria-label="REIS IA — Voltar ao início">
        <!-- H1-B Hourglass (same as Nav) -->
        <svg width="24" height="24" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent-blue);">
          <line x1="14" y1="8" x2="50" y2="8" />
          <line x1="50" y1="8" x2="14" y2="56" />
          <line x1="14" y1="8" x2="25" y2="25" />
          <line x1="39" y1="39" x2="50" y2="56" />
          <line x1="14" y1="56" x2="50" y2="56" />
        </svg>
        <span class="logo-text">REIS IA</span>
      </a>
      <span class="context-label">
        {isBuilders ? 'Aplicação · Builders' : 'Sessão Estratégica'}
      </span>
    </div>

    <!-- Chat -->
    <div class="chat-area">
      <div class="chat-inner">
        <LeadTypebot
          client:load
          source={apiSource}
          defaultIntro={defaultIntro}
        />
      </div>
    </div>
  </div>
</body>
</html>
