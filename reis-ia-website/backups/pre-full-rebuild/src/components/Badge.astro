---
interface Props {
  variant?: 'accent' | 'neutral' | 'recommended';
  class?: string;
}

const { variant = 'neutral', class: className = '' } = Astro.props;

const variantClasses = {
  accent: 'bg-accent/10 border border-accent/20 text-accent',
  neutral: 'bg-neutral-800/60 border border-neutral-700 text-neutral-400',
  recommended: 'bg-accent/10 border border-accent/30 text-accent',
};
---

<span class={`inline-block text-xs font-semibold tracking-widest uppercase px-3 py-1 rounded ${variantClasses[variant]} ${className}`}>
  <slot />
</span>
