---
import MainLayout from '../layouts/MainLayout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import Badge from '../components/Badge.astro';
import IconTarget from '../components/icons/IconTarget.astro';
import IconTrendingUp from '../components/icons/IconTrendingUp.astro';
import IconCheckCircle from '../components/icons/IconCheckCircle.astro';
import IconShield from '../components/icons/IconShield.astro';
---

<MainLayout
  title="Agende Sua Sessão Estratégica | Reis IA"
  description="30 minutos. Sem pitch. Um mapa claro de onde AI gera receita no seu negócio. Agende sua sessão estratégica de Revenue com AI gratuita."
  activePage="home"
>

  <!-- PAGE HEADER -->
  <section
    class="relative overflow-hidden"
    style="background-color: #080808; padding: 120px 0 64px;"
  >
    <!-- Radial glow -->
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse 70% 50% at 50% -10%, rgba(201, 168, 76, 0.10) 0%, transparent 65%);"
    ></div>

    <div class="relative z-10 mx-auto max-w-[1200px] px-5 md:px-8 lg:px-0">
      <div class="hero-animate hero-animate-1">
        <Badge variant="accent">Sessão Gratuita</Badge>
      </div>
      <h1
        class="hero-animate hero-animate-2 mt-5 max-w-[760px]"
        style="font-size: clamp(32px, 5vw, 60px); font-weight: 700; line-height: 1.05; letter-spacing: -0.03em; color: #ffffff;"
      >
        Agende Sua Sessão Estratégica de Revenue com AI
      </h1>
      <p
        class="hero-animate hero-animate-3 mt-5 max-w-[560px]"
        style="font-size: clamp(16px, 1.8vw, 18px); font-weight: 400; line-height: 1.7; color: rgba(255,255,255,0.55);"
      >
        30 minutos. Sem pitch. Um mapa claro de onde AI gera receita no seu negócio.
      </p>
    </div>
  </section>

  <!-- MAIN CONTENT: What to expect + Calendar -->
  <section style="background-color: #080808; padding: 0 0 96px;">
    <div class="mx-auto max-w-[1200px] px-5 md:px-8 lg:px-0">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">

        <!-- LEFT: What to expect -->
        <div class="lg:col-span-5 reveal">
          <h2
            class="text-xl font-semibold mb-6"
            style="color: #ffffff; letter-spacing: -0.01em;"
          >
            O que acontece na sessão:
          </h2>

          <ul class="space-y-5" role="list">
            <li class="flex items-start gap-4">
              <span
                class="flex-shrink-0 w-9 h-9 rounded-lg flex items-center justify-center mt-0.5"
                style="background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.2);"
                aria-hidden="true"
              >
                <IconTarget size={18} class="text-accent" />
              </span>
              <div>
                <p class="text-sm font-medium" style="color: #ffffff;">Análise do seu modelo de negócio atual</p>
                <p class="text-sm mt-1 leading-relaxed" style="color: rgba(255,255,255,0.45);">Entendemos seu negócio, seus processos e onde estão as maiores alavancas de crescimento.</p>
              </div>
            </li>

            <li class="flex items-start gap-4">
              <span
                class="flex-shrink-0 w-9 h-9 rounded-lg flex items-center justify-center mt-0.5"
                style="background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.2);"
                aria-hidden="true"
              >
                <IconTrendingUp size={18} class="text-accent" />
              </span>
              <div>
                <p class="text-sm font-medium" style="color: #ffffff;">Mapeamento de oportunidades de AI com impacto direto em receita</p>
                <p class="text-sm mt-1 leading-relaxed" style="color: rgba(255,255,255,0.45);">Identificamos onde AI gera retorno mensurável — não onde parece impressionante.</p>
              </div>
            </li>

            <li class="flex items-start gap-4">
              <span
                class="flex-shrink-0 w-9 h-9 rounded-lg flex items-center justify-center mt-0.5"
                style="background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.2);"
                aria-hidden="true"
              >
                <IconCheckCircle size={18} class="text-accent" />
              </span>
              <div>
                <p class="text-sm font-medium" style="color: #ffffff;">Recomendações práticas e próximos passos claros</p>
                <p class="text-sm mt-1 leading-relaxed" style="color: rgba(255,255,255,0.45);">Você sai com um caminho concreto — não um slide deck genérico sobre o futuro da AI.</p>
              </div>
            </li>

            <li class="flex items-start gap-4">
              <span
                class="flex-shrink-0 w-9 h-9 rounded-lg flex items-center justify-center mt-0.5"
                style="background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.2);"
                aria-hidden="true"
              >
                <IconShield size={18} class="text-accent" />
              </span>
              <div>
                <p class="text-sm font-medium" style="color: #ffffff;">Sem compromisso — a sessão é gratuita</p>
                <p class="text-sm mt-1 leading-relaxed" style="color: rgba(255,255,255,0.45);">Sem pitch, sem pressão de venda. Se fizer sentido seguir em frente, conversamos sobre isso.</p>
              </div>
            </li>
          </ul>

          <!-- Session badges -->
          <div class="flex flex-wrap gap-3 mt-8">
            <span
              class="inline-flex items-center gap-2 text-sm font-medium px-4 py-2 rounded-full"
              style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.7);"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color: #C9A84C;"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              30 minutos
            </span>
            <span
              class="inline-flex items-center gap-2 text-sm font-medium px-4 py-2 rounded-full"
              style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.7);"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color: #C9A84C;"><path d="M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14"/><rect x="3" y="6" width="12" height="12" rx="2"/></svg>
              Online via Google Meet
            </span>
          </div>
        </div>

        <!-- RIGHT: Cal.com embed area -->
        <div class="lg:col-span-7 reveal">
          <div
            class="rounded-2xl overflow-hidden"
            style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08);"
          >
            <!-- Cal.com Embed — uncomment when Cal.com account is configured:
            <div
              id="cal-embed"
              data-cal-link="moroni-reis/revenue-assessment"
              data-cal-config='{"layout":"month_view","theme":"dark"}'
            ></div>
            <script src="https://app.cal.com/embed/embed.js" async></script>
            -->

            <!-- Placeholder embed area -->
            <div
              class="flex flex-col items-center justify-center text-center placeholder-content"
              style="min-height: 480px; padding: 48px 32px; border: 2px dashed rgba(201,168,76,0.2); border-radius: 14px; margin: 16px;"
            >
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color: rgba(201,168,76,0.4); margin-bottom: 20px;"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <p class="text-base font-medium mb-2" style="color: rgba(255,255,255,0.5);">Calendário de agendamento será integrado aqui</p>
              <p class="text-sm" style="color: rgba(255,255,255,0.25);">Cal.com embed — disponível em breve</p>
            </div>
          </div>

          <!-- WhatsApp fallback CTA -->
          <div
            class="mt-6 rounded-xl p-6 text-center"
            style="background: rgba(37,211,102,0.07); border: 1px solid rgba(37,211,102,0.18);"
          >
            <p class="text-sm font-medium mb-4" style="color: rgba(255,255,255,0.6);">
              Enquanto o calendário online não está disponível, agende pelo WhatsApp:
            </p>
            <a
              href="https://wa.me/XXXXXXXXXXX?text=Ol%C3%A1!%20Gostaria%20de%20agendar%20uma%20sess%C3%A3o%20estrat%C3%A9gica%20de%20Revenue%20com%20AI."
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-3 font-semibold px-8 py-4 rounded-lg transition-all duration-200"
              style="background: #25D366; color: #000000; font-size: 15px;"
              onmouseover="this.style.backgroundColor='#22C55E'; this.style.transform='translateY(-1px)'; this.style.boxShadow='0 8px 24px rgba(37,211,102,0.3)';"
              onmouseout="this.style.backgroundColor='#25D366'; this.style.transform='translateY(0)'; this.style.boxShadow='none';"
            >
              <!-- WhatsApp icon -->
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Agendar pelo WhatsApp
            </a>
            <p class="text-xs mt-3" style="color: rgba(255,255,255,0.25);"><!-- Replace XXXXXXXXXXX with the real WhatsApp number --></p>
          </div>
        </div>
      </div>

      <!-- Trust signals -->
      <div class="flex flex-wrap justify-center gap-3 mt-16 reveal">
        <span
          class="inline-flex items-center text-xs font-medium px-4 py-2 rounded-full"
          style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); color: rgba(255,255,255,0.5); letter-spacing: 0.04em;"
        >
          Mais de 50 implementações de AI
        </span>
        <span
          class="inline-flex items-center text-xs font-medium px-4 py-2 rounded-full"
          style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); color: rgba(255,255,255,0.5); letter-spacing: 0.04em;"
        >
          Revenue-First Framework
        </span>
        <span
          class="inline-flex items-center text-xs font-medium px-4 py-2 rounded-full"
          style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); color: rgba(255,255,255,0.5); letter-spacing: 0.04em;"
        >
          Resultados em 60 dias
        </span>
      </div>
    </div>
  </section>

</MainLayout>
