---
import MainLayout from '../layouts/MainLayout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import Badge from '../components/Badge.astro';
import ChessKnightIcon from '../components/ChessKnightIcon.astro';
---

<MainLayout
  title="Candidate-se ao Builder | Reis IA"
  description="O programa Reis IA Builder para donos de agência que querem adicionar AI como linha de receita em 12 semanas. Candidate-se à próxima turma."
  activePage="builder"
>

  <!-- PAGE HEADER -->
  <section
    class="relative overflow-hidden"
    style="background-color: #080808; padding: 120px 0 64px;"
  >
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse 70% 50% at 50% -10%, rgba(201, 168, 76, 0.10) 0%, transparent 65%);"
    ></div>

    <div class="relative z-10 mx-auto max-w-[1200px] px-5 md:px-8 lg:px-0">
      <div class="flex items-center gap-3 hero-animate hero-animate-1">
        <Badge variant="accent">Vagas limitadas</Badge>
      </div>
      <h1
        class="hero-animate hero-animate-2 mt-5 max-w-[760px]"
        style="font-size: clamp(32px, 5vw, 60px); font-weight: 700; line-height: 1.05; letter-spacing: -0.03em; color: #ffffff;"
      >
        Candidate-se à Próxima Turma do Builder
      </h1>
      <p
        class="hero-animate hero-animate-3 mt-5 max-w-[580px]"
        style="font-size: clamp(16px, 1.8vw, 18px); font-weight: 400; line-height: 1.7; color: rgba(255,255,255,0.55);"
      >
        O programa para donos de agência que querem adicionar AI como linha de receita em 12 semanas.
      </p>
    </div>
  </section>

  <!-- MAIN: Form + What happens next -->
  <section style="background-color: #080808; padding: 0 0 112px;">
    <div class="mx-auto max-w-[1200px] px-5 md:px-8 lg:px-0">

      <!-- Success message (shown via JS when ?enviado=true) -->
      <div
        id="success-message"
        class="hidden max-w-[640px] mx-auto mb-12 rounded-2xl p-8 text-center"
        style="background: rgba(201,168,76,0.08); border: 1px solid rgba(201,168,76,0.25);"
        role="alert"
        aria-live="polite"
      >
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color: #C9A84C; margin: 0 auto 16px;"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <h2 class="text-2xl font-semibold mb-3" style="color: #ffffff;">Candidatura enviada com sucesso!</h2>
        <p class="text-base leading-relaxed mb-6" style="color: rgba(255,255,255,0.6);">
          Analisaremos seu perfil e entraremos em contato em até 48 horas via WhatsApp.
        </p>
        <a
          href="/"
          class="inline-flex items-center gap-2 text-sm font-medium transition-colors duration-200"
          style="color: #C9A84C;"
          onmouseover="this.style.opacity='0.8';"
          onmouseout="this.style.opacity='1';"
        >
          &#8592; Voltar para a página inicial
        </a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">

        <!-- Application Form -->
        <div class="lg:col-span-7 reveal">
          <!-- Replace PLACEHOLDER_FORM_ID with your Formspree form ID -->
          <form
            id="application-form"
            action="https://formspree.io/f/PLACEHOLDER_FORM_ID"
            method="POST"
            novalidate
            aria-label="Formulário de candidatura ao Builder"
          >
            <!-- Hidden source field -->
            <input type="hidden" name="_source" value="aplicar-builder" />
            <input type="hidden" name="_next" value="/aplicar?enviado=true" />

            <div class="space-y-5">
              <!-- Nome -->
              <div>
                <label
                  for="nome"
                  class="block text-sm font-medium mb-2"
                  style="color: rgba(255,255,255,0.75);"
                >Nome completo <span class="text-accent" aria-label="obrigatório">*</span></label>
                <input
                  type="text"
                  id="nome"
                  name="nome"
                  required
                  placeholder="Seu nome completo"
                  class="glass-input w-full"
                  autocomplete="name"
                />
              </div>

              <!-- Email -->
              <div>
                <label
                  for="email"
                  class="block text-sm font-medium mb-2"
                  style="color: rgba(255,255,255,0.75);"
                >Email <span class="text-accent" aria-label="obrigatório">*</span></label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="seu@email.com"
                  class="glass-input w-full"
                  autocomplete="email"
                />
              </div>

              <!-- WhatsApp -->
              <div>
                <label
                  for="whatsapp"
                  class="block text-sm font-medium mb-2"
                  style="color: rgba(255,255,255,0.75);"
                >WhatsApp <span class="text-accent" aria-label="obrigatório">*</span></label>
                <input
                  type="tel"
                  id="whatsapp"
                  name="whatsapp"
                  required
                  placeholder="+55 11 99999-9999"
                  class="glass-input w-full"
                  autocomplete="tel"
                />
              </div>

              <!-- Empresa / Cargo -->
              <div>
                <label
                  for="empresa"
                  class="block text-sm font-medium mb-2"
                  style="color: rgba(255,255,255,0.75);"
                >Empresa / Cargo <span class="text-accent" aria-label="obrigatório">*</span></label>
                <input
                  type="text"
                  id="empresa"
                  name="empresa"
                  required
                  placeholder="Ex: Agência XYZ / CEO"
                  class="glass-input w-full"
                />
              </div>

              <!-- Faturamento -->
              <div>
                <label
                  for="faturamento"
                  class="block text-sm font-medium mb-2"
                  style="color: rgba(255,255,255,0.75);"
                >Faixa de faturamento mensal <span class="text-accent" aria-label="obrigatório">*</span></label>
                <select
                  id="faturamento"
                  name="faturamento"
                  required
                  class="glass-input w-full"
                  style="appearance: none; -webkit-appearance: none; cursor: pointer;"
                >
                  <option value="" disabled selected>Selecione...</option>
                  <option value="ate-20k">Até R$ 20.000</option>
                  <option value="20k-50k">R$ 20.000 – R$ 50.000</option>
                  <option value="50k-100k">R$ 50.000 – R$ 100.000</option>
                  <option value="100k-300k">R$ 100.000 – R$ 300.000</option>
                  <option value="acima-300k">Acima de R$ 300.000</option>
                </select>
              </div>

              <!-- Desafio -->
              <div>
                <label
                  for="desafio"
                  class="block text-sm font-medium mb-2"
                  style="color: rgba(255,255,255,0.75);"
                >Qual seu maior desafio com AI hoje? <span class="text-accent" aria-label="obrigatório">*</span></label>
                <textarea
                  id="desafio"
                  name="desafio"
                  required
                  rows="4"
                  placeholder="Ex: Não sei como precificar serviços de AI, não tenho time técnico..."
                  class="glass-input w-full"
                  style="resize: vertical; min-height: 100px;"
                ></textarea>
              </div>

              <!-- Como conheceu -->
              <div>
                <label
                  for="origem"
                  class="block text-sm font-medium mb-2"
                  style="color: rgba(255,255,255,0.75);"
                >Como conheceu a Reis IA?</label>
                <select
                  id="origem"
                  name="origem"
                  class="glass-input w-full"
                  style="appearance: none; -webkit-appearance: none; cursor: pointer;"
                >
                  <option value="" disabled selected>Selecione...</option>
                  <option value="linkedin">LinkedIn</option>
                  <option value="instagram">Instagram</option>
                  <option value="indicacao">Indicação</option>
                  <option value="google">Google</option>
                  <option value="evento">Evento</option>
                  <option value="outro">Outro</option>
                </select>
              </div>
            </div>

            <!-- Submit -->
            <div class="mt-8">
              <button
                type="submit"
                class="w-full sm:w-auto btn-submit-apply"
                style="background: #C9A84C; color: #000000; font-size: 16px; font-weight: 700; padding: 18px 40px; border-radius: 10px; border: none; cursor: pointer; letter-spacing: -0.01em; transition: background-color 200ms ease, transform 150ms ease, box-shadow 200ms ease; width: 100%;"
                onmouseover="this.style.backgroundColor='#D4B85E'; this.style.transform='translateY(-1px)'; this.style.boxShadow='0 8px 24px rgba(201,168,76,0.3)';"
                onmouseout="this.style.backgroundColor='#C9A84C'; this.style.transform='translateY(0)'; this.style.boxShadow='none';"
              >
                Enviar Candidatura &#8594;
              </button>
              <p class="mt-3 text-xs" style="color: rgba(255,255,255,0.3);">
                Suas informações são confidenciais. Responderemos em até 48 horas.
              </p>
            </div>
          </form>
        </div>

        <!-- RIGHT: What happens next -->
        <div class="lg:col-span-5 reveal">
          <!-- Chess icon -->
          <div
            class="w-12 h-12 rounded-xl flex items-center justify-center mb-8"
            style="background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.2);"
            aria-hidden="true"
          >
            <ChessKnightIcon size={28} class="text-accent" />
          </div>

          <h2 class="text-xl font-semibold mb-6" style="color: #ffffff; letter-spacing: -0.01em;">
            O que acontece depois:
          </h2>

          <ol class="space-y-6" role="list">
            <li class="flex gap-4">
              <span
                class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold"
                style="background: rgba(201,168,76,0.15); border: 1px solid rgba(201,168,76,0.3); color: #C9A84C;"
                aria-label="Passo 1"
              >1</span>
              <div class="pt-0.5">
                <p class="text-sm font-semibold mb-1" style="color: #ffffff;">Análise da sua candidatura (24–48h)</p>
                <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.45);">Revisamos seu perfil e verificamos o alinhamento com a próxima turma.</p>
              </div>
            </li>

            <li class="flex gap-4">
              <span
                class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold"
                style="background: rgba(201,168,76,0.15); border: 1px solid rgba(201,168,76,0.3); color: #C9A84C;"
                aria-label="Passo 2"
              >2</span>
              <div class="pt-0.5">
                <p class="text-sm font-semibold mb-1" style="color: #ffffff;">Conversa de alinhamento por WhatsApp</p>
                <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.45);">Uma conversa rápida para alinhar expectativas, tirar dúvidas e confirmar o fit.</p>
              </div>
            </li>

            <li class="flex gap-4">
              <span
                class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold"
                style="background: rgba(201,168,76,0.15); border: 1px solid rgba(201,168,76,0.3); color: #C9A84C;"
                aria-label="Passo 3"
              >3</span>
              <div class="pt-0.5">
                <p class="text-sm font-semibold mb-1" style="color: #ffffff;">Confirmação e onboarding na turma</p>
                <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.45);">Confirmação da vaga, informações de acesso e início do programa.</p>
              </div>
            </li>
          </ol>

          <!-- Trust badges -->
          <div
            class="mt-10 p-5 rounded-xl"
            style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.07);"
          >
            <p class="text-xs uppercase tracking-widest font-medium mb-4" style="color: rgba(255,255,255,0.3); letter-spacing: 0.1em;">Por que o Builder?</p>
            <ul class="space-y-2">
              {[
                'Máximo de 12 participantes por turma',
                'Candidaturas revisadas pessoalmente por Moroni',
                'Vagas limitadas — próxima turma: Abril 2026',
                'Seu primeiro projeto entregue com suporte total',
              ].map(item => (
                <li class="flex items-start gap-2 text-sm" style="color: rgba(255,255,255,0.5);">
                  <span class="text-accent mt-px" aria-hidden="true">—</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>

</MainLayout>

<style>
  /* Glass-morphism form inputs */
  .glass-input {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 14px 16px;
    color: rgba(255, 255, 255, 0.85);
    font-size: 15px;
    font-family: inherit;
    transition: border-color 200ms ease, background 200ms ease;
    outline: none;
  }
  .glass-input::placeholder {
    color: rgba(255, 255, 255, 0.25);
  }
  .glass-input:focus {
    border-color: rgba(201, 168, 76, 0.5);
    background: rgba(255, 255, 255, 0.06);
  }
  .glass-input option {
    background: #111113;
    color: rgba(255, 255, 255, 0.85);
  }
</style>

<script>
  // Show success message if ?enviado=true is in the URL
  const params = new URLSearchParams(window.location.search);
  if (params.get('enviado') === 'true') {
    const successMsg = document.getElementById('success-message');
    const form = document.getElementById('application-form');
    if (successMsg) {
      successMsg.classList.remove('hidden');
      successMsg.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
    if (form) form.classList.add('hidden');
  }
</script>
