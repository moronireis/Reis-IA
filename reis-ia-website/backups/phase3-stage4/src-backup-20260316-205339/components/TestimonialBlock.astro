---
interface Props {
  quote: string;
  name: string;
  role: string;
  isPlaceholder?: boolean;
}

const { quote, name, role, isPlaceholder = false } = Astro.props;
---

<div class={`border-l-2 border-accent pl-6 ${isPlaceholder ? 'placeholder-content p-4 rounded-r' : ''}`}>
  {isPlaceholder && (
    <span class="text-xs uppercase tracking-widest text-neutral-600 block mb-3">Placeholder Testimonial</span>
  )}
  <blockquote class="text-lg italic text-neutral-300 leading-relaxed">
    "{quote}"
  </blockquote>
  <div class="mt-4">
    <p class="text-[15px] font-semibold text-white">{name}</p>
    <p class="text-sm text-neutral-500">{role}</p>
  </div>
</div>
