---

<footer
  style="background-color: #0A0A0A; border-top: 1px solid rgba(255,255,255,0.06);"
  aria-label="Rodapé do site"
>
  <div class="mx-auto max-w-[1200px] px-5 md:px-8 lg:px-0 pt-12 pb-8">
    <div class="flex flex-col sm:flex-row justify-between gap-8">
      <!-- Brand column -->
      <div class="max-w-[260px]">
        <a
          href="/"
          class="text-white font-bold text-xl tracking-tight transition-opacity duration-200 hover:opacity-80"
          aria-label="Reis IA - Início"
        >REIS IA</a>
        <p class="text-sm mt-3 leading-relaxed" style="color: rgba(255,255,255,0.35);">O Ecossistema de Receita com IA</p>
      </div>

      <!-- Ecosystem links -->
      <div>
        <p class="text-[13px] uppercase tracking-widest font-medium mb-4" style="color: rgba(255,255,255,0.45); letter-spacing: 0.1em;">Ecossistema</p>
        <ul class="space-y-3">
          <li><a href="/" class="text-sm transition-colors duration-200 hover:text-white" style="color: rgba(255,255,255,0.35);">Home</a></li>
          <li><a href="/builder" class="text-sm transition-colors duration-200 hover:text-white" style="color: rgba(255,255,255,0.35);">Builder</a></li>
          <li><a href="/systems" class="text-sm transition-colors duration-200 hover:text-white" style="color: rgba(255,255,255,0.35);">Systems</a></li>
          <li><a href="/agendar" class="text-sm transition-colors duration-200 hover:text-white" style="color: rgba(255,255,255,0.35);">Agendar</a></li>
        </ul>
      </div>
    </div>

    <!-- Divider — gold accent gradient -->
    <div class="divider-accent mt-10 mb-6"></div>

    <!-- Copyright row -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      <p class="text-[13px]" style="color: rgba(255,255,255,0.25);">&copy; 2026 Reis IA. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>
