---
import IconMenu from './icons/IconMenu.astro';
import IconX from './icons/IconX.astro';

interface Props {
  activePage?: 'home' | 'builder' | 'systems' | 'partners' | 'network' | 'about';
}

const { activePage = 'home' } = Astro.props;

const navLinks = [
  { label: 'Builder', href: '/builder', key: 'builder' },
  { label: 'Systems', href: '/systems', key: 'systems' },
];
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 h-[72px] transition-all duration-300"
  style="
    background: rgba(0,0,0,0.75);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid transparent;
  "
  aria-label="Navegação principal"
>
  <div class="mx-auto max-w-[1200px] px-5 md:px-8 lg:px-0 h-full flex items-center justify-between">
    <!-- Logo -->
    <a
      href="/"
      class="text-white font-bold text-xl tracking-tight transition-opacity duration-200 hover:opacity-80"
      aria-label="Reis IA - Home"
    >
      REIS IA
    </a>

    <!-- Desktop nav links -->
    <div class="hidden lg:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`text-sm font-medium transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-accent/20 rounded-sm ${
            activePage === link.key
              ? 'text-white border-b-2 border-accent pb-0.5'
              : 'hover:text-white'
          }`}
          style={activePage === link.key ? '' : 'color: rgba(255,255,255,0.5);'}
          aria-current={activePage === link.key ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- CTA + Mobile menu toggle -->
    <div class="flex items-center gap-4">
      <a
        href="/agendar"
        class="hidden lg:inline-flex items-center justify-center text-white text-sm font-semibold tracking-wide px-5 py-2.5 rounded-md transition-all duration-200 nav-cta-btn"
        style="background-color: #4A90FF; color: #ffffff;"
      >
        Agende uma Conversa
      </a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-toggle"
        class="lg:hidden text-white focus:outline-none focus:ring-2 focus:ring-accent/20 rounded-sm p-1 transition-opacity duration-200 hover:opacity-70"
        aria-label="Abrir menu de navegação"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <IconMenu size={24} />
      </button>
    </div>
  </div>
</nav>

<!-- Mobile menu overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-50 flex flex-col items-center justify-center hidden lg:hidden"
  style="background: rgba(0,0,0,0.97); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);"
  aria-hidden="true"
>
  <button
    id="mobile-menu-close"
    class="absolute top-6 right-5 text-white focus:outline-none focus:ring-2 focus:ring-accent/20 rounded-sm p-1 transition-opacity duration-200 hover:opacity-70"
    aria-label="Fechar menu de navegação"
  >
    <IconX size={24} />
  </button>

  <div class="flex flex-col items-center gap-6">
    <a href="/" class="text-white font-bold text-2xl tracking-tight">REIS IA</a>
    <div class="w-8 h-px" style="background: rgba(255,255,255,0.1);"></div>
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="text-white text-2xl font-semibold transition-colors duration-200 hover:text-accent"
      >
        {link.label}
      </a>
    ))}
    <div class="w-8 h-px" style="background: rgba(255,255,255,0.1);"></div>
    <a
      href="/agendar"
      class="inline-flex items-center justify-center text-white text-lg font-semibold px-10 py-4 rounded-lg transition-all duration-200 w-full max-w-xs text-center"
      style="background-color: #4A90FF; color: #ffffff;"
    >
      Agende uma Conversa
    </a>
  </div>
</div>

<style>
  /* Scroll-aware border (Task J) */
  #main-nav[data-scrolled] {
    border-bottom-color: rgba(255,255,255,0.08) !important;
  }

  /* CTA glow on hover (Task D / Task J) */
  .nav-cta-btn:hover {
    background-color: #6AADFF !important;
    box-shadow: 0 0 16px rgba(74, 144, 255, 0.25), 0 4px 12px rgba(74, 144, 255, 0.15);
    transform: translateY(-1px);
  }
  .nav-cta-btn:active {
    transform: translateY(0);
  }
</style>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const closeBtn = document.getElementById('mobile-menu-close');
  const menu = document.getElementById('mobile-menu');

  function openMenu() {
    menu?.classList.remove('hidden');
    menu?.setAttribute('aria-hidden', 'false');
    toggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    menu?.setAttribute('aria-hidden', 'true');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);

  // Close on link click
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>
