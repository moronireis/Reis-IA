---
/**
 * SectionLabel — "[01] SECTION TITLE" pattern in accent blue.
 */
interface Props {
  number?: string;
  class?: string;
}

const { number, class: className = '' } = Astro.props;
---

<p
  class:list={['text-[var(--text-label)] font-semibold uppercase tracking-[0.05em] text-[var(--accent-blue)]', className]}
>
  {number && <span class="mr-2">[{number}]</span>}
  <slot />
</p>
