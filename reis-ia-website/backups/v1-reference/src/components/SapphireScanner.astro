---
/**
 * SapphireScanner — Wrapper that applies the rotating blue conic-gradient border.
 * Use on 1-2 featured cards per page maximum.
 */
interface Props {
  class?: string;
  tag?: string;
}

const { class: className = '', tag = 'div' } = Astro.props;
const Tag = tag as any;
---

<Tag class:list={['sapphire-scanner', className]}>
  <slot />
</Tag>
