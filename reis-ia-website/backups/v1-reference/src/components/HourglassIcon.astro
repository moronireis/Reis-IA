---
/**
 * HourglassIcon — H1-B Variation A brand mark
 * Geometric hourglass with two horizontal bars and crossing diagonals.
 * Uses currentColor so parent can set the color.
 */
interface Props {
  class?: string;
  size?: number;
  strokeWidth?: number;
  ariaHidden?: boolean;
}

const {
  class: className = '',
  size = 24,
  strokeWidth = 1.5,
  ariaHidden = true
} = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 64 64"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  width={size}
  height={size}
  class={className}
  aria-hidden={ariaHidden ? "true" : undefined}
  role={ariaHidden ? "presentation" : undefined}
>
  <line x1="16" y1="8" x2="48" y2="8"/>
  <line x1="16" y1="8" x2="32" y2="32"/>
  <line x1="48" y1="8" x2="32" y2="32"/>
  <line x1="32" y1="32" x2="16" y2="56"/>
  <line x1="32" y1="32" x2="48" y2="56"/>
  <line x1="16" y1="56" x2="48" y2="56"/>
</svg>
