---
/**
 * /agendar — Booking Page: Sessao Estrategica Gratuita
 * Copy source: brain/assets/campaigns/agendar/FINAL-agendar-copy.md v1.0
 * Single-surface page (Surface-0). Functional, not narrative.
 * NO aurora, NO heavy animations. Fast-loading, clear, frictionless.
 */
import MainLayout from '../layouts/MainLayout.astro';
import Badge from '../components/Badge.astro';
import SectionLabel from '../components/SectionLabel.astro';
import AmbientPool from '../components/AmbientPool.astro';
import SapphireScanner from '../components/SapphireScanner.astro';
import HourglassIcon from '../components/HourglassIcon.astro';
---

<MainLayout
  title="Agende Sua Sessao Estrategica"
  description="30 minutos. Sem pitch. Um mapa claro de onde IA gera receita no seu negocio. Agende sua sessao estrategica gratuita."
>

  <!-- ============================================================
       SECTION 1: HERO — Surface-0, Badge, headline, subtext
       ============================================================ -->
  <section
    class="relative overflow-hidden"
    style="background: var(--surface-0); padding-top: var(--space-4xl); padding-bottom: var(--space-2xl);"
    aria-labelledby="hero-heading"
  >
    <!-- Subtle ambient pool in header area only -->
    <AmbientPool position="center" color="blue" size={600} opacity={0.04} />

    <div class="container-narrow relative z-10 text-center">
      <!-- Badge -->
      <div class="hero-animate hero-animate-1">
        <Badge variant="accent">Sessao Estrategica Gratuita</Badge>
      </div>

      <!-- Headline -->
      <h1
        id="hero-heading"
        class="hero-animate hero-animate-2 mt-6 text-balance mx-auto"
        style="font-size: var(--text-h1); font-weight: 700; line-height: 1.08; letter-spacing: -0.025em; color: var(--text-primary); max-width: var(--container-headline);"
      >
        Antes de investir em IA, saiba exatamente onde esta o retorno.
      </h1>

      <!-- Subheadline -->
      <p
        class="hero-animate hero-animate-3 mt-6 mx-auto text-pretty"
        style="font-size: var(--text-body-lg); line-height: 1.60; color: var(--text-secondary); max-width: var(--container-text);"
      >
        Essa nao e uma call de vendas. E uma sessao de diagnostico onde o Moroni analisa seu negocio e mostra — com clareza — onde IA faz sentido como estrategia de receita. E onde nao faz.
      </p>
    </div>
  </section>


  <!-- ============================================================
       SECTION 2: O QUE ESPERAR — 4 bullet items with icons
       ============================================================ -->
  <section
    class="relative"
    style="background: var(--surface-0); padding: var(--space-2xl) 0;"
    aria-labelledby="oque-esperar-heading"
  >
    <div class="gradient-divider" style="position: absolute; top: 0; left: 0; right: 0;"></div>

    <div class="container-narrow relative z-10">
      <h2
        id="oque-esperar-heading"
        class="animate-on-scroll"
        style="font-size: var(--text-h3); font-weight: 600; line-height: 1.15; letter-spacing: -0.015em; color: var(--text-primary);"
      >
        O que acontece na sessao:
      </h2>

      <!-- 4 bullets in a 2-column grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8 grid-stagger">

        <!-- Bullet 1: Diagnostico -->
        <div class="flex gap-4 p-5 rounded-[var(--radius-xl)]" style="background: var(--surface-2); border: 1px solid var(--border-default);">
          <div class="flex-shrink-0 mt-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent-blue);" aria-hidden="true">
              <circle cx="11" cy="11" r="8"/>
              <path d="m21 21-4.3-4.3"/>
              <path d="M11 8v6"/>
              <path d="M8 11h6"/>
            </svg>
          </div>
          <div>
            <p style="font-size: var(--text-body); font-weight: 600; color: var(--text-primary);" class="mb-1">
              Analise do seu modelo de negocio
            </p>
            <p style="font-size: var(--text-body-sm); line-height: 1.55; color: var(--text-secondary);">
              Entendemos como sua operacao funciona hoje, onde estao os gargalos e quais sao as maiores alavancas de crescimento.
            </p>
          </div>
        </div>

        <!-- Bullet 2: Mapeamento -->
        <div class="flex gap-4 p-5 rounded-[var(--radius-xl)]" style="background: var(--surface-2); border: 1px solid var(--border-default);">
          <div class="flex-shrink-0 mt-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent-blue);" aria-hidden="true">
              <path d="M3 3v18h18"/>
              <path d="m19 9-5 5-4-4-3 3"/>
            </svg>
          </div>
          <div>
            <p style="font-size: var(--text-body); font-weight: 600; color: var(--text-primary);" class="mb-1">
              Mapeamento de oportunidades de IA com impacto em receita
            </p>
            <p style="font-size: var(--text-body-sm); line-height: 1.55; color: var(--text-secondary);">
              Nao onde IA parece interessante — onde ela gera retorno mensuravel. Essa distincao muda tudo.
            </p>
          </div>
        </div>

        <!-- Bullet 3: Saida concreta -->
        <div class="flex gap-4 p-5 rounded-[var(--radius-xl)]" style="background: var(--surface-2); border: 1px solid var(--border-default);">
          <div class="flex-shrink-0 mt-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent-blue);" aria-hidden="true">
              <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
              <polyline points="14 2 14 8 20 8"/>
              <path d="m9 15 2 2 4-4"/>
            </svg>
          </div>
          <div>
            <p style="font-size: var(--text-body); font-weight: 600; color: var(--text-primary);" class="mb-1">
              Recomendacoes praticas e proximos passos claros
            </p>
            <p style="font-size: var(--text-body-sm); line-height: 1.55; color: var(--text-secondary);">
              Voce sai com um caminho concreto. Nao um slide deck generico sobre o futuro da IA.
            </p>
          </div>
        </div>

        <!-- Bullet 4: Sem compromisso -->
        <div class="flex gap-4 p-5 rounded-[var(--radius-xl)]" style="background: var(--surface-2); border: 1px solid var(--border-default);">
          <div class="flex-shrink-0 mt-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent-blue);" aria-hidden="true">
              <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
              <path d="m9 12 2 2 4-4"/>
            </svg>
          </div>
          <div>
            <p style="font-size: var(--text-body); font-weight: 600; color: var(--text-primary);" class="mb-1">
              Sem pitch, sem pressao — a sessao e gratuita
            </p>
            <p style="font-size: var(--text-body-sm); line-height: 1.55; color: var(--text-secondary);">
              Se fizer sentido seguir em frente, conversamos sobre isso. Se nao fizer, o Moroni diz. Direto.
            </p>
          </div>
        </div>
      </div>

      <!-- Context badges -->
      <div class="flex flex-wrap items-center justify-center gap-3 mt-8 animate-on-scroll">
        <span
          class="inline-flex items-center gap-2 px-4 py-2 rounded-[var(--radius-full)]"
          style="background: var(--surface-2); border: 1px solid var(--border-default); font-size: var(--text-body-sm); color: var(--text-secondary);"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent-blue);" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          30 minutos
        </span>
        <span
          class="inline-flex items-center gap-2 px-4 py-2 rounded-[var(--radius-full)]"
          style="background: var(--surface-2); border: 1px solid var(--border-default); font-size: var(--text-body-sm); color: var(--text-secondary);"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent-blue);" aria-hidden="true">
            <path d="M15 10l5 5-5 5"/>
            <path d="M4 4v7a4 4 0 0 0 4 4h12"/>
          </svg>
          Online via Google Meet
        </span>
      </div>
    </div>
  </section>


  <!-- ============================================================
       SECTION 3: PARA QUEM E / NAO E — Qualifier
       ============================================================ -->
  <section
    class="relative"
    style="background: var(--surface-0); padding: var(--space-2xl) 0;"
    aria-labelledby="para-quem-heading"
  >
    <div class="gradient-divider" style="position: absolute; top: 0; left: 0; right: 0;"></div>

    <div class="container-narrow relative z-10">
      <h2
        id="para-quem-heading"
        class="animate-on-scroll"
        style="font-size: var(--text-h3); font-weight: 600; line-height: 1.15; letter-spacing: -0.015em; color: var(--text-primary);"
      >
        Pra quem e — e pra quem nao e.
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-8">
        <!-- Para quem e -->
        <div class="animate-on-scroll">
          <p
            class="mb-4 flex items-center gap-2"
            style="font-size: var(--text-label); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--accent-blue);"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m9 12 2 2 4-4"/>
              <circle cx="12" cy="12" r="10"/>
            </svg>
            Para quem e
          </p>
          <ul class="space-y-3" style="font-size: var(--text-body); line-height: 1.65; color: var(--text-secondary);">
            <li class="flex items-start gap-3">
              <span style="color: var(--accent-blue); flex-shrink: 0; margin-top: 2px;" aria-hidden="true">—</span>
              CEOs e fundadores de empresas com faturamento acima de R$5M/ano
            </li>
            <li class="flex items-start gap-3">
              <span style="color: var(--accent-blue); flex-shrink: 0; margin-top: 2px;" aria-hidden="true">—</span>
              Que ja tem equipe e estao buscando escalar operacoes com IA
            </li>
            <li class="flex items-start gap-3">
              <span style="color: var(--accent-blue); flex-shrink: 0; margin-top: 2px;" aria-hidden="true">—</span>
              Que querem entender onde IA gera resultado real antes de investir
            </li>
          </ul>
        </div>

        <!-- Nao e para -->
        <div class="animate-on-scroll">
          <p
            class="mb-4 flex items-center gap-2"
            style="font-size: var(--text-label); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-tertiary);"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <path d="m15 9-6 6"/>
              <path d="m9 9 6 6"/>
            </svg>
            Nao e para
          </p>
          <ul class="space-y-3" style="font-size: var(--text-body); line-height: 1.65; color: var(--text-tertiary);">
            <li class="flex items-start gap-3">
              <span style="color: var(--text-quaternary); flex-shrink: 0; margin-top: 2px;" aria-hidden="true">—</span>
              Startups em estagio inicial, sem receita recorrente
            </li>
            <li class="flex items-start gap-3">
              <span style="color: var(--text-quaternary); flex-shrink: 0; margin-top: 2px;" aria-hidden="true">—</span>
              Agencias buscando um fornecedor tecnico de IA (pra isso, veja o Partners)
            </li>
            <li class="flex items-start gap-3">
              <span style="color: var(--text-quaternary); flex-shrink: 0; margin-top: 2px;" aria-hidden="true">—</span>
              Quem quer consultoria gratuita sem intencao de implementar
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================================
       SECTION 4: COMO FUNCIONA — 3 steps with numbered indicators
       ============================================================ -->
  <section
    class="relative"
    style="background: var(--surface-0); padding: var(--space-2xl) 0;"
    aria-labelledby="como-funciona-heading"
  >
    <div class="gradient-divider" style="position: absolute; top: 0; left: 0; right: 0;"></div>

    <div class="container-narrow relative z-10">
      <h2
        id="como-funciona-heading"
        class="animate-on-scroll"
        style="font-size: var(--text-h3); font-weight: 600; line-height: 1.15; letter-spacing: -0.015em; color: var(--text-primary);"
      >
        Funciona assim:
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8 grid-stagger">
        <!-- Step 1 -->
        <div class="flex flex-col items-start p-6 rounded-[var(--radius-xl)]" style="background: var(--surface-2); border: 1px solid var(--border-default);">
          <span
            class="flex items-center justify-center w-9 h-9 rounded-full mb-4"
            style="background: var(--blue-10); border: 1px solid var(--blue-20); font-size: var(--text-body-sm); font-weight: 700; color: var(--accent-blue);"
            aria-hidden="true"
          >1</span>
          <p style="font-size: var(--text-body); font-weight: 600; color: var(--text-primary);" class="mb-2">
            Escolha um horario no calendario
          </p>
          <p style="font-size: var(--text-body-sm); line-height: 1.55; color: var(--text-secondary);">
            Selecione o melhor dia e horario disponivel logo abaixo.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="flex flex-col items-start p-6 rounded-[var(--radius-xl)]" style="background: var(--surface-2); border: 1px solid var(--border-default);">
          <span
            class="flex items-center justify-center w-9 h-9 rounded-full mb-4"
            style="background: var(--blue-10); border: 1px solid var(--blue-20); font-size: var(--text-body-sm); font-weight: 700; color: var(--accent-blue);"
            aria-hidden="true"
          >2</span>
          <p style="font-size: var(--text-body); font-weight: 600; color: var(--text-primary);" class="mb-2">
            Responda um questionario rapido (2 minutos)
          </p>
          <p style="font-size: var(--text-body-sm); line-height: 1.55; color: var(--text-secondary);">
            Algumas perguntas sobre seu negocio pra que a conversa ja comece no ponto certo.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="flex flex-col items-start p-6 rounded-[var(--radius-xl)]" style="background: var(--surface-2); border: 1px solid var(--border-default);">
          <span
            class="flex items-center justify-center w-9 h-9 rounded-full mb-4"
            style="background: var(--blue-10); border: 1px solid var(--blue-20); font-size: var(--text-body-sm); font-weight: 700; color: var(--accent-blue);"
            aria-hidden="true"
          >3</span>
          <p style="font-size: var(--text-body); font-weight: 600; color: var(--text-primary);" class="mb-2">
            Sessao de 30 minutos por video com o Moroni
          </p>
          <p style="font-size: var(--text-body-sm); line-height: 1.55; color: var(--text-secondary);">
            Diagnostico ao vivo, oportunidades mapeadas e um plano claro do que faz sentido (ou nao) implementar.
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================================
       SECTION 5: CAL.COM EMBED — Placeholder with Sapphire Scanner
       ============================================================ -->
  <section
    id="calendario"
    class="relative"
    style="background: var(--surface-0); padding: var(--space-2xl) 0;"
    aria-labelledby="calendario-heading"
  >
    <div class="gradient-divider" style="position: absolute; top: 0; left: 0; right: 0;"></div>

    <div class="container-narrow relative z-10">
      <h2
        id="calendario-heading"
        class="animate-on-scroll text-center mb-8"
        style="font-size: var(--text-h3); font-weight: 600; line-height: 1.15; letter-spacing: -0.015em; color: var(--text-primary);"
      >
        Escolha o melhor horario
      </h2>

      <!-- Cal.com embed placeholder with Sapphire Scanner -->
      <SapphireScanner class="animate-on-scroll">
        <div
          class="w-full min-h-[400px] flex flex-col items-center justify-center p-8 rounded-[11px] placeholder-content"
          style="background: var(--surface-1); border: none;"
          aria-label="Calendario de agendamento — sera carregado com Cal.com"
        >
          <HourglassIcon size={40} class="text-[var(--accent-blue)] mb-4" />
          <p style="font-size: var(--text-body-lg); font-weight: 600; color: var(--text-secondary); text-align: center;">
            Calendario carrega aqui
          </p>
          <p style="font-size: var(--text-body-sm); color: var(--text-quaternary); text-align: center; margin-top: 8px;">
            [PLACEHOLDER: Cal.com embed sera integrado aqui]
          </p>
        </div>
      </SapphireScanner>
    </div>
  </section>


  <!-- ============================================================
       SECTION 6: TRUST SIGNALS — Inline horizontal badges
       ============================================================ -->
  <section
    class="relative"
    style="background: var(--surface-0); padding: var(--space-xl) 0;"
  >
    <div class="gradient-divider" style="position: absolute; top: 0; left: 0; right: 0;"></div>

    <div class="container-narrow relative z-10">
      <div class="flex flex-wrap items-center justify-center gap-3 animate-on-scroll">
        <span
          class="inline-flex items-center gap-2 px-4 py-2 rounded-[var(--radius-full)]"
          style="background: var(--surface-2); border: 1px solid var(--border-default); font-size: var(--text-body-sm); color: var(--text-secondary);"
        >
          Mais de 50 implementacoes de IA
        </span>
        <span
          class="inline-flex items-center gap-2 px-4 py-2 rounded-[var(--radius-full)]"
          style="background: var(--surface-2); border: 1px solid var(--border-default); font-size: var(--text-body-sm); color: var(--text-secondary);"
        >
          Revenue-First Framework
        </span>
        <span
          class="inline-flex items-center gap-2 px-4 py-2 rounded-[var(--radius-full)]"
          style="background: var(--surface-2); border: 1px solid var(--border-default); font-size: var(--text-body-sm); color: var(--text-secondary);"
        >
          Resultados em 60 dias
        </span>
      </div>
    </div>
  </section>


  <!-- ============================================================
       SECTION 7: WHATSAPP FALLBACK — Green WhatsApp CTA
       ============================================================ -->
  <section
    class="relative"
    style="background: var(--surface-0); padding: var(--space-2xl) 0 var(--space-3xl);"
  >
    <div class="gradient-divider" style="position: absolute; top: 0; left: 0; right: 0;"></div>

    <div class="container-narrow relative z-10 text-center animate-on-scroll">
      <p style="font-size: var(--text-h4); font-weight: 600; color: var(--text-primary);" class="mb-3">
        Prefere WhatsApp?
      </p>
      <p style="font-size: var(--text-body); line-height: 1.65; color: var(--text-secondary); max-width: 480px;" class="mx-auto mb-6">
        Se o calendario nao funcionar pro seu horario, mande uma mensagem direta. A gente marca por la.
      </p>
      <a
        href="https://wa.me/PLACEHOLDER_PHONE_NUMBER?text=Oi%2C%20quero%20agendar%20uma%20sess%C3%A3o%20estrat%C3%A9gica."
        target="_blank"
        rel="noopener noreferrer"
        class="whatsapp-btn inline-flex items-center justify-center gap-2 text-white font-semibold px-8 py-[13px] pb-[15px] rounded-[var(--radius)] btn-press focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--focus-ring)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--surface-0)]"
        style="background: #25D366; transition: background-color var(--duration-fast) var(--ease-base), transform 150ms var(--ease-base); min-width: 220px;"
      >
        <!-- WhatsApp icon -->
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Agendar pelo WhatsApp
      </a>
    </div>
  </section>


  <!-- ============================================================
       SUCCESS MESSAGE — Hidden by default, shown after booking
       ============================================================ -->
  <div
    id="booking-success"
    class="hidden"
    style="background: var(--surface-0); padding: var(--space-3xl) 0;"
    role="status"
    aria-live="polite"
  >
    <div class="container-narrow text-center">
      <div class="flex justify-center mb-6">
