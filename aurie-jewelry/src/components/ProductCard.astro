---
import { formatBRL, type Product } from '../data/products';
const { product } = Astro.props as { product: Product };
---
<a href={`/produto/${product.slug}`} class="product-card group block">
  <div class="img-wrap relative aspect-[4/5] bg-[color:var(--color-cream)]">
    <img
      src={product.hero}
      alt={product.name}
      loading="lazy"
      class="w-full h-full object-cover"
    />
    {product.badge && (
      <span class="absolute top-4 left-4 bg-[color:var(--color-ivory)] text-[10px] tracking-[0.28em] uppercase px-3 py-1 text-[color:var(--color-ink)] border border-[color:rgba(12,10,8,0.1)]">
        {product.badge}
      </span>
    )}
  </div>
  <div class="pt-5 flex items-start justify-between gap-4">
    <div>
      <p class="eyebrow">{product.collection}</p>
      <h3 class="font-display text-xl mt-1 leading-tight group-hover:text-[color:var(--color-gold-deep)] transition-colors">{product.name}</h3>
    </div>
    <span class="font-display text-lg whitespace-nowrap">{formatBRL(product.price)}</span>
  </div>
</a>
