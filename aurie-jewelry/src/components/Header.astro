---
const { current = '' } = Astro.props as { current?: string };
const link = (href: string, label: string, key: string) => ({ href, label, key });
const links = [
  link('/', 'Início', 'home'),
  link('/colecao', 'Coleção', 'colecao'),
  link('/historia', 'História', 'historia'),
  link('/atelier', 'Atelier', 'atelier'),
];
---
<header class="sticky top-0 z-40 backdrop-blur bg-[color-mix(in_oklab,var(--color-ivory),transparent_15%)] border-b border-[color:rgba(12,10,8,0.08)]">
  <div class="max-w-[1280px] mx-auto px-6 lg:px-10 h-20 flex items-center justify-between">
    <nav class="hidden md:flex items-center gap-9 text-[12px] uppercase tracking-[0.28em]">
      {links.slice(0, 2).map(l => (
        <a href={l.href} class={`transition-colors ${current === l.key ? 'text-[color:var(--color-gold-deep)]' : 'text-[color:var(--color-ink)] hover:text-[color:var(--color-gold-deep)]'}`}>{l.label}</a>
      ))}
    </nav>

    <a href="/" class="font-display text-[28px] md:text-[32px] tracking-[0.18em] text-[color:var(--color-ink)]">
      AURIÊ
      <span class="block text-[9px] tracking-[0.5em] text-[color:var(--color-gold-deep)] mt-[-2px]">JOIAS — DESDE 1968</span>
    </a>

    <div class="flex items-center gap-6">
      <nav class="hidden md:flex items-center gap-9 text-[12px] uppercase tracking-[0.28em]">
        {links.slice(2).map(l => (
          <a href={l.href} class={`transition-colors ${current === l.key ? 'text-[color:var(--color-gold-deep)]' : 'text-[color:var(--color-ink)] hover:text-[color:var(--color-gold-deep)]'}`}>{l.label}</a>
        ))}
      </nav>
      <button id="open-cart" type="button" aria-label="Abrir sacola" class="relative inline-flex items-center gap-2 text-[12px] uppercase tracking-[0.28em] text-[color:var(--color-ink)] hover:text-[color:var(--color-gold-deep)] transition-colors">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
          <path d="M4 7h16l-1.5 12.2A2 2 0 0116.5 21H7.5a2 2 0 01-2-1.8L4 7z"/>
          <path d="M9 7V5a3 3 0 016 0v2"/>
        </svg>
        <span class="hidden md:inline">Sacola</span>
        <span id="cart-count" class="absolute -top-2 -right-3 md:static md:ml-1 text-[10px] tracking-normal w-5 h-5 rounded-full bg-[color:var(--color-ink)] text-[color:var(--color-ivory)] grid place-items-center" data-empty="true">0</span>
      </button>
    </div>
  </div>
</header>
