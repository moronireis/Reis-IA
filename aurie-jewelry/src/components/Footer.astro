---
---
<footer class="relative mt-32 bg-[color:var(--color-ink)] text-[color:var(--color-ivory)]">
  <div class="max-w-[1280px] mx-auto px-6 lg:px-10 py-20 grid md:grid-cols-4 gap-12">
    <div class="md:col-span-2">
      <div class="font-display text-[40px] tracking-[0.18em]">AURIÊ</div>
      <p class="mt-4 max-w-md text-sm leading-relaxed text-[color:var(--color-bone)] opacity-80">
        Joalheria autoral feita em Belo Horizonte desde 1968. Cada peça nasce de uma conversa entre cliente, designer e ourives — nunca de um catálogo.
      </p>
      <div class="mt-8 hairline-gold pt-6 max-w-sm">
        <p class="eyebrow text-[color:var(--color-gold-soft)]">Receba primeiro</p>
        <form class="mt-3 flex items-end gap-3" onsubmit="event.preventDefault(); this.querySelector('input').value=''; this.querySelector('span').textContent='Recebido — em breve falamos.';">
          <input class="input-line text-[color:var(--color-ivory)] placeholder:text-[color:var(--color-bone)] border-[color:rgba(243,232,202,0.25)]" type="email" required placeholder="seu e-mail" />
          <button class="btn-primary !bg-[color:var(--color-gold)] !border-[color:var(--color-gold)] !text-[color:var(--color-ink)] hover:!bg-[color:var(--color-gold-soft)]">Enviar</button>
        </form>
        <span class="block text-[11px] tracking-[0.18em] text-[color:var(--color-gold-soft)] mt-3"></span>
      </div>
    </div>

    <div>
      <p class="eyebrow text-[color:var(--color-gold-soft)]">Boutique</p>
      <ul class="mt-4 space-y-2 text-sm text-[color:var(--color-bone)] opacity-80">
        <li><a class="hover:text-[color:var(--color-gold-soft)] transition-colors" href="/colecao">Coleção</a></li>
        <li><a class="hover:text-[color:var(--color-gold-soft)] transition-colors" href="/historia">História</a></li>
        <li><a class="hover:text-[color:var(--color-gold-soft)] transition-colors" href="/atelier">Atelier</a></li>
        <li><a class="hover:text-[color:var(--color-gold-soft)] transition-colors" href="#">Agendar visita</a></li>
      </ul>
    </div>

    <div>
      <p class="eyebrow text-[color:var(--color-gold-soft)]">Cuidado</p>
      <ul class="mt-4 space-y-2 text-sm text-[color:var(--color-bone)] opacity-80">
        <li><a class="hover:text-[color:var(--color-gold-soft)] transition-colors" href="#">Garantia vitalícia</a></li>
        <li><a class="hover:text-[color:var(--color-gold-soft)] transition-colors" href="#">Limpeza & polimento</a></li>
        <li><a class="hover:text-[color:var(--color-gold-soft)] transition-colors" href="#">Trocas em 30 dias</a></li>
        <li><a class="hover:text-[color:var(--color-gold-soft)] transition-colors" href="#">Frete segurado</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-[color:rgba(243,232,202,0.12)]">
    <div class="max-w-[1280px] mx-auto px-6 lg:px-10 py-6 flex flex-col md:flex-row items-center justify-between gap-3 text-[11px] tracking-[0.22em] uppercase text-[color:var(--color-bone)] opacity-60">
      <span>R. Cláudio Manoel, 240 — Belo Horizonte / MG</span>
      <span>+55 31 3221.0000</span>
      <span>© 2026 Auriê Joias</span>
    </div>
  </div>
</footer>
