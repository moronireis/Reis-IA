---
import Base from '../../layouts/Base.astro';
import ProductCard from '../../components/ProductCard.astro';
import { products, formatBRL } from '../../data/products';

export async function getStaticPaths() {
  return products.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const product = products.find((p) => p.slug === slug)!;
const related = products.filter((p) => p.collection === product.collection && p.slug !== product.slug).slice(0, 3);
---
<Base title={`${product.name} — Auriê`} description={product.shortDescription} current="colecao">
  <section class="max-w-[1280px] mx-auto px-6 lg:px-10 pt-10">
    <nav class="text-[11px] tracking-[0.24em] uppercase opacity-60">
      <a href="/" class="hover:opacity-100">Início</a>
      <span class="mx-2">/</span>
      <a href="/colecao" class="hover:opacity-100">Coleção</a>
      <span class="mx-2">/</span>
      <span class="text-[color:var(--color-ink)] opacity-90">{product.name}</span>
    </nav>
  </section>

  <section class="max-w-[1280px] mx-auto px-6 lg:px-10 py-10 lg:py-16 grid lg:grid-cols-12 gap-12">
    <!-- Gallery -->
    <div class="lg:col-span-7">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        <div class="md:col-span-2 aspect-[4/5] bg-[color:var(--color-cream)] overflow-hidden">
          <img src={product.hero} alt={product.name} class="w-full h-full object-cover" />
        </div>
        {product.gallery.slice(1).map((g) => (
          <div class="aspect-[4/5] bg-[color:var(--color-cream)] overflow-hidden">
            <img src={g} alt={product.name} class="w-full h-full object-cover" loading="lazy" />
          </div>
        ))}
      </div>
    </div>

    <!-- Detail -->
    <aside class="lg:col-span-5 lg:sticky lg:top-28 self-start">
      {product.badge && <span class="eyebrow">{product.badge}</span>}
      <p class="eyebrow text-[color:var(--color-ink)] opacity-60 mt-2">{product.collection}</p>
      <h1 class="font-display text-5xl lg:text-6xl mt-3 leading-[1]">{product.name}</h1>
      <p class="mt-5 text-base leading-relaxed opacity-80">{product.longDescription}</p>

      <p class="font-display text-4xl mt-8">{formatBRL(product.price)}</p>
      <p class="text-[12px] tracking-[0.22em] uppercase opacity-60 mt-1">ou 12x sem juros</p>

      {product.category === 'aneis' && (
        <div class="mt-8">
          <p class="eyebrow">Aro</p>
          <div class="mt-3 flex flex-wrap gap-2" id="size-options">
            {[12, 14, 16, 18, 20].map((s, i) => (
              <button
                type="button"
                data-size={s}
                class={`size-btn w-12 h-12 border text-sm tracking-wide transition-colors ${i === 2 ? 'border-[color:var(--color-ink)] bg-[color:var(--color-ink)] text-[color:var(--color-ivory)]' : 'border-[color:rgba(12,10,8,0.25)] hover:border-[color:var(--color-ink)]'}`}
              >
                {s}
              </button>
            ))}
          </div>
          <a href="#" class="text-[12px] tracking-[0.22em] uppercase border-b border-[color:rgba(12,10,8,0.4)] mt-4 inline-block opacity-70 hover:opacity-100">Guia de medidas</a>
        </div>
      )}

      <div class="mt-10 flex gap-3">
        <button
          id="add-btn"
          type="button"
          data-slug={product.slug}
          data-name={product.name}
          data-price={product.price}
          data-image={product.hero}
          class="btn-primary flex-1"
        >
          Adicionar à sacola
        </button>
        <button
          type="button"
          aria-label="Salvar"
          class="border border-[color:rgba(12,10,8,0.25)] w-14 h-14 grid place-items-center hover:border-[color:var(--color-ink)] transition-colors"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
            <path d="M12 21s-7-4.35-9.5-8.5C.92 9.6 2.69 6 6 6c2 0 3.5 1 4.5 2.5C11.5 7 13 6 15 6c3.31 0 5.08 3.6 3.5 6.5C19 16.65 12 21 12 21z"/>
          </svg>
        </button>
      </div>

      <p id="add-feedback" class="text-[12px] tracking-[0.22em] uppercase text-[color:var(--color-gold-deep)] mt-4 opacity-0 transition-opacity">
        Adicionado à sacola.
      </p>

      <!-- Details accordion -->
      <div class="mt-12 hairline pt-1">
        <details open class="group border-b border-[color:rgba(12,10,8,0.1)] py-5">
          <summary class="flex justify-between items-center cursor-pointer list-none">
            <span class="text-[12px] tracking-[0.28em] uppercase">Especificações</span>
            <span class="font-display text-2xl group-open:rotate-45 transition-transform">+</span>
          </summary>
          <ul class="mt-4 space-y-2 text-sm opacity-80">
            {product.details.map((d) => <li class="flex gap-3"><span class="text-[color:var(--color-gold-deep)]">·</span>{d}</li>)}
          </ul>
        </details>
        <details class="group border-b border-[color:rgba(12,10,8,0.1)] py-5">
          <summary class="flex justify-between items-center cursor-pointer list-none">
            <span class="text-[12px] tracking-[0.28em] uppercase">Entrega & frete</span>
            <span class="font-display text-2xl group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="mt-4 text-sm opacity-80 leading-relaxed">
            Frete segurado para o Brasil inteiro, sem custo, em embalagem assinada por nosso atelier. Despacho em até 3 dias úteis após confirmação do pagamento. Peças sob medida em 30-45 dias.
          </p>
        </details>
        <details class="group border-b border-[color:rgba(12,10,8,0.1)] py-5">
          <summary class="flex justify-between items-center cursor-pointer list-none">
            <span class="text-[12px] tracking-[0.28em] uppercase">Garantia & cuidados</span>
            <span class="font-display text-2xl group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="mt-4 text-sm opacity-80 leading-relaxed">
            Garantia vitalícia em qualquer peça Auriê: limpeza, polimento e ajuste de aro grátis para sempre. Trocas em 30 dias sem perguntas — exceto peças sob medida.
          </p>
        </details>
      </div>
    </aside>
  </section>

  {related.length > 0 && (
    <section class="max-w-[1280px] mx-auto px-6 lg:px-10 py-20 lg:py-28">
      <p class="eyebrow fade-up">Da mesma coleção</p>
      <h2 class="font-display text-4xl lg:text-5xl mt-3 fade-up">Você também pode gostar</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-x-6 gap-y-12 mt-10">
        {related.map((p, i) => (
          <div class="fade-up" style={`transition-delay:${i * 80}ms`}>
            <ProductCard product={p} />
          </div>
        ))}
      </div>
    </section>
  )}

  <script is:inline>
    (function () {
      const sizeBtns = document.querySelectorAll('.size-btn');
      let selectedSize = '16';
      sizeBtns.forEach((b) => {
        if (b.classList.contains('bg-[color:var(--color-ink)]')) selectedSize = b.dataset.size;
        b.addEventListener('click', () => {
          sizeBtns.forEach((x) => {
            x.classList.remove('bg-[color:var(--color-ink)]', 'text-[color:var(--color-ivory)]', 'border-[color:var(--color-ink)]');
            x.classList.add('border-[color:rgba(12,10,8,0.25)]');
          });
          b.classList.add('bg-[color:var(--color-ink)]', 'text-[color:var(--color-ivory)]', 'border-[color:var(--color-ink)]');
          b.classList.remove('border-[color:rgba(12,10,8,0.25)]');
          selectedSize = b.dataset.size;
        });
      });

      const addBtn = document.getElementById('add-btn');
      const feedback = document.getElementById('add-feedback');
      if (addBtn) {
        addBtn.addEventListener('click', () => {
          const detail = {
            slug: addBtn.dataset.slug,
            name: addBtn.dataset.name,
            price: Number(addBtn.dataset.price),
            image: addBtn.dataset.image,
            size: sizeBtns.length > 0 ? selectedSize : undefined,
            qty: 1,
          };
          window.dispatchEvent(new CustomEvent('aurie:add-to-cart', { detail }));
          if (feedback) {
            feedback.style.opacity = '1';
            setTimeout(() => { feedback.style.opacity = '0'; }, 2400);
          }
        });
      }
    })();
  </script>
</Base>
