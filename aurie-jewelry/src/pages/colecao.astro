---
import Base from '../layouts/Base.astro';
import ProductCard from '../components/ProductCard.astro';
import { products, collections } from '../data/products';

const cats = [
  { slug: 'todos', label: 'Todos' },
  { slug: 'aneis', label: 'Anéis' },
  { slug: 'colares', label: 'Colares' },
  { slug: 'brincos', label: 'Brincos' },
  { slug: 'pulseiras', label: 'Pulseiras' },
];
---
<Base title="Coleção — Auriê" current="colecao">
  <section class="max-w-[1280px] mx-auto px-6 lg:px-10 pt-16 lg:pt-24 pb-10">
    <p class="eyebrow fade-up">Auriê — Catálogo 2026</p>
    <h1 class="font-display text-6xl lg:text-8xl mt-4 leading-[0.95] fade-up">
      A coleção.
    </h1>
    <p class="mt-6 max-w-xl text-base leading-relaxed opacity-80 fade-up">
      Peças prontas para entrega imediata. Para qualquer outra coisa, nosso atelier desenha sob medida.
    </p>
  </section>

  <!-- Filter bar -->
  <section class="border-y border-[color:rgba(12,10,8,0.1)] bg-[color:var(--color-ivory)] sticky top-20 z-30 backdrop-blur">
    <div class="max-w-[1280px] mx-auto px-6 lg:px-10 py-4 flex items-center justify-between gap-4 overflow-x-auto">
      <div class="flex items-center gap-1" role="tablist" aria-label="Filtrar categoria">
        {cats.map((c) => (
          <button
            type="button"
            data-cat={c.slug}
            class={`filter-btn px-4 py-2 text-[12px] tracking-[0.22em] uppercase rounded-full transition-colors ${c.slug === 'todos' ? 'bg-[color:var(--color-ink)] text-[color:var(--color-ivory)]' : 'text-[color:var(--color-ink)] hover:text-[color:var(--color-gold-deep)]'}`}
          >
            {c.label}
          </button>
        ))}
      </div>
      <div class="hidden md:flex items-center gap-3 text-[12px] tracking-[0.22em] uppercase">
        <span class="opacity-60">Coleção</span>
        <select id="col-filter" class="bg-transparent text-[color:var(--color-ink)] tracking-[0.22em] uppercase text-[12px] border-b border-[color:var(--color-ink)] py-1">
          <option value="todas">Todas</option>
          {collections.map((c) => <option value={c.slug}>{c.name}</option>)}
        </select>
      </div>
    </div>
  </section>

  <section class="max-w-[1280px] mx-auto px-6 lg:px-10 py-14 lg:py-20">
    <div id="grid" class="grid grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-16">
      {products.map((p, i) => (
        <div
          class="fade-up product-item"
          data-cat={p.category}
          data-col={p.collection.toLowerCase().replace('ç','c').replace('ã','a')}
          style={`transition-delay:${(i % 6) * 60}ms`}
        >
          <ProductCard product={p} />
        </div>
      ))}
    </div>
    <p id="empty" class="hidden text-center text-sm opacity-60 mt-16">Nenhuma peça nesse filtro. Fale com o atelier.</p>
  </section>

  <script is:inline>
    (function () {
      const buttons = document.querySelectorAll('.filter-btn');
      const colSelect = document.getElementById('col-filter');
      const items = document.querySelectorAll('.product-item');
      const empty = document.getElementById('empty');
      let activeCat = 'todos';
      let activeCol = 'todas';

      const colNorm = {
        'constelacao': 'constelacao',
        'jardim': 'jardim',
        'arquitetura': 'arquitetura',
      };

      const apply = () => {
        let visible = 0;
        items.forEach((el) => {
          const cat = el.getAttribute('data-cat');
          const col = el.getAttribute('data-col');
          const matchCat = activeCat === 'todos' || cat === activeCat;
          const matchCol = activeCol === 'todas' || col === colNorm[activeCol];
          const show = matchCat && matchCol;
          el.style.display = show ? '' : 'none';
          if (show) visible++;
        });
        empty.classList.toggle('hidden', visible > 0);
      };

      buttons.forEach((b) => {
        b.addEventListener('click', () => {
          activeCat = b.getAttribute('data-cat');
          buttons.forEach((x) => {
            x.classList.remove('bg-[color:var(--color-ink)]', 'text-[color:var(--color-ivory)]');
            x.classList.add('text-[color:var(--color-ink)]');
          });
          b.classList.add('bg-[color:var(--color-ink)]', 'text-[color:var(--color-ivory)]');
          b.classList.remove('text-[color:var(--color-ink)]');
          apply();
        });
      });

      if (colSelect) {
        colSelect.addEventListener('change', () => {
          activeCol = colSelect.value;
          apply();
        });

        // Read ?col= query param to pre-select
        const params = new URLSearchParams(window.location.search);
        const col = params.get('col');
        if (col && Array.from(colSelect.options).some((o) => o.value === col)) {
          colSelect.value = col;
          activeCol = col;
          apply();
        }
      }
    })();
  </script>
</Base>
